        "title": "Resumen Digital de Atencion - Consulta Externa Fisioterapia",
        "custodian": {
          "reference": "urn:uuid:00000000-0000-0000-0000-000000000005",
          "display": "DOKTRINO IPS RT - Agencia Demo"
        },
        "section": [
          {
            "title": "Motivo de consulta",
            "code": {
              "coding": [
                {
                  "system": "http://loinc.org",
                  "code": "10154-3",
                  "display": "Chief complaint Narrative - Reported"
                }
              ]
            },
            "text": {
              "status": "additional",
              "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>Paciente acude por dolor lumbar de 2 semanas de evolucion, sin trauma previo.</p></div>"
            }
          },
          {
            "title": "Historia de la enfermedad actual",
            "code": {
              "coding": [
                {
                  "system": "http://loinc.org",
                  "code": "10164-2",
                  "display": "History of Present illness Narrative"
                }
              ]
            },
            "text": {
              "status": "additional",
              "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>Cuadro de 15 dias de dolor lumbar mecanico, EVA 6/10, sin irradiacion. Empeora con sedestacion prolongada por trabajo de oficina. Mejora parcial con AINEs OTC.</p></div>"
            }
          },
          {
            "title": "Antecedentes patologicos",
            "code": {
              "coding": [
                {
                  "system": "http://loinc.org",
                  "code": "11348-0",
                  "display": "History of Past illness Narrative"
                }
              ]
            },
            "text": {
              "status": "additional",
              "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>Sin antecedentes patologicos de importancia. Niega diabetes, hipertension, cirugias previas.</p></div>"
            }
          },
          {
            "title": "Antecedentes farmacologicos",
            "code": {
              "coding": [
                {
                  "system": "http://loinc.org",
                  "code": "10160-0",
                  "display": "History of Medication use Narrative"
                }
              ]
            },
            "entry": [
              {
                "reference": "urn:uuid:00000000-0000-0000-0000-000000000007"
              }
            ]
          },
          {
            "title": "Alergias e intolerancias",
            "code": {
              "coding": [
                {
                  "system": "http://loinc.org",
                  "code": "48765-2",
                  "display": "Allergies and adverse reactions Document"
                }
              ]
            },
            "entry": [
              {
                "reference": "urn:uuid:00000000-0000-0000-0000-000000000009"
              }
            ]
          },
          {
            "title": "Examen fisico",
            "code": {
              "coding": [
                {
                  "system": "http://loinc.org",
                  "code": "29545-1",
                  "display": "Physical findings Narrative"
                }
              ]
            },
            "text": {
              "status": "additional",
              "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>TA 120/80, FC 78, FR 16, Temp 36.6. Marcha conservada. Dolor a la palpacion paravertebral L4-L5. Schober 3 cm. Lasegue negativo bilateral. Fuerza 5/5 en MMII.</p></div>"
            }
          },
          {
            "title": "Diagnosticos",
            "code": {
              "coding": [
                {
                  "system": "http://loinc.org",
                  "code": "11450-4",
                  "display": "Problem list - Reported"
                }
              ]
            },
            "entry": [
              {
                "reference": "urn:uuid:00000000-0000-0000-0000-000000000006"
              }
            ]
          },
          {
            "title": "Plan de tratamiento",
            "code": {
              "coding": [
                {
                  "system": "http://loinc.org",
                  "code": "18776-5",
                  "display": "Plan of care note"
                }
              ]
            },
            "entry": [
              {
                "reference": "urn:uuid:00000000-0000-0000-0000-000000000008"
              }
            ],
            "text": {
              "status": "additional",
              "div": "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p>10 sesiones de terapia fisica integral, frecuencia 3/semana. Higiene postural. Control en 4 semanas.</p></div>"
            }
          }
        ]
