@implements IDisposable
@inject NavigationManager Navigation
@inject ITenantAdminService TenantsSvc

<div class="doktrino-brand doktrino-brand-stack">
    <div class="doktrino-logo @( !_showAdmin && !string.IsNullOrWhiteSpace(_tenantLogoUrl) ? "doktrino-logo-wide" : "" )">
        @* Para usuarios de tenant: si configuraron un logo en /mi-cuenta lo usamos
           aqui; si no, mostramos el SVG por defecto. Para super-admin de plataforma
           queda siempre el SVG (es la consola, no una agencia). El logo del tenant
           se muestra ancho para que se vea completo (no recortado en cuadrado). *@
        @if (!_showAdmin && !string.IsNullOrWhiteSpace(_tenantLogoUrl))
        {
            <img src="@_tenantLogoUrl" alt="Logo" />
        }
        else
        {
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        }
    </div>
    <div class="doktrino-brand-text">
        <div class="doktrino-brand-name">@(_showAdmin || string.IsNullOrWhiteSpace(_tenantName) ? "DokTrino" : _tenantName)</div>
        <div class="doktrino-brand-sub">@(_showAdmin ? "Consola de gobierno" : (string.IsNullOrWhiteSpace(_tenantSlogan) ? "Gestion Documental" : _tenantSlogan))</div>
    </div>
</div>

<div class="doktrino-agency">
    @if (_showAdmin)
    {
        <div class="lbl">Plataforma</div>
        <div class="name">DokTrino</div>
        <div class="meta">Consola de gobierno</div>
    }
    else
    {
        <div class="lbl">Agencia</div>
        <div class="name">@(_tenantName ?? "Mi agencia")</div>
        <div class="meta">@_roleLabel</div>
    }
</div>

