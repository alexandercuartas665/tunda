@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // El menu se arma por rol: el operador de plataforma (platform_role) ve el grupo
    // Super Admin SaaS y previsualiza los modulos del tenant; el usuario de agencia
    // (tenant_id) ve solo sus grupos comerciales y Mi agencia.
    private bool _showAdmin;
    private bool _showTenant;
    /// <summary>True cuando el tenant_role es Owner o Admin. Solo estos perfiles ven
    /// "Mi cuenta" (datos de la agencia, plan, facturacion).</summary>
    private bool _esAdminAgencia;
    private string? _userName;
    private string? _tenantName;
    private string? _tenantLogoUrl;
    private string? _tenantSlogan;
    private string _roleLabel = "Operador de plataforma";
    private string _avatar = "SA";

    protected override async Task OnInitializedAsync()
    {
        Navigation.LocationChanged += OnLocationChanged;

        if (AuthState is null)
        {
            return;
        }

        var state = await AuthState;
        var isPlatformOperator = state.User.FindFirst("platform_role") is not null;
        var tenantClaim = state.User.FindFirst("tenant_id")?.Value;
        var isTenantUser = tenantClaim is not null;

        _showAdmin = isPlatformOperator;
        _showTenant = isPlatformOperator || isTenantUser;
        var rol = state.User.FindFirst("tenant_role")?.Value ?? "";
        _esAdminAgencia = isPlatformOperator || rol.Equals("Owner", StringComparison.OrdinalIgnoreCase) || rol.Equals("Admin", StringComparison.OrdinalIgnoreCase);

        _userName = state.User.Identity?.Name;
        _avatar = Initials(_userName);

        if (isPlatformOperator)
        {
            _roleLabel = "Operador de plataforma";
        }
        else if (isTenantUser)
        {
            _roleLabel = state.User.FindFirst("tenant_role")?.Value ?? "Agencia";
            if (Guid.TryParse(tenantClaim, out var tenantId))
            {
                var tenant = await TenantsSvc.GetAsync(tenantId);
                _tenantName = tenant?.Name;
                _tenantLogoUrl = tenant?.LogoUrl;
                _tenantSlogan = tenant?.Slogan;
            }
        }
    }

    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e) => StateHasChanged();
    public void Dispose() => Navigation.LocationChanged -= OnLocationChanged;
}
