@page "/login-google"
@attribute [Authorize(Policy = "PlatformOperator")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Admin
@inject IGoogleAuthConfigService GoogleSvc

<PageTitle>Login con Google - DokTrino</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/></svg>
            </div>
            <span>Super Admin SaaS</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Login con <span>Google</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Permite a los usuarios iniciar sesion con su cuenta de Google. Google confirma la identidad; el acceso lo decide DOKTRINO (solo usuarios existentes). El Client Secret se guarda cifrado.</p>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="card-soft" style="max-width:680px;padding:22px;">
        <div class="auth-alert" style="background:var(--muted);border:1px solid var(--border);color:var(--foreground);">
            <strong>URIs de redireccion</strong> que debes registrar en Google Cloud (Clientes &rarr; Aplicacion web):
            <div style="margin-top:6px;font-family:var(--bs-font-monospace);font-size:12.5px;">
                http://localhost:5232/signin-google<br />
                https://doktrinocrm-production.up.railway.app/signin-google
            </div>
        </div>

        <div class="auth-field" style="margin-top:16px;">
            <label>Client ID</label>
            <input class="form-control" @bind="_clientId" placeholder="xxxxxxxx.apps.googleusercontent.com" />
        </div>
        <div class="auth-field" style="margin-top:14px;">
            <label>Client Secret @(_hasSecret ? "(guardado; deja vacio para conservarlo)" : "")</label>
            <input class="form-control" type="password" @bind="_clientSecret" placeholder="@(_hasSecret ? "********" : "GOCSPX-...")" />
        </div>

        <div class="form-check form-switch" style="margin-top:16px;">
            <input class="form-check-input" type="checkbox" id="genabled" @bind="_enabled" />
            <label class="form-check-label" for="genabled">Habilitar login con Google en la pantalla de ingreso</label>
        </div>

        <div style="margin-top:18px;display:flex;gap:10px;align-items:center;">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Guardando..." : "Guardar")</button>
            @if (_savedOk) { <span class="text-success" style="font-size:.9rem;">Guardado.</span> }
            @if (!string.IsNullOrWhiteSpace(_error)) { <span class="text-danger" style="font-size:.9rem;">@_error</span> }
        </div>

        <p class="text-muted" style="margin-top:14px;font-size:.84rem;">
            Nota: la app esta en modo "Prueba" en Google, asi que solo los correos agregados como
            <strong>usuarios de prueba</strong> en Google Cloud podran iniciar sesion. Ademas, el correo de Google
            debe corresponder a un usuario existente y activo en DOKTRINO.
        </p>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true, _saving, _savedOk, _enabled, _hasSecret;
    private string? _error, _clientId, _clientSecret;

    protected override async Task OnInitializedAsync()
    {
        var c = await GoogleSvc.GetAsync();
        if (c is not null) { _clientId = c.ClientId; _enabled = c.IsEnabled; _hasSecret = c.HasSecret; }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _saving = true; _savedOk = false; _error = null;
        try
        {
            await GoogleSvc.SaveAsync(new SaveGoogleAuthConfigRequest(_clientId, _clientSecret, _enabled), await ActorAsync());
            _clientSecret = null;
            _hasSecret = _hasSecret || true;
            _savedOk = true;
        }
        catch { _error = "No se pudo guardar."; }
        finally { _saving = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }
}
