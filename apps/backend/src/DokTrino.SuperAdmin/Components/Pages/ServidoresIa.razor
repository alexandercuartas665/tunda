@page "/servidores-ia"
@attribute [Authorize(Policy = "PlatformOperator")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Admin
@using DokTrino.Domain.Enums
@inject IAiServerConfigService AiSvc

<PageTitle>Servidores de IA - Archimente</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
            </div>
            <span>Super Admin SaaS</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Servidores de <span>IA</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Cuentas de proveedores de IA de la plataforma. Las agencias usan los proveedores habilitados aqui en sus agentes. Las API keys se guardan cifradas.</p>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando proveedores...</em></p>
}
else
{
    <div class="ai-grid">
        @foreach (var p in _providers)
        {
            <div class="ai-card">
                <div class="ai-card-head">
                    <div class="ai-logo @ProviderClass(p.Provider)">@Short(p.DisplayName)</div>
                    <div style="flex:1;min-width:0;">
                        <div class="ai-name">@p.DisplayName</div>
                        <div class="ai-prov">@p.Provider</div>
                    </div>
                    <span class="badge bg-@StatusColor(p)">@StatusText(p)</span>
                </div>
                <div class="ai-rows">
                    <div><span>Modelo</span><strong>@(string.IsNullOrWhiteSpace(p.Model) ? p.DefaultModel + " (def.)" : p.Model)</strong></div>
                    <div><span>API key</span><strong style="font-family:var(--bs-font-monospace);font-size:11.5px;">@(p.ApiKeyMasked ?? "—")</strong></div>
                </div>
                <button class="btn @(p.HasApiKey ? "btn-outline-secondary" : "btn-primary") btn-sm" style="margin-top:12px;width:100%;" @onclick="() => OpenEdit(p)">
                    @(p.HasApiKey ? "Editar configuracion" : "Configurar")
                </button>
            </div>
        }
    </div>
}

@if (_editing is not null)
{
    <div class="modal-overlay">
        <div class="modal-dialog" style="max-width:480px;">
            <div class="modal-head">
                <h3>@_editing.DisplayName</h3>
                <button class="modal-close" @onclick="() => _editing = null">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">API key</label>
                    <input class="form-control" type="password" @bind="_form.ApiKey" autocomplete="new-password"
                           placeholder="@(_editing.HasApiKey ? "Dejar vacio para conservar la actual" : "Pega la API key del proveedor")" />
                    <div class="text-muted" style="font-size:11px;margin-top:4px;">Se guarda cifrada; nunca se muestra completa.</div>
                </div>
                <div class="field">
                    <label class="form-label">Modelo por defecto</label>
                    <input class="form-control" list="ai-models-@_editing.Provider" @bind="_form.Model" placeholder="@_editing.DefaultModel" autocomplete="off" />
                    <datalist id="ai-models-@_editing.Provider">
                        @foreach (var m in _editing.SuggestedModels)
                        {
                            <option value="@m">@m</option>
                        }
                    </datalist>
                </div>
                <div class="field">
                    <label class="form-label">URL base (opcional)</label>
                    <input class="form-control" @bind="_form.BaseUrl" placeholder="Por defecto del proveedor" autocomplete="off" />
                </div>
                <label class="ai-toggle">
                    <input type="checkbox" checked="@_form.IsEnabled" @onchange="e => _form.IsEnabled = (bool)e.Value!" />
                    <span>Habilitado para las agencias</span>
                </label>
                <div class="text-muted" style="font-size:11px;">Solo se puede habilitar si hay API key guardada.</div>
                @if (_modalError is not null)
                {
                    <div class="text-danger small" style="margin-top:8px;">@_modalError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _editing = null">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">Guardar</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _busy;
    private string? _modalError;
    private List<AiProviderDto> _providers = new();
    private AiProviderDto? _editing;
    private readonly Form _form = new();

    protected override async Task OnInitializedAsync()
    {
        _providers = (await AiSvc.ListAsync()).ToList();
        _loading = false;
    }

    private void OpenEdit(AiProviderDto p)
    {
        _editing = p;
        _modalError = null;
        _form.ApiKey = null;
        _form.Model = p.Model;
        _form.BaseUrl = p.BaseUrl;
        _form.IsEnabled = p.IsEnabled;
    }

    private async Task SaveAsync()
    {
        if (_editing is null) { return; }
        _modalError = null;
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var req = new SaveAiProviderRequest(_editing.Provider, _form.ApiKey, _form.Model, _form.BaseUrl, _form.IsEnabled);
            await AiSvc.SaveAsync(req, actor);
            _providers = (await AiSvc.ListAsync()).ToList();
            _editing = null;
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var state = await AuthState;
        return Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string StatusText(AiProviderDto p) => !p.HasApiKey ? "Sin configurar" : p.IsEnabled ? "Habilitado" : "Apagado";
    private static string StatusColor(AiProviderDto p) => !p.HasApiKey ? "secondary" : p.IsEnabled ? "success" : "warning";

    private static string ProviderClass(AiProvider p) => p switch
    {
        AiProvider.Claude => "p-claude",
        AiProvider.Gemini => "p-gemini",
        AiProvider.ChatGpt => "p-gpt",
        AiProvider.DeepSeek => "p-deepseek",
        _ => ""
    };

    private static string Short(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? (parts[^1][..1]).ToUpperInvariant() + "" : name[..Math.Min(2, name.Length)].ToUpperInvariant();
    }

    private sealed class Form
    {
        public string? ApiKey { get; set; }
        public string? Model { get; set; }
        public string? BaseUrl { get; set; }
        public bool IsEnabled { get; set; }
    }
}
