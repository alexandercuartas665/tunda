@page "/seleccionar-sede"
@layout EmptyLayout
@attribute [Authorize]
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@inject ISedeSelectorService Sedes
@inject DokTrino.Application.Admin.IPlatformBrandingService BrandingSvc
@inject DokTrino.Application.Admin.ITenantAdminService TenantsSvc

<PageTitle>Selecciona tu sede - @_brand.PlatformName</PageTitle>

<div class="auth-shell">
    <aside class="auth-aside">
        <div class="auth-aside-deco auth-deco-tr"></div>
        <div class="auth-aside-deco auth-deco-bl"></div>

        <div class="auth-brand">
            @if (!string.IsNullOrWhiteSpace(_brand.LoginLogoUrl))
            {
                <img class="auth-brand-logo-img" src="@_brand.LoginLogoUrl" alt="@_brand.PlatformName" />
            }
            else
            {
                <div class="auth-brand-logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                </div>
            }
            <span class="auth-brand-name">@_brand.PlatformName</span>
        </div>

        <div class="auth-aside-body">
            <h2>Elige tu sede</h2>
            <p>Trabajas en varias sedes de @(_empresaNombre ?? "esta empresa"). Selecciona la sede donde vas a operar en esta sesion.</p>
            <div class="auth-dots"><span></span><span></span><span></span></div>
        </div>
    </aside>

    <main class="auth-main">
        <div class="auth-form-wrap">
            <section class="auth-pane auth-pane-login" style="opacity:1;visibility:visible;position:relative;">
                <div class="auth-head">
                    <h1>Selecciona tu sede</h1>
                    <p>@(_empresaNombre ?? "")</p>
                </div>

                @if (Error == 1)
                {
                    <div class="auth-alert auth-alert-error">No tienes acceso a esa sede.</div>
                }

                @if (_loading)
                {
                    <div class="ase-empty">Cargando sedes...</div>
                }
                else if (_sedes.Count == 0)
                {
                    <div class="auth-alert auth-alert-error">No hay sedes asignadas para tu usuario. Pidele al administrador asignar al menos una sede.</div>
                    <form method="post" action="/auth/logout" class="auth-form" style="margin-top:14px;">
                        <button class="auth-submit" type="submit"><span>Cerrar sesion</span></button>
                    </form>
                }
                else
                {
                    <form method="post" action="/auth/select-sede" class="auth-form">
                        <div class="emp-list">
                            @foreach (var s in _sedes)
                            {
                                <label class="emp-row @(s.Id == _seleccion ? "sel" : "")">
                                    <input type="radio" name="sucursalId" value="@s.Id" checked="@(s.Id == _seleccion)" @onchange="() => _seleccion = s.Id" />
                                    <div class="emp-info">
                                        <div class="emp-name">@s.Nombre</div>
                                        <div class="emp-legal">@s.Codigo @(s.Ciudad is not null ? "· " + s.Ciudad : "")</div>
                                    </div>
                                </label>
                            }
                        </div>
                        <button class="auth-submit" type="submit" disabled="@(_seleccion == Guid.Empty)">
                            <span>Entrar a la sede</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </button>
                    </form>
                    <p class="auth-switch" style="margin-top:18px;">
                        <form method="post" action="/auth/logout" style="display:inline;">
                            <button type="submit" class="auth-link-btn">Cerrar sesion</button>
                        </form>
                    </p>
                }
            </section>
        </div>
        <footer class="auth-footer">&copy; @DateTime.UtcNow.Year @_brand.PlatformName. Todos los derechos reservados.</footer>
    </main>
</div>

<style>
    .emp-list { display:flex; flex-direction:column; gap:10px; margin-bottom:18px; }
    .emp-row { display:flex; align-items:center; gap:12px; padding:12px 14px; border:1.5px solid #e2e8f0; border-radius:10px; cursor:pointer; transition: all .15s; background:#fff; }
    .emp-row:hover { border-color:#0288d1; }
    .emp-row.sel { border-color:#0288d1; background:#eff6ff; box-shadow:0 0 0 3px rgba(2,136,209,.10); }
    .emp-row input { margin:0; }
    .emp-info { flex:1; }
    .emp-name { font-weight:600; color:#0f172a; }
    .emp-legal { font-size:12px; color:#64748b; }
    .auth-link-btn { background:none; border:none; color:#0288d1; cursor:pointer; font-weight:600; padding:0; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    [SupplyParameterFromQuery] public int? Error { get; set; }

    private DokTrino.Application.Admin.PlatformBrandingDto _brand = DokTrino.Application.Admin.PlatformBrandingDto.Default;
    private List<SucursalDto> _sedes = new();
    private Guid _seleccion = Guid.Empty;
    private bool _loading = true;
    private string? _empresaNombre;

    protected override async Task OnInitializedAsync()
    {
        _brand = await BrandingSvc.GetAsync();
        if (AuthState is null) { _loading = false; return; }
        var st = await AuthState;
        if (Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var uid)
            && Guid.TryParse(st.User.FindFirst("tenant_id")?.Value, out var tid))
        {
            try { _empresaNombre = (await TenantsSvc.GetAsync(tid))?.Name; } catch { }
            _sedes = (await Sedes.GetSedesAsync(uid, tid)).ToList();
            _seleccion = _sedes.Count > 0 ? _sedes[0].Id : Guid.Empty;
        }
        _loading = false;
    }
}
