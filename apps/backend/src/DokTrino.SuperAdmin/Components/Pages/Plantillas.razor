@page "/plantillas"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text
@using DokTrino.Application.Tenancy
@inject IQuoteTemplateService TemplatesSvc
@inject ITemplateAssetService AssetsSvc
@inject IPipelineService PipelineSvc
@inject IWebHostEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Plantillas - Archimente</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h8"/></svg>
            </div>
            <span>Mi agencia</span>
        </div>
        <h1 class="page-title">Plantillas de <span>cotizacion</span></h1>
        <p class="page-sub">Edita plantillas HTML para imprimir las cotizaciones de tus clientes. Sube imagenes a la galeria y reutilizalas con su URL.</p>
    </div>
    <div>
        <button class="btn btn-primary" @onclick="NewTemplate">+ Nueva plantilla</button>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="pl-tpl-layout">
        <!-- Lista de plantillas -->
        <aside class="pl-tpl-list card-soft">
            <div class="pl-tpl-list-title">Plantillas (@_list.Count)</div>
            @if (_list.Count == 0)
            {
                <div class="text-muted" style="font-size:13px;padding:8px 2px;">Aun no hay plantillas. Crea la primera con "+ Nueva plantilla".</div>
            }
            @foreach (var t in _list)
            {
                <div class="pl-tpl-item-row @(_editingId == t.Id ? "active" : "")">
                    <button class="pl-tpl-item" @onclick="() => Select(t.Id)">
                        <div class="nm">@t.Name @if (t.IsDefault) { <span class="pl-tpl-default">predeterminada</span> }</div>
                        <div class="mt">Actualizada @t.UpdatedAt.LocalDateTime.ToString("dd MMM yyyy HH:mm")</div>
                    </button>
                    <button class="pl-tpl-del" title="Eliminar plantilla" @onclick="() => DeleteByIdAsync(t.Id, t.Name)">&times;</button>
                </div>
            }
        </aside>

        <!-- Editor + vista previa -->
        <section class="pl-tpl-editor">
            <div class="card-soft" style="padding:18px;">
                <div class="auth-field">
                    <label>Nombre de la plantilla</label>
                    <input class="form-control" @bind="_name" placeholder="Ej. Cotizacion playa" />
                </div>

                <div class="auth-field" style="margin-top:14px;">
                    <label>Al enviar la cotizacion, mandar como</label>
                    <select class="form-control" @bind="SendFormat" style="max-width:220px;">
                        <option value="pdf">PDF adjunto</option>
                        <option value="image">Imagen (PNG)</option>
                    </select>
                </div>

                <div class="auth-field" style="margin-top:14px;">
                    <label>Contenido HTML <span class="text-muted" style="font-weight:400;">(la vista previa se actualiza al salir del editor)</span></label>
                    <textarea class="form-control pl-tpl-html" rows="16" @bind="_html" @bind:event="onchange" spellcheck="false"></textarea>
                </div>

                <div style="margin-top:14px;display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">@(_busy ? "Guardando..." : (_editingId is null ? "Crear plantilla" : "Guardar cambios"))</button>
                    @if (_editingId is not null)
                    {
                        <button class="btn btn-outline-secondary" @onclick="SetDefaultAsync" disabled="@(_busy || _isDefault)">@(_isDefault ? "Es la predeterminada" : "Marcar predeterminada")</button>
                        <button class="btn btn-outline-danger" @onclick="DeleteAsync" disabled="@_busy">Eliminar</button>
                    }
                    @if (_savedOk) { <span class="pl-saved-flag">Guardado</span> }
                    @if (!string.IsNullOrWhiteSpace(_error)) { <span class="text-danger" style="font-size:.88rem;">@_error</span> }
                </div>

                <div class="pl-tpl-vars">
                    <div class="pl-tpl-vars-title">Catalogo de campos del lead <span class="text-muted" style="font-weight:400;">(clic para copiar)</span></div>

                    @* Campos de sistema (nativos) y datos de agencia/cotizacion, agrupados *@
                    @foreach (var g in _placeholders.GroupBy(p => p.Group))
                    {
                        <div class="pl-tpl-stage-label">@g.Key</div>
                        <div class="pl-tpl-vars-grid" style="margin-bottom:8px;">
                            @foreach (var v in g)
                            {
                                <code class="pl-tpl-var" title="@v.Label" @onclick="() => CopyText(v.Tag)">@v.Tag &middot; @v.Label</code>
                            }
                        </div>
                    }

                    @* Campos parametrizables del embudo, por etapa, en el orden del pipeline *@
                    @if (_fieldGroups.Count == 0)
                    {
                        <div class="text-muted" style="font-size:11.5px;padding:4px 0;">
                            Aun no hay campos del embudo. Crealos en <strong>Pipeline &rarr; Configurar embudo</strong> y apareceran aqui.
                        </div>
                    }
                    else
                    {
                        @foreach (var grp in _fieldGroups)
                        {
                            <div class="pl-tpl-stage-label">Embudo &middot; @grp.Stage</div>
                            <div class="pl-tpl-vars-grid" style="margin-bottom:8px;">
                                @foreach (var f in grp.Fields)
                                {
                                    var tag = "{{campo." + f.FieldKey + "}}";
                                    var tip = f.Label + (f.AllowMultiple ? " (multiple)" : "");
                                    <code class="pl-tpl-var" title="@tip" @onclick="() => CopyText(tag)">@tag &middot; @f.Label</code>
                                }
                            </div>
                        }
                    }
                    <div class="text-muted" style="font-size:11.5px;margin-top:8px;">
                        Los <strong>campos de sistema</strong> (nombre, telefono, destino, valor, moneda) vienen con cada lead. Los <strong>campos del embudo</strong> (<code>@("{{campo.clave}}")</code>) se llenan con lo que captures en la tarjeta.
                    </div>
                </div>
            </div>

            <div class="card-soft" style="padding:0;overflow:hidden;">
                <div class="pl-tpl-preview-head">Vista previa (con datos de ejemplo)</div>
                <iframe class="pl-tpl-preview" srcdoc="@PreviewHtml" title="Vista previa de la plantilla"></iframe>
            </div>
        </section>
    </div>

    <!-- Galeria de recursos -->
    <div class="card-soft pl-tpl-gallery">
        <div class="pl-tpl-gallery-head">
            <div>
                <div class="pl-tpl-list-title" style="margin:0;">Galeria de recursos (@_assets.Count)</div>
                <div class="text-muted" style="font-size:11.5px;">Sube imagenes (logos, hoteles, aerolineas) y copia su URL para usarla en cualquier plantilla con <code>&lt;img src="..."&gt;</code>.</div>
            </div>
            <label class="btn btn-primary" style="cursor:pointer;margin:0;">
                @(_uploading ? "Subiendo..." : "+ Subir imagen")
                <InputFile OnChange="OnAssetSelected" accept="image/*" multiple style="display:none;" disabled="@_uploading" />
            </label>
        </div>
        @if (!string.IsNullOrWhiteSpace(_assetError)) { <div class="text-danger" style="font-size:.85rem;margin-top:8px;">@_assetError</div> }
        @if (_assets.Count == 0)
        {
            <div class="text-muted" style="font-size:13px;padding:10px 2px;">Aun no hay recursos. Sube tu primera imagen.</div>
        }
        else
        {
            <div class="pl-tpl-assets">
                @foreach (var a in _assets)
                {
                    <div class="pl-tpl-asset">
                        <div class="pl-tpl-asset-thumb"><img src="@a.Url" alt="@a.FileName" /></div>
                        <div class="pl-tpl-asset-name" title="@a.FileName">@a.FileName</div>
                        <div class="pl-tpl-asset-actions">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => CopyUrl(a.Url)">Copiar URL</button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAssetAsync(a.Id)">Quitar</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@code {
    private bool _loading = true, _busy, _savedOk, _isDefault, _uploading, _sendAsImage;
    // El binding de <select> a bool en Blazor es problematico (formatea True/False); usamos un string.
    private string SendFormat { get => _sendAsImage ? "image" : "pdf"; set => _sendAsImage = value == "image"; }
    private string? _error, _assetError;
    private Guid? _editingId;
    private string _name = "";
    private string _html = "";
    private List<QuoteTemplateDto> _list = new();
    private List<TemplateAssetDto> _assets = new();
    private List<PipelineFieldDto> _fields = new();
    // Campos del embudo agrupados por etapa, en el mismo orden que el pipeline.
    private List<(string Stage, List<PipelineFieldDto> Fields)> _fieldGroups = new();

    // Catalogo de marcadores fijos: campos de sistema (nativos del lead) y datos de agencia/cotizacion.
    // Tag = marcador; Sample = valor de ejemplo en la vista previa; Label = nombre legible; Group = agrupacion en la UI.
    private readonly (string Tag, string Sample, string Label, string Group)[] _placeholders =
    {
        ("{{contactName}}", "Maria Perez", "Nombre del cliente", "Campos de sistema"),
        ("{{contactPhone}}", "573001234567", "Telefono", "Campos de sistema"),
        ("{{destination}}", "Cancun", "Destino", "Campos de sistema"),
        ("{{estimatedValue}}", "1,970,000", "Valor estimado", "Campos de sistema"),
        ("{{currency}}", "COP", "Moneda", "Campos de sistema"),
        ("{{agencyName}}", "Tu Agencia", "Nombre de la agencia", "Agencia y cotizacion"),
        ("{{date}}", DateTime.Now.ToString("dd/MM/yyyy"), "Fecha de la cotizacion", "Agencia y cotizacion")
    };

    // Ejemplos para los campos del embudo en la vista previa (los reales salen del lead al imprimir).
    private readonly Dictionary<string, string> _fieldSamples = new()
    {
        ["adultos"] = "4",
        ["ninos"] = "0",
        ["hotel1"] = "Hotel Palma Linda",
        ["valorVuelosPax"] = "1,970,000",
        ["aerolinea"] = "Avianca"
    };

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
        _assets = (await AssetsSvc.ListAsync()).ToList();
        await LoadFieldsAsync();
        _loading = false;
        if (_list.Count > 0) { Select(_list[0].Id); } else { NewTemplate(); }
    }

    private async Task ReloadAsync() => _list = (await TemplatesSvc.ListAsync()).ToList();

    // Carga los campos del embudo agrupados por etapa, en el mismo orden que estan configurados
    // en el pipeline (etapa por SortOrder, luego campo por SortOrder). Sus claves alimentan {{campo.clave}}.
    private async Task LoadFieldsAsync()
    {
        var stages = await PipelineSvc.ListStagesAsync();
        var all = await PipelineSvc.ListFieldsAsync();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        _fieldGroups = new();
        foreach (var s in stages)
        {
            var fs = all.Where(f => f.StageId == s.Id)
                .OrderBy(f => f.SortOrder)
                .Where(f => seen.Add(f.FieldKey))
                .ToList();
            if (fs.Count > 0) { _fieldGroups.Add((s.Name, fs)); }
        }
        // Campos sin etapa conocida (por si acaso): se agrupan al final.
        var orphans = all.Where(f => seen.Add(f.FieldKey)).OrderBy(f => f.SortOrder).ToList();
        if (orphans.Count > 0) { _fieldGroups.Add(("Otros", orphans)); }
        _fields = _fieldGroups.SelectMany(g => g.Fields).ToList();
    }

    private void NewTemplate()
    {
        _editingId = null; _isDefault = false; _name = ""; _html = StarterHtml; _savedOk = false; _error = null; _sendAsImage = false;
    }

    private void Select(Guid id)
    {
        var t = _list.FirstOrDefault(x => x.Id == id);
        if (t is null) { return; }
        _editingId = t.Id; _name = t.Name; _html = t.HtmlContent; _isDefault = t.IsDefault; _savedOk = false; _error = null; _sendAsImage = t.SendAsImage;
    }

    private async Task SaveAsync()
    {
        _busy = true; _savedOk = false; _error = null;
        try
        {
            if (string.IsNullOrWhiteSpace(_name)) { _error = "Escribe un nombre para la plantilla."; return; }
            var saved = _editingId is Guid id
                ? await TemplatesSvc.UpdateAsync(id, _name, _html, _sendAsImage, Guid.Empty)
                : await TemplatesSvc.CreateAsync(_name, _html, _sendAsImage, Guid.Empty);
            if (saved is null) { _error = "No se pudo guardar."; return; }
            await ReloadAsync();
            _editingId = saved.Id; _isDefault = saved.IsDefault; _savedOk = true;
        }
        finally { _busy = false; }
    }

    private async Task SetDefaultAsync()
    {
        if (_editingId is not Guid id) { return; }
        _busy = true;
        try { if (await TemplatesSvc.SetDefaultAsync(id, Guid.Empty)) { await ReloadAsync(); _isDefault = true; } }
        finally { _busy = false; }
    }

    private async Task DeleteAsync()
    {
        if (_editingId is not Guid id) { return; }
        _busy = true;
        try
        {
            if (await TemplatesSvc.DeleteAsync(id, Guid.Empty))
            {
                await ReloadAsync();
                if (_list.Count > 0) { Select(_list[0].Id); } else { NewTemplate(); }
            }
        }
        finally { _busy = false; }
    }

    private async Task DeleteByIdAsync(Guid id, string nombre)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", $"Eliminar la plantilla \"{nombre}\"? Esta accion no se puede deshacer.");
        if (!ok) { return; }
        _busy = true;
        try
        {
            if (await TemplatesSvc.DeleteAsync(id, Guid.Empty))
            {
                await ReloadAsync();
                if (_editingId == id) { _editingId = null; NewTemplate(); }
            }
        }
        finally { _busy = false; }
    }

    // ===== Galeria de recursos =====
    private async Task OnAssetSelected(InputFileChangeEventArgs e)
    {
        _assetError = null;
        _uploading = true;
        try
        {
            const long max = 5L * 1024 * 1024;
            var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "templates");
            System.IO.Directory.CreateDirectory(dir);
            foreach (var file in e.GetMultipleFiles(20))
            {
                if (file.Size <= 0 || file.Size > max) { _assetError = $"\"{file.Name}\" supera 5 MB y se omitio."; continue; }
                using var ms = new MemoryStream();
                await file.OpenReadStream(max).CopyToAsync(ms);
                var ext = System.IO.Path.GetExtension(file.Name);
                var name = $"tpl-{Guid.NewGuid():N}{ext}";
                await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), ms.ToArray());
                await AssetsSvc.AddAsync(file.Name, $"/uploads/templates/{name}", file.ContentType, file.Size);
            }
            _assets = (await AssetsSvc.ListAsync()).ToList();
        }
        catch { _assetError = "No se pudo subir la imagen."; }
        finally { _uploading = false; }
    }

    private async Task DeleteAssetAsync(Guid id)
    {
        if (await AssetsSvc.DeleteAsync(id)) { _assets = (await AssetsSvc.ListAsync()).ToList(); }
    }

    private async Task CopyUrl(string url)
    {
        // Copia la ruta relativa (portable entre entornos). Sirve en <img src="...">.
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", url); } catch { }
    }

    // Copia un marcador (ej. {{campo.aerolinea}}) al portapapeles para pegarlo en el HTML.
    private async Task CopyText(string text)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", text); } catch { }
    }

    // Reemplaza los marcadores conocidos e inyecta un <base> para resolver imagenes en la vista previa.
    private string PreviewHtml
    {
        get
        {
            var html = string.IsNullOrWhiteSpace(_html) ? "<p style='font-family:sans-serif;color:#888;padding:24px'>Escribe HTML para ver la vista previa.</p>" : _html;
            var sb = new StringBuilder(html);
            foreach (var p in _placeholders) { sb.Replace(p.Tag, p.Sample); }
            var result = sb.ToString();
            // Campos del embudo {{campo.clave}}: en la vista previa se muestran con un valor de ejemplo.
            // Prioridad: ejemplo conocido -> nombre (Label) del campo real del embudo -> marcador generico.
            result = System.Text.RegularExpressions.Regex.Replace(result, @"\{\{campo\.([a-zA-Z0-9_]+)\}\}", m =>
            {
                var key = m.Groups[1].Value;
                if (_fieldSamples.TryGetValue(key, out var s)) { return s; }
                var field = _fields.FirstOrDefault(f => string.Equals(f.FieldKey, key, StringComparison.OrdinalIgnoreCase));
                return field is not null ? $"[{field.Label}]" : "(dato)";
            });
            var baseTag = $"<base href=\"{Nav.BaseUri}\">";
            var headIdx = result.IndexOf("<head>", StringComparison.OrdinalIgnoreCase);
            return headIdx >= 0 ? result.Insert(headIdx + 6, baseTag) : baseTag + result;
        }
    }

    private const string StarterHtml = @"<!DOCTYPE html>
<html>
<head>
<meta charset=""utf-8"">
<style>
  * { box-sizing: border-box; }
  html, body { margin: 0; }
  body { font-family: 'Segoe UI', Arial, sans-serif; color: #2b2b2b; background:#fff; }
  .page { padding: 14px 30px 0; }
  .top { display: flex; justify-content: space-between; align-items: center; }
  .brand { display: flex; align-items: center; gap: 11px; }
  .brand img { width: 50px; height: 50px; }
  .brand .name { font-size: 21px; font-weight: 800; line-height:1.1; }
  .brand .nit { font-size: 10px; color: #7a2fb8; font-weight: 700; line-height: 1.3; }
  .dest { font-size: 32px; font-weight: 700; color: #b14de0; font-family: 'Brush Script MT','Segoe Script',cursive; }
  h2.client { margin: 12px 0 1px; font-size: 22px; font-weight: 800; letter-spacing:.5px; }
  .sub { font-weight: 800; letter-spacing:.5px; font-size: 13px; }
  table.info { width: 100%; border-collapse: collapse; margin-top: 10px; }
  table.info th { background:#a23ddc; color:#fff; padding:9px; font-size:12.5px; border:2px solid #a23ddc; letter-spacing:.4px; }
  table.info td { text-align:center; padding:9px; border:1px solid #c9c9c9; font-size:13.5px; }
  h3 { color:#a23ddc; font-size:19px; font-weight:800; letter-spacing:.4px; margin:16px 0 8px; }
  .incluye { display:flex; gap:10px; }
  .incluye .it { text-align:center; flex:1; font-size:12px; line-height:1.25; }
  .incluye .it img { width:62px; height:62px; border-radius:50%; display:block; margin:0 auto 5px; }
  .hotel { display:flex; gap:16px; align-items:center; }
  .hotel img { width:108px; height:108px; border-radius:50%; object-fit:cover; flex:none; }
  .hotel .det { font-size:14px; line-height:1.5; }
  .hotel .det .hname { font-size:19px; font-weight:800; }
  .hotel .det b { color:#a23ddc; }
  .fly { display:flex; align-items:center; gap:14px; padding:8px 0; border-bottom:1px solid #e5e5e5; font-size:13px; }
  .fly img { width:44px; }
  .fly .when { font-weight:800; font-size:14px; }
  .fly .meta { color:#777; font-size:11.5px; }
  .fly .col { flex:1; }
  .valores { display:flex; margin-top:18px; gap:0; }
  .valores .v { flex:1; text-align:center; }
  .valores .v .lbl { background:#a23ddc; color:#fff; padding:10px; font-weight:800; letter-spacing:.4px; font-size:13px; }
  .valores .v .amt { background:#efe6fb; padding:13px; font-size:20px; font-weight:800; }
  .foot { margin-top:18px; background:#a23ddc; color:#fff; padding:12px 30px; font-size:12px; display:flex; gap:22px; justify-content:center; flex-wrap:wrap; }
</style>
</head>
<body>
  <div class=""page"">
    <div class=""top"">
      <div class=""brand"">
        <img src=""/uploads/templates/demo-logo.svg"" alt=""logo"">
        <div>
          <div class=""name"">{{agencyName}}</div>
          <div class=""nit"">NIT: 000000000-0<br>RNT: 000000</div>
        </div>
      </div>
      <div class=""dest"">{{destination}}</div>
    </div>

    <h2 class=""client"">{{contactName}}</h2>
    <div class=""sub"">ENCUENTRA LOS DETALLES DE TU VIAJE AQUI:</div>

    <table class=""info"">
      <tr><th>ORIGEN-DESTINO</th><th>FECHA DE VIAJE</th><th>PASAJEROS</th></tr>
      <tr><td>{{destination}}</td><td>{{date}}</td><td>{{campo.adultos}} adultos</td></tr>
    </table>

    <h3>QUE INCLUYE TU PLAN?</h3>
    <div class=""incluye"">
      <div class=""it""><img src=""/uploads/templates/demo-icon-vuelo.svg"" alt="""">Vuelos<br>ida y regreso</div>
      <div class=""it""><img src=""/uploads/templates/demo-icon-traslado.svg"" alt="""">Traslados<br>A-H-A</div>
      <div class=""it""><img src=""/uploads/templates/demo-icon-hotel.svg"" alt="""">Noches<br>de hotel</div>
      <div class=""it""><img src=""/uploads/templates/demo-icon-salud.svg"" alt="""">Asistencia<br>medica de viaje</div>
    </div>

    <h3>HOTEL PREVISTO:</h3>
    <div class=""hotel"">
      <img src=""/uploads/templates/demo-hotel.svg"" alt=""hotel"">
      <div class=""det"">
        <div class=""hname"">{{campo.hotel1}}</div>
        <b>ALIMENTACION:</b> Desayunos y cenas<br>
        <b>ACOMODACION:</b> Habitacion doble
      </div>
    </div>

    <h3>ITINERARIO DE VUELOS:</h3>
    <div class=""fly"">
      <img src=""/uploads/templates/demo-avianca.svg"" alt=""avianca"">
      <div class=""col""><div class=""when"">Ida</div><div class=""meta"">Avianca - {{destination}}</div></div>
      <div class=""col""><div class=""meta"">Directo</div></div>
    </div>
    <div class=""fly"">
      <img src=""/uploads/templates/demo-avianca.svg"" alt=""avianca"">
      <div class=""col""><div class=""when"">Regreso</div><div class=""meta"">Avianca - {{destination}}</div></div>
      <div class=""col""><div class=""meta"">Directo</div></div>
    </div>

    <div class=""valores"">
      <div class=""v""><div class=""lbl"">VALOR POR PERSONA</div><div class=""amt"">{{currency}} {{campo.valorVuelosPax}}</div></div>
      <div class=""v""><div class=""lbl"">VALOR TOTAL</div><div class=""amt"">{{currency}} {{estimatedValue}}</div></div>
    </div>
  </div>

  <div class=""foot"">
    <span>{{agencyName}}</span><span>Tel: {{contactPhone}}</span><span>Cotizacion: {{date}}</span>
  </div>
</body>
</html>";
}
