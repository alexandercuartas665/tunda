@page "/trd"
@page "/transacciones"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@inject ITrdAdminService Trd
@inject NavigationManager Nav

<PageTitle>Transacciones documentales - DokTrino</PageTitle>

<div class="trx">
    <div class="trx-breadcrumb">Inicio &middot; Configuracion &middot; Tablas documentales</div>

    <div class="trx-head">
        <div>
            <div class="trx-title">Transacciones documentales</div>
            <div class="trx-sub">Configuraciones de Tablas de Retencion &middot; @_filtradas.Count registros</div>
        </div>
        <div class="trx-head-actions">
            <div class="trx-toggle">
                <a class="@(_vista == "cards" ? "on" : "")" @onclick='() => _vista = "cards"'>&#9638; Tarjetas</a>
                <a class="@(_vista == "list" ? "on" : "")" @onclick='() => _vista = "list"'>&#9776; Lista</a>
            </div>
            @if (_trds.Count == 0)
            {
                <button class="trx-btn ghost" @onclick="SeedDemo">Sembrar TRD demo</button>
            }
            <button class="trx-btn" @onclick="() => _nuevaOpen = !_nuevaOpen">+ Nueva transaccion</button>
        </div>
    </div>

    @if (_error is not null) { <div class="ase-alert">@_error</div> }
    @if (_ok is not null) { <div class="ase-ok">@_ok</div> }

    @* --- Alta de transaccion --- *@
    @if (_nuevaOpen)
    {
        <div class="trx-filtros" style="align-items: flex-end;">
            <div class="trx-f grow">
                <label>Titulo de la transaccion</label>
                <input @bind="_nt.Titulo" placeholder="TRD Institucional 2026" />
            </div>
            <div class="trx-f">
                <label>Segmento</label>
                <select @bind="_ntSeg">
                    <option value="">(sin segmento)</option>
                    @foreach (var s in _segmentos) { <option value="@s.Id">@s.Nombre</option> }
                </select>
            </div>
            <div class="trx-f">
                <label>Vigencia desde</label>
                <input type="date" @bind="_ntIni" />
            </div>
            <div class="trx-f">
                <label>Hasta</label>
                <input type="date" @bind="_ntFin" />
            </div>
            <button class="trx-btn" @onclick="CrearTrd">Crear</button>
            <button class="trx-btn ghost" @onclick="() => _nuevaOpen = false">Cancelar</button>
        </div>
    }

    @* --- Filtros --- *@
    <div class="trx-filtros">
        <div class="trx-f grow">
            <label>N.o transaccion / documento</label>
            <input @bind="_fltNum" @bind:event="oninput" placeholder="Ej. TRD-0001" />
        </div>
        <div class="trx-f">
            <label>Fecha inicio (desde)</label>
            <input type="date" @bind="_fltFecha" />
        </div>
        <div class="trx-f">
            <label>Estado</label>
            <select @bind="_fltEstado">
                <option value="TODOS">Todos</option>
                <option value="DESARROLLO">Desarrollo</option>
                <option value="ACTIVO">Activo</option>
                <option value="CERRADO">Cerrado</option>
            </select>
        </div>
        <button class="trx-btn ghost" @onclick="LimpiarFiltros">Limpiar</button>
    </div>

    @if (_filtradas.Count == 0)
    {
        <div class="trx-list"><div class="trx-empty">Sin transacciones que coincidan con el filtro.</div></div>
    }
    else if (_vista == "cards")
    {
        <div class="trx-cards">
            @foreach (var t in _filtradas)
            {
                <div class="trx-card" @onclick="() => Abrir(t)">
                    <div class="trx-card-top">
                        <span class="trx-num">@t.Consecutivo</span>
                        <span class="trx-est @t.Estado.ToLowerInvariant()">@t.Estado</span>
                    </div>
                    <div class="trx-dep">&#127963; @(t.Segmento ?? "Sin segmento")</div>
                    <div class="trx-obs">@(string.IsNullOrWhiteSpace(t.Observaciones) ? t.Titulo : t.Observaciones)</div>
                    <div class="trx-vig">
                        <div><div class="k">Vigencia desde</div><div class="v">@Fecha(t.FechaInicio)</div></div>
                        <div><div class="k">Hasta</div><div class="v">@Fecha(t.FechaFin)</div></div>
                    </div>
                    <div class="trx-card-foot">
                        <span>@t.Dependencias dependencias &middot; @t.Documentos documentos</span>
                        <span class="go">Abrir &rarr;</span>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="trx-list">
            <div class="trx-list-head">
                <div>N.o Doc.</div><div>Estado</div><div>Observacion</div>
                <div>Vigencia desde</div><div>Hasta</div><div>Depend.</div><div>Docs</div><div></div>
            </div>
            @foreach (var t in _filtradas)
            {
                <div class="trx-list-row" @onclick="() => Abrir(t)">
                    <div class="num">@t.Consecutivo</div>
                    <div><span class="trx-est @t.Estado.ToLowerInvariant()">@t.Estado</span></div>
                    <div class="txt">@(string.IsNullOrWhiteSpace(t.Observaciones) ? t.Titulo : t.Observaciones)</div>
                    <div class="mono">@Fecha(t.FechaInicio)</div>
                    <div class="mono">@Fecha(t.FechaFin)</div>
                    <div class="txt">@t.Dependencias</div>
                    <div class="txt">@t.Documentos</div>
                    <div class="go" style="color: var(--primary); font-weight: 700; font-size: 12px;">Abrir &rarr;</div>
                </div>
            }
        </div>
    }

    @* --- Catalogo del tenant (pasa a Configuracion Documental en la Fase 2E) --- *@
    <div class="trx-acc" style="margin-top: 18px;">
        <div class="trx-acc-h" @onclick="() => _catOpen = !_catOpen" style="cursor: pointer;">
            <span class="trx-acc-ico">&#128218;</span>
            <span class="trx-acc-t">Catalogo: series, subseries y tipologias</span>
            <span class="trx-acc-meta">@_series.Count series &middot; @_tipos.Count tipologias</span>
            <span style="color: #9aa3bd;">@(_catOpen ? "-" : "+")</span>
        </div>
        @if (_catOpen)
        {
            <div class="trx-acc-b">
                <div class="trd-cat" style="margin-top: 14px;">
                    <div>
                        <div class="trd-sub">Series (@_series.Count)</div>
                        @foreach (var s in _series)
                        {
                            <div class="trd-row"><span class="mono">@s.Codigo</span> @s.Nombre <span class="trd-muted">(@s.Subseries subseries)</span></div>
                        }
                        <div class="trd-form" style="margin-top: 10px;">
                            <input class="form-control form-control-sm" @bind="_nsCod" placeholder="100" />
                            <input class="form-control form-control-sm" @bind="_nsNom" placeholder="Actas" />
                            <button class="trx-btn" @onclick="AddSerie">+ Serie</button>
                        </div>
                    </div>
                    <div>
                        <div class="trd-sub">Tipologias (@_tipos.Count)</div>
                        @foreach (var ti in _tipos)
                        {
                            <div class="trd-row"><span class="mono">@ti.Codigo</span> @ti.Nombre <span class="trd-muted">@ti.Tipo</span></div>
                        }
                        <div class="trd-form" style="margin-top: 10px;">
                            <select class="form-select form-select-sm" @bind="_ntSerie">
                                <option value="">(serie)</option>
                                @foreach (var s in _series) { <option value="@s.Id">@s.Codigo @s.Nombre</option> }
                            </select>
                            <input class="form-control form-control-sm" @bind="_ntiCod" placeholder="100-01" />
                            <input class="form-control form-control-sm" @bind="_ntiNom" placeholder="Acta de comite" />
                            <button class="trx-btn" @onclick="AddTipo">+ Tipologia</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@* ===================== Detalle de la transaccion ===================== *@
@if (_sel is not null)
{
    <div class="doktrino-drawer-scrim" style="display: block;" @onclick="Cerrar"></div>
    <div style="position: fixed; inset: 0; z-index: 1950; display: flex; align-items: center; justify-content: center; padding: 18px; pointer-events: none;">
        <div class="trx-modal-xl">

            <div class="trx-detalle-hero">
                <div class="row1">
                    <span class="chip">@_sel.Consecutivo</span>
                    <span class="est">@_sel.Estado</span>
                    <span class="ttl">@(string.IsNullOrWhiteSpace(_sel.Observaciones) ? _sel.Titulo : _sel.Observaciones)</span>
                    <span style="margin-left: auto; cursor: pointer; font-size: 22px; color: oklch(0.88 0.05 237);" @onclick="Cerrar">&#10005;</span>
                </div>
                <div class="sub">
                    &#127963; @(_sel.Segmento ?? "Sin segmento") &middot; Vigencia @Fecha(_sel.FechaInicio) &rarr; @Fecha(_sel.FechaFin)
                </div>
            </div>

            @* --- Datos de la transaccion --- *@
            <div class="trx-acc">
                <div class="trx-acc-h" @onclick="() => _cabOpen = !_cabOpen" style="cursor: pointer;">
                    <span class="trx-acc-ico">&#128203;</span>
                    <span class="trx-acc-t">Datos de la transaccion</span>
                    <span class="trx-acc-meta">@_sel.Consecutivo &middot; @_sel.Estado</span>
                    <span style="color: #9aa3bd;">@(_cabOpen ? "-" : "+")</span>
                </div>
                @if (_cabOpen)
                {
                    <div class="trx-acc-b">
                        <div class="trx-grid8">
                            <div><div class="trx-lbl">Estado</div><div class="trx-ro">@_sel.Estado</div></div>
                            <div><div class="trx-lbl">#Id Tabla Documental</div><div class="trx-ro">@_sel.Consecutivo</div></div>
                            <div><div class="trx-lbl">Fecha</div><div class="trx-ro">@(_sel.Fecha?.ToLocalTime().ToString("dd/MM/yyyy") ?? "-")</div></div>
                            <div><div class="trx-lbl">Fecha inicial</div><div class="trx-ro">@Fecha(_sel.FechaInicio)</div></div>
                            <div><div class="trx-lbl">Fecha final</div><div class="trx-ro">@Fecha(_sel.FechaFin)</div></div>
                            <div><div class="trx-lbl">Segmento</div><div class="trx-ro">@(_sel.Segmento ?? "-")</div></div>
                            <div><div class="trx-lbl">Dependencias</div><div class="trx-ro">@_sel.Dependencias</div></div>
                            <div><div class="trx-lbl">Documentos</div><div class="trx-ro">@_sel.Documentos</div></div>
                            <div style="grid-column: 1 / -1;">
                                <div class="trx-lbl">Observacion</div>
                                <div class="trx-ro">@(string.IsNullOrWhiteSpace(_sel.Observaciones) ? "-" : _sel.Observaciones)</div>
                            </div>
                        </div>
                        <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 18px; flex-wrap: wrap;">
                            <a class="trx-btn ghost" href="@($"/api/doktrino/trd/{_sel.Id}/excel")" target="_blank">Exportar matriz (Excel AGN)</a>
                            @if (_sel.Estado == "DESARROLLO")
                            {
                                <button class="trx-btn" @onclick='() => Estado(_sel!.Id, "ACTIVO")'>Activar</button>
                            }
                            else if (_sel.Estado == "ACTIVO")
                            {
                                <button class="trx-btn danger" @onclick='() => Estado(_sel!.Id, "CERRADO")'>Cerrar transaccion</button>
                            }
                        </div>
                    </div>
                }
            </div>

            @* --- Dependencias (organigrama + token) --- *@
            <div class="trx-acc">
                <div class="trx-acc-h" @onclick="() => _depOpen = !_depOpen" style="cursor: pointer;">
                    <span class="trx-acc-ico">&#127963;</span>
                    <span class="trx-acc-t">Dependencias</span>
                    <span class="trx-acc-meta">@_deps.Count en el organigrama</span>
                    <span style="color: #9aa3bd;">@(_depOpen ? "-" : "+")</span>
                </div>
                @if (_depOpen)
                {
                    <div class="trx-acc-b">
                        @if (_depError is not null)
                        {
                            <div class="trx-error">@_depError</div>
                        }
                        <div class="dep-split">

                            @* --- Columna 4/12: jerarquia con scroll --- *@
                            <div class="dep-arbol">
                                <div class="dep-col-h">
                                    <span>Organigrama</span>
                                    <button class="trx-btn mini" @onclick="() => AbrirAlta(null)">&#43; Raiz</button>
                                </div>
                                <div class="dep-arbol-scroll">
                                    @if (_deps.Count == 0)
                                    {
                                        <div class="trx-empty">Sin dependencias todavia.</div>
                                    }
                                    @foreach (var d in Jerarquia())
                                    {
                                        <div class="dep-nodo @(_depSel?.Id == d.Id ? "on" : "")"
                                             style="padding-left: @(d.Nivel * 14 + 8)px"
                                             @onclick="() => SeleccionarDep(d)">
                                            <span class="cod mono">@d.Codigo</span>
                                            <span class="nom">@d.NombreCargo</span>
                                            @if (d.Personas > 0)
                                            {
                                                <span class="pers">&#128101; @d.Personas</span>
                                            }
                                            <span class="mas" title="Agregar sub-dependencia"
                                                  @onclick:stopPropagation="true" @onclick="() => AbrirAlta(d.Id)">&#43;</span>
                                        </div>
                                    }
                                </div>

                                @if (_altaAbierta)
                                {
                                    <div class="dep-alta">
                                        <div class="dep-alta-t">
                                            @if (_ndPadreNombre is null)
                                            {
                                                <span>Nueva dependencia raiz</span>
                                            }
                                            else
                                            {
                                                <span>Bajo <b>@_ndPadreNombre</b></span>
                                            }
                                        </div>
                                        <input class="dep-in cod" @bind="_nd.Codigo" placeholder="Cod." />
                                        <input class="dep-in" @bind="_nd.NombreCargo" placeholder="Nombre de la dependencia" />
                                        <div class="dep-alta-btns">
                                            <button class="trx-btn mini" @onclick="AddDep">Agregar</button>
                                            <button class="trx-btn ghost mini" @onclick="CerrarAlta">Cancelar</button>
                                        </div>
                                    </div>
                                }
                            </div>

                            @* --- Columna 8/12: tabla de todas las dependencias --- *@
                            <div class="dep-tabla">
                                <div class="dep-col-h">
                                    <span>Dependencias &middot; @_deps.Count</span>
                                    @if (_sinCuenta > 0)
                                    {
                                        <button class="trx-btn ghost mini" @onclick="CrearCuentasPendientes">
                                            Crear @_sinCuenta cuenta(s) faltante(s)
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="dep-hint">Abre una para asignar personas</span>
                                    }
                                </div>
                                <div class="dep-tabla-scroll">
                                    <table class="dep-tb">
                                        <thead>
                                            <tr>
                                                <th style="width: 90px;">Codigo</th>
                                                <th>Dependencia</th>
                                                <th style="width: 70px;">Nivel</th>
                                                <th style="width: 90px;">Personas</th>
                                                <th style="width: 90px;">Estado</th>
                                                <th style="width: 170px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (_deps.Count == 0)
                                            {
                                                <tr><td colspan="6" class="vacio">Sin dependencias. Crea la raiz del organigrama.</td></tr>
                                            }
                                            @foreach (var d in Jerarquia())
                                            {
                                                <tr class="@(_depSel?.Id == d.Id ? "on" : "")" @onclick="() => AbrirPersonas(d)">
                                                    <td @onclick:stopPropagation="true">
                                                        <input class="dep-in cod celda" value="@d.Codigo"
                                                               @onchange="e => GuardarDep(d, e.Value?.ToString(), null)" />
                                                    </td>
                                                    <td @onclick:stopPropagation="true">
                                                        <input class="dep-in celda" style="margin-left: @(d.Nivel * 12)px;" value="@d.NombreCargo"
                                                               @onchange="e => GuardarDep(d, null, e.Value?.ToString())" />
                                                    </td>
                                                    <td>@d.Nivel</td>
                                                    <td>@d.Personas</td>
                                                    <td><span class="dep-badge">@d.Estado</span></td>
                                                    <td class="acc" @onclick:stopPropagation="true">
                                                        <button class="trx-btn ghost mini" @onclick="() => AbrirPersonas(d)">Personas</button>
                                                        <button class="trx-btn danger mini" @onclick="() => DelDep(d.Id)">&times;</button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ===================== Personas de una dependencia ===================== *@
@if (_personasDe is not null)
{
    <div class="doktrino-drawer-scrim" style="display: block; z-index: 1990;" @onclick="CerrarPersonas"></div>
    <div style="position: fixed; inset: 0; z-index: 1995; display: flex; align-items: center; justify-content: center; padding: 24px; pointer-events: none;">
        <div class="per-modal">
            <div class="per-h">
                <div>
                    <div class="per-t">Personas de la dependencia</div>
                    <div class="per-sub"><span class="mono">@_personasDe.Codigo</span> &middot; @_personasDe.NombreCargo</div>
                </div>
                <span class="per-x" @onclick="CerrarPersonas">&#10005;</span>
            </div>

            <div class="per-b">
                @if (_perError is not null)
                {
                    <div class="trx-error">@_perError</div>
                }
                <div class="per-nota">
                    Puedes asignar varias personas a la misma dependencia. Cada una entra con su
                    propio enlace y su cuenta nace con la clave <b>12345</b>.
                </div>

                @if (_personas.Count == 0)
                {
                    <div class="trx-empty">Nadie asignado todavia.</div>
                }
                @foreach (var p in _personas)
                {
                    <div class="per-row">
                        <span class="per-ini">@Iniciales(p.Nombre)</span>
                        <div class="per-datos">
                            <div class="per-campos">
                                <input class="dep-in celda" value="@p.Nombre"
                                       @onchange="e => GuardarPersona(p, nombre: e.Value?.ToString())" />
                                <input class="dep-in celda" value="@p.Email"
                                       @onchange="e => GuardarPersona(p, email: e.Value?.ToString())" />
                                <input class="dep-in celda" value="@p.Telefono" placeholder="Telefono"
                                       @onchange="e => GuardarPersona(p, telefono: e.Value?.ToString())" />
                                <select class="dep-in celda" value="@p.Rol"
                                        @onchange="e => GuardarPersona(p, rol: e.Value?.ToString())">
                                    <option value="RESPONSABLE">Responsable</option>
                                    <option value="REVISOR">Revisor</option>
                                    <option value="APOYO">Apoyo</option>
                                </select>
                            </div>
                            @if (p.TokenUrl is string enlace)
                            {
                                <div class="per-link">
                                    <a href="@enlace" target="_blank">@Trunc(enlace)</a>
                                </div>
                            }
                        </div>
                        <div class="per-acc">
                            <button class="trx-btn ghost mini" @onclick="() => TokenPersona(p.Id)">
                                @(p.TokenUrl is null ? "Generar enlace" : "Reemitir")
                            </button>
                            <button class="trx-btn danger mini" @onclick="() => DelPersona(p.Id)">&times;</button>
                        </div>
                    </div>
                }

                <div class="per-alta">
                    <input class="dep-in" @bind="_np.Nombre" placeholder="Nombre de la persona" />
                    <input class="dep-in" @bind="_np.Email" placeholder="Correo electronico" />
                    <input class="dep-in" @bind="_np.Telefono" placeholder="Telefono" />
                    <select class="dep-in" @bind="_np.Rol">
                        <option value="RESPONSABLE">Responsable</option>
                        <option value="REVISOR">Revisor</option>
                        <option value="APOYO">Apoyo</option>
                    </select>
                    <button class="trx-btn" @onclick="AddPersona">&#43; Asignar</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* Modal de la transaccion: casi pantalla completa. */
    .trx-modal-xl { width:97vw; height:94vh; background:#faf9f5; border-radius:18px;
                    box-shadow:0 30px 80px rgba(0,0,0,.32); pointer-events:auto;
                    padding:18px; overflow:auto; }

    /* Cabecera identificatoria en 8 columnas. */
    .trx-grid8 { display:grid; grid-template-columns:repeat(8, minmax(0,1fr)); gap:14px 18px; }
    @@media (max-width: 1500px) { .trx-grid8 { grid-template-columns:repeat(4, minmax(0,1fr)); } }
    @@media (max-width: 800px)  { .trx-grid8 { grid-template-columns:repeat(2, minmax(0,1fr)); } }

    /* Dependencias: 4 columnas de arbol + 8 de tabla. */
    .dep-split { display:grid; grid-template-columns:4fr 8fr; gap:16px; align-items:start; }
    @@media (max-width: 1100px) { .dep-split { grid-template-columns:1fr; } }

    .dep-col-h { display:flex; align-items:center; justify-content:space-between; gap:10px;
                 padding:0 2px 8px; font-size:11px; font-weight:800; letter-spacing:.4px;
                 text-transform:uppercase; color:#8a93ad; }
    .dep-hint { font-weight:600; text-transform:none; letter-spacing:0; color:#a8b0c4; }

    .dep-arbol, .dep-tabla { background:#fff; border:1px solid #e6e9f2; border-radius:12px; padding:12px; }
    .dep-arbol-scroll { max-height:46vh; overflow:auto; }
    .dep-tabla-scroll { max-height:56vh; overflow:auto; }

    .dep-nodo { display:flex; align-items:center; gap:8px; padding:6px 8px; border-radius:8px;
                cursor:pointer; font-size:12.5px; }
    .dep-nodo:hover { background:#f6f8fc; }
    .dep-nodo.on { background:var(--primary-soft); }
    .dep-nodo .cod { font-size:11px; font-weight:700; color:var(--primary); flex-shrink:0; }
    .dep-nodo .nom { overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .dep-nodo .pers { font-size:10.5px; color:#8a93ad; flex-shrink:0; }
    .dep-nodo .mas { margin-left:auto; flex-shrink:0; width:20px; height:20px; border-radius:6px;
                     display:grid; place-items:center; background:var(--primary-soft);
                     color:var(--primary); font-weight:800; }

    .dep-alta { margin-top:10px; padding-top:10px; border-top:1px dashed #e0e4ee;
                display:flex; flex-direction:column; gap:6px; }
    .dep-alta-t { font-size:11px; color:#8a93ad; }
    .dep-alta-btns { display:flex; gap:6px; }
    .dep-in { width:100%; border:1px solid #e3e7f2; background:#fff; border-radius:8px;
              padding:7px 9px; font-size:12.5px; color:#37415c; outline:none; }
    .dep-in:focus { border-color:var(--primary); }
    .dep-in.cod { font-family:'IBM Plex Mono',monospace; }
    /* Celda editable: parece texto hasta que se enfoca. */
    .dep-in.celda { border-color:transparent; background:transparent; padding:4px 6px; }
    .dep-in.celda:hover { border-color:#e3e7f2; background:#fff; }
    .dep-in.celda:focus { border-color:var(--primary); background:#fff; }

    .dep-tb { width:100%; border-collapse:collapse; font-size:12.5px; }
    .dep-tb th { position:sticky; top:0; background:#1e2436; color:#fff; text-align:left;
                 font-size:10.5px; letter-spacing:.4px; text-transform:uppercase;
                 padding:9px 10px; z-index:1; }
    .dep-tb td { padding:9px 10px; border-bottom:1px solid #eef1f7; }
    .dep-tb tbody tr { cursor:pointer; }
    .dep-tb tbody tr:hover { background:#f6f8fc; }
    .dep-tb tbody tr.on { background:var(--primary-soft); }
    .dep-tb tr.tok td { font-size:11px; color:#8a93ad; background:#fbfcfe; cursor:default; }
    .dep-tb td.acc { display:flex; gap:5px; justify-content:flex-end; }
    .dep-tb td.vacio { text-align:center; color:#a8b0c4; padding:22px; }
    .dep-badge { font-size:10px; font-weight:800; letter-spacing:.3px; padding:2px 7px;
                 border-radius:20px; background:#e8f5ee; color:#2f7d54; }

    .trx-btn.mini { padding:5px 9px; font-size:11px; }
    .trx-error { background:#fdecec; border:1px solid #f5c6c6; color:#a33; border-radius:8px;
                 padding:8px 11px; font-size:12px; margin-bottom:10px; }

    /* Modal de personas. */
    .per-modal { width:860px; max-width:100%; max-height:86vh; overflow:auto; background:#faf9f5;
                 border-radius:16px; box-shadow:0 30px 80px rgba(0,0,0,.35); pointer-events:auto; }
    .per-h { display:flex; align-items:flex-start; justify-content:space-between; gap:12px;
             padding:18px 20px; background:linear-gradient(135deg, var(--primary), var(--primary-deep));
             color:#fff; border-radius:16px 16px 0 0; }
    .per-t { font-size:16px; font-weight:800; }
    .per-sub { font-size:12px; opacity:.9; margin-top:2px; }
    .per-x { cursor:pointer; font-size:18px; opacity:.9; }
    .per-b { padding:16px 20px 20px; }
    .per-nota { font-size:11.5px; color:#8a93ad; margin-bottom:12px; }
    .per-row { display:flex; align-items:center; gap:10px; padding:9px 0; border-bottom:1px solid #eef1f7; }
    .per-ini { width:30px; height:30px; border-radius:50%; flex-shrink:0; display:grid; place-items:center;
               background:var(--primary-soft); color:var(--primary); font-size:11px; font-weight:800; }
    .per-datos { min-width:0; flex:1; }
    .per-nom { font-size:13px; font-weight:700; }
    .per-mail { font-size:11px; color:#8a93ad; }
    .per-rol { font-size:10px; font-weight:800; letter-spacing:.3px; padding:2px 8px;
               border-radius:20px; background:#eef2fb; color:#4a5878; }
    .per-campos { display:grid; grid-template-columns:1.2fr 1.4fr .9fr .9fr; gap:4px; }
    .per-link { font-size:10.5px; margin-top:3px; padding-left:6px; }
    .per-link a { color:var(--primary); }
    .per-acc { display:flex; gap:5px; flex-shrink:0; }
    .per-alta { margin-top:14px; padding-top:14px; border-top:1px dashed #e0e4ee;
                display:grid; grid-template-columns:1.2fr 1.4fr .9fr .9fr auto; gap:8px; align-items:center; }
    @@media (max-width: 760px) { .per-alta, .per-campos { grid-template-columns:1fr; } }

    .trd-form { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
    .trd-form .form-control, .trd-form .form-select { max-width:220px; }
    .mono { font-family:'IBM Plex Mono','Consolas',monospace; }
    .trd-cat { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
    .trd-sub { font-weight:700; margin-bottom:6px; }
    .trd-row { padding:5px 0; border-bottom:1px solid var(--chrome-border); font-size:13px; }
    .trd-muted { color:var(--muted-foreground); font-size:11px; }
    @@media (max-width: 900px) { .trd-cat { grid-template-columns:1fr; } }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<TrdDto> _trds = new();
    private List<SegmentoDto> _segmentos = new();
    private List<DependenciaDto> _deps = new();
    private List<SerieDto> _series = new();
    private List<TipologiaDocDto> _tipos = new();
    private Dictionary<Guid, string> _tokenUrls = new();
    private TrdDto? _sel;

    // Vista y filtros de la cabecera.
    private string _vista = "cards";
    private string _fltNum = "";
    private DateTime? _fltFecha;
    private string _fltEstado = "TODOS";

    // La cabecera arranca plegada: identifica la transaccion pero no es lo que se
    // viene a trabajar. El organigrama si abre de una.
    private bool _nuevaOpen, _catOpen, _cabOpen = false, _depOpen = true;

    private CrearTrdRequest _nt = new();
    private string _ntSeg = "";
    private DateTime? _ntIni, _ntFin;
    private CrearDependenciaRequest _nd = new();
    private string _ndPadre = "";
    private string? _ndPadreNombre;
    private bool _altaAbierta;
    private string? _depError;
    private DependenciaDto? _depSel;
    private int _sinCuenta;

    // Modal de personas de una dependencia.
    private DependenciaDto? _personasDe;
    private List<ColaboradorDto> _personas = new();
    private CrearColaboradorRequest _np = new();
    private string? _perError;
    private string _nsCod = "", _nsNom = "", _ntiCod = "", _ntiNom = "", _ntSerie = "";
    private string? _error, _ok;

    /// <summary>Lo que se pinta: la lista filtrada por numero, fecha y estado.</summary>
    private List<TrdDto> _filtradas => _trds
        .Where(t => string.IsNullOrWhiteSpace(_fltNum)
                    || t.Consecutivo.Contains(_fltNum.Trim(), StringComparison.OrdinalIgnoreCase)
                    || t.Titulo.Contains(_fltNum.Trim(), StringComparison.OrdinalIgnoreCase))
        .Where(t => _fltEstado == "TODOS" || t.Estado == _fltEstado)
        .Where(t => _fltFecha is null
                    || (t.FechaInicio is DateOnly fi && fi >= DateOnly.FromDateTime(_fltFecha.Value)))
        .ToList();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        _trds = (await Trd.ListarTrdAsync()).ToList();
        _segmentos = (await Trd.ListSegmentosAsync()).ToList();
        _series = (await Trd.ListSeriesAsync()).ToList();
        _tipos = (await Trd.ListTipologiasAsync()).ToList();

        if (_sel is not null)
        {
            // Refresca la seleccion contra la lista recien traida.
            _sel = _trds.FirstOrDefault(t => t.Id == _sel.Id);
            if (_sel is not null)
            {
                _deps = (await Trd.ArbolDependenciasAsync(_sel.Id)).ToList();
                _sinCuenta = await Trd.ColaboradoresSinCuentaAsync(_sel.Id);
            }
        }
    }

    private void LimpiarFiltros()
    {
        _fltNum = "";
        _fltFecha = null;
        _fltEstado = "TODOS";
    }

    private async Task Abrir(TrdDto t)
    {
        _sel = t;
        _deps = (await Trd.ArbolDependenciasAsync(t.Id)).ToList();
        _sinCuenta = await Trd.ColaboradoresSinCuentaAsync(t.Id);
    }

    private async Task CrearCuentasPendientes()
    {
        _depError = null;
        if (_sel is null) { return; }
        try
        {
            var n = await Trd.CrearCuentasPendientesAsync(_sel.Id, await Actor());
            _ok = $"{n} cuenta(s) creada(s) con la clave por defecto.";
            await LoadAll();
        }
        catch (InvalidOperationException ex) { _depError = ex.Message; }
    }

    private void Cerrar() => _sel = null;

    private static string Fecha(DateOnly? d) => d?.ToString("dd/MM/yyyy") ?? "-";

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task CrearTrd()
    {
        _error = _ok = null;
        _nt.SegmentoId = Guid.TryParse(_ntSeg, out var g) ? g : null;
        _nt.FechaInicio = _ntIni is DateTime i ? DateOnly.FromDateTime(i) : null;
        _nt.FechaFin = _ntFin is DateTime f ? DateOnly.FromDateTime(f) : null;
        try
        {
            var s = await Trd.CrearTrdAsync(_nt, await Actor());
            if (s is null) { _error = "Sin tenant."; return; }
            _ok = $"Transaccion {s.Consecutivo} creada.";
            _nt = new(); _ntSeg = ""; _ntIni = _ntFin = null; _nuevaOpen = false;
            await LoadAll();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Estado(Guid id, string e)
    {
        _error = _ok = null;
        try { await Trd.CambiarEstadoAsync(id, e, await Actor()); _ok = $"Estado -> {e}."; await LoadAll(); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    // ---------- Organigrama ----------

    /// <summary>
    /// Aplana el arbol en preorden (cada padre seguido de sus hijos) para que la
    /// sangria del arbol y de la tabla lean igual. El servicio devuelve por nivel,
    /// que agrupa a todos los hermanos lejos de su padre.
    /// </summary>
    private List<DependenciaDto> Jerarquia()
    {
        // ToLookup y no ToDictionary: las raices tienen PadreId nulo y un
        // Dictionary no admite clave nula.
        var porPadre = _deps.ToLookup(d => d.PadreId);
        var salida = new List<DependenciaDto>();

        void Bajar(Guid? padre)
        {
            foreach (var h in porPadre[padre].OrderBy(d => d.Orden))
            {
                salida.Add(h);
                Bajar(h.Id);
            }
        }
        Bajar(null);

        // Si algun nodo quedo huerfano (padre borrado), no lo escondemos.
        foreach (var d in _deps.Where(d => !salida.Any(s => s.Id == d.Id))) { salida.Add(d); }
        return salida;
    }

    private void SeleccionarDep(DependenciaDto d) => _depSel = d;

    private void AbrirAlta(Guid? padreId)
    {
        _depError = null;
        _altaAbierta = true;
        _nd = new CrearDependenciaRequest();
        _ndPadre = padreId?.ToString() ?? "";
        _ndPadreNombre = padreId is Guid p ? _deps.FirstOrDefault(x => x.Id == p)?.NombreCargo : null;
    }

    private void CerrarAlta() { _altaAbierta = false; _depError = null; _nd = new(); _ndPadre = ""; _ndPadreNombre = null; }

    private async Task AddDep()
    {
        _error = _ok = _depError = null;
        if (_sel is null) { return; }
        _nd.TrdId = _sel.Id;
        _nd.PadreId = Guid.TryParse(_ndPadre, out var g) ? g : null;
        try { await Trd.AgregarDependenciaAsync(_nd, await Actor()); CerrarAlta(); await LoadAll(); }
        catch (InvalidOperationException ex) { _depError = ex.Message; }
    }

    /// <summary>Guarda codigo o nombre desde la celda; el que no se toca viaja igual.</summary>
    private async Task GuardarDep(DependenciaDto d, string? codigo, string? nombre)
    {
        _depError = null;
        try
        {
            await Trd.ActualizarDependenciaAsync(d.Id, codigo ?? d.Codigo, nombre ?? d.NombreCargo, await Actor());
            await LoadAll();
        }
        catch (InvalidOperationException ex) { _depError = ex.Message; }
    }

    private async Task DelDep(Guid id)
    {
        _error = _ok = _depError = null;
        await Trd.EliminarDependenciaAsync(id, await Actor());
        if (_depSel?.Id == id) { _depSel = null; }
        if (_personasDe?.Id == id) { CerrarPersonas(); }
        await LoadAll();
    }

    // ---------- Personas de una dependencia ----------

    private async Task AbrirPersonas(DependenciaDto d)
    {
        _depSel = d;
        _personasDe = d;
        _perError = null;
        _np = new CrearColaboradorRequest();
        _personas = (await Trd.ColaboradoresAsync(d.Id, Nav.BaseUri)).ToList();
    }

    private async Task RecargarPersonas()
    {
        if (_personasDe is null) { return; }
        _personas = (await Trd.ColaboradoresAsync(_personasDe.Id, Nav.BaseUri)).ToList();
    }

    /// <summary>Edita en sitio; los campos no tocados viajan con su valor actual.</summary>
    private async Task GuardarPersona(ColaboradorDto p, string? nombre = null, string? email = null,
                                      string? telefono = null, string? rol = null)
    {
        _perError = null;
        try
        {
            await Trd.ActualizarColaboradorAsync(new EditarColaboradorRequest
            {
                Id = p.Id,
                Nombre = nombre ?? p.Nombre,
                Email = email ?? p.Email,
                Telefono = telefono ?? p.Telefono,
                Rol = rol ?? p.Rol
            }, await Actor());
            await RecargarPersonas();
        }
        catch (InvalidOperationException ex) { _perError = ex.Message; }
    }

    private async Task TokenPersona(Guid colaboradorId)
    {
        _perError = null;
        try
        {
            await Trd.GenerarTokenColaboradorAsync(colaboradorId, Nav.BaseUri.TrimEnd('/'), await Actor());
            await RecargarPersonas();
        }
        catch (InvalidOperationException ex) { _perError = ex.Message; }
    }

    private void CerrarPersonas() { _personasDe = null; _personas.Clear(); _perError = null; }

    private async Task AddPersona()
    {
        _perError = null;
        if (_personasDe is null) { return; }
        _np.DependenciaId = _personasDe.Id;
        try
        {
            await Trd.AgregarColaboradorAsync(_np, await Actor());
            _np = new CrearColaboradorRequest();
            await RecargarPersonas();
            await LoadAll();
        }
        catch (InvalidOperationException ex) { _perError = ex.Message; }
    }

    private async Task DelPersona(Guid id)
    {
        _perError = null;
        if (_personasDe is null) { return; }
        await Trd.EliminarColaboradorAsync(id, await Actor());
        await RecargarPersonas();
        await LoadAll();
    }

    /// <summary>Iniciales para el avatar; una sola palabra devuelve una sola letra.</summary>
    private static string Iniciales(string nombre)
    {
        var partes = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (partes.Length == 0) { return "?"; }
        return partes.Length == 1
            ? partes[0][..1].ToUpperInvariant()
            : (partes[0][..1] + partes[1][..1]).ToUpperInvariant();
    }

    private async Task Token(Guid depId)
    {
        _error = _ok = null;
        try
        {
            var baseUrl = Nav.BaseUri.TrimEnd('/');
            var t = await Trd.GenerarTokenAsync(depId, null, baseUrl, await Actor());
            if (t is not null) { _tokenUrls[depId] = t.Url; _ok = "Token generado; copia el enlace para el colaborador."; }
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task AddSerie()
    {
        _error = _ok = null;
        try { await Trd.CrearSerieAsync(_nsCod, _nsNom, await Actor()); _nsCod = ""; _nsNom = ""; await LoadAll(); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task AddTipo()
    {
        _error = _ok = null;
        Guid? serie = Guid.TryParse(_ntSerie, out var g) ? g : null;
        try { await Trd.CrearTipologiaAsync(serie, null, _ntiCod, _ntiNom, "GENERAL", await Actor()); _ntiCod = ""; _ntiNom = ""; _ntSerie = ""; await LoadAll(); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task SeedDemo()
    {
        _error = _ok = null;
        var baseUrl = Nav.BaseUri.TrimEnd('/');
        var n = await Trd.SeedDemoAsync(baseUrl, await Actor());
        _ok = n > 0 ? "TRD demo sembrada (segmento, serie/subserie/tipologia, TRD con organigrama)." : "Ya existian TRD.";
        await LoadAll();
    }

    private static string Trunc(string s) => s.Length > 48 ? "..." + s[^45..] : s;
}
