@page "/imprimir-paquete/{HcId:guid}"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities
@using DokTrino.Application.Tenancy
@using DokTrino.SuperAdmin.Components.Forms
@inject IHistoriaClinicaService HcSvc
@inject IAsignacionService AsigSvc
@inject IFormDefinitionService FormsSvc
@inject IOrdenMedicamentoService MedSvc
@inject IOrdenServicioService SrvSvc
@inject IIncapacidadService IncSvc
@inject ICertificacionService CertSvc
@inject IRemisionService RemSvc
@inject IEscalaService EscSvc
@inject IDocumentoHcService DocSvc
@inject IJSRuntime JS
@inject NavigationManager Nav

@*
   Vista "paquete": renderiza en una sola pagina varios documentos seleccionados
   por el especialista (HC + 0..N ordenes). Cada documento queda en su propia
   pagina al imprimir gracias a page-break-after:always. La lista de docs viene
   en query string ?docs=HC,MED,SRV,INC,CERT.
*@

<PageTitle>Paquete de impresion - DokTrino</PageTitle>

<style>
    .doc-actions { display:flex; gap:8px; align-items:center; margin:14px auto; max-width:920px; }
    .doc-actions .dbtn { padding:8px 14px; border:1px solid var(--border); border-radius:8px; background:var(--card); font-size:13px; font-weight:600; cursor:pointer; color:var(--foreground); text-decoration:none; }
    .doc-actions .dbtn.primary { background:var(--primary); border-color:var(--primary); color:#fff; }
    .doc-actions .spacer { flex:1; }
    .doc-actions .meta { font-size:12px; color:var(--muted-foreground); }

    .pack { max-width:920px; margin: 0 auto; }
    .pack-doc { background:#fff; color:#000; font-family:'Segoe UI', Arial, sans-serif; font-size:12px; line-height:1.35; border:1px solid #000; margin-bottom: 22px; }
    .pack-header { border-bottom:1px solid #000; padding:8px 10px; }
    .pack-hdr-top { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; }
    .pack-hdr-brand { display:flex; align-items:center; gap:8px; }
    .pack-hdr-brand svg { width:30px; height:30px; color:#1565c0; }
    .pack-hdr-logo { max-height:48px; max-width:180px; object-fit:contain; }
    .pack-hdr-inst { font-size:16px; font-weight:800; color:#1565c0; }
    .pack-hdr-tag { font-size:10px; font-style:italic; color:#555; }
    .pack-hdr-nohist { font-size:11px; white-space:nowrap; text-align:right; }
    .pack-hdr-nohist b { font-size:12px; color:#1565c0; }
    .pack-hdr-title { text-align:center; font-size:15px; font-weight:800; text-transform:uppercase; margin:6px 0; }
    .pack-hdr-meta { display:flex; gap:28px; font-size:11px; flex-wrap:wrap; }
    .pack-hdr-meta b { color:#1565c0; }

    .pack-band { background:#dde7f3; font-weight:800; font-size:11px; padding:4px 8px; text-transform:uppercase; border-bottom:1px solid #000; letter-spacing:.04em; }
    .pack-sub { font-weight:700; font-size:11px; padding:4px 8px; background:#f3f6fb; border-bottom:1px solid #000; }
    .pack-para { padding:4px 8px; border-bottom:1px solid #000; color:#222; white-space:pre-wrap; }
    .pack-grid { display:grid; grid-template-columns: repeat(12, 1fr); }
    .pack-cell { border-right:1px solid #000; border-bottom:1px solid #000; padding:2px 6px 4px; min-height:34px; }
    .pack-label { font-size:9px; font-weight:700; text-transform:uppercase; color:#333; }
    .pack-value { min-height:14px; border-bottom:1px dotted #999; margin-top:4px; padding:1px 2px; font-size:12px; color:#000; white-space:pre-wrap; word-break:break-word; }

    .pack-table { width:100%; border-collapse:collapse; }
    .pack-table th { border:1px solid #000; background:#dde7f3; font-size:10px; padding:4px 6px; text-align:left; font-weight:700; text-transform:uppercase; }
    .pack-table td { border:1px solid #000; padding:4px 6px; font-size:11px; vertical-align:top; }
    .pack-table td.mono { font-family:'JetBrains Mono','Consolas',monospace; font-size:10.5px; }
    .pack-table td.num { text-align:center; }
    .pack-empty-row { text-align:center; font-style:italic; color:#666; padding:18px !important; }

    .pack-section { padding:8px 10px; border-bottom:1px solid #000; white-space:pre-wrap; font-size:11.5px; }
    .pack-section h4 { margin:0 0 4px; font-size:11px; text-transform:uppercase; color:#1565c0; }

    .pack-footer { display:flex; justify-content:space-between; gap:24px; padding:24px 14px 12px; border-top:1px solid #000; font-size:11px; }
    .pack-firma { flex:1; max-width:280px; }
    .pack-firma-line { border-top:1px solid #000; padding-top:4px; font-weight:700; }
    .pack-firma-rol { font-size:10px; color:#555; }

    /* Cada documento es una pagina al imprimir. */
    .pack-doc { page-break-after: always; break-after: page; }
    .pack-doc:last-child { page-break-after: auto; break-after: auto; }

    @@media print {
        .doktrino-sidebar, .doktrino-topbar, .doc-actions { display:none !important; }
        .doktrino-main, .doktrino-shell { margin:0 !important; padding:0 !important; }
        .pack { max-width:none; }
        .pack-doc { margin-bottom:0; border:1px solid #000; }
        body { background:#fff !important; }
        @@page { size: A4; margin: 12mm; }
    }
</style>

@if (_loading)
{
    <p class="doc-actions">Cargando paquete...</p>
}
else if (_hc is null)
{
    <p class="doc-actions">Historia clinica no encontrada.</p>
}
else
{
    <div class="doc-actions">
        <a class="dbtn" href="javascript:window.close()">&times; Cerrar</a>
        <button class="dbtn primary" @onclick="PrintAsync">&#128424; Imprimir todo / Guardar PDF</button>
        <span class="spacer"></span>
        <span class="meta">@_docs.Count documento(s) en el paquete</span>
    </div>

    <div class="pack">
        @* ============ DOCUMENTO 1: HISTORIA CLINICA ============ *@
        @if (_incluirHc && _hcSchema is not null)
        {
            <div class="pack-doc">
                @RenderHeader(HdrHc, _hc.FormatoNombre, "HC", _hc.Id.ToString().Substring(0, 8).ToUpperInvariant(),
                    $"Apertura: {_hc.FechaApertura.ToLocalTime():dd/MM/yyyy HH:mm}")

                @foreach (var node in _hcSchema.Children)
                {
                    @RenderTopNode(node, _valores)
                }

                @RenderFirma(_hc.EspecialistaNombre, "Firma del profesional tratante")
            </div>
        }

        @* ============ ORDEN DE MEDICAMENTOS ============ *@
        @if (_incluirMed && _meds.Count > 0)
        {
            <div class="pack-doc">
                @RenderHeader(HdrMed, "Orden de Medicamentos", "MED",
                    _hc.Id.ToString().Substring(0,8).ToUpperInvariant() + "-MED",
                    "Fecha: " + DateTime.Now.ToString("dd/MM/yyyy HH:mm"))
                <div class="pack-band">Detalle de la orden</div>
                <table class="pack-table">
                    <thead>
                        <tr>
                            <th style="width:40px">#</th>
                            <th>Medicamento</th>
                            <th style="width:140px">Posologia</th>
                            <th style="width:80px">Cantidad</th>
                            <th>Observacion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in _meds)
                        {
                            <tr>
                                <td class="num">@m.Orden</td>
                                <td><b>@m.NombreMedicamento</b></td>
                                <td>@(string.IsNullOrWhiteSpace(m.Posologia) ? "-" : m.Posologia)</td>
                                <td class="num">@(string.IsNullOrWhiteSpace(m.Cantidad) ? "-" : m.Cantidad)</td>
                                <td>@(m.Observacion ?? "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @RenderFirma(_hc.EspecialistaNombre, "Firma del profesional tratante")
            </div>
        }

        @* ============ ORDEN A SERVICIOS ============ *@
        @if (_incluirSrv && _srv.Count > 0)
        {
            <div class="pack-doc">
                @RenderHeader(HdrSrv, "Orden a Servicios", "SRV",
                    _hc.Id.ToString().Substring(0,8).ToUpperInvariant() + "-SRV",
                    "Fecha: " + DateTime.Now.ToString("dd/MM/yyyy HH:mm"))
                <div class="pack-band">Detalle de la orden</div>
                <table class="pack-table">
                    <thead>
                        <tr>
                            <th style="width:40px">#</th>
                            <th style="width:110px">Cod. Servicio</th>
                            <th>Descripcion</th>
                            <th style="width:80px">Cantidad</th>
                            <th>Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _srv)
                        {
                            <tr>
                                <td class="num">@s.Orden</td>
                                <td class="mono">@(s.CodigoServicio ?? "-")</td>
                                <td><b>@s.Descripcion</b></td>
                                <td class="num">@(string.IsNullOrWhiteSpace(s.Cantidad) ? "-" : s.Cantidad)</td>
                                <td>@(s.Observaciones ?? "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @RenderFirma(_hc.EspecialistaNombre, "Firma del profesional tratante")
            </div>
        }

        @* ============ REMISIONES ============ *@
        @if (_incluirRem && _rem.Count > 0)
        {
            <div class="pack-doc">
                @RenderHeader(HdrRem, "Ordenes de Remision", "REM",
                    _hc.Id.ToString().Substring(0,8).ToUpperInvariant() + "-REM",
                    "Fecha: " + DateTime.Now.ToString("dd/MM/yyyy HH:mm"))
                <div class="pack-band">Detalle de las remisiones</div>
                <table class="pack-table">
                    <thead>
                        <tr>
                            <th style="width:40px">#</th>
                            <th style="width:230px">Capitulo</th>
                            <th style="width:100px">Codigo</th>
                            <th>Especialidad</th>
                            <th>Motivo / Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _rem)
                        {
                            <tr>
                                <td class="num">@r.Orden</td>
                                <td>@r.Capitulo</td>
                                <td class="mono">@(r.EspecialidadCodigo ?? "-")</td>
                                <td><b>@r.EspecialidadNombre</b></td>
                                <td>@(r.Motivo ?? "")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @RenderFirma(_hc.EspecialistaNombre, "Firma del profesional tratante")
            </div>
        }

        @* ============ INCAPACIDADES ============ *@
        @if (_incluirInc && _inc.Count > 0)
        {
            <div class="pack-doc">
                @RenderHeader(HdrInc, "Orden de Incapacidad", "INC",
                    _hc.Id.ToString().Substring(0,8).ToUpperInvariant() + "-INC",
                    "Fecha: " + DateTime.Now.ToString("dd/MM/yyyy HH:mm"))
                <div class="pack-band">Detalle de la orden</div>
                <table class="pack-table">
                    <thead>
                        <tr>
                            <th style="width:40px">#</th>
                            <th>Motivo</th>
                            <th style="width:90px">Desde</th>
                            <th style="width:90px">Hasta</th>
                            <th style="width:50px">Dias</th>
                            <th style="width:160px">Tipo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var i in _inc)
                        {
                            <tr>
                                <td class="num">@i.Orden</td>
                                <td>@i.Motivo</td>
                                <td class="num">@(i.FechaDesde?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td class="num">@(i.FechaHasta?.ToString("dd/MM/yyyy") ?? "-")</td>
                                <td class="num">@(i.Dias?.ToString() ?? "-")</td>
                                <td>@(i.Tipo ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
                @RenderFirma(_hc.EspecialistaNombre, "Firma del profesional tratante")
            </div>
        }

        @* ============ CERTIFICACIONES ============ *@
        @if (_incluirCert && _cert.Count > 0)
        {
            <div class="pack-doc">
                @RenderHeader(HdrCert, "Certificacion Medica", "CERT",
                    _hc.Id.ToString().Substring(0,8).ToUpperInvariant() + "-CERT",
                    "Fecha: " + DateTime.Now.ToString("dd/MM/yyyy HH:mm"))
                <div class="pack-band">Detalle</div>
                @foreach (var c in _cert)
                {
                    <div class="pack-section">
                        <h4>#@c.Orden &middot; @c.Titulo</h4>
                        @c.Contenido
                    </div>
                }
                @RenderFirma(_hc.EspecialistaNombre, "Firma del profesional tratante")
            </div>
        }

        @* ============ ESCALAS DILIGENCIADAS ============ *@
        @if (_incluirEsc && _escalasDetails.Count > 0)
        {
            @foreach (var esc in _escalasDetails)
            {
                var schEsc = TryParseSchema(esc.SchemaJson);
                var valEsc = TryParseValores(esc.ValoresJson);
                // Usar el Header del schema de la escala — asi sale el logo
                // del tenant y el Titulo configurado (ej. "ESCALA BARTHEL")
                // en vez del Codigo+Nombre del FormDefinition.
                var hdrEsc = schEsc?.Header ?? FormHeader.Default();
                <div class="pack-doc">
                    @RenderHeader(hdrEsc, esc.FormatoNombre, "ESC",
                        esc.Id.ToString().Substring(0,8).ToUpperInvariant(),
                        $"Aplicada: {esc.FechaApertura.ToLocalTime():dd/MM/yyyy HH:mm}")
                    <div class="pack-band">Resultado</div>
                    @if (schEsc is not null)
                    {
                        @foreach (var node in schEsc.Children) { @RenderTopNode(node, valEsc) }
                    }
                    @RenderFirma(esc.EspecialistaNombre ?? _hc.EspecialistaNombre, "Firma del profesional tratante")
                </div>
            }
        }

        @* ============ EVOLUCIONES DILIGENCIADAS ============ *@
        @if (_incluirEvo && _evoDetails.Count > 0)
        {
            @foreach (var doc in _evoDetails)
            {
                var schDoc = TryParseSchema(doc.SchemaJson);
                var valDoc = TryParseValores(doc.ValoresJson);
                var hdrEvo = schDoc?.Header ?? FormHeader.Default();
                <div class="pack-doc">
                    @RenderHeader(hdrEvo, doc.FormatoNombre, "EVO",
                        doc.Id.ToString().Substring(0,8).ToUpperInvariant(),
                        $"Fecha: {doc.FechaApertura.ToLocalTime():dd/MM/yyyy HH:mm}")
                    <div class="pack-band">Evolucion</div>
                    @if (schDoc is not null)
                    {
                        @foreach (var node in schDoc.Children) { @RenderTopNode(node, valDoc) }
                    }
                    @RenderFirma(doc.EspecialistaNombre ?? _hc.EspecialistaNombre, "Firma del profesional tratante")
                </div>
            }
        }

        @* ============ CONSENTIMIENTOS DILIGENCIADOS ============ *@
        @if (_incluirCon && _conDetails.Count > 0)
        {
            @foreach (var doc in _conDetails)
            {
                var schDoc = TryParseSchema(doc.SchemaJson);
                var valDoc = TryParseValores(doc.ValoresJson);
                var hdrCon = schDoc?.Header ?? FormHeader.Default();
                <div class="pack-doc">
                    @RenderHeader(hdrCon, doc.FormatoNombre, "CON",
                        doc.Id.ToString().Substring(0,8).ToUpperInvariant(),
                        $"Fecha: {doc.FechaApertura.ToLocalTime():dd/MM/yyyy HH:mm}")
                    <div class="pack-band">Consentimiento informado</div>
                    @if (schDoc is not null)
                    {
                        @foreach (var node in schDoc.Children) { @RenderTopNode(node, valDoc) }
                    }
                    @RenderFirma(doc.EspecialistaNombre ?? _hc.EspecialistaNombre, "Firma del profesional tratante")
                </div>
            }
        }
    </div>
}

@code {
    [Parameter] public Guid HcId { get; set; }

    private bool _loading = true;
    private HistoriaClinicaDetailDto? _hc;
    private PacienteAsignacionDto? _paciente;

    // Que docs incluir, calculados desde ?docs=
    private List<string> _docs = new();
    private bool _incluirHc, _incluirMed, _incluirSrv, _incluirInc, _incluirCert, _incluirRem, _incluirEsc, _incluirEvo, _incluirCon;
    private List<EscalaDetailDto> _escalasDetails = new();
    private List<DocumentoHcDetailDto> _evoDetails = new();
    private List<DocumentoHcDetailDto> _conDetails = new();

    // HC: schema + valores
    private FormSchema? _hcSchema;
    private Dictionary<string, string?> _valores = new();

    // Forms para encabezado de cada orden (institucion, logo, etc.)
    private FormDefinitionDetailDto? _fdHc, _fdMed, _fdSrv, _fdInc, _fdCert, _fdRem;
    private FormSchema _schHc = new(), _schMed = new(), _schSrv = new(), _schInc = new(), _schCert = new(), _schRem = new();
    private FormHeader HdrHc => _schHc.Header ?? FormHeader.Default();
    private FormHeader HdrMed => _schMed.Header ?? FormHeader.Default();
    private FormHeader HdrSrv => _schSrv.Header ?? FormHeader.Default();
    private FormHeader HdrInc => _schInc.Header ?? FormHeader.Default();
    private FormHeader HdrCert => _schCert.Header ?? FormHeader.Default();
    private FormHeader HdrRem => _schRem.Header ?? FormHeader.Default();

    // Items
    private List<OrdenMedicamentoItemDto> _meds = new();
    private List<OrdenServicioItemDto> _srv = new();
    private List<IncapacidadItemDto> _inc = new();
    private List<CertificacionItemDto> _cert = new();
    private List<RemisionItemDto> _rem = new();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        var query = QueryHelpers.ParseQuery(new Uri(Nav.Uri).Query);
        var raw = query.TryGetValue("docs", out var v) ? v.ToString() : "HC";
        _docs = raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                   .Select(s => s.ToUpperInvariant())
                   .ToList();
        _incluirHc   = _docs.Contains("HC");
        _incluirMed  = _docs.Contains("MED");
        _incluirSrv  = _docs.Contains("SRV");
        _incluirInc  = _docs.Contains("INC");
        _incluirCert = _docs.Contains("CERT");
        _incluirRem  = _docs.Contains("REM");
        _incluirEsc  = _docs.Contains("ESC");
        _incluirEvo  = _docs.Contains("EVO");
        _incluirCon  = _docs.Contains("CON");

        _hc = await HcSvc.GetAsync(HcId);
        if (_hc is null) { _loading = false; return; }
        _paciente = await AsigSvc.GetPacienteAsync(_hc.PacienteId);

        // Si va a salir HC, cargar su schema + valores.
        if (_incluirHc)
        {
            _fdHc = await FormsSvc.GetAsync(_hc.FormDefinitionId);
            if (_fdHc is not null)
            {
                try { _schHc = JsonSerializer.Deserialize<FormSchema>(_fdHc.SchemaJson) ?? new(); }
                catch { _schHc = new(); }
                _hcSchema = _schHc;
            }
            if (!string.IsNullOrWhiteSpace(_hc.ValoresJson))
            {
                try { _valores = JsonSerializer.Deserialize<Dictionary<string, string?>>(_hc.ValoresJson) ?? new(); }
                catch { _valores = new(); }
            }
        }

        if (_incluirMed)
        {
            _fdMed = await FormsSvc.GetActivoByTipoAsync("ORDEN_MEDICAMENTOS");
            if (_fdMed is not null) { try { _schMed = JsonSerializer.Deserialize<FormSchema>(_fdMed.SchemaJson) ?? new(); } catch { } }
            _meds = (await MedSvc.ListarPorHistoriaAsync(HcId)).ToList();
        }
        if (_incluirSrv)
        {
            _fdSrv = await FormsSvc.GetActivoByTipoAsync("ORDEN_SERVICIOS");
            if (_fdSrv is not null) { try { _schSrv = JsonSerializer.Deserialize<FormSchema>(_fdSrv.SchemaJson) ?? new(); } catch { } }
            _srv = (await SrvSvc.ListarPorHistoriaAsync(HcId)).ToList();
        }
        if (_incluirInc)
        {
            _fdInc = await FormsSvc.GetActivoByTipoAsync("INCAPACIDADES");
            if (_fdInc is not null) { try { _schInc = JsonSerializer.Deserialize<FormSchema>(_fdInc.SchemaJson) ?? new(); } catch { } }
            _inc = (await IncSvc.ListarPorHistoriaAsync(HcId)).ToList();
        }
        if (_incluirCert)
        {
            _fdCert = await FormsSvc.GetActivoByTipoAsync("CERTIFICADOS");
            if (_fdCert is not null) { try { _schCert = JsonSerializer.Deserialize<FormSchema>(_fdCert.SchemaJson) ?? new(); } catch { } }
            _cert = (await CertSvc.ListarPorHistoriaAsync(HcId)).ToList();
        }
        if (_incluirRem)
        {
            _fdRem = await FormsSvc.GetActivoByTipoAsync("REMISIONES");
            if (_fdRem is not null) { try { _schRem = JsonSerializer.Deserialize<FormSchema>(_fdRem.SchemaJson) ?? new(); } catch { } }
            _rem = (await RemSvc.ListarPorHistoriaAsync(HcId)).ToList();
        }
        if (_incluirEsc)
        {
            // Cada escala usa su propio FormDefinition; cargamos solo las definitivas
            // (estado "Cerrada"). Si quieres incluir las abiertas, quita el filtro.
            var items = await EscSvc.ListarPorHistoriaAsync(HcId);
            foreach (var it in items.Where(x => x.Estado == "Cerrada"))
            {
                var d = await EscSvc.GetAsync(it.Id);
                if (d is not null) { _escalasDetails.Add(d); }
            }
        }
        if (_incluirEvo)
        {
            // Solo los documentos cerrados se incluyen en el paquete impreso.
            var items = await DocSvc.ListarPorHistoriaAsync(HcId, "EVOLUCION");
            foreach (var it in items.Where(x => x.Estado == "Cerrada"))
            {
                var d = await DocSvc.GetAsync(it.Id);
                if (d is not null) { _evoDetails.Add(d); }
            }
        }
        if (_incluirCon)
        {
            var items = await DocSvc.ListarPorHistoriaAsync(HcId, "CONSENTIMIENTO");
            foreach (var it in items.Where(x => x.Estado == "Cerrada"))
            {
                var d = await DocSvc.GetAsync(it.Id);
                if (d is not null) { _conDetails.Add(d); }
            }
        }

        _loading = false;

        // Auto-print cuando se entra desde "Imprimir" del listado (URL trae #print=1).
        if (Nav.Uri.Contains("#print=1"))
        {
            _ = Task.Delay(400).ContinueWith(async _ =>
            {
                try { await JS.InvokeVoidAsync("print"); } catch { }
            });
        }
    }

    private async Task PrintAsync() { await JS.InvokeVoidAsync("print"); }

    // ---- helpers de render ----

    private RenderFragment RenderHeader(FormHeader hd, string titulo, string tipoCorto, string ordenNum, string fechaLinea) => __builder =>
    {
        // El titulo del documento es el del HEADER del schema (lo que el
        // disenador escribio en "Titulo" del editor de formularios, ej.
        // "HISTORIA CLINICA GENERAL"). Si esta vacio se cae a `titulo`, que
        // tipicamente es el Codigo + Nombre del FormDefinition (ej.
        // "HC-FO-08 FORMATO HC GENERAL") — mejor algo que nada en papel.
        var tituloFinal = !string.IsNullOrWhiteSpace(hd.Titulo) ? hd.Titulo! : titulo;
        <div class="pack-header">
            <div class="pack-hdr-top">
                <div class="pack-hdr-brand">
                    @if (!string.IsNullOrWhiteSpace(hd.LogoUrl))
                    {
                        <img class="pack-hdr-logo" src="@hd.LogoUrl" alt="logo" />
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    }
                    <div>
                        <div class="pack-hdr-inst">@hd.Institucion</div>
                        <div class="pack-hdr-tag">@hd.Tagline</div>
                    </div>
                </div>
                <div class="pack-hdr-nohist">
                    @tipoCorto N°: <b>@ordenNum</b><br />
                    @fechaLinea<br />
                    HC: <b>@_hc!.Id.ToString().Substring(0,8).ToUpperInvariant()</b>
                </div>
            </div>
            <div class="pack-hdr-title">@tituloFinal</div>
            <div class="pack-hdr-meta">
                <span><b>Paciente:</b> @(_paciente?.NombreCompleto ?? "-")</span>
                <span><b>Doc:</b> @(_paciente?.TipoDocumento) @(_paciente?.NumeroDocumento)</span>
                @if (!string.IsNullOrWhiteSpace(_hc.EspecialistaNombre))
                {
                    <span><b>Atiende:</b> @_hc.EspecialistaNombre</span>
                }
            </div>
        </div>
    };

    private RenderFragment RenderFirma(string? nombreProf, string rol) => __builder =>
    {
        <div class="pack-footer">
            <div class="pack-firma">
                <div class="pack-firma-line">@(nombreProf ?? "Especialista")</div>
                <div class="pack-firma-rol">@rol</div>
            </div>
            <div class="pack-firma">
                <div class="pack-firma-line">@(_paciente?.NombreCompleto ?? "Paciente")</div>
                <div class="pack-firma-rol">Recibido por paciente / acudiente</div>
            </div>
        </div>
    };

    // Render de un nodo del primer nivel del schema.
    // - Si es bloque de texto: una fila completa con el contenido.
    // - Si es seccion: subtitulo (si tiene label) + grid de 12 columnas con sus hijos,
    //   donde cada hijo respeta su WidthColumns (1..12).
    // - Si es campo/tabla suelto en el top-level: lo metemos en su propio grid para
    //   que tambien respete su WidthColumns.
    private RenderFragment RenderTopNode(FormNode n, Dictionary<string, string?> vals) => __builder =>
    {
        if (n.IsText)
        {
            <div class="pack-para">@(n.Content ?? "")</div>
            return;
        }
        if (n.IsSection)
        {
            if (!string.IsNullOrWhiteSpace(n.Label))
            {
                <div class="pack-sub">@n.Label</div>
            }
            <div class="pack-grid">
                @foreach (var ch in n.Children ?? new()) { @RenderDocNode(ch, vals) }
            </div>
            return;
        }
        // Campo o tabla en top-level: contenedor grid para que respete WidthColumns.
        <div class="pack-grid">
            @RenderDocNode(n, vals)
        </div>
    };

    /// <summary>
    /// Render de un nodo hoja dentro de una grid de 12 columnas. Usa el WidthColumns del
    /// nodo (1..12, clamped) para que el ancho de cada campo coincida con el disenador.
    /// Si no tiene WidthColumns valido, se asume 12 (toda la fila).
    /// </summary>
    private RenderFragment RenderDocNode(FormNode n, Dictionary<string, string?> vals) => __builder =>
    {
        var span = Math.Clamp(n.WidthColumns <= 0 ? 12 : n.WidthColumns, 1, 12);
        if (n.IsText)
        {
            <div class="pack-para" style="grid-column: span @span;">@(n.Content ?? "")</div>
            return;
        }
        if (n.IsTable)
        {
            // Leer filas reales: combina SeedRows (texto fijo) + filas extras
            // controladas por tbl:{id}:_rows. Cada celda viene de vals["tbl:{id}:{idx}:{colId}"].
            // Asi medicamentos / remisiones / etc. mapeados via historiaMedica
            // aparecen en la impresion con su contenido real.
            var tblKey = $"tbl:{n.Id}";
            var seedCount = n.SeedRows?.Count ?? 0;
            int extraRows = 0;
            if (!n.LockRows && vals.TryGetValue($"{tblKey}:_rows", out var rs)
                && int.TryParse(rs, out var parsed) && parsed > 0)
            {
                extraRows = parsed;
            }
            var totalRows = seedCount + extraRows;
            // Fallback: si no hay datos y la tabla es libre, deja 1 fila para
            // que el doctor pueda escribir a mano sobre papel.
            if (totalRows == 0 && !n.LockRows) { totalRows = 1; }
            <div style="grid-column: span @span; border-bottom:1px solid #000;">
                <table class="pack-table">
                    <thead>
                        <tr>
                            @foreach (var col in n.Columns ?? new()) { <th>@col.Label</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @for (var r = 0; r < totalRows; r++)
                        {
                            var idx = r;
                            var isSeed = r < seedCount;
                            var seedRow = isSeed ? n.SeedRows![r] : null;
                            <tr>
                                @{ var colIdx = 0; }
                                @foreach (var col in n.Columns ?? new())
                                {
                                    var seedVal = (seedRow is not null && colIdx < seedRow.Count) ? seedRow[colIdx] : null;
                                    string? cellVal;
                                    if (!string.IsNullOrEmpty(seedVal)) { cellVal = seedVal; }
                                    else { vals.TryGetValue($"{tblKey}:{idx}:{col.Id}", out cellVal); }
                                    // Columnas date guardan ISO (yyyy-MM-dd) para que el datepicker
                                    // del FormViewer las pueda leer. En impresion las mostramos en
                                    // formato local dd/MM/yyyy para que se lean como en papel.
                                    var displayVal = FormatCellForPrint(cellVal, col.FieldType);
                                    <td>@(string.IsNullOrWhiteSpace(displayVal) ? new MarkupString("&nbsp;") : (MarkupString)System.Net.WebUtility.HtmlEncode(displayVal))</td>
                                    colIdx++;
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            return;
        }
        var key = n.Name ?? $"fld:{n.Id}";
        var val = vals.TryGetValue(key, out var vv) ? vv : null;
        <div class="pack-cell" style="grid-column: span @span;">
            <div class="pack-label">@n.Label</div>
            <div class="pack-value">@(val ?? "")</div>
        </div>
    };

    private static FormSchema? TryParseSchema(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) { return null; }
        try { return JsonSerializer.Deserialize<FormSchema>(json); } catch { return null; }
    }

    /// <summary>
    /// Si la celda pertenece a una columna date y el valor esta en ISO
    /// (yyyy-MM-dd) lo reformatea a dd/MM/yyyy para impresion. Cualquier
    /// otra cosa se devuelve tal cual.
    /// </summary>
    private static string? FormatCellForPrint(string? raw, string? fieldType)
    {
        if (string.IsNullOrWhiteSpace(raw)) { return raw; }
        if (!string.Equals(fieldType, "date", StringComparison.OrdinalIgnoreCase)) { return raw; }
        if (DateOnly.TryParseExact(raw, "yyyy-MM-dd", out var d))
        {
            return d.ToString("dd/MM/yyyy");
        }
        return raw;
    }

    private static Dictionary<string, string?> TryParseValores(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) { return new(); }
        try { return JsonSerializer.Deserialize<Dictionary<string, string?>>(json) ?? new(); } catch { return new(); }
    }
}
