@* Consola SaaS del operador de plataforma. La raiz "/" la toma el dashboard
   documental del tenant (Dashboard.razor), que redirige aqui al Super Admin. *@
@page "/admin"
@attribute [Authorize(Policy = "PlatformOperator")]
@inject ITenantAdminService TenantsSvc
@inject IPlanAdminService PlansSvc

<PageTitle>Dashboard - DokTrino</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>
            </div>
            <span>Super Admin SaaS</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Dashboard</h1>
        <p class="page-sub" style="margin-bottom:0;">Resumen operativo de <span style="color:var(--primary)">DokTrino</span>.</p>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-primary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/></svg>
                </div>
            </div>
            <div class="kpi-label">Agencias</div>
            <div class="kpi-value">@_totalTenants</div>
            <div class="kpi-hint">Tenants registrados</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-success">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                </div>
            </div>
            <div class="kpi-label">Agencias activas</div>
            <div class="kpi-value">@_activeTenants</div>
            <div class="kpi-hint">Operando hoy</div>
        </div>

        <div class="kpi-card">
            <div class="kpi-top">
                <div class="kpi-icon tone-gold">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
                </div>
            </div>
            <div class="kpi-label">Planes</div>
            <div class="kpi-value">@_totalPlans</div>
            <div class="kpi-hint">Oferta comercial</div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private int _totalTenants;
    private int _activeTenants;
    private int _totalPlans;

    protected override async Task OnInitializedAsync()
    {
        var tenants = await TenantsSvc.ListAsync();
        var plans = await PlansSvc.ListAsync();
        _totalTenants = tenants.Count;
        _activeTenants = tenants.Count(t => t.Status == TenantStatus.Active);
        _totalPlans = plans.Count;
        _loading = false;
    }
}
