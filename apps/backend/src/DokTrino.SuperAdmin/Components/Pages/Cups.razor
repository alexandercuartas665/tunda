@page "/cups"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using ClosedXML.Excel
@using Microsoft.AspNetCore.Components.Forms
@using DokTrino.Application.Tenancy
@inject ICupService Svc
@inject IJSRuntime JS

<PageTitle>Base de datos CUPS - DokTrino</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion del Sistema</div>
        <h1 class="ase-title">Base de datos de CUPS</h1>
        <small class="text-muted">Codigo Unico de Procedimientos en Salud - MSPS. @(_total) registro(s)</small>
    </div>
    <div class="med-toolbar">
        <InputFile id="cups-file" OnChange="OnImportExcel" style="display:none;" accept=".xlsx,.xls" />
        <label for="cups-file" class="btn btn-outline-primary @(_busy ? "disabled" : "")">&#128190; Importar Excel</label>
        <button class="btn btn-outline-danger" @onclick="OnClearAll" disabled="@(_busy || _total == 0)">&#128465; Vaciar todo</button>
        <button class="btn btn-primary" @onclick="OnNuevo" disabled="@_busy">+ Nuevo registro</button>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

@if (_progFase is not null)
{
    <div class="med-prog-backdrop"></div>
    <div class="med-prog-card">
        <div class="med-prog-h">&#128190; Importando CUPS</div>
        <div class="med-prog-fase">@_progFase...</div>
        <div class="med-prog-bar">
            <div class="med-prog-bar-fill" style="width: @(_progTotal > 0 ? Math.Min(100, (_progAct * 100 / _progTotal)) : 0)%;"></div>
        </div>
        <div class="med-prog-counts">
            <strong>@_progAct.ToString("N0")</strong>
            @if (_progTotal > 0) { <span> / @_progTotal.ToString("N0") filas</span> }
            @if (_progTotal > 0) { <span class="med-prog-pct"> (@(_progAct * 100 / _progTotal)%)</span> }
        </div>
        <small class="text-muted">No cierres esta pestana - el proceso se cancela.</small>
    </div>
}

<div class="ase-card">
    <div class="med-filtros">
        <input class="form-control" placeholder="Buscar por codigo, nombre, capitulo, clasificacion o codigo jerarquico..."
               @bind="_termino" @bind:event="oninput" @onkeyup="OnKeyup" />
        <button class="btn btn-outline-secondary" @onclick="Buscar" disabled="@_busy">&#128270; Buscar</button>
    </div>

    @if (_busy && _rows.Count == 0)
    {
        <div class="ase-empty">Cargando...</div>
    }
    else if (_rows.Count == 0)
    {
        <div class="ase-empty" style="padding:30px;">
            @(_total == 0 && string.IsNullOrEmpty(_termino)
                ? "No hay registros. Importa el Excel oficial CUPS o crea uno con el boton 'Nuevo registro'."
                : "Sin resultados para tu busqueda.")
        </div>
    }
    else
    {
        <div class="med-tbl-wrap">
            <table class="table table-sm med-tbl">
                <thead>
                    <tr>
                        <th style="width:100px">Codigo</th>
                        <th>Nombre</th>
                        <th>Capitulo</th>
                        <th style="width:130px">Clasificacion</th>
                        <th style="width:110px">Cod. Jerarquico</th>
                        <th style="width:80px">Habilitado</th>
                        <th style="width:90px">Estandar</th>
                        <th style="width:90px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _rows)
                    {
                        <tr>
                            <td class="mono"><strong>@c.Codigo</strong></td>
                            <td>@c.Nombre</td>
                            <td><span class="med-desc">@c.Descripcion</span></td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(c.ExtraIV))
                                { <span class="med-pill med-cls">@c.ExtraIV</span> }
                            </td>
                            <td class="mono">@c.ExtraV</td>
                            <td>
                                @if (string.Equals(c.Habilitado, "SI", StringComparison.OrdinalIgnoreCase))
                                { <span class="med-pill med-vig">SI</span> }
                                else if (!string.IsNullOrWhiteSpace(c.Habilitado))
                                { <span class="med-pill med-vnc">@c.Habilitado</span> }
                            </td>
                            <td>
                                @if (string.Equals(c.IsStandardMSPS, "True", StringComparison.OrdinalIgnoreCase))
                                { <span class="med-pill med-msps">MSPS</span> }
                                @if (string.Equals(c.IsStandardGEL, "True", StringComparison.OrdinalIgnoreCase))
                                { <span class="med-pill med-gel">GEL</span> }
                            </td>
                            <td class="text-end">
                                <button class="btn btn-link btn-sm" title="Editar" @onclick="() => EditarAsync(c.Id)">&#9998;</button>
                                <button class="btn btn-link btn-sm text-danger" title="Eliminar" @onclick="() => EliminarAsync(c.Id)">&#128465;</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="med-pag">
            <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(_skip == 0 || _busy)">&laquo; Anterior</button>
            <span>Pagina @(((_skip / _take) + 1)) de @((Math.Max(1, (int)Math.Ceiling((double)_total / _take))))</span>
            <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@((_skip + _take) >= _total || _busy)">Siguiente &raquo;</button>
        </div>
    }
</div>

@* ============== MODAL CREAR/EDITAR ============== *@
@if (_edit is CupEdit ed)
{
    <div class="med-bk" @onclick="CerrarModal"></div>
    <div class="med-modal">
        <div class="med-modal-h">
            <h3>@(ed.Id is null ? "Nuevo CUP" : "Editar CUP")</h3>
            <button class="btn btn-sm btn-outline-secondary" @onclick="CerrarModal">&#10006; Cerrar</button>
        </div>
        <div class="med-modal-body">
            <div class="med-section">Identificador</div>
            <div class="med-grid">
                <div class="med-fld med-w-3"><label>Tabla</label>
                    <input class="form-control form-control-sm" @bind="ed.Tabla" placeholder="CUPS" />
                </div>
                <div class="med-fld med-w-3"><label>Codigo</label>
                    <input class="form-control form-control-sm mono" @bind="ed.Codigo" />
                </div>
                <div class="med-fld med-w-3"><label>Habilitado</label>
                    <input class="form-control form-control-sm" @bind="ed.Habilitado" placeholder="SI / NO" />
                </div>
                <div class="med-fld med-w-3"><label>Aplicacion</label>
                    <input class="form-control form-control-sm" @bind="ed.Aplicacion" />
                </div>
                <div class="med-fld med-w-12"><label>Nombre</label>
                    <input class="form-control form-control-sm" @bind="ed.Nombre" />
                </div>
                <div class="med-fld med-w-12"><label>Capitulo / descripcion</label>
                    <input class="form-control form-control-sm" @bind="ed.Descripcion" />
                </div>
            </div>

            <div class="med-section">Estandares</div>
            <div class="med-grid">
                <div class="med-fld med-w-6"><label>IsStandardGEL</label>
                    <input class="form-control form-control-sm" @bind="ed.IsStandardGEL" placeholder="True / False" />
                </div>
                <div class="med-fld med-w-6"><label>IsStandardMSPS</label>
                    <input class="form-control form-control-sm" @bind="ed.IsStandardMSPS" placeholder="True / False" />
                </div>
            </div>

            <div class="med-section">Columnas Extra (preservadas del Excel oficial)</div>
            <div class="med-grid">
                <div class="med-fld med-w-3"><label>Extra I (Cobertura)</label><input class="form-control form-control-sm" @bind="ed.ExtraI" /></div>
                <div class="med-fld med-w-3"><label>Extra II</label><input class="form-control form-control-sm" @bind="ed.ExtraII" /></div>
                <div class="med-fld med-w-3"><label>Extra III</label><input class="form-control form-control-sm" @bind="ed.ExtraIII" /></div>
                <div class="med-fld med-w-3"><label>Extra IV (clasificacion)</label><input class="form-control form-control-sm" @bind="ed.ExtraIV" /></div>
                <div class="med-fld med-w-3"><label>Extra V (cod. jerarquico)</label><input class="form-control form-control-sm mono" @bind="ed.ExtraV" /></div>
                <div class="med-fld med-w-3"><label>Extra VI</label><input class="form-control form-control-sm" @bind="ed.ExtraVI" /></div>
                <div class="med-fld med-w-3"><label>Extra VII</label><input class="form-control form-control-sm" @bind="ed.ExtraVII" /></div>
                <div class="med-fld med-w-3"><label>Extra VIII</label><input class="form-control form-control-sm" @bind="ed.ExtraVIII" /></div>
                <div class="med-fld med-w-3"><label>Extra IX</label><input class="form-control form-control-sm" @bind="ed.ExtraIX" /></div>
                <div class="med-fld med-w-3"><label>Extra X</label><input class="form-control form-control-sm" @bind="ed.ExtraX" /></div>
            </div>

            <div class="med-section">Auditoria del archivo</div>
            <div class="med-grid">
                <div class="med-fld med-w-4"><label>Valor de registro</label><input class="form-control form-control-sm" @bind="ed.ValorRegistro" /></div>
                <div class="med-fld med-w-4"><label>Usuario responsable</label><input class="form-control form-control-sm" @bind="ed.UsuarioResponsable" /></div>
                <div class="med-fld med-w-4"><label>IsPublicPrivate</label><input class="form-control form-control-sm" @bind="ed.IsPublicPrivate" /></div>
            </div>
        </div>
        <div class="med-modal-f">
            <button class="btn btn-outline-secondary" @onclick="CerrarModal">Cancelar</button>
            <button class="btn btn-primary" @onclick="GuardarAsync" disabled="@_busy">@(ed.Id is null ? "Crear" : "Guardar cambios")</button>
        </div>
    </div>
}

<style>
    /* Estilos espejo de Medicamentos.razor para que /cups se vea identico
       (header, toolbar, grid, modal CRUD, overlay de progreso). Las clases
       hacen ping-pong entre paginas pero Blazor inyecta cada estilo al
       cargar el componente, asi que duplicamos para no depender de orden. */
    .ase-head { display:flex; justify-content:space-between; align-items:flex-end; gap:12px; margin-bottom:16px; }
    .ase-eyebrow { font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:.05em; }
    .ase-title { font-size:24px; font-weight:700; margin:4px 0; }
    .ase-card { background:#fff; border:1px solid #e2e8f0; border-radius:10px; }
    .ase-alert { background:#fee2e2; color:#991b1b; padding:10px 14px; border-radius:8px; margin-bottom:10px; }
    .ase-ok { background:#dcfce7; color:#166534; padding:10px 14px; border-radius:8px; margin-bottom:10px; }
    .ase-empty { padding:30px; text-align:center; color:#64748b; }

    .med-toolbar { display:flex; gap:8px; align-items:center; }

    .med-filtros { display:flex; gap:8px; padding:14px; border-bottom:1px solid #e2e8f0; }
    .med-filtros input { flex:1; }

    .med-tbl-wrap { overflow:auto; max-height:65vh; }
    .med-tbl { margin:0; font-size:12.5px; }
    .med-tbl thead th { position:sticky; top:0; background:#f1f5f9; color:#334155; font-size:11px; font-weight:700; border-bottom:1px solid #cbd5e1; padding:8px 10px; }
    .med-tbl td { vertical-align:top; padding:8px 10px; }
    .med-desc { font-size:11px; color:#64748b; margin-top:2px; font-style:italic; }
    .mono { font-family:'JetBrains Mono','Consolas',monospace; font-size:11.5px; }
    .med-pill { display:inline-block; font-size:10.5px; font-weight:700; padding:2px 8px; border-radius:999px; }
    .med-vig { background:#dcfce7; color:#166534; }
    .med-vnc { background:#fee2e2; color:#991b1b; }
    .med-cls { background:#e0e7ff; color:#3730a3; }
    .med-msps { background:#dbeafe; color:#1e40af; margin-right:4px; }
    .med-gel { background:#fef3c7; color:#92400e; }

    .med-pag { display:flex; justify-content:space-between; align-items:center; padding:10px 14px; border-top:1px solid #e2e8f0; font-size:12.5px; color:#475569; }

    .med-bk { position:fixed; inset:0; background:rgba(15,23,42,.55); z-index:1000; }
    .med-modal { position:fixed; top:24px; left:50%; transform:translateX(-50%); width:min(1100px, 96vw); max-height:calc(100vh - 48px); background:#fff; border-radius:12px; box-shadow:0 30px 80px rgba(15,23,42,.35); z-index:1001; display:flex; flex-direction:column; overflow:hidden; }
    .med-modal-h { display:flex; justify-content:space-between; align-items:center; padding:14px 22px; border-bottom:1px solid #e2e8f0; background:#fff; }
    .med-modal-h h3 { margin:0; font-size:16px; font-weight:700; }
    .med-modal-body { padding:14px 22px; overflow:auto; }
    .med-modal-f { display:flex; justify-content:flex-end; gap:8px; padding:12px 22px; border-top:1px solid #e2e8f0; background:#f8fafc; }
    .med-section { font-size:11px; font-weight:800; color:#1565c0; text-transform:uppercase; letter-spacing:.04em; margin:14px 0 6px; border-bottom:1px solid #cbd5e1; padding-bottom:4px; }
    .med-section:first-child { margin-top:0; }
    .med-grid { display:grid; grid-template-columns:repeat(12, 1fr); gap:10px; }
    .med-fld { display:flex; flex-direction:column; gap:4px; }
    .med-fld label { font-size:11px; font-weight:600; color:#475569; text-transform:uppercase; letter-spacing:.03em; }
    .med-w-3 { grid-column: span 3; }
    .med-w-4 { grid-column: span 4; }
    .med-w-6 { grid-column: span 6; }
    .med-w-9 { grid-column: span 9; }
    .med-w-12 { grid-column: span 12; }

    /* ---- Overlay de progreso de importacion (centrado, fixed, sobre todo) ---- */
    .med-prog-backdrop { position:fixed; inset:0; background:rgba(15,23,42,.55); z-index:1000; }
    .med-prog-card { position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); width:min(480px, 92vw); background:#fff; border-radius:12px; box-shadow:0 30px 80px rgba(15,23,42,.35); z-index:1001; padding:24px 28px; }
    .med-prog-h { font-size:14px; font-weight:700; color:#0f172a; margin-bottom:6px; }
    .med-prog-fase { font-size:12.5px; color:#475569; margin-bottom:14px; font-style:italic; }
    .med-prog-bar { height:10px; background:#f1f5f9; border-radius:999px; overflow:hidden; margin-bottom:10px; }
    .med-prog-bar-fill { height:100%; background:linear-gradient(90deg,#1565c0,#1976d2); transition:width .25s ease; }
    .med-prog-counts { font-size:13px; color:#0f172a; margin-bottom:8px; }
    .med-prog-counts strong { font-family:'JetBrains Mono','Consolas',monospace; }
    .med-prog-pct { color:#1565c0; font-weight:600; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string? _error;
    private string? _ok;
    private bool _busy;
    private string? _progFase;
    private int _progAct;
    private int _progTotal;
    private string? _termino;
    private List<CupDto> _rows = new();
    private int _total;
    private int _skip;
    private int _take = 50;
    private CupEdit? _edit;

    protected override async Task OnInitializedAsync()
    {
        await Buscar();
    }

    private async Task Buscar()
    {
        _busy = true; _error = null;
        try
        {
            var (rows, total) = await Svc.SearchAsync(_termino, _skip, _take);
            _rows = rows.ToList();
            _total = total;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task OnKeyup(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _skip = 0; await Buscar(); }
    }

    private async Task PrevPage()
    {
        if (_skip <= 0) { return; }
        _skip = Math.Max(0, _skip - _take);
        await Buscar();
    }
    private async Task NextPage()
    {
        if ((_skip + _take) >= _total) { return; }
        _skip += _take;
        await Buscar();
    }

    private void OnNuevo() { _edit = new CupEdit { Tabla = "CUPS" }; _error = _ok = null; }
    private void CerrarModal() => _edit = null;

    private async Task EditarAsync(Guid id)
    {
        var d = await Svc.GetAsync(id);
        if (d is null) { _error = "Registro no encontrado."; return; }
        _edit = CupEdit.From(d);
    }

    private async Task GuardarAsync()
    {
        if (_edit is not CupEdit ed) { return; }
        _busy = true; _error = _ok = null;
        try
        {
            await Svc.SaveAsync(ed.ToRequest(), await Actor());
            _ok = ed.Id is null ? "CUP creado." : "CUP actualizado.";
            _edit = null;
            await Buscar();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task EliminarAsync(Guid id)
    {
        var ok = await JS.InvokeAsync<bool>("confirm", "Eliminar este CUP?");
        if (!ok) { return; }
        _busy = true; _error = _ok = null;
        try
        {
            await Svc.DeleteAsync(id, await Actor());
            _ok = "CUP eliminado.";
            await Buscar();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task OnClearAll()
    {
        var ok = await JS.InvokeAsync<bool>("confirm",
            $"Borrar TODOS los {_total} registros CUPS? Esto NO se puede deshacer.");
        if (!ok) { return; }
        _busy = true; _error = _ok = null;
        try
        {
            var n = await Svc.ClearAllAsync(await Actor());
            _ok = $"{n} registro(s) eliminado(s).";
            _skip = 0;
            await Buscar();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task OnImportExcel(InputFileChangeEventArgs e)
    {
        _error = _ok = null;
        _busy = true;
        _progFase = "Subiendo"; _progAct = 0; _progTotal = 0;
        await InvokeAsync(StateHasChanged);
        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(50L * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;

            _progFase = "Leyendo Excel"; await InvokeAsync(StateHasChanged);
            using var wb = new XLWorkbook(ms);
            var ws = wb.Worksheet(1);
            // Mapa case-insensitive de "header limpio" -> indice de columna. Los
            // headers oficiales traen ":" y "_": Extra_I:Cobertura, Extra_II, etc.
            // Normalizamos quitando esos separadores para que el lookup funcione.
            static string Clean(string s) =>
                new string(s.Where(c => char.IsLetterOrDigit(c)).ToArray()).ToLowerInvariant();
            var map = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
            foreach (var cell in ws.Row(1).CellsUsed())
            {
                map[Clean(cell.GetString().Trim())] = cell.Address.ColumnNumber;
            }
            string? Col(IXLRow r, string name) =>
                map.TryGetValue(Clean(name), out var ci) ? r.Cell(ci).GetString().Trim() : null;

            var last = ws.LastRowUsed()?.RowNumber() ?? 1;
            _progTotal = Math.Max(0, last - 1);
            var rows = new List<CupImportRow>(_progTotal);
            for (var i = 2; i <= last; i++)
            {
                var r = ws.Row(i);
                rows.Add(new CupImportRow(
                    Col(r, "tabla"), Col(r, "codigo"), Col(r, "nombre"), Col(r, "descripcion"),
                    Col(r, "habilitado"), Col(r, "aplicacion"),
                    Col(r, "isstandardgel"), Col(r, "isstandardmsps"),
                    Col(r, "extraicobertura"), Col(r, "extraii"), Col(r, "extraiii"),
                    Col(r, "extraiv"), Col(r, "extrav"), Col(r, "extravi"),
                    Col(r, "extravii"), Col(r, "extraviii"), Col(r, "extraix"), Col(r, "extrax"),
                    Col(r, "valorregistro"), Col(r, "usuarioresponsable"),
                    Col(r, "fechaactualizacion"), Col(r, "ispublicprivate")));
                _progAct = i - 1;
                if ((i - 1) % 500 == 0) { await InvokeAsync(StateHasChanged); }
            }
            _progAct = rows.Count; await InvokeAsync(StateHasChanged);

            var ui = new Progress<CupImportProgress>(p =>
            {
                _progFase = p.Fase;
                _progAct = p.Procesados;
                _progTotal = p.Total;
                _ = InvokeAsync(StateHasChanged);
            });
            var n = await Svc.ImportAsync(rows, await Actor(), ui);
            _ok = $"{n} CUP(s) importado(s) desde Excel.";
            _skip = 0;
            await Buscar();
        }
        catch (Exception ex) { _error = "No se pudo importar el Excel: " + ex.Message; }
        finally
        {
            _busy = false;
            _progFase = null; _progAct = 0; _progTotal = 0;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private sealed class CupEdit
    {
        public Guid? Id { get; set; }
        public string? Tabla { get; set; }
        public string? Codigo { get; set; }
        public string? Nombre { get; set; }
        public string? Descripcion { get; set; }
        public string? Habilitado { get; set; }
        public string? Aplicacion { get; set; }
        public string? IsStandardGEL { get; set; }
        public string? IsStandardMSPS { get; set; }
        public string? ExtraI { get; set; }
        public string? ExtraII { get; set; }
        public string? ExtraIII { get; set; }
        public string? ExtraIV { get; set; }
        public string? ExtraV { get; set; }
        public string? ExtraVI { get; set; }
        public string? ExtraVII { get; set; }
        public string? ExtraVIII { get; set; }
        public string? ExtraIX { get; set; }
        public string? ExtraX { get; set; }
        public string? ValorRegistro { get; set; }
        public string? UsuarioResponsable { get; set; }
        public DateTimeOffset? FechaActualizacion { get; set; }
        public string? IsPublicPrivate { get; set; }

        public static CupEdit From(CupDetailDto d) => new()
        {
            Id = d.Id,
            Tabla = d.Tabla, Codigo = d.Codigo, Nombre = d.Nombre, Descripcion = d.Descripcion,
            Habilitado = d.Habilitado, Aplicacion = d.Aplicacion,
            IsStandardGEL = d.IsStandardGEL, IsStandardMSPS = d.IsStandardMSPS,
            ExtraI = d.ExtraI, ExtraII = d.ExtraII, ExtraIII = d.ExtraIII,
            ExtraIV = d.ExtraIV, ExtraV = d.ExtraV, ExtraVI = d.ExtraVI,
            ExtraVII = d.ExtraVII, ExtraVIII = d.ExtraVIII, ExtraIX = d.ExtraIX, ExtraX = d.ExtraX,
            ValorRegistro = d.ValorRegistro, UsuarioResponsable = d.UsuarioResponsable,
            FechaActualizacion = d.FechaActualizacion, IsPublicPrivate = d.IsPublicPrivate
        };

        public SaveCupRequest ToRequest() => new(
            Id, Tabla, Codigo, Nombre, Descripcion,
            Habilitado, Aplicacion, IsStandardGEL, IsStandardMSPS,
            ExtraI, ExtraII, ExtraIII, ExtraIV, ExtraV,
            ExtraVI, ExtraVII, ExtraVIII, ExtraIX, ExtraX,
            ValorRegistro, UsuarioResponsable, FechaActualizacion, IsPublicPrivate);
    }
