@page "/servidor-evolution"
@attribute [Authorize(Policy = "PlatformOperator")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Servidor Evolution - Archimente</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
            </div>
            <span>Super Admin SaaS</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Servidor <span>Evolution API</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Servidor maestro de WhatsApp de la plataforma. Las agencias pueden usar este servidor compartido o configurar uno propio.</p>
    </div>
</div>

<div class="card" style="max-width:1040px;padding:22px 24px;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:16px;flex-wrap:wrap;">
        <div style="display:flex;align-items:center;gap:12px;">
            <div class="module-icon" style="width:38px;height:38px;">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 17l6-6-6-6"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
            </div>
            <div>
                <div style="font-weight:700;">Evolution API &mdash; servidor maestro</div>
                <div class="text-muted" style="font-size:12px;">Conexion central para crear instancias y enviar/recibir WhatsApp.</div>
            </div>
        </div>
        <span class="badge bg-@StatusColor()">@StatusText()</span>
    </div>

    @if (_cfg is null)
    {
        <p class="text-muted" style="margin:16px 0 0;">Aun no has configurado el servidor Evolution. Agrega la URL y la API key para habilitar WhatsApp.</p>
    }
    else
    {
        <div class="field-row" style="margin-top:18px;max-width:760px;">
            <div><div class="wlbl">URL del servidor</div><div class="wval" style="font-family:var(--bs-font-monospace);font-size:12px;">@(_cfg.BaseUrl ?? "—")</div></div>
            <div><div class="wlbl">API key</div><div class="wval" style="font-family:var(--bs-font-monospace);font-size:12px;">@(_cfg.ApiKeyMasked ?? "—")</div></div>
        </div>
        <div class="field-row" style="max-width:760px;">
            <div><div class="wlbl">Ultima validacion</div><div class="wval">@(_cfg.LastValidatedAt is { } v ? v.LocalDateTime.ToString("dd MMM yyyy HH:mm") : "Nunca")</div></div>
        </div>
    }

    @if (_msg is not null)
    {
        <div class="@(_ok ? "text-success" : "text-danger")" style="margin-top:14px;font-size:0.85rem;">@_msg</div>
    }

    <div style="display:flex;gap:8px;margin-top:18px;">
        <button class="btn btn-primary" @onclick="OpenEdit">@(_cfg is null ? "Configurar servidor" : "Editar configuracion")</button>
        <button class="btn btn-outline-secondary" @onclick="ValidateAsync" disabled="@(_cfg is null || _busy)">@(_busy ? "Validando..." : "Validar conexion")</button>
    </div>
</div>

@if (_modalOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>Servidor Evolution API</h3>
                <button class="modal-close" @onclick="() => _modalOpen = false">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">URL del servidor</label>
                    <input class="form-control" @bind="_form.BaseUrl" autocomplete="off" placeholder="https://evo.doktrino.com.co" />
                    <div class="text-muted" style="font-size:11px;margin-top:4px;">Puedes pegar la URL del manager; se guarda la base automaticamente.</div>
                </div>
                <div class="field">
                    <label class="form-label">API key global (AUTHENTICATION_API_KEY)</label>
                    <input class="form-control" type="password" @bind="_form.ApiKey" autocomplete="new-password" placeholder="@(_cfg?.HasApiKey == true ? "Dejar vacio para conservar la actual" : "")" />
                </div>
                @if (_modalError is not null)
                {
                    <div class="text-danger small">@_modalError</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="() => _modalOpen = false">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_busy">Guardar</button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private EvolutionMasterDto? _cfg;
    private bool _modalOpen;
    private bool _busy;
    private string? _msg;
    private bool _ok;
    private string? _modalError;
    private readonly Form _form = new();

    [Inject] private DokTrino.Application.Admin.IEvolutionMasterConfigService EvolutionSvc { get; set; } = default!;

    protected override async Task OnInitializedAsync() => _cfg = await EvolutionSvc.GetAsync();

    private void OpenEdit()
    {
        _modalError = null;
        _form.BaseUrl = _cfg?.BaseUrl;
        _form.ApiKey = null; // se conserva si se deja vacio
        _modalOpen = true;
    }

    private async Task SaveAsync()
    {
        _modalError = null;
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            _cfg = await EvolutionSvc.SaveAsync(new DokTrino.Application.Admin.SaveEvolutionMasterRequest(_form.BaseUrl, _form.ApiKey), actor);
            _msg = null;
            _modalOpen = false;
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task ValidateAsync()
    {
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var result = await EvolutionSvc.ValidateAsync(actor);
            if (result is not null)
            {
                _ok = result.Ok;
                _msg = result.Message;
                _cfg = await EvolutionSvc.GetAsync();
            }
        }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var state = await AuthState;
        return Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private string StatusText() => _cfg?.Status switch
    {
        EvolutionIntegrationStatus.Validated => "Validado",
        EvolutionIntegrationStatus.Configured => "Configurado",
        EvolutionIntegrationStatus.Error => "Con error",
        _ => "Sin configurar"
    };

    private string StatusColor() => _cfg?.Status switch
    {
        EvolutionIntegrationStatus.Validated => "success",
        EvolutionIntegrationStatus.Configured => "info",
        EvolutionIntegrationStatus.Error => "danger",
        _ => "secondary"
    };

    private sealed class Form
    {
        public string? BaseUrl { get; set; }
        public string? ApiKey { get; set; }
    }
}
