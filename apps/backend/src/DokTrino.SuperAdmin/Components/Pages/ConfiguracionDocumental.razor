@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private string _tab = "series";
    private string _filtro = "";
    private string _csv = "";
    private bool _compOpen, _importOpen;
    private string? _error, _ok;

    // --- Editor de series ---
    private bool _editorOpen;
    private List<NodoArbolDto> _arbol = new();
    private NodoArbolDto? _sel;
    private Guid? _selId;
    private CaracterizacionDto? _carac;
    private FormatosTipologiaDto? _formatos;
    private string? _edError;

    private List<SerieConfigDto> _series = new();
    private List<BancoItemDto> _banco = new();
    private List<ComplementoDto> _complementos = new();
    private List<SugerenciaDto> _sugerencias = new();

    protected override async Task OnInitializedAsync() => await Recargar();

    private async Task Recargar()
    {
        _series = (await Cfg.ListarSeriesAsync(null)).ToList();
        _banco = (await Cfg.ListarBancoAsync(null)).ToList();
        _complementos = (await Cfg.ListarComplementosAsync()).ToList();
        _sugerencias = (await Cfg.ListarSugerenciasAsync()).ToList();
    }

    private void Cambiar(string tab) { _tab = tab; _filtro = ""; }

    // El filtro se aplica en memoria: las listas ya vienen acotadas al tenant.
    private List<SerieConfigDto> Filtradas(List<SerieConfigDto> origen) =>
        string.IsNullOrWhiteSpace(_filtro)
            ? origen
            : origen.Where(s => s.Codigo.Contains(_filtro.Trim(), StringComparison.OrdinalIgnoreCase)
                                || s.Nombre.Contains(_filtro.Trim(), StringComparison.OrdinalIgnoreCase)).ToList();

    private List<BancoItemDto> FiltradasBanco() =>
        string.IsNullOrWhiteSpace(_filtro)
            ? _banco
            : _banco.Where(b => b.Codigo.Contains(_filtro.Trim(), StringComparison.OrdinalIgnoreCase)
                                || b.Nombre.Contains(_filtro.Trim(), StringComparison.OrdinalIgnoreCase)).ToList();

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task Aplicar(ComplementoDto c)
    {
        _error = _ok = null;
        try
        {
            var n = await Cfg.AplicarComplementoAsync(c.Id, await Actor());
            _ok = n > 0
                ? $"Complemento \"{c.Nombre}\" aplicado: {n} entradas nuevas en el catalogo."
                : $"El complemento \"{c.Nombre}\" ya estaba aplicado; no habia nada nuevo que crear.";
            _compOpen = false;
            await Recargar();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Importar()
    {
        _error = _ok = null;
        if (string.IsNullOrWhiteSpace(_csv)) { _error = "Pega primero el CSV."; return; }
        try
        {
            var r = await Cfg.ImportarAgnCsvAsync(_csv, await Actor());
            _ok = $"Importadas {r.Series} series, {r.Subseries} subseries y {r.Tipologias} tipologias.";
            if (r.Errores.Count > 0) { _error = string.Join(" | ", r.Errores.Take(5)); }
            _importOpen = false;
            _csv = "";
            await Recargar();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Resolver(SugerenciaDto s, bool aprobar)
    {
        _error = _ok = null;
        await Cfg.ResolverSugerenciaAsync(s.Nivel, s.Id, aprobar, await Actor());
        _ok = aprobar
            ? $"\"{s.Nombre}\" pasa al catalogo maestro."
            : $"\"{s.Nombre}\" quedo rechazada.";
        await Recargar();
    }

    // ==================== Editor de series ====================

    private static string IconoNivel(string nivel) => nivel switch
    {
        "SERIE" => "📁",
        "SUBSERIE" => "🗂",
        _ => "📄"
    };

    private string _filtroArbol = "";

    /// <summary>
    /// Filtra el arbol por los tres niveles conservando la rama completa de cada
    /// coincidencia: hacia arriba sus ancestros, para saber de que serie cuelga
    /// una tipologia; y hacia abajo sus descendientes, para ver que contiene una
    /// serie encontrada. Sin los ancestros, una tipologia suelta no dice nada.
    /// </summary>
    private List<NodoArbolDto> ArbolFiltrado
    {
        get
        {
            var q = Normalizar(_filtroArbol);
            if (q.Length == 0) { return _arbol; }

            var coincide = _arbol
                .Where(n => Normalizar(n.Nombre).Contains(q) || Normalizar(n.Codigo).Contains(q))
                .ToList();
            if (coincide.Count == 0) { return new(); }

            var visibles = new HashSet<Guid>();
            var porId = _arbol.ToDictionary(n => n.Id);

            foreach (var n in coincide)
            {
                visibles.Add(n.Id);

                // Ancestros: la ruta hasta la serie raiz.
                var padre = n.PadreId;
                while (padre is Guid p && porId.TryGetValue(p, out var nodo))
                {
                    if (!visibles.Add(p)) { break; }   // rama ya recorrida
                    padre = nodo.PadreId;
                }

                // Descendientes: lo que cuelga de la coincidencia.
                AgregarDescendientes(n.Id, visibles);
            }

            // Se respeta el orden original de dibujo del arbol.
            return _arbol.Where(n => visibles.Contains(n.Id)).ToList();
        }
    }

    private void AgregarDescendientes(Guid padreId, HashSet<Guid> destino)
    {
        foreach (var hijo in _arbol.Where(x => x.PadreId == padreId))
        {
            if (destino.Add(hijo.Id))
            {
                AgregarDescendientes(hijo.Id, destino);
            }
        }
    }

    /// <summary>Compara sin distinguir mayusculas ni acentos (Narino / Nariño).</summary>
    private static string Normalizar(string? texto)
    {
        if (string.IsNullOrWhiteSpace(texto)) { return ""; }

        var descompuesto = texto.Trim().ToLowerInvariant().Normalize(System.Text.NormalizationForm.FormD);
        var sb = new System.Text.StringBuilder(descompuesto.Length);

        foreach (var c in descompuesto)
        {
            if (System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c)
                != System.Globalization.UnicodeCategory.NonSpacingMark)
            {
                sb.Append(c);
            }
        }

        return sb.ToString().Normalize(System.Text.NormalizationForm.FormC);
    }

    private async Task AbrirEditor()
    {
        _editorOpen = true;
        _edError = null;
        _filtroArbol = "";
        await RecargarArbol();
    }

    private async Task RecargarArbol()
    {
        _arbol = (await Editor.ArbolAsync()).ToList();

        // Tras un alta o borrado, la seleccion puede haber dejado de existir.
        var vigente = _selId is Guid id ? _arbol.FirstOrDefault(n => n.Id == id) : null;
        if (vigente is null)
        {
            _sel = null; _selId = null; _carac = null; _formatos = null;
            return;
        }

        await Seleccionar(vigente);
    }

    private async Task Seleccionar(NodoArbolDto n)
    {
        _sel = n;
        _selId = n.Id;
        _carac = null;
        _formatos = null;

        if (n.Nivel == "SERIE")
        {
            _compTab = "cargos";
            await CargarComplementos(n.Id);
        }

        if (n.Nivel == "TIPOLOGIA")
        {
            _formatos = await Editor.FormatosAsync(n.Id);
        }
        else if (n.Nivel == "SUBSERIE" || n.SinSubseries)
        {
            // La serie solo se caracteriza cuando declara no tener subseries.
            _carac = await Editor.CaracterizacionAsync(n.Nivel, n.Id);
        }
    }

    private async Task Ejecutar(Func<Task> accion)
    {
        _edError = null;
        try { await accion(); await RecargarArbol(); }
        catch (InvalidOperationException ex) { _edError = ex.Message; }
    }

    private async Task AgregarSerie() => await Ejecutar(async () =>
    {
        _selId = await Editor.AgregarSerieAsync(await Actor());
    });

    private async Task AgregarHijo(NodoArbolDto n) => await Ejecutar(async () =>
    {
        var actor = await Actor();
        _selId = n.Nivel switch
        {
            // Una serie sin subseries cuelga tipologias directo.
            "SERIE" when !n.SinSubseries => await Editor.AgregarSubserieAsync(n.Id, actor),
            _ => await Editor.AgregarTipologiaAsync(n.Id, n.Nivel, actor)
        };
    });

    private async Task Renombrar(NodoArbolDto n, string nombre) => await Ejecutar(async () =>
        await Editor.RenombrarAsync(n.Nivel, n.Id, nombre, await Actor()));

    private async Task Eliminar(NodoArbolDto n) => await Ejecutar(async () =>
    {
        await Editor.EliminarAsync(n.Nivel, n.Id);
        if (_selId == n.Id) { _selId = null; }
    });

    private async Task AlternarSinSubseries() => await Ejecutar(async () =>
    {
        if (_sel is null) { return; }
        await Editor.AlternarSinSubseriesAsync(_sel.Id, await Actor());
    });

    private async Task GuardarCarac(string? ag = null, string? ac = null, string? proc = null) => await Ejecutar(async () =>
    {
        if (_carac is null) { return; }

        // Solo llega el campo que cambio; el resto conserva lo que ya tenia.
        var nuevoAg = ag is null ? _carac.TiempoAg : Decimal(ag);
        var nuevoAc = ac is null ? _carac.TiempoAc : Decimal(ac);
        var nuevoProc = proc ?? _carac.Procedimiento;

        await Editor.GuardarCaracterizacionAsync(
            _carac.Nivel, _carac.Id, nuevoAg, nuevoAc, nuevoProc, await Actor());
    });

    private static decimal? Decimal(string? v) =>
        decimal.TryParse(v, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var d) ? d : null;

    private async Task AlternarFormato(string formato) => await Ejecutar(async () =>
    {
        if (_formatos is null) { return; }
        await Editor.AlternarFormatoAsync(_formatos.Id, formato, await Actor());
    });

    private async Task AgregarCampo() => await Ejecutar(async () =>
    {
        if (_sel is null) { return; }
        await Editor.AgregarCampoAsync(_sel.Nivel, _sel.Id, await Actor());
    });

    private async Task GuardarCampo(CampoDinamicoDto c, string? clave = null, string? tipo = null, string? valor = null) =>
        await Ejecutar(async () => await Editor.GuardarCampoAsync(
            c.Id, clave ?? c.Clave, tipo ?? c.Tipo, valor ?? c.Valor, await Actor()));

    private async Task EliminarCampo(CampoDinamicoDto c) => await Ejecutar(async () =>
        await Editor.EliminarCampoAsync(c.Id));

    // ---- Complementos de la serie ----

    private static readonly (string Clave, string Etiqueta)[] Permisos =
    [
        ("subir", "Subir"), ("editar", "Editar"),
        ("eliminar", "Eliminar"), ("central", "Archivo Central")
    ];

    private string _compTab = "cargos";
    private List<CargoSerieDto> _cargos = new();
    private List<DirectorioSerieDto> _directorios = new();
    private string _cargoNuevo = "", _dirNuevo = "";
    private readonly Dictionary<Guid, string> _funcNuevo = new();
    private readonly Dictionary<Guid, string> _subdirNuevo = new();

    private static bool TienePermiso(CargoSerieDto c, string clave) => clave switch
    {
        "subir" => c.PuedeSubir,
        "editar" => c.PuedeEditar,
        "eliminar" => c.PuedeEliminar,
        "central" => c.PuedeArchivoCentral,
        _ => false
    };

    private async Task CargarComplementos(Guid serieId)
    {
        _cargos = (await Editor.CargosAsync(serieId)).ToList();
        _directorios = (await Editor.DirectoriosAsync(serieId)).ToList();
    }

    /// <summary>Ejecuta y refresca solo los complementos, sin recargar el arbol.</summary>
    private async Task EjecutarComp(Func<Task> accion)
    {
        _edError = null;
        try
        {
            await accion();
            if (_sel is not null) { await CargarComplementos(_sel.Id); }
        }
        catch (InvalidOperationException ex) { _edError = ex.Message; }
    }

    private async Task AgregarCargo() => await EjecutarComp(async () =>
    {
        if (_sel is null) { return; }
        await Editor.AgregarCargoAsync(_sel.Id, _cargoNuevo, await Actor());
        _cargoNuevo = "";
    });

    private async Task AlternarPermiso(CargoSerieDto c, string permiso) => await EjecutarComp(async () =>
        await Editor.AlternarPermisoAsync(c.Id, permiso, await Actor()));

    private async Task EliminarCargo(CargoSerieDto c) => await EjecutarComp(async () =>
        await Editor.EliminarCargoAsync(c.Id));

    private async Task AgregarFuncionario(CargoSerieDto c) => await EjecutarComp(async () =>
    {
        var nombre = _funcNuevo.TryGetValue(c.Id, out var v) ? v : "";
        await Editor.AgregarFuncionarioAsync(c.Id, nombre, await Actor());
        _funcNuevo[c.Id] = "";
    });

    private async Task EliminarFuncionario(FuncionarioDto f) => await EjecutarComp(async () =>
        await Editor.EliminarFuncionarioAsync(f.Id));

    private async Task AgregarDirectorio(Guid? padreId) => await EjecutarComp(async () =>
    {
        if (_sel is null) { return; }
        var nombre = padreId is Guid p
            ? (_subdirNuevo.TryGetValue(p, out var sv) ? sv : "")
            : _dirNuevo;

        await Editor.AgregarDirectorioAsync(_sel.Id, padreId, nombre, await Actor());

        if (padreId is Guid pid) { _subdirNuevo[pid] = ""; } else { _dirNuevo = ""; }
    });

    private async Task EliminarDirectorio(DirectorioSerieDto d) => await EjecutarComp(async () =>
        await Editor.EliminarDirectorioAsync(d.Id));
}
