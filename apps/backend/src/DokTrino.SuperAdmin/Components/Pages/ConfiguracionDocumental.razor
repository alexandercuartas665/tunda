@page "/configuracion-documental"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@inject IConfiguracionDocumentalService Cfg
@inject IEditorSeriesService Editor
@inject IImportadorBancoAgnService Banco
@inject IWebHostEnvironment Entorno

<PageTitle>Configuracion documental - DokTrino</PageTitle>

<div class="trx">
    <div class="trx-breadcrumb">Inicio &middot; Configuracion documental</div>

    <div class="trx-head">
        <div>
            <div class="trx-title">Configuracion documental</div>
            <div class="trx-sub">Define el catalogo de series y administra el banco documental del que se nutren las TRD.</div>
        </div>
    </div>

    @* --- Tabs --- *@
    <div class="tcl-tabs">
        <button class="tcl-tab @(_tab == "series" ? "on" : "")" @onclick='() => Cambiar("series")'>
            Configuracion de series <span class="badge2">@_series.Count</span>
        </button>
        <button class="tcl-tab @(_tab == "banco" ? "on" : "")" @onclick='() => Cambiar("banco")'>
            Banco documental <span class="badge2">@_banco.Count</span>
        </button>
        <button class="tcl-tab @(_tab == "sugerencias" ? "on" : "")" @onclick='() => Cambiar("sugerencias")'>
            Sugerencias <span class="badge2">@_sugerencias.Count</span>
        </button>
    </div>

    @if (_error is not null) { <div class="ase-alert">@_error</div> }
    @if (_ok is not null) { <div class="ase-ok">@_ok</div> }

    @* --- Toolbar --- *@
    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px; flex-wrap: wrap; justify-content: flex-end;">
        @if (_tab == "series")
        {
            <div style="margin-left: auto; display: flex; gap: 9px;">
                <button class="cfgd-comp-btn" @onclick="() => _compOpen = true">&#129513; Complementos</button>
                <button class="cfgd-import-btn" @onclick="CargarBancoAgn" disabled="@_cargandoBanco">
                    @(_cargandoBanco ? "Cargando banco AGN..." : "⬇ Cargar banco AGN")
                </button>
                <button class="trx-btn" @onclick="AbrirEditor">&#65291; Editor de series</button>
            </div>
        }
        else if (_tab == "banco")
        {
            <button class="cfgd-import-btn" style="margin-left: auto;" @onclick="() => _importOpen = true">
                &#11015; Importar del bunker (AGN)
            </button>
        }
    </div>

    @if (_tab == "series")
    {
        <div class="cfgd-tabla">
            <div class="cfgd-scroll">
                <div class="cfgd-grid cfgd-head">
                    <div>Codigo</div><div>Serie documental</div><div>Subseries</div>
                    <div>Tipologias</div><div>Retencion (AG/AC)</div><div>Estado</div>
                </div>

                @* Filtros por columna, fijos junto a la cabecera. *@
                <div class="cfgd-grid cfgd-filtros">
                    <input class="cfgd-f" placeholder="Codigo" @bind="_fCodigo" @bind:event="oninput" />
                    <input class="cfgd-f" placeholder="Nombre de la serie" @bind="_fNombre" @bind:event="oninput" />
                    <div></div><div></div>
                    <select class="cfgd-f" @bind="_fRetencion">
                        <option value="">Retencion: todas</option>
                        <option value="si">Declarada</option>
                        <option value="no">Sin declarar</option>
                    </select>
                    <select class="cfgd-f" @bind="_fEstado">
                        <option value="">Estado: todos</option>
                        <option value="MAESTRA">Maestra</option>
                        <option value="SUGERIDA">Sugerida</option>
                    </select>
                </div>

                @if (SeriesFiltradas.Count == 0)
                {
                    <div class="cfgd-vacio">
                        @(_series.Count == 0
                            ? "Sin series en el catalogo. Aplica un complemento o importa el cuadro del AGN."
                            : "Ninguna serie coincide con los filtros.")
                    </div>
                }
                @foreach (var s in SeriesFiltradas)
                {
                    <div class="cfgd-grid cfgd-row">
                        <div class="num">@s.Codigo</div>
                        <div class="nom">@s.Nombre</div>
                        <div class="txt">@s.Subseries</div>
                        <div class="txt">@s.Tipologias</div>
                        <div class="mono">@s.Retencion</div>
                        <div><span class="trx-est @(s.Estado == "MAESTRA" ? "activo" : "desarrollo")">@s.Estado</span></div>
                    </div>
                }
            </div>

            <div class="cfgd-pie">
                <span>@SeriesFiltradas.Count de @_series.Count series</span>
                @if (HayFiltroSeries)
                {
                    <button class="cfgd-limpiar" @onclick="LimpiarFiltrosSeries">Limpiar filtros</button>
                }
            </div>
        </div>
        <div class="cfgd-nota">
            AG = Archivo de Gestion &middot; AC = Archivo Central. Las series maestras quedan disponibles para el Cliente Encuesta.
        </div>
    }
    else if (_tab == "banco")
    {
        <div class="cfgd-tabla">
            <div class="cfgd-scroll">
                <div class="cfgd-grid-banco cfgd-head">
                    <div>Codigo</div><div>Registro documental</div><div>Serie</div><div>Fuente</div>
                </div>

                <div class="cfgd-grid-banco cfgd-filtros">
                    <input class="cfgd-f" placeholder="Codigo" @bind="_fCodigo" @bind:event="oninput" />
                    <input class="cfgd-f" placeholder="Registro" @bind="_fNombre" @bind:event="oninput" />
                    <input class="cfgd-f" placeholder="Serie" @bind="_fSerie" @bind:event="oninput" />
                    <select class="cfgd-f" @bind="_fEstado">
                        <option value="">Fuente: todas</option>
                        <option value="MAESTRA">Catalogo maestro</option>
                        <option value="SUGERIDA">Propuesta</option>
                    </select>
                </div>

                @if (BancoFiltrado.Count == 0)
                {
                    <div class="cfgd-vacio">
                        @(_banco.Count == 0 ? "El banco documental esta vacio." : "Ningun registro coincide con los filtros.")
                    </div>
                }
                @foreach (var b in BancoFiltrado)
                {
                    <div class="cfgd-grid-banco cfgd-row">
                        <div class="num">@b.Codigo</div>
                        <div class="nom">@b.Nombre</div>
                        <div class="txt">@b.Serie</div>
                        <div><span class="trx-est @(b.Estado == "MAESTRA" ? "activo" : "desarrollo")">@b.Fuente</span></div>
                    </div>
                }
            </div>

            <div class="cfgd-pie">
                <span>@BancoFiltrado.Count de @_banco.Count registros</span>
                @if (HayFiltroSeries)
                {
                    <button class="cfgd-limpiar" @onclick="LimpiarFiltrosSeries">Limpiar filtros</button>
                }
            </div>
        </div>
        <div class="cfgd-nota">
            El banco documental es el catalogo maestro (bunker del AGN mas los registros propios) del que las dependencias
            seleccionan sus subseries y tipologias.
        </div>
    }
    else
    {
        <div class="cfgd-tabla">
            <div class="cfgd-scroll">
                <div class="cfgd-grid-sug cfgd-head">
                    <div>Nivel</div><div>Codigo</div><div>Nombre propuesto</div><div>Dependencia</div><div>Accion</div>
                </div>
                @if (_sugerencias.Count == 0)
                {
                    <div class="cfgd-vacio">No hay propuestas de catalogo pendientes.</div>
                }
                @foreach (var s in _sugerencias)
                {
                    <div class="cfgd-grid-sug cfgd-row">
                        <div><span class="tcl-propia">@s.Nivel</span></div>
                        <div class="num">@s.Codigo</div>
                        <div class="nom">@s.Nombre</div>
                        <div class="txt">@s.Dependencia</div>
                        <div style="display: flex; gap: 6px;">
                            <button class="btn btn-outline-success btn-sm" @onclick="() => Resolver(s, true)">Aprobar</button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Resolver(s, false)">Rechazar</button>
                        </div>
                    </div>
                }
            </div>
        </div>
        <div class="cfgd-nota">
            Al aprobar, la entrada pasa al catalogo maestro y la ven todas las dependencias.
            Al rechazar queda archivada y desaparece de la encuesta del colaborador.
        </div>
    }
</div>

@* ===================== Editor de series (arbol + paneles) ===================== *@
@if (_editorOpen)
{
    <div class="doktrino-drawer-scrim" style="display: block;" @onclick="() => _editorOpen = false"></div>
    <div class="ed-modal">
        <div class="ed-head">
            <div class="ico">&#128218;</div>
            <div style="flex: 1;">
                <div class="ttl">Configuracion de series</div>
                <div class="sub">Construye el arbol: serie &rarr; subserie &rarr; tipologia. Selecciona un nivel para su caracterizacion o formatos.</div>
            </div>
            <span class="cls" @onclick="() => _editorOpen = false">&#10005;</span>
        </div>

        @if (_edError is not null) { <div class="ase-alert" style="margin: 12px 18px 0;">@_edError</div> }

        <div class="ed-body">
            @* --- Columna 1: arbol --- *@
            <div class="ed-arbol">
                <div class="ed-arbol-h">
                    <span>Jerarquia documental</span>
                    <button class="ed-add-serie" @onclick="AgregarSerie">&#65291; Serie</button>
                </div>

                @* Busca en los tres niveles; lo que encuentra viaja con su rama. *@
                <div class="ed-buscar-caja">
                    <input class="ed-buscar" @bind="_filtroArbol" @bind:event="oninput"
                           placeholder="Buscar serie, subserie o tipologia..." />
                    @if (_filtroArbol.Length > 0)
                    {
                        <button type="button" class="ed-buscar-x" title="Limpiar busqueda"
                                @onclick='() => _filtroArbol = ""'>&#10005;</button>
                    }
                </div>

                @if (_arbol.Count == 0)
                {
                    <div class="dkd-empty">Sin series. Crea la primera con el boton de arriba.</div>
                }
                else if (ArbolVisible.Count == 0)
                {
                    <div class="dkd-empty">Nada coincide con "@_filtroArbol".</div>
                }

                @foreach (var n in ArbolVisible)
                {
                    <div class="ed-nodo @(_selId == n.Id ? "on" : "")"
                         style="padding-left: @(n.Profundidad * 16 + 8)px"
                         @onclick="() => Seleccionar(n)">
                        @if (TieneHijos(n.Id))
                        {
                            <span class="ed-chevron" @onclick:stopPropagation="true" @onclick="() => Plegar(n.Id)">
                                @(_expandidos.Contains(n.Id) ? "▾" : "▸")
                            </span>
                        }
                        else
                        {
                            <span class="ed-chevron vacio"></span>
                        }
                        <span class="ico">@IconoNivel(n.Nivel)</span>
                        <input class="ed-nombre" value="@n.Nombre"
                               @onclick:stopPropagation="true"
                               @onchange="e => Renombrar(n, e.Value?.ToString() ?? string.Empty)" />

                        @if (n.Nivel is "SERIE" or "SUBSERIE")
                        {
                            <span class="ed-mas" title="@(n.Nivel == "SERIE" && !n.SinSubseries ? "Agregar subserie" : "Agregar tipologia")"
                                  @onclick:stopPropagation="true" @onclick="() => AgregarHijo(n)">&#65291;</span>
                        }
                        <span class="ed-quitar" @onclick:stopPropagation="true" @onclick="() => Eliminar(n)">&#10005;</span>
                    </div>
                }
            </div>

            @* --- Columna 2: panel contextual --- *@
            <div class="ed-panel">
                @if (_sel is null)
                {
                    <div class="ed-vacio">
                        Selecciona un elemento del arbol.<br />
                        Serie o subserie &rarr; caracterizacion &middot; Tipologia &rarr; formatos.
                    </div>
                }
                else if (_sel.Nivel == "SERIE" && !_sel.SinSubseries)
                {
                    @* Serie que usa subseries: aqui no se caracteriza. *@
                    <div class="ed-t">@_sel.Nombre</div>
                    <div class="ed-s">Serie con subseries</div>

                    <label class="ed-chk" @onclick="AlternarSinSubseries">
                        <span class="caja"></span>
                        <div>
                            <div class="t">Esta serie no tiene subseries</div>
                            <div class="s">Activalo para colgar tipologias directamente y definir aqui la caracterizacion.</div>
                        </div>
                    </label>

                    <div class="ed-nota">
                        La caracterizacion (tiempos de retencion, procedimiento, campos) se define en cada
                        <b>subserie</b>. Selecciona una subserie en el arbol para editarla.
                    </div>
                }
                else if (_carac is not null)
                {
                    @* Caracterizacion: subserie, o serie marcada sin subseries. *@
                    <div class="ed-t">Caracterizacion <span class="ed-chip">@_carac.Nombre</span></div>
                    <div class="ed-s">Tiempos de retencion, procedimiento y atributos de este nivel documental.</div>

                    @if (_carac.Nivel == "SERIE")
                    {
                        <label class="ed-chk on" @onclick="AlternarSinSubseries">
                            <span class="caja">&#10003;</span>
                            <div><div class="t">Serie sin subseries: las tipologias cuelgan directo</div></div>
                        </label>
                    }

                    @* --- Tiempo de retencion --- *@
                    <div class="ed-bloque">
                        <div class="ed-bloque-t">Tiempo</div>
                        <div class="ed-fila">
                            <div style="flex: 1;">
                                <div class="ed-lbl">AG (anios)</div>
                                <input class="ed-input mono" type="number" min="0" step="0.5" placeholder="2"
                                       value="@_carac.TiempoAg" @onchange="e => Guardar(r => r.TiempoAg = Decimal(e.Value?.ToString()))" />
                            </div>
                            <div style="flex: 1;">
                                <div class="ed-lbl">AC (anios)</div>
                                <input class="ed-input mono" type="number" min="0" step="0.5" placeholder="8"
                                       value="@_carac.TiempoAc" @onchange="e => Guardar(r => r.TiempoAc = Decimal(e.Value?.ToString()))" />
                            </div>
                        </div>
                        <div class="ed-lbl">Descripcion</div>
                        <textarea class="ed-input" rows="2" placeholder="Momento en que se gestiona el archivo"
                                  @onchange="e => Guardar(r => r.DescripcionTiempo = e.Value?.ToString() ?? string.Empty)">@_carac.DescripcionTiempo</textarea>
                    </div>

                    @* --- Disposicion final --- *@
                    <div class="ed-bloque verde">
                        <div class="ed-bloque-t">Disposicion final</div>
                        <div class="ed-casillas">
                            @RenderCasilla("CT", "DispCt", _carac.DispCt)
                            @RenderCasilla("S", "DispS", _carac.DispS)
                            @RenderCasilla("E", "DispE", _carac.DispE)
                        </div>
                        <div class="ed-lbl">Descripcion</div>
                        <textarea class="ed-input" rows="2" placeholder="Describe el proceso en caso que tenga eliminacion"
                                  @onchange="e => Guardar(r => r.DescripcionDisposicion = e.Value?.ToString() ?? string.Empty)">@_carac.DescripcionDisposicion</textarea>
                    </div>

                    @* --- Valoraciones --- *@
                    <div class="ed-bloque verde">
                        <div class="ed-bloque-t">Valoracion primaria</div>
                        <div class="ed-casillas">
                            @RenderCasilla("Administrativo", "Val1Admin", _carac.Val1Admin)
                            @RenderCasilla("Tecnico", "Val1Tecnica", _carac.Val1Tecnica)
                            @RenderCasilla("Legal", "Val1Legal", _carac.Val1Legal)
                            @RenderCasilla("Contable", "Val1Contable", _carac.Val1Contable)
                            @RenderCasilla("Fiscal", "Val1Fiscal", _carac.Val1Fiscal)
                        </div>
                    </div>

                    <div class="ed-bloque verde">
                        <div class="ed-bloque-t">Valoracion secundaria</div>
                        <div class="ed-casillas">
                            @RenderCasilla("Historico", "Val2Historica", _carac.Val2Historica)
                            @RenderCasilla("Cientifico", "Val2Cientifica", _carac.Val2Cientifica)
                            @RenderCasilla("Cultural", "Val2Cultural", _carac.Val2Cultural)
                        </div>
                    </div>

                    @* --- Marcas archivisticas --- *@
                    <div class="ed-bloque">
                        <div class="ed-bloque-t">Marcas</div>
                        <div class="ed-casillas">
                            @RenderCasilla("REP (reproduccion tecnica)", "Rep", _carac.Rep)
                            @RenderCasilla("Serie DDHH / DIH", "Ddhh", _carac.Ddhh)
                            @RenderCasilla("Relacion con el SIG", "Sig", _carac.Sig)
                        </div>
                    </div>

                    @* --- Procedimiento --- *@
                    <div class="ed-bloque azul">
                        <div class="ed-bloque-t">Procedimiento</div>
                        <textarea class="ed-input" rows="3" placeholder="Define todos los aspectos del procedimiento"
                                  @onchange="e => Guardar(r => r.Procedimiento = e.Value?.ToString() ?? string.Empty)">@_carac.Procedimiento</textarea>
                    </div>

                    @* --- Campos dinamicos --- *@
                    <div class="ed-campos-h">
                        <span>Campos dinamicos</span>
                        <button class="ed-add-campo" @onclick="AgregarCampo">&#65291; Campo</button>
                    </div>
                    @RenderCampos(_carac.Campos)
                }
                else if (_formatos is not null)
                {
                    @* Tipologia: formatos aceptados. *@
                    <div class="ed-t">Formatos de archivo <span class="ed-chip">@_formatos.Nombre</span></div>
                    <div class="ed-s">Marca los soportes en los que puede llegar esta tipologia documental.</div>

                    <div class="ed-formatos">
                        @foreach (var f in EditorSeriesService.FormatosDisponibles)
                        {
                            <span class="ed-fmt @(_formatos.Formatos.Contains(f) ? "on" : "")"
                                  @onclick="() => AlternarFormato(f)">@f</span>
                        }
                    </div>

                    <div class="ed-campos-h">
                        <span>Campos dinamicos</span>
                        <button class="ed-add-campo" @onclick="AgregarCampo">&#65291; Campo</button>
                    </div>
                    @RenderCampos(_formatos.Campos)
                }
            </div>

            @* --- Columna 3: complementos, solo con una serie seleccionada --- *@
            @if (_sel is not null && _sel.Nivel == "SERIE")
            {
                <div class="ed-comp">
                    <div class="ed-comp-t">&#129513; Complementos de la serie</div>
                    <div class="ed-comp-s">Configuracion con permiso elevado. La aplica el modulo Archivo Central.</div>

                    <div class="ed-subtabs">
                        <button class="ed-subtab @(_compTab == "cargos" ? "on" : "")" @onclick='() => _compTab = "cargos"'>&#128274; Cargos</button>
                        <button class="ed-subtab @(_compTab == "dirs" ? "on" : "")" @onclick='() => _compTab = "dirs"'>&#128450; Directorios</button>
                    </div>

                    @if (_compTab == "cargos")
                    {
                        <div class="ed-alta">
                            <input class="ed-input" placeholder="Nuevo cargo..." @bind="_cargoNuevo" />
                            <button class="ed-alta-btn" @onclick="AgregarCargo">&#65291;</button>
                        </div>

                        @if (_cargos.Count == 0)
                        {
                            <div class="ed-sin-campos">Sin cargos definidos para esta serie.</div>
                        }

                        @foreach (var c in _cargos)
                        {
                            <div class="ed-cargo">
                                <div class="ed-cargo-h">
                                    <span>&#128084;</span>
                                    <span class="nm">@c.Nombre</span>
                                    <span class="ed-quitar" @onclick="() => EliminarCargo(c)">&#10005;</span>
                                </div>

                                <div class="ed-perms">
                                    @foreach (var p in Permisos)
                                    {
                                        <span class="ed-perm @(TienePermiso(c, p.Clave) ? "on" : "")"
                                              @onclick="() => AlternarPermiso(c, p.Clave)">@p.Etiqueta</span>
                                    }
                                </div>

                                @if (c.Funcionarios.Count > 0)
                                {
                                    <div class="ed-funcs">
                                        @foreach (var f in c.Funcionarios)
                                        {
                                            <span class="ed-func">
                                                @f.Nombre
                                                <span class="x" @onclick="() => EliminarFuncionario(f)">&#10005;</span>
                                            </span>
                                        }
                                    </div>
                                }

                                <div class="ed-alta">
                                    <input class="ed-input" style="font-size: 11.5px;" placeholder="Agregar funcionario..."
                                           value="@(_funcNuevo.TryGetValue(c.Id, out var v) ? v : "")"
                                           @onchange="e => _funcNuevo[c.Id] = e.Value?.ToString() ?? string.Empty" />
                                    <button class="ed-alta-btn ghost" @onclick="() => AgregarFuncionario(c)">&#65291;</button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="ed-alta">
                            <input class="ed-input" placeholder="Directorio raiz..." @bind="_dirNuevo" />
                            <button class="ed-alta-btn" @onclick="() => AgregarDirectorio(null)">&#65291;</button>
                        </div>

                        @if (_directorios.Count == 0)
                        {
                            <div class="ed-sin-campos">Sin plantilla de carpetas para esta serie.</div>
                        }

                        @foreach (var d in _directorios)
                        {
                            <div class="ed-dir" style="padding-left: @(d.Profundidad * 16 + 10)px">
                                <span>&#128450;</span>
                                <span class="nm">@d.Nombre</span>
                                <input class="ed-sub" placeholder="+ sub"
                                       value="@(_subdirNuevo.TryGetValue(d.Id, out var sv) ? sv : "")"
                                       @onchange="e => _subdirNuevo[d.Id] = e.Value?.ToString() ?? string.Empty" />
                                <span class="ed-mas" @onclick="() => AgregarDirectorio(d.Id)">&#65291;</span>
                                <span class="ed-quitar" @onclick="() => EliminarDirectorio(d)">&#10005;</span>
                            </div>
                        }

                        <div class="ed-comp-nota">
                            Al abrir un expediente de esta serie, el Archivo Central puede materializar
                            esta estructura como carpetas reales.
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@* ===================== Modal complementos ===================== *@
@if (_compOpen)
{
    <div class="doktrino-drawer-scrim" style="display: block;" @onclick="() => _compOpen = false"></div>
    <div class="cfgd-modal">
        <div class="cfgd-modal-head" style="background: linear-gradient(135deg, #5b3fa8, #7c5cd0);">
            <div style="flex: 1;">
                <div class="ttl">Complementos</div>
                <div class="sub">Paquetes de catalogo listos para aplicar sobre tu banco documental.</div>
            </div>
            <span class="cls" @onclick="() => _compOpen = false">&#10005;</span>
        </div>
        <div class="cfgd-modal-body">
            @if (_complementos.Count == 0)
            {
                <div class="trx-empty">No hay complementos publicados en la plataforma.</div>
            }
            @foreach (var c in _complementos)
            {
                <div class="cfgd-comp-item">
                    <div style="flex: 1;">
                        <div style="font-weight: 700; font-size: 13px; color: #1f2433;">@c.Nombre</div>
                        <div style="font-size: 11.5px; color: #8a93a8; margin-top: 2px;">@c.Descripcion</div>
                    </div>
                    <span class="tcl-count">@c.Series series</span>
                    <button class="trx-btn" @onclick="() => Aplicar(c)">Aplicar</button>
                </div>
            }
        </div>
    </div>
}

@* ===================== Modal importador AGN ===================== *@
@if (_importOpen)
{
    <div class="doktrino-drawer-scrim" style="display: block;" @onclick="() => _importOpen = false"></div>
    <div class="cfgd-modal">
        <div class="cfgd-modal-head">
            <div style="flex: 1;">
                <div class="ttl">Importar del bunker (AGN)</div>
                <div class="sub">Pega el cuadro de clasificacion en CSV separado por punto y coma.</div>
            </div>
            <span class="cls" @onclick="() => _importOpen = false">&#10005;</span>
        </div>
        <div class="cfgd-modal-body">
            <div class="cfgd-nota" style="margin: 0 0 10px;">
                Columnas: <code>codigo_serie;nombre_serie;codigo_subserie;nombre_subserie;codigo_tipologia;nombre_tipologia</code>
            </div>
            <textarea class="tcl-input" rows="10" style="font-family: 'IBM Plex Mono', monospace; font-size: 12px;"
                      @bind="_csv" placeholder="100;Actas;100-10;Actas de comite;100-10-01;Acta de comite directivo"></textarea>
            <div style="display: flex; gap: 8px; justify-content: flex-end; margin-top: 12px;">
                <button class="trx-btn ghost" @onclick="() => _importOpen = false">Cancelar</button>
                <button class="trx-btn" @onclick="Importar">Importar</button>
            </div>
        </div>
    </div>
}

@* Los campos dinamicos se pintan igual en caracterizacion y en tipologia. *@
@{
    RenderFragment RenderCasilla(string etiqueta, string propiedad, bool marcada) =>
    @<label class="ed-casilla @(marcada ? "on" : "")" @onclick="() => Alternar(propiedad)">
        <span class="caja">@(marcada ? "✓" : "")</span>
        <span>@etiqueta</span>
    </label>;

    RenderFragment RenderCampos(IReadOnlyList<CampoDinamicoDto> campos) =>
    @<text>
        @if (campos.Count == 0)
        {
            <div class="ed-sin-campos">Sin campos adicionales.</div>
        }
        <div class="ed-campos">
            @foreach (var c in campos)
            {
                <div class="ed-campo">
                    <input class="ed-input" style="flex: 1.1;" placeholder="Nombre del campo" value="@c.Clave"
                           @onchange="e => GuardarCampo(c, clave: e.Value?.ToString())" />
                    <select class="ed-input" style="width: 110px; flex-shrink: 0;" value="@c.Tipo"
                            @onchange="e => GuardarCampo(c, tipo: e.Value?.ToString())">
                        <option value="Texto">Texto</option>
                        <option value="Numero">Numero</option>
                        <option value="Fecha">Fecha</option>
                        <option value="SiNo">Si / No</option>
                        <option value="Lista">Lista</option>
                    </select>
                    <input class="ed-input" style="flex: 1;" placeholder="Valor / opciones" value="@c.Valor"
                           @onchange="e => GuardarCampo(c, valor: e.Value?.ToString())" />
                    <span class="ed-quitar" @onclick="() => EliminarCampo(c)">&#10005;</span>
                </div>
            }
        </div>
    </text>;
}

