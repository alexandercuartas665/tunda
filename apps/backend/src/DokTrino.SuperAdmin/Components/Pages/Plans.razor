@page "/plans"
@attribute [Authorize(Policy = "PlatformOperator")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IPlanAdminService PlansSvc

<PageTitle>Planes - DokTrino</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
            </div>
            <span>Super Admin SaaS</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Planes comerciales</h1>
        <p class="page-sub" style="margin-bottom:0;">Cada plan define limites duros de usuarios, lineas WhatsApp, llamadas a la capa IA y automatizaciones.</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreate">+ Nuevo plan</button>
</div>

@if (_plans is null)
{
    <p><em>Cargando...</em></p>
}
else if (_plans.Count == 0)
{
    <p class="text-muted">No hay planes todavia. Crea el primero con "Nuevo plan".</p>
}
else
{
    <div class="plan-grid">
        @foreach (var p in _plans)
        {
            <div class="plan-card">
                <div class="pname">@p.Name</div>
                <div class="pprice">
                    @if (p.MonthlyPrice is decimal m)
                    {
                        @($"$ {m:N0}") <small>@p.Currency / mes</small>
                    }
                    else
                    {
                        <span style="font-size:1.1rem;">Sin precio</span>
                    }
                </div>
                @if (!p.IsActive)
                {
                    <span class="badge bg-secondary" style="align-self:flex-start;margin-top:6px;">Inactivo</span>
                }
                <ul class="plan-features">
                    @foreach (var feat in Features(p))
                    {
                        <li>
                            <svg class="plan-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                            <span>@feat</span>
                        </li>
                    }
                </ul>
                <button class="btn btn-outline-secondary w-100 plan-edit" @onclick="() => OpenEdit(p)">Editar plan</button>
            </div>
        }
    </div>
}

@if (_modalOpen)
{
    <div class="modal-overlay">
        <div class="modal-dialog">
            <div class="modal-head">
                <h3>@(_editingId is null ? "Nuevo plan" : "Editar plan")</h3>
                <button class="modal-close" @onclick="Close">&times;</button>
            </div>
            <div class="modal-body">
                <div class="field">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" @bind="_form.Name" />
                </div>
                <div class="field">
                    <label class="form-label">Descripcion</label>
                    <input class="form-control" @bind="_form.Description" />
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Precio mensual</label>
                        <input class="form-control" type="number" @bind="_form.Monthly" />
                    </div>
                    <div class="field">
                        <label class="form-label">Precio anual</label>
                        <input class="form-control" type="number" @bind="_form.Yearly" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Moneda</label>
                        <input class="form-control" @bind="_form.Currency" />
                    </div>
                    <div class="field">
                        <label class="form-label">Usuarios (max)</label>
                        <input class="form-control" type="number" @bind="_form.MaxUsers" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label class="form-label">Lineas WhatsApp (max)</label>
                        <input class="form-control" type="number" @bind="_form.MaxLines" />
                    </div>
                    <div class="field">
                        <label class="form-label">Llamadas IA / mes (max)</label>
                        <input class="form-control" type="number" @bind="_form.MaxAi" />
                    </div>
                </div>
                @if (_error is not null)
                {
                    <div class="text-danger small">@_error</div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-outline-secondary" @onclick="Close">Cancelar</button>
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_form.Name))">
                    @(_editingId is null ? "Crear plan" : "Guardar cambios")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<PlanDetail>? _plans;
    private bool _modalOpen;
    private Guid? _editingId;
    private bool _busy;
    private string? _error;
    private readonly PlanForm _form = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync() => _plans = (await PlansSvc.ListAsync()).ToList();

    private void OpenCreate()
    {
        _editingId = null;
        _error = null;
        _form.Reset();
        _modalOpen = true;
    }

    private void OpenEdit(PlanDetail p)
    {
        _editingId = p.Id;
        _error = null;
        _form.Name = p.Name;
        _form.Description = p.Description;
        _form.Monthly = p.MonthlyPrice;
        _form.Yearly = p.YearlyPrice;
        _form.Currency = p.Currency ?? "COP";
        _form.MaxUsers = LimitValue(p, "max_users");
        _form.MaxLines = LimitValue(p, "max_whatsapp_lines");
        _form.MaxAi = LimitValue(p, "max_ai_tokens_monthly");
        _modalOpen = true;
    }

    // El modal solo se cierra con la "X" o "Cancelar" (no al hacer clic fuera/dentro),
    // para evitar cierres accidentales mientras se edita.
    private void Close() => _modalOpen = false;

    private async Task SaveAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var limits = new List<PlanLimitInput>
            {
                new("max_users", _form.MaxUsers, "users"),
                new("max_whatsapp_lines", _form.MaxLines, "lines"),
                new("max_ai_tokens_monthly", _form.MaxAi, "tokens", LimitEnforcementMode.Soft)
            };
            var request = new CreatePlanRequest(_form.Name, _form.Description, _form.Monthly, _form.Yearly, _form.Currency, limits);

            if (_editingId is Guid id)
            {
                await PlansSvc.UpdateAsync(id, request, actor);
            }
            else
            {
                await PlansSvc.CreateAsync(request, actor);
            }

            _modalOpen = false;
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static long LimitValue(PlanDetail p, string key) =>
        p.Limits.FirstOrDefault(l => l.LimitKey == key)?.LimitValue ?? 0;

    private static IEnumerable<string> Features(PlanDetail p)
    {
        foreach (var l in p.Limits.OrderBy(x => x.LimitKey))
        {
            yield return FriendlyLimit(l);
        }
        yield return "Pipeline + Bandeja unificada";
        yield return "Soporte multi-tenant";
    }

    private static string FriendlyLimit(PlanLimitDto l) => l.LimitKey switch
    {
        "max_users" => $"{l.LimitValue} usuarios",
        "max_whatsapp_lines" => $"{l.LimitValue} lineas WhatsApp",
        "max_ai_tokens_monthly" => $"{l.LimitValue:N0} llamadas IA",
        _ => $"{l.LimitValue:N0} {l.LimitKey}"
    };

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) return Guid.Empty;
        var state = await AuthState;
        return Guid.TryParse(state.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private sealed class PlanForm
    {
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public decimal? Monthly { get; set; }
        public decimal? Yearly { get; set; }
        public string Currency { get; set; } = "COP";
        public long MaxUsers { get; set; } = 10;
        public long MaxLines { get; set; } = 2;
        public long MaxAi { get; set; } = 100000;

        public void Reset()
        {
            Name = string.Empty;
            Description = null;
            Monthly = null;
            Yearly = null;
            Currency = "COP";
            MaxUsers = 10;
            MaxLines = 2;
            MaxAi = 100000;
        }
    }
}
