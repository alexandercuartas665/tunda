@page "/restablecer"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject DokTrino.Application.Admin.IPlatformBrandingService BrandingSvc

<PageTitle>Restablecer contrasena - @_brand.PlatformName</PageTitle>

<div class="auth-shell">
    <aside class="auth-aside">
        <div class="auth-aside-deco auth-deco-tr"></div>
        <div class="auth-aside-deco auth-deco-bl"></div>
        <div class="auth-brand">
            @if (!string.IsNullOrWhiteSpace(_brand.LoginLogoUrl))
            {
                <img class="auth-brand-logo-img" src="@_brand.LoginLogoUrl" alt="@_brand.PlatformName" />
            }
            else
            {
                <div class="auth-brand-logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                </div>
            }
            <span class="auth-brand-name">@_brand.PlatformName</span>
        </div>
        <div class="auth-aside-body">
            <h2>Crea una nueva contrasena</h2>
            <p>Elige una clave segura de al menos 8 caracteres para tu cuenta.</p>
            <div class="auth-dots"><span></span><span></span><span></span></div>
        </div>
    </aside>

    <main class="auth-main">
        <div class="auth-form-wrap">
            <section class="auth-pane" style="display:block;">
                <div class="auth-head">
                    <h1>Restablecer contrasena</h1>
                    <p>Define tu nueva contrasena.</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(ErrorMsg))
                {
                    <div class="auth-alert auth-alert-error">@ErrorMsg</div>
                }

                @if (string.IsNullOrWhiteSpace(Token))
                {
                    <div class="auth-alert auth-alert-error">Falta el token del enlace. Solicita un nuevo enlace de reseteo.</div>
                    <p class="auth-switch"><a href="/recuperar" style="color:var(--primary);font-weight:700;text-decoration:none;">Solicitar nuevo enlace</a></p>
                }
                else
                {
                    <form method="post" action="/auth/reset" class="auth-form">
                        <input type="hidden" name="token" value="@Token" />
                        <div class="auth-field">
                            <label for="rp-password">Nueva contrasena</label>
                            <div class="auth-input-icon">
                                <input id="rp-password" name="password" type="password" required minlength="8" placeholder="Minimo 8 caracteres" />
                                <button type="button" class="auth-eye" onclick="doktrinoAuth.toggle('rp-password', this)">MOSTRAR</button>
                            </div>
                        </div>
                        <button class="auth-submit" type="submit">
                            <span>Guardar nueva contrasena</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                        </button>
                    </form>
                    <p class="auth-switch"><a href="/login" style="color:var(--primary);font-weight:700;text-decoration:none;">Volver a iniciar sesion</a></p>
                }
            </section>
        </div>
        <footer class="auth-footer">&copy; @DateTime.UtcNow.Year @_brand.PlatformName. Todos los derechos reservados.</footer>
    </main>
</div>

<script>
    window.doktrinoAuth = window.doktrinoAuth || {
        toggle: function (id, btn) {
            var input = document.getElementById(id);
            if (!input) return;
            var show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            btn.textContent = show ? 'OCULTAR' : 'MOSTRAR';
        }
    };
</script>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery(Name = "error")] public string? ErrorMsg { get; set; }

    private DokTrino.Application.Admin.PlatformBrandingDto _brand = DokTrino.Application.Admin.PlatformBrandingDto.Default;

    protected override async Task OnInitializedAsync() => _brand = await BrandingSvc.GetAsync();
}
