@page "/power-bi"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@inject IPowerBiService Pbi

<PageTitle>Power BI Servicios - DokTrino</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">BI / Analitica</div>
        <h1 class="ase-title">Power BI Servicios</h1>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-card">
    <div class="ase-card-h">Tableros configurados (@_items.Count)</div>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead><tr><th class="text-center">#</th><th>Nombre</th><th>Embed URL</th><th></th></tr></thead>
            <tbody>
                @foreach (var r in _items)
                {
                    <tr class="@(r.Id == _sel?.Id ? "pbi-sel" : "")">
                        <td class="text-center">@r.Orden</td>
                        <td>@r.Nombre</td>
                        <td><small class="mono">@Trunc(r.EmbedUrl)</small></td>
                        <td class="ase-row-actions">
                            <button class="btn btn-outline-primary btn-sm" @onclick="() => Ver(r)">Ver</button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Del(r.Id)">&times;</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_items.Count == 0) { <div class="ase-empty">Sin tableros. Agrega uno con su URL de "Publicar en la web" / embed de Power BI.</div> }
    </div>
    <div class="pbi-form">
        <div class="pbi-f"><label>Nombre</label><input class="form-control form-control-sm" @bind="_n.Nombre" placeholder="KPIs documentales" /></div>
        <div class="pbi-f pbi-grow"><label>Embed URL (https)</label><input class="form-control form-control-sm" @bind="_n.EmbedUrl" placeholder="https://app.powerbi.com/view?r=..." /></div>
        <div class="pbi-f"><label>&nbsp;</label><button class="btn btn-primary btn-sm" @onclick="Add">Agregar tablero</button></div>
    </div>
    <small class="text-muted">El reporte vive en tu workspace de Power BI; aqui solo se guarda la URL de embed. Requiere un tablero publicado para visualizarse.</small>
</div>

@if (_sel is not null)
{
    <div class="ase-card">
        <div class="ase-card-h">@_sel.Nombre</div>
        <div class="pbi-frame">
            <iframe title="@_sel.Nombre" src="@_sel.EmbedUrl" frameborder="0" allowfullscreen></iframe>
        </div>
    </div>
}

<style>
    .pbi-form { display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end; margin-top: 8px; }
    .pbi-f { display: flex; flex-direction: column; gap: 3px; }
    .pbi-f label { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--muted-foreground); }
    .pbi-grow { flex: 1; min-width: 320px; }
    .pbi-sel { background: var(--primary-soft); }
    .mono { font-family: 'JetBrains Mono','Consolas',monospace; }
    .pbi-frame { position: relative; width: 100%; aspect-ratio: 16 / 9; background: var(--muted); border-radius: 10px; overflow: hidden; }
    .pbi-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private List<PowerBiReporteDto> _items = new();
    private PowerBiReporteDto? _sel;
    private SavePowerBiReporteRequest _n = new();
    private string? _error, _ok;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load() => _items = (await Pbi.ListAsync()).ToList();

    private void Ver(PowerBiReporteDto r) => _sel = r;

    private async Task Add()
    {
        _error = _ok = null;
        try
        {
            var s = await Pbi.SaveAsync(_n, await Actor());
            if (s is null) { _error = "Sin tenant activo."; return; }
            _ok = $"Tablero '{s.Nombre}' agregado.";
            _n = new();
            await Load();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Del(Guid id)
    {
        _error = _ok = null;
        if (_sel?.Id == id) { _sel = null; }
        await Pbi.DeleteAsync(id, await Actor());
        await Load();
    }

    private static string Trunc(string s) => s.Length > 70 ? s[..70] + "..." : s;

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }
}
