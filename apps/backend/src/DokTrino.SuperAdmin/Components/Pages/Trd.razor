@page "/trd"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@inject ITrdService TrdSvc

<PageTitle>Tabla de Retencion Documental - DokTrino</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Gestion Documental</div>
        <h1 class="ase-title">Tabla de Retencion Documental (TRD)</h1>
    </div>
    <div>
        @if (_items.Count == 0)
        {
            <button class="btn btn-outline-primary btn-sm" @onclick="SeedDemo">Sembrar TRD demo</button>
        }
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-card">
    <div class="ase-card-h">Series documentales y disposicion final</div>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr>
                    <th>Sede</th><th>Codigo</th><th>Serie</th>
                    <th class="text-center" title="Archivo de Gestion (anios)">AG</th>
                    <th class="text-center" title="Archivo Central (anios)">AC</th>
                    <th class="text-center" title="Conservacion Total">CT</th>
                    <th class="text-center" title="Eliminacion">E</th>
                    <th class="text-center" title="Seleccion">S</th>
                    <th class="text-center">Subseries</th>
                    <th class="text-center">Activa</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in _items)
                {
                    <tr>
                        <td><span class="mono">@s.Sucursal</span></td>
                        <td><span class="mono">@s.Codigo</span></td>
                        <td>@s.Nombre</td>
                        <td class="text-center">@(s.AgAnios?.ToString() ?? "-")</td>
                        <td class="text-center">@(s.AcAnios?.ToString() ?? "-")</td>
                        <td class="text-center">@(s.ConservacionPermanente ? "X" : "")</td>
                        <td class="text-center">@(s.Eliminacion ? "X" : "")</td>
                        <td class="text-center">@(s.Seleccion ? "X" : "")</td>
                        <td class="text-center">@s.Subseries</td>
                        <td class="text-center">@(s.Activo ? "Si" : "No")</td>
                        <td class="ase-row-actions">
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(s.Id)">&times;</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_items.Count == 0) { <div class="ase-empty">Sin series en la TRD. Agrega la primera o siembra el demo.</div> }
    </div>
</div>

<div class="ase-card">
    <div class="ase-card-h">Nueva serie</div>
    <div class="trd-form">
        <div class="trd-f"><label>Sede</label><input class="form-control form-control-sm" @bind="_n.Sucursal" placeholder="PRINCIPAL" /></div>
        <div class="trd-f"><label>Codigo</label><input class="form-control form-control-sm mono" @bind="_n.Codigo" placeholder="100" /></div>
        <div class="trd-f trd-grow"><label>Nombre de la serie</label><input class="form-control form-control-sm" @bind="_n.Nombre" placeholder="Actas" /></div>
        <div class="trd-f trd-sm"><label>AG</label><input type="number" min="0" class="form-control form-control-sm" @bind="_n.AgAnios" /></div>
        <div class="trd-f trd-sm"><label>AC</label><input type="number" min="0" class="form-control form-control-sm" @bind="_n.AcAnios" /></div>
        <div class="trd-f trd-chk"><label>CT</label><input type="checkbox" class="form-check-input" @bind="_n.ConservacionPermanente" /></div>
        <div class="trd-f trd-chk"><label>E</label><input type="checkbox" class="form-check-input" @bind="_n.Eliminacion" /></div>
        <div class="trd-f trd-chk"><label>S</label><input type="checkbox" class="form-check-input" @bind="_n.Seleccion" /></div>
        <div class="trd-f"><label>&nbsp;</label><button class="btn btn-primary btn-sm" @onclick="Add">Agregar</button></div>
    </div>
    <small class="text-muted">AG = anios en Archivo de Gestion, AC = en Archivo Central. CT conservacion total, E eliminacion, S seleccion (Ley 594/2000, Acuerdos AGN).</small>
</div>

<div class="ase-card">
    <div class="ase-card-h">Tipologias documentales</div>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead><tr><th>Sede</th><th>Codigo</th><th>Tipologia</th><th>Tipo</th><th>Serie</th><th class="text-center">Activa</th><th></th></tr></thead>
            <tbody>
                @foreach (var t in _tips)
                {
                    <tr>
                        <td><span class="mono">@t.Sucursal</span></td>
                        <td><span class="mono">@t.Codigo</span></td>
                        <td>@t.Nombre</td>
                        <td>@t.Tipo</td>
                        <td>@(t.SerieNombre ?? "-")</td>
                        <td class="text-center">@(t.Activo ? "Si" : "No")</td>
                        <td class="ase-row-actions"><button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteTip(t.Id)">&times;</button></td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_tips.Count == 0) { <div class="ase-empty">Sin tipologias. Agrega la primera abajo.</div> }
    </div>
    <div class="trd-form">
        <div class="trd-f"><label>Sede</label><input class="form-control form-control-sm" @bind="_nt.Sucursal" placeholder="PRINCIPAL" /></div>
        <div class="trd-f"><label>Codigo</label><input class="form-control form-control-sm mono" @bind="_nt.Codigo" placeholder="100-01" /></div>
        <div class="trd-f trd-grow"><label>Nombre de la tipologia</label><input class="form-control form-control-sm" @bind="_nt.Nombre" placeholder="Acta de comite" /></div>
        <div class="trd-f"><label>Tipo</label>
            <select class="form-select form-select-sm" @bind="_nt.Tipo">
                <option value="general">general</option>
                <option value="financiera">financiera</option>
            </select>
        </div>
        <div class="trd-f trd-grow"><label>Serie</label>
            <select class="form-select form-select-sm" @bind="_ntSerie">
                <option value="">(sin serie)</option>
                @foreach (var s in _items)
                {
                    <option value="@s.Id">@s.Codigo - @s.Nombre</option>
                }
            </select>
        </div>
        <div class="trd-f"><label>&nbsp;</label><button class="btn btn-primary btn-sm" @onclick="AddTip">Agregar</button></div>
    </div>
</div>

<style>
    .trd-form { display: flex; flex-wrap: wrap; gap: 10px; align-items: flex-end; }
    .trd-f { display: flex; flex-direction: column; gap: 3px; }
    .trd-f label { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--muted-foreground); }
    .trd-grow { flex: 1; min-width: 200px; }
    .trd-sm input { width: 70px; }
    .trd-chk { align-items: center; }
    .mono { font-family: 'JetBrains Mono','Consolas',monospace; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private List<SerieTrdDto> _items = new();
    private List<TipologiaDto> _tips = new();
    private SaveSerieRequest _n = Empty();
    private SaveTipologiaRequest _nt = EmptyTip();
    private string _ntSerie = "";
    private string? _error, _ok;

    private static SaveSerieRequest Empty() => new() { Sucursal = "PRINCIPAL", Activo = true };
    private static SaveTipologiaRequest EmptyTip() => new() { Sucursal = "PRINCIPAL", Tipo = "general", Activo = true };

    protected override async Task OnInitializedAsync()
    {
        await Load();
        await LoadTips();
    }

    private async Task Load() => _items = (await TrdSvc.ListSeriesAsync()).ToList();
    private async Task LoadTips() => _tips = (await TrdSvc.ListTipologiasAsync()).ToList();

    private async Task AddTip()
    {
        _error = _ok = null;
        _nt.SerieId = Guid.TryParse(_ntSerie, out var g) ? g : null;
        try
        {
            var saved = await TrdSvc.SaveTipologiaAsync(_nt, await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            _ok = $"Tipologia '{saved.Codigo} - {saved.Nombre}' guardada.";
            _nt = EmptyTip();
            _ntSerie = "";
            await LoadTips();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task DeleteTip(Guid id)
    {
        _error = _ok = null;
        await TrdSvc.DeleteTipologiaAsync(id, await Actor());
        await LoadTips();
    }

    private async Task Add()
    {
        _error = _ok = null;
        try
        {
            var saved = await TrdSvc.SaveSerieAsync(_n, await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            _ok = $"Serie '{saved.Codigo} - {saved.Nombre}' guardada.";
            _n = Empty();
            await Load();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Delete(Guid id)
    {
        _error = _ok = null;
        await TrdSvc.DeleteSerieAsync(id, await Actor());
        await Load();
    }

    private async Task SeedDemo()
    {
        _error = _ok = null;
        var n = await TrdSvc.SeedDemoAsync();
        _ok = n > 0 ? $"Se sembraron {n} series de ejemplo." : "Ya existian series; no se sembro nada.";
        await Load();
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }
}
