@page "/cfg-aseguradoras"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Globalization
@using System.Security.Claims
@using ClosedXML.Excel
@using DokTrino.Application.Tenancy
@inject IAseguradoraService Svc
@inject IJSRuntime JS

<PageTitle>Entidades Aseguradoras - DokTrino</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion del Sistema</div>
        <h1 class="ase-title">Entidades Aseguradoras</h1>
    </div>
    <button class="btn btn-primary btn-sm" @onclick="NewAseguradora">+ Nueva aseguradora</button>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-grid">
    <!-- Lista de aseguradoras -->
    <div class="ase-card ase-list">
        <div class="ase-card-h">Aseguradoras (@_aseguradoras.Count)</div>
        @foreach (var a in _aseguradoras)
        {
            <button class="ase-li @(a.Id == _aseId ? "sel" : "")" @onclick="() => SelectAseguradora(a.Id)">
                <div class="ase-li-name">@a.Nombre</div>
                <div class="ase-li-sub">@a.Codigo &middot; @a.Tipo &middot; @a.Contratos contrato(s)</div>
            </button>
        }
        @if (_aseguradoras.Count == 0) { <div class="ase-empty">Sin aseguradoras. Crea una nueva.</div> }
    </div>

    <!-- Detalle -->
    <div class="ase-detail">
        @if (!_showForm)
        {
            <div class="ase-card"><div class="ase-empty">Selecciona o crea una aseguradora.</div></div>
        }
        else
        {
            <div class="ase-card">
                <div class="ase-card-h">Datos de la entidad</div>
                <div class="ase-form">
                    <div class="ase-f"><label>Codigo *</label><input class="form-control form-control-sm" @bind="_aCodigo" /></div>
                    <div class="ase-f"><label>Tipo</label>
                        <select class="form-select form-select-sm" @bind="_aTipo">
                            <option>EPS</option><option>IPS</option><option>ARL</option><option>EAPB</option><option>PARTICULAR</option><option>OTRO</option>
                        </select>
                    </div>
                    <div class="ase-f ase-f-wide"><label>Nombre *</label><input class="form-control form-control-sm" @bind="_aNombre" /></div>
                    <div class="ase-f"><label>Codigo Movilidad</label><input class="form-control form-control-sm" @bind="_aMov" /></div>
                    <div class="ase-f"><label>NIT</label><input class="form-control form-control-sm" @bind="_aNit" /></div>
                    <div class="ase-f"><label>Regimen</label>
                        <select class="form-select form-select-sm" @bind="_aRegimen">
                            <option value="">--</option><option>CONTRIBUTIVO</option><option>SUBSIDIADO</option><option>PARTICULAR</option><option>ESPECIAL</option>
                        </select>
                    </div>
                    <div class="ase-f"><label>CodInt</label><input class="form-control form-control-sm" @bind="_aCodInt" /></div>
                    <div class="ase-f ase-f-full"><label>Descripcion</label><textarea class="form-control form-control-sm" rows="2" @bind="_aDesc"></textarea></div>
                </div>
                <div class="ase-actions">
                    <button class="btn btn-primary btn-sm" @onclick="SaveAseguradora" disabled="@_busy">Guardar entidad</button>
                    @if (_aseId is not null)
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick="DeleteAseguradora">Eliminar</button>
                    }
                </div>
            </div>

            @if (_aseId is not null)
            {
                <!-- Contratos -->
                <div class="ase-card">
                    <div class="ase-card-h">Contratos <button class="btn btn-outline-primary btn-sm ms-2" @onclick="AddContrato">+ Contrato</button></div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle ase-table">
                            <thead><tr><th>Codigo</th><th>Fecha inicial</th><th>Fecha final</th><th>Estado</th><th>Prorroga</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var c in _contratos)
                                {
                                    <tr class="@(c.Id == _contratoId ? "sel" : "")">
                                        <td><input class="form-control form-control-sm mono" @bind="c.CodigoContrato" /></td>
                                        <td><input type="date" class="form-control form-control-sm" @bind="c.FechaInicial" /></td>
                                        <td><input type="date" class="form-control form-control-sm" @bind="c.FechaFinal" /></td>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="c.Estado">
                                                <option>ACTIVO</option><option>INACTIVO</option><option>SUSPENDIDO</option><option>VENCIDO</option>
                                            </select>
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm" @bind="c.Prorroga">
                                                <option value="false">NO</option><option value="true">SI</option>
                                            </select>
                                        </td>
                                        <td class="ase-row-actions">
                                            <button class="btn btn-primary btn-sm" title="Guardar" @onclick="() => SaveContrato(c)">&#10003;</button>
                                            @if (c.Id is not null)
                                            {
                                                <button class="btn @(c.Id == _contratoId ? "btn-primary" : "btn-outline-secondary") btn-sm" title="Ver servicios" @onclick="() => SelectContrato(c.Id!.Value)">Servicios</button>
                                                <button class="btn btn-outline-danger btn-sm" title="Eliminar" @onclick="() => DeleteContrato(c)">&times;</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (_contratos.Count == 0) { <div class="ase-empty">Sin contratos. Agrega uno.</div> }
                    </div>
                </div>

                <!-- Servicios -->
                @if (_contratoId is not null)
                {
                    <div class="ase-card">
                        <div class="ase-card-h">
                            Servicios del contrato
                            <span class="ase-tools">
                                <input class="form-control form-control-sm ase-filter" placeholder="Filtrar servicios..." value="@_filtro" @oninput="OnFiltroInput" />
                                <button class="btn btn-outline-primary btn-sm" @onclick="AddServicio">+ Servicio</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="DescargarPlantilla" disabled="@_busy" title="Descarga un Excel con las columnas esperadas y un ejemplo.">&#11015; Plantilla</button>
                                <label class="btn btn-primary btn-sm mb-0">
                                    Importar Excel
                                    <InputFile OnChange="OnImportExcel" accept=".xlsx" style="display:none" />
                                </label>
                                <button class="btn btn-outline-danger btn-sm" @onclick="BorrarTodosLosServicios" disabled="@(_busy || _contratoId is null)" title="Borra TODOS los servicios de este contrato. Util cuando hiciste un import incorrecto.">&#128465; Borrar todos</button>
                            </span>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle ase-table ase-serv">
                                <thead><tr>
                                    <th>Historia</th><th>Cod. Servicio</th><th>Cod. Interno</th><th>Descripcion</th><th>Tarifa</th>
                                    <th>Modulo</th><th>Especialidad</th><th>Modalidad</th><th>Sede</th><th></th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var s in FilteredServicios())
                                    {
                                        <tr>
                                            <td><input class="form-control form-control-sm mono" @bind="s.Historia" /></td>
                                            <td><input class="form-control form-control-sm mono" @bind="s.CodigoServicio" /></td>
                                            <td><input class="form-control form-control-sm mono" @bind="s.CodigoInterno" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Descripcion" /></td>
                                            <td><input class="form-control form-control-sm" type="number" step="0.01" @bind="s.Tarifa" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Modulo" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Especialidad" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Modalidad" /></td>
                                            <td><input class="form-control form-control-sm" @bind="s.Sede" /></td>
                                            <td class="ase-row-actions">
                                                <button class="btn btn-primary btn-sm" title="Guardar" @onclick="() => SaveServicio(s)">&#10003;</button>
                                                @if (s.Id is not null)
                                                {
                                                    <button class="btn btn-outline-danger btn-sm" title="Eliminar" @onclick="() => DeleteServicio(s)">&times;</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (_servicios.Count == 0) { <div class="ase-empty">Sin servicios. Importa el Excel o agrega manualmente.</div> }
                        </div>
                    </div>
                }
            }
        }
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<AseguradoraDto> _aseguradoras = new();
    private bool _showForm;
    private Guid? _aseId;
    private string _aCodigo = "", _aTipo = "EPS", _aNombre = "";
    private string? _aMov, _aNit, _aRegimen, _aCodInt, _aDesc;

    private List<ContratoEdit> _contratos = new();
    private Guid? _contratoId;

    private List<ServicioEdit> _servicios = new();
    private string _filtro = "";

    private bool _busy;
    private string? _error, _ok;

    protected override async Task OnInitializedAsync() => await LoadAseguradoras();

    private async Task LoadAseguradoras() => _aseguradoras = (await Svc.ListAseguradorasAsync()).ToList();

    private void NewAseguradora()
    {
        _aseId = null; _aCodigo = ""; _aTipo = "EPS"; _aNombre = "";
        _aMov = _aNit = _aRegimen = _aCodInt = _aDesc = null;
        _contratos = new(); _contratoId = null; _servicios = new();
        _showForm = true; _error = _ok = null;
    }

    private async Task SelectAseguradora(Guid id)
    {
        var d = await Svc.GetAseguradoraAsync(id);
        if (d is null) { return; }
        _aseId = d.Id; _aCodigo = d.Codigo; _aTipo = d.Tipo; _aNombre = d.Nombre;
        _aMov = d.CodigoMovilidad; _aNit = d.Nit; _aRegimen = d.Regimen; _aCodInt = d.CodInt; _aDesc = d.Descripcion;
        _showForm = true; _error = _ok = null;
        _contratoId = null; _servicios = new();
        await LoadContratos();
    }

    private async Task SaveAseguradora()
    {
        _error = _ok = null; _busy = true;
        try
        {
            var req = new SaveAseguradoraRequest(_aseId, _aCodigo, _aTipo, _aNombre, _aMov, _aNit, _aRegimen, _aCodInt, _aDesc);
            var saved = await Svc.SaveAseguradoraAsync(req, await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            _aseId = saved.Id;
            await LoadAseguradoras();
            await LoadContratos();
            _ok = $"Aseguradora \"{saved.Nombre}\" guardada.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task DeleteAseguradora()
    {
        if (_aseId is not Guid id) { return; }
        await Svc.DeleteAseguradoraAsync(id, await Actor());
        _showForm = false; _aseId = null;
        await LoadAseguradoras();
        _ok = "Aseguradora eliminada.";
    }

    // ── Contratos ──
    private async Task LoadContratos()
    {
        if (_aseId is not Guid id) { _contratos = new(); return; }
        _contratos = (await Svc.ListContratosAsync(id)).Select(ContratoEdit.From).ToList();
    }

    private void AddContrato()
    {
        if (_aseId is null) { return; }
        _contratos.Add(new ContratoEdit { Estado = "ACTIVO" });
    }

    private async Task SaveContrato(ContratoEdit c)
    {
        _error = _ok = null;
        try
        {
            var req = new SaveContratoRequest(c.Id, _aseId!.Value, c.CodigoContrato, c.FechaInicial, c.FechaFinal, c.Estado, c.Prorroga);
            var saved = await Svc.SaveContratoAsync(req, await Actor());
            if (saved is null) { _error = "No se pudo guardar el contrato."; return; }
            c.Id = saved.Id;
            await LoadAseguradoras();
            _ok = "Contrato guardado.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task DeleteContrato(ContratoEdit c)
    {
        if (c.Id is Guid id) { await Svc.DeleteContratoAsync(id, await Actor()); if (_contratoId == id) { _contratoId = null; _servicios = new(); } }
        await LoadContratos();
        await LoadAseguradoras();
    }

    private async Task SelectContrato(Guid id) { _contratoId = id; _filtro = ""; await LoadServicios(); }

    // ── Servicios ──
    private async Task LoadServicios()
    {
        if (_contratoId is not Guid id) { _servicios = new(); return; }
        // Se cargan todos una sola vez; el filtro se aplica en memoria para no consultar la BD por cada tecla.
        _servicios = (await Svc.ListServiciosAsync(id, null)).Select(ServicioEdit.From).ToList();
    }

    private void OnFiltroInput(ChangeEventArgs e) => _filtro = e.Value?.ToString() ?? "";

    private IEnumerable<ServicioEdit> FilteredServicios()
    {
        if (string.IsNullOrWhiteSpace(_filtro)) { return _servicios; }
        var f = _filtro.Trim().ToLowerInvariant();
        return _servicios.Where(s =>
            (s.Descripcion ?? "").ToLowerInvariant().Contains(f) ||
            (s.CodigoServicio ?? "").ToLowerInvariant().Contains(f) ||
            (s.CodigoInterno ?? "").ToLowerInvariant().Contains(f) ||
            (s.Historia ?? "").ToLowerInvariant().Contains(f) ||
            (s.Modulo ?? "").ToLowerInvariant().Contains(f) ||
            (s.Especialidad ?? "").ToLowerInvariant().Contains(f) ||
            (s.Modalidad ?? "").ToLowerInvariant().Contains(f) ||
            (s.Sede ?? "").ToLowerInvariant().Contains(f));
    }

    private void AddServicio()
    {
        if (_contratoId is null) { return; }
        _servicios.Insert(0, new ServicioEdit());
    }

    private async Task SaveServicio(ServicioEdit s)
    {
        _error = _ok = null;
        try
        {
            var req = new SaveServicioRequest(s.Id, _contratoId!.Value, s.Sede, s.Historia, s.CodigoServicio, s.CodigoInterno,
                s.Descripcion, s.Tarifa, s.Modulo, s.Especialidad, s.Modalidad, s.Clasificacion, s.Observaciones);
            var saved = await Svc.SaveServicioAsync(req, await Actor());
            if (saved is null) { _error = "No se pudo guardar el servicio."; return; }
            s.Id = saved.Id;
            _ok = "Servicio guardado.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task DeleteServicio(ServicioEdit s)
    {
        if (s.Id is Guid id) { await Svc.DeleteServicioAsync(id, await Actor()); }
        await LoadServicios();
    }

    private async Task OnImportExcel(InputFileChangeEventArgs e)
    {
        _error = _ok = null;
        if (_contratoId is not Guid id) { _error = "Selecciona un contrato antes de importar."; return; }
        _busy = true;
        try
        {
            var rows = new List<ServicioImportRow>();
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(10L * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;
            using var wb = new XLWorkbook(ms);
            var ws = wb.Worksheet(1);
            var map = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
            foreach (var cell in ws.Row(1).CellsUsed())
            {
                map[cell.GetString().Trim()] = cell.Address.ColumnNumber;
            }
            string? Col(IXLRow r, string name) => map.TryGetValue(name, out var ci) ? r.Cell(ci).GetString().Trim() : null;
            decimal? Num(IXLRow r, string name)
            {
                var v = Col(r, name);
                return decimal.TryParse(v, NumberStyles.Any, CultureInfo.InvariantCulture, out var d) ? d : (decimal?)null;
            }
            var last = ws.LastRowUsed()?.RowNumber() ?? 1;
            for (var i = 2; i <= last; i++)
            {
                var r = ws.Row(i);
                rows.Add(new ServicioImportRow(
                    Col(r, "CONTRATO"), Col(r, "SEDE"), Col(r, "HISTORIA"), Col(r, "CODIGO_SERVICIO"),
                    Col(r, "CODIGO_INTERNO"), Col(r, "DESCRIPCION"), Num(r, "TARIFA"), Col(r, "MODULO"),
                    Col(r, "ESPECIALIDAD"), Col(r, "MODALIDAD"), Col(r, "CLASIFICACION"), Col(r, "OBSERVACIONES")));
            }
            var n = await Svc.ImportServiciosAsync(id, rows, await Actor());
            await LoadServicios();
            _ok = $"{n} servicio(s) importado(s) desde Excel.";
        }
        catch (Exception ex) { _error = "No se pudo importar el Excel: " + ex.Message; }
        finally { _busy = false; }
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task DescargarPlantilla()
    {
        _error = _ok = null;
        _busy = true;
        try
        {
            // Columnas EN EL MISMO ORDEN que espera OnImportExcel para que el
            // usuario llene la plantilla y reimporte sin renombrar nada.
            var columnas = new (string Cabecera, string Significado, string Ejemplo)[]
            {
                ("CONTRATO",        "Codigo del contrato (informativo, no se importa).", "NAC-006-25-PGP"),
                ("SEDE",            "Sede o sucursal del servicio. Opcional.",            "IBAGUE"),
                ("HISTORIA",        "Codigo del formato de historia clinica (HC-FO-XX). Conecta este servicio con la HC que se abre al atenderlo.", "HC-FO-08"),
                ("CODIGO_SERVICIO", "Codigo CUPS o interno del servicio.",                "890201"),
                ("CODIGO_INTERNO",  "Codigo interno de la aseguradora. Opcional.",        "S001"),
                ("DESCRIPCION",     "Descripcion del servicio que aparecera en el listado.", "HC-FO-08 FORMATO HC GENERAL VERSION 02"),
                ("TARIFA",          "Valor unitario en pesos (solo numero, sin separadores).", "65000"),
                ("MODULO",          "Modulo operativo: CONSULTAS / TERAPIAS / ENFERMERIA / EQUIPOS.", "CONSULTAS"),
                ("ESPECIALIDAD",    "Especialidad medica si aplica. Opcional.",           "GENERAL"),
                ("MODALIDAD",       "Modalidad de atencion (ambulatoria, domiciliaria, etc.). Opcional.", "DOMICILIARIA"),
                ("CLASIFICACION",   "Clasificacion interna. Opcional.",                   ""),
                ("OBSERVACIONES",   "Notas libres. Opcional.",                            "")
            };

            using var wb = new XLWorkbook();
            var ws = wb.Worksheets.Add("Servicios");
            for (var i = 0; i < columnas.Length; i++)
            {
                ws.Cell(1, i + 1).Value = columnas[i].Cabecera;
                ws.Cell(2, i + 1).Value = columnas[i].Ejemplo;
            }
            ws.Row(1).Style.Font.Bold = true;
            ws.Row(1).Style.Fill.BackgroundColor = XLColor.LightGray;
            ws.Columns().AdjustToContents();
            ws.SheetView.FreezeRows(1);

            var wsHelp = wb.Worksheets.Add("Instrucciones");
            wsHelp.Cell(1, 1).Value = "Columna";
            wsHelp.Cell(1, 2).Value = "Significado";
            wsHelp.Row(1).Style.Font.Bold = true;
            wsHelp.Row(1).Style.Fill.BackgroundColor = XLColor.LightGray;
            for (var i = 0; i < columnas.Length; i++)
            {
                wsHelp.Cell(i + 2, 1).Value = columnas[i].Cabecera;
                wsHelp.Cell(i + 2, 2).Value = columnas[i].Significado;
            }
            wsHelp.Column(1).Width = 22;
            wsHelp.Column(2).Width = 90;
            wsHelp.Cell(columnas.Length + 4, 1).Value = "NOTA:";
            wsHelp.Cell(columnas.Length + 4, 1).Style.Font.Bold = true;
            wsHelp.Cell(columnas.Length + 4, 2).Value =
                "Borra la fila de ejemplo de la hoja 'Servicios' antes de importar. "
                + "El campo HISTORIA es el unico que conecta el servicio con un formato de HC; "
                + "si lo dejas vacio el servicio se podra asignar pero no abrira HC automaticamente.";

            using var ms = new MemoryStream();
            wb.SaveAs(ms);
            var b64 = Convert.ToBase64String(ms.ToArray());
            var dataUrl = "data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64," + b64;
            await JS.InvokeVoidAsync("eval",
                $"(()=>{{const a=document.createElement('a');a.href='{dataUrl}';a.download='plantilla-servicios-contrato.xlsx';document.body.appendChild(a);a.click();a.remove();}})()");
            _ok = "Plantilla descargada.";
        }
        catch (Exception ex) { _error = "No se pudo generar la plantilla: " + ex.Message; }
        finally { _busy = false; }
    }

    private async Task BorrarTodosLosServicios()
    {
        _error = _ok = null;
        if (_contratoId is not Guid id) { _error = "Selecciona un contrato primero."; return; }
        var ok = await JS.InvokeAsync<bool>("confirm",
            "Vas a borrar TODOS los servicios de este contrato. Esta accion no se puede deshacer y dejara sin servicio_contrato_id las asignaciones que los referenciaban. Continuar?");
        if (!ok) { return; }
        _busy = true;
        try
        {
            var n = await Svc.EliminarServiciosDeContratoAsync(id, await Actor());
            await LoadServicios();
            _ok = $"{n} servicio(s) borrado(s).";
        }
        catch (Exception ex) { _error = "No se pudieron borrar: " + ex.Message; }
        finally { _busy = false; }
    }

    private sealed class ContratoEdit
    {
        public Guid? Id { get; set; }
        public string CodigoContrato { get; set; } = "";
        public DateOnly? FechaInicial { get; set; }
        public DateOnly? FechaFinal { get; set; }
        public string Estado { get; set; } = "ACTIVO";
        public bool Prorroga { get; set; }
        public static ContratoEdit From(ContratoDto d) => new()
        { Id = d.Id, CodigoContrato = d.CodigoContrato, FechaInicial = d.FechaInicial, FechaFinal = d.FechaFinal, Estado = d.Estado, Prorroga = d.Prorroga };
    }

    private sealed class ServicioEdit
    {
        public Guid? Id { get; set; }
        public string? Sede { get; set; }
        public string? Historia { get; set; }
        public string? CodigoServicio { get; set; }
        public string? CodigoInterno { get; set; }
        public string? Descripcion { get; set; }
        public decimal? Tarifa { get; set; }
        public string? Modulo { get; set; }
        public string? Especialidad { get; set; }
        public string? Modalidad { get; set; }
        public string? Clasificacion { get; set; }
        public string? Observaciones { get; set; }
        public static ServicioEdit From(ServicioDto d) => new()
        {
            Id = d.Id, Sede = d.Sede, Historia = d.Historia, CodigoServicio = d.CodigoServicio, CodigoInterno = d.CodigoInterno,
            Descripcion = d.Descripcion, Tarifa = d.Tarifa, Modulo = d.Modulo, Especialidad = d.Especialidad,
            Modalidad = d.Modalidad, Clasificacion = d.Clasificacion, Observaciones = d.Observaciones
        };
    }
}
