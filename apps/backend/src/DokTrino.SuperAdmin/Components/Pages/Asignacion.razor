@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    // Paciente seleccionado.
    private string _docBusqueda = "";
    private PacienteAsignacionDto? _paciente;
    private string _contratoIdSel = "";
    // Todos los contratos activos del sistema (no solo los del paciente).
    private List<ContratoMiniDto> _todosContratos = new();
    private ContratoMiniDto? _contratoSel => _todosContratos.FirstOrDefault(c => c.ContratoId.ToString() == _contratoIdSel);

    // Catalogo servicios del contrato actual (todos los modulos, se filtran por modulo y filtro libre).
    private List<ServicioCatalogoDto> _servicios = new();
    // Modulos disponibles para el contrato actual (EQUIPOS, INSUMOS, TERAPIAS, ...). Derivados de _servicios.
    private List<string> _modulos = new();
    private string _moduloSel = "";
    private string _filtroSvc = "";
    // Lista visible en el grid: filtrada por modulo elegido y luego por texto libre (descripcion o codigo).
    private List<ServicioCatalogoDto> _serviciosVisibles
    {
        get
        {
            if (_servicios.Count == 0 || string.IsNullOrEmpty(_moduloSel)) { return new(); }
            var f = _filtroSvc?.Trim().ToLower() ?? "";
            return _servicios
                .Where(s => s.Modulo == _moduloSel)
                .Where(s => f.Length == 0
                    || (s.Descripcion ?? "").ToLower().Contains(f)
                    || (s.Codigo ?? "").ToLower().Contains(f)
                    || (s.CodigoInterno ?? "").ToLower().Contains(f))
                .ToList();
        }
    }
    private ServicioCatalogoDto? _servicioSel;

    // Historico.
    private List<AsignacionMiniDto> _ultimas = new();
    // Id de la tarjeta del historico con su menu (⋮) abierto. Null = ninguno.
    private Guid? _menuHistAbierto;

    // Carrito.
    private List<CartItem> _carrito = new();
    private string? _autorizacion;
    private DateOnly? _fechaInicio = DateOnly.FromDateTime(DateTime.Now);
    private DateOnly? _fechaFinal;
    private string _anio = DateTime.Now.Year.ToString();
    private int _mesVig = DateTime.Now.Month;
    private int _mesFin;
    private string? _obs;
    private int _cantidad = 1;

    private bool _busy;
    private string? _error, _ok;

    // Modal BUSCAR PACIENTES.
    private bool _modal;
    private List<ContratoMiniDto> _modalContratos = new();
    private HashSet<Guid> _modalContratoSel = new();
    private string _modalDoc = "";
    private string _modalNombre = "";
    private string _modalTel = "";
    private string _modalCorreo = "";
    private List<PacienteFiltroResultadoDto> _modalGrid = new();
    private bool _modalBusy;

    protected override async Task OnInitializedAsync()
    {
        // Carga la lista global de contratos activos (la dropdown CONTRATOS muestra TODOS, no solo los del paciente).
        _todosContratos = (await Svc.ListContratosDisponiblesAsync()).ToList();
    }

    private async Task BuscarPorDocumento()
    {
        _error = _ok = null;
        if (string.IsNullOrWhiteSpace(_docBusqueda)) { return; }
        var lista = await Svc.BuscarPacientesAsync(_docBusqueda.Trim(), null);
        if (lista.Count == 0) { _error = "Paciente no encontrado."; _paciente = null; return; }
        await PickPaciente(lista[0]);
    }

    private async Task OnDocKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { await BuscarPorDocumento(); }
    }

    private async Task PickPaciente(PacienteAsignacionDto p)
    {
        _paciente = p;
        _docBusqueda = p.NumeroDocumento;
        _servicios = new(); _modulos = new(); _moduloSel = ""; _servicioSel = null;
        // Auto-seleccionar Contrato1 (primer elemento de Contratos, gracias al
        // orden Contrato1Id -> 2 -> 3 que arma el backend). Si el paciente no
        // tiene contratos configurados en admision, el select queda vacio.
        if (p.Contratos.Count > 0)
        {
            _contratoIdSel = p.Contratos[0].ContratoId.ToString();
            await CargarServiciosDelContrato();
        }
        else
        {
            _contratoIdSel = "";
        }
        _ultimas = (await Svc.UltimasAsignacionesAsync(p.Id, 10)).ToList();
        _modal = false;
    }

    private async Task OnContratoChanged(ChangeEventArgs e)
    {
        _contratoIdSel = e.Value?.ToString() ?? "";
        await CargarServiciosDelContrato();
    }

    // Carga los servicios y modulos del contrato seleccionado (_contratoIdSel).
    // Se llama desde OnContratoChanged y desde CopiarProgramacion (que setea el
    // _contratoIdSel directamente sin disparar el @onchange).
    private async Task CargarServiciosDelContrato()
    {
        _servicios = new(); _modulos = new(); _moduloSel = ""; _servicioSel = null;
        if (Guid.TryParse(_contratoIdSel, out var cid))
        {
            // Trae TODOS los servicios del contrato; el filtrado por modulo se hace luego con los radios.
            _servicios = (await Svc.ServiciosPorContratoAsync(cid, null)).ToList();
            _modulos = _servicios
                .Where(s => !string.IsNullOrWhiteSpace(s.Modulo))
                .Select(s => s.Modulo!)
                .Distinct()
                .OrderBy(m => m)
                .ToList();
        }
    }

    private void OnModuloChanged(string m)
    {
        _moduloSel = m;
        _servicioSel = null;
        _ok = null; _error = null;
    }

    // Equivalente al gvServicios.RowCommand "Select" del legacy: marca el servicio elegido y muestra mensaje.
    private void PreseleccionarServicio(ServicioCatalogoDto s)
    {
        _servicioSel = s;
        _error = null;
        _ok = $"Servicio '{s.Descripcion}' preseleccionado. Ingrese cantidad y presione Agregar.";
    }

    // Equivalente a Linkbutton2_Click → PrepararServicio() del legacy. Valida todos los campos antes de agregar al carrito.
    private void Agregar()
    {
        _error = null; _ok = null;
        // Mismo orden de validaciones que ctrAsignaciones.PrepararServicio() (empty_field por campo).
        if (_paciente is null) { _error = "Debe indicar una identificacion de paciente."; return; }
        if (string.IsNullOrWhiteSpace(_paciente.NombreCompleto)) { _error = "Debe indicar un nombre de paciente."; return; }
        if (_cantidad < 1) { _error = "Debe indicar cantidad de servicios."; return; }
        if (string.IsNullOrWhiteSpace(_contratoIdSel)) { _error = "Debe seleccionar un contrato."; return; }
        if (string.IsNullOrWhiteSpace(_moduloSel)) { _error = "Debe seleccionar un tipo de servicio (modulo)."; return; }
        if (string.IsNullOrWhiteSpace(_autorizacion)) { _error = "Debe indicar un Numero de Orden / Autorizacion."; return; }
        if (_fechaInicio is not DateOnly fi) { _error = "Debe indicar una Fecha de Inicio."; return; }
        if (_fechaFinal is not DateOnly ff) { _error = "Debe indicar una Fecha Final."; return; }
        if (_mesVig < 1 || _mesVig > 12) { _error = "Debe indicar un Mes de Vigencia."; return; }
        if (_mesFin < 1 || _mesFin > 12) { _error = "Debe indicar un Mes Final."; return; }
        if (!short.TryParse(_anio, out var anio) || anio < 2000 || anio > 2100) { _error = "Debe seleccionar un anio del servicio."; return; }
        if (_servicioSel is null) { _error = "Debe seleccionar un servicio de la grilla."; return; }
        if (string.IsNullOrWhiteSpace(_paciente.Sede)) { _error = "El paciente no tiene una sede asignada, consulta el paciente."; return; }

        _carrito.Add(new CartItem
        {
            Servicio = _servicioSel,
            TipoServicio = _servicioSel.Modulo ?? "(sin modulo)",
            Modulo = _servicioSel.Modulo,
            Cantidad = _cantidad,
            Autorizacion = _autorizacion?.Trim(),
            FechaInicio = fi,
            FechaFinal = ff,
            Anio = anio,
            MesVigencia = (short)_mesVig,
            MesFinal = (short)_mesFin,
            Observaciones = _obs?.Trim()
        });
        // Limpieza posterior al estilo legacy: deja listo para preseleccionar/agregar otro.
        _servicioSel = null;
        _cantidad = 1;
        _ok = "Servicio agregado al lote.";
    }

    private void EliminarSeleccionados()
    {
        _carrito = _carrito.Where(c => !c.Seleccionado).ToList();
    }
    private void LimpiarCarrito() => _carrito = new();

    // ---- Menu ⋮ de cada tarjeta del historico (col 2: "Ultimo servicios agregados") ----

    private void ToggleHistMenu(Guid id)
    {
        _menuHistAbierto = _menuHistAbierto == id ? null : id;
    }

    // "Copiar programacion": replica la asignacion anterior en el form de col 3 dejando
    // todo listo para Agregar. Carga (1) los datos de programacion (fechas, periodo,
    // autorizacion, cantidad, observaciones), (2) el contrato matching por codigo,
    // (3) el modulo y (4) el ServicioCatalogoDto matching por id, para que el boton
    // Agregar quede habilitado de inmediato.
    private async Task CopiarProgramacion(AsignacionMiniDto u)
    {
        _menuHistAbierto = null;
        _error = null;

        // 1) Datos de programacion (siempre se aplican).
        _autorizacion = u.CodigoAutorizacion;
        _fechaInicio = u.FechaInicio;
        _fechaFinal = u.FechaFinal;
        _cantidad = u.Cantidad;
        _obs = u.Observaciones;
        if (u.AnioServicio is short anio) { _anio = anio.ToString(); }
        if (u.MesVigencia is short mv) { _mesVig = mv; }
        if (u.MesFinal is short mf) { _mesFin = mf; } else { _mesFin = 0; }

        // 2) Localizar el contrato original por codigo. Si no lo encontramos (puede que
        //    el contrato haya sido archivado / la lista no lo incluya) el operador puede
        //    escoger uno manual y el resto del form sigue editable.
        var contrato = _todosContratos.FirstOrDefault(c =>
            string.Equals(c.CodigoContrato, u.ContratoCodigo, StringComparison.OrdinalIgnoreCase));
        if (contrato is null)
        {
            _ok = $"Programacion copiada de '{u.NombreServicio}'. El contrato original ({u.ContratoCodigo}) ya no esta disponible — selecciona uno manualmente.";
            return;
        }

        if (_contratoIdSel != contrato.ContratoId.ToString())
        {
            _contratoIdSel = contrato.ContratoId.ToString();
            await CargarServiciosDelContrato();
        }

        // 3) Modulo (TipoServicio del legacy mapea al campo Modulo del ServicioContrato).
        var moduloTarget = !string.IsNullOrWhiteSpace(u.Modulo) ? u.Modulo! : u.TipoServicio;
        if (_modulos.Contains(moduloTarget))
        {
            _moduloSel = moduloTarget;
        }

        // 4) Pre-seleccionar el ServicioCatalogoDto por id. El ServicioId persistido en
        //    Asignacion es el Guid del ServicioContrato serializado a string.
        if (Guid.TryParse(u.ServicioId, out var sid))
        {
            var match = _servicios.FirstOrDefault(s => s.Id == sid);
            if (match != null)
            {
                _servicioSel = match;
                _ok = $"Programacion copiada de '{u.NombreServicio}'. Revisa los datos y presiona Agregar.";
                return;
            }
        }

        _ok = $"Programacion copiada de '{u.NombreServicio}'. Selecciona un servicio de la grilla y presiona Agregar.";
    }

    // "Eliminar" desde la tarjeta del historico. El servicio decide si se puede
    // (lanza InvalidOperationException si el estado no lo permite).
    private async Task EliminarUltimaAsync(AsignacionMiniDto u)
    {
        _menuHistAbierto = null;
        var ok = await JS.InvokeAsync<bool>("confirm", $"Eliminar la asignacion '{u.NombreServicio}'? Esta accion no se puede deshacer.");
        if (!ok) { return; }
        try
        {
            await Svc.EliminarAsignacionAsync(u.Id, await Actor());
            _ultimas.RemoveAll(x => x.Id == u.Id);
            _ok = "Asignacion eliminada.";
            _error = null;
        }
        catch (InvalidOperationException ex) { _error = ex.Message; _ok = null; }
        catch (Exception ex) { _error = "Error tecnico: " + ex.Message; _ok = null; }
    }

    private async Task Guardar()
    {
        _error = _ok = null; _busy = true;
        try
        {
            if (_paciente is null) { _error = "Selecciona un paciente."; return; }
            if (_contratoSel is null) { _error = "Selecciona un contrato."; return; }
            if (_carrito.Count == 0) { _error = "Agrega al menos un servicio."; return; }

            var items = _carrito.Select(c => new AsignacionItemRequest(
                c.Servicio.Id.ToString(),
                c.Servicio.Descripcion,
                c.TipoServicio,
                c.Modulo,
                c.Cantidad,
                c.Autorizacion,
                c.Anio,
                c.MesVigencia,
                c.MesFinal,
                c.FechaInicio,
                c.FechaFinal,
                c.Observaciones,
                // Copiamos el campo HISTORIA del servicio del contrato a la asignacion
                // para que el profesional NO tenga que elegir formato en /atencion -
                // el servicio ya dice que formato de HC corresponde.
                c.Servicio.Historia)).ToList();

            var req = new CrearLoteRequest(_paciente.Id, _contratoSel.CodigoContrato, _paciente.Sede ?? "-", items);
            var r = await Svc.CrearLoteAsync(req, await Actor());
            _ok = $"Lote guardado: {r.CantidadServicios} servicio(s) asignados.";
            _carrito = new();
            _ultimas = (await Svc.UltimasAsignacionesAsync(_paciente.Id, 10)).ToList();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        catch (Exception ex) { _error = "Error tecnico: " + ex.Message; }
        finally { _busy = false; }
    }

    private void Reset()
    {
        _docBusqueda = ""; _paciente = null; _contratoIdSel = "";
        _servicios = new(); _modulos = new(); _moduloSel = ""; _servicioSel = null;
        _ultimas = new(); _carrito = new();
        _autorizacion = null; _obs = null; _fechaFinal = null;
        _cantidad = 1; _filtroSvc = "";
        _error = _ok = null;
    }

    private async Task OpenBuscadorModal()
    {
        _modal = true;
        _modalDoc = _docBusqueda; _modalNombre = ""; _modalTel = ""; _modalCorreo = "";
        _modalContratoSel = new();
        _modalGrid = new();
        _modalContratos = (await Svc.ListContratosDisponiblesAsync()).ToList();
    }
    private void CloseBuscadorModal() => _modal = false;
    private async Task OnModalKey(KeyboardEventArgs e) { if (e.Key == "Enter") { await BuscarEnModal(); } }
    private void ToggleContratoModal(Guid contratoId, ChangeEventArgs e)
    {
        var on = e.Value is bool b && b;
        if (on) { _modalContratoSel.Add(contratoId); } else { _modalContratoSel.Remove(contratoId); }
    }
    private void LimpiarFiltrosModal()
    {
        _modalDoc = _modalNombre = _modalTel = _modalCorreo = "";
        _modalContratoSel = new();
        _modalGrid = new();
    }
    private async Task BuscarEnModal()
    {
        _modalBusy = true;
        try
        {
            var f = new BusquedaPacienteFiltro(
                _modalContratoSel.Count > 0 ? _modalContratoSel.ToList() : null,
                string.IsNullOrWhiteSpace(_modalDoc) ? null : _modalDoc.Trim(),
                string.IsNullOrWhiteSpace(_modalNombre) ? null : _modalNombre.Trim(),
                string.IsNullOrWhiteSpace(_modalTel) ? null : _modalTel.Trim(),
                string.IsNullOrWhiteSpace(_modalCorreo) ? null : _modalCorreo.Trim());
            _modalGrid = (await Svc.BuscarPacientesAvanzadoAsync(f)).ToList();
        }
        finally { _modalBusy = false; }
    }
    private async Task PickPacienteFromGrid(PacienteFiltroResultadoDto r)
    {
        var p = await Svc.GetPacienteAsync(r.Id);
        if (p is not null) { await PickPaciente(p); }
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string MesNombre(int m) => m switch
    {
        1 => "Enero", 2 => "Febrero", 3 => "Marzo", 4 => "Abril", 5 => "Mayo", 6 => "Junio",
        7 => "Julio", 8 => "Agosto", 9 => "Septiembre", 10 => "Octubre", 11 => "Noviembre", 12 => "Diciembre",
        _ => "-"
    };

    private sealed class CartItem
    {
        public ServicioCatalogoDto Servicio { get; set; } = default!;
        public string TipoServicio { get; set; } = "";
        public string? Modulo { get; set; }
        public int Cantidad { get; set; }
        public string? Autorizacion { get; set; }
        public DateOnly FechaInicio { get; set; }
        public DateOnly? FechaFinal { get; set; }
        public short? Anio { get; set; }
        public short MesVigencia { get; set; }
        public short? MesFinal { get; set; }
        public string? Observaciones { get; set; }
        public string NombreServicio => Servicio.Descripcion;
        public bool Seleccionado { get; set; }
    }
}
