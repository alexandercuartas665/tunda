@page "/asignacion"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@inject IAsignacionService Svc
@inject IPacienteService PacSvc
@inject IJSRuntime JS

<PageTitle>Asignacion de Servicios - DokTrino</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Operacion Clinica</div>
        <h1 class="ase-title">Asignacion de Servicios</h1>
    </div>
    <button class="btn btn-warning btn-sm" @onclick="Reset">Nuevo</button>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@* _ok se renderiza dentro de la columna 3, antes de "Datos del servicio a agregar",
   para dar feedback contextual al lado de la accion. *@

<div class="asg-grid">

    @* ============ COLUMNA 1: Paciente + servicios disponibles ============ *@
    <div class="asg-col">
        <div class="ase-card">
            <div class="ase-card-h">1. Agregar Servicios</div>

            <div class="ase-form">
                @* La fila de busqueda ocupa toda la columna 1 para dar aire al input + lupa + reset.
                   Numero Historia y Tipo doc quedan en una fila aparte (2 cols cada uno). *@
                <div class="ase-f ase-f-full">
                    <label>Numero Documento</label>
                    <div class="asg-input-row">
                        <input class="form-control form-control-sm mono" placeholder="Busqueda por identificacion"
                               value="@_docBusqueda" @oninput="e => _docBusqueda = e.Value?.ToString() ?? string.Empty" @onkeyup="OnDocKey" />
                        <button class="btn btn-outline-secondary btn-sm" title="Busqueda avanzada" @onclick="OpenBuscadorModal">&#128270;</button>
                        <button class="btn btn-primary btn-sm" title="Buscar" @onclick="BuscarPorDocumento">&#128269;</button>
                    </div>
                </div>
                <div class="ase-f ase-f-wide"><label>Numero Historia</label><input class="form-control form-control-sm mono asg-ro" readonly value="@_paciente?.NumeroDocumento" /></div>
                <div class="ase-f ase-f-wide"><label>Tipo doc</label><input class="form-control form-control-sm mono asg-ro" readonly value="@_paciente?.TipoDocumento" /></div>
                <div class="ase-f ase-f-full"><label>Nombre paciente</label><input class="form-control form-control-sm asg-ro" readonly value="@_paciente?.NombreCompleto" /></div>
                <div class="ase-f ase-f-wide"><label>Sede</label><input class="form-control form-control-sm asg-ro" readonly value="@_paciente?.Sede" /></div>
                <div class="ase-f ase-f-wide"><label>Municipio</label><input class="form-control form-control-sm asg-ro" readonly value="@_paciente?.Ciudad" /></div>
                <div class="ase-f ase-f-wide">
                    <label>Contratos</label>
                    <select class="form-select form-select-sm" value="@_contratoIdSel" @onchange="OnContratoChanged" disabled="@(_paciente == null)">
                        @if (_paciente is null)
                        {
                            <option value="">Carga un paciente primero</option>
                        }
                        else if (_paciente.Contratos.Count == 0)
                        {
                            <option value="">Paciente sin contratos configurados</option>
                        }
                        else
                        {
                            <option value="">Selecciona un contrato</option>
                            @for (var i = 0; i < _paciente.Contratos.Count; i++)
                            {
                                var c = _paciente.Contratos[i];
                                <option value="@c.ContratoId">@(i + 1). @c.CodigoContrato - @c.AseguradoraNombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="ase-f ase-f-wide">
                    <div class="asg-modulos">
                        @if (_modulos.Count == 0)
                        {
                            <span class="asg-muted">Selecciona un contrato para ver los modulos disponibles.</span>
                        }
                        else
                        {
                            @foreach (var m in _modulos)
                            {
                                <label class="asg-mod-radio">
                                    <input type="radio" name="modSvc" checked="@(m == _moduloSel)" @onchange="() => OnModuloChanged(m)" />
                                    <span>@m</span>
                                </label>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="ase-card">
            <div class="ase-card-h">2. Seleccione el Servicio</div>
            <div class="ase-form">
                <div class="ase-f ase-f-full">
                    <label>Busqueda por servicio</label>
                    <input class="form-control form-control-sm" placeholder="Buscar por descripcion o codigo..."
                           value="@_filtroSvc" @oninput="e => _filtroSvc = e.Value?.ToString() ?? string.Empty" />
                </div>
            </div>
            <div class="asg-grid-wrap asg-grid-svc">
                @if (_serviciosVisibles.Count == 0)
                {
                    <div class="ase-empty">
                        @(_contratoIdSel == "" ? "Selecciona un contrato primero." :
                          _moduloSel == "" ? "Selecciona un modulo arriba (EQUIPOS, INSUMOS, ...)." :
                          "Sin servicios para esta combinacion.")
                    </div>
                }
                else
                {
                    <table class="table table-sm asg-tbl">
                        <thead>
                            <tr>
                                <th style="width:90px">Accion</th>
                                <th>CodServicio</th>
                                <th>CodInterno</th>
                                <th>Historia</th>
                                <th>Descripcion</th>
                                <th>Clasificacion</th>
                                <th>Modulo</th>
                                <th>Modalidad</th>
                                <th class="text-end">Tarifa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in _serviciosVisibles)
                            {
                                <tr class="@(_servicioSel?.Id == s.Id ? "asg-row-sel" : "")">
                                    <td><button class="btn btn-primary btn-sm" @onclick="() => PreseleccionarServicio(s)">Seleccionar</button></td>
                                    <td class="mono">@s.Codigo</td>
                                    <td class="mono">@s.CodigoInterno</td>
                                    <td class="mono">@s.Historia</td>
                                    <td>@s.Descripcion</td>
                                    <td>@s.Clasificacion</td>
                                    <td>@s.Modulo</td>
                                    <td>@s.Modalidad</td>
                                    <td class="text-end">@(s.Tarifa is decimal t ? $"$ {t:N0}" : "")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    @* ============ COLUMNA 2: Ultimos servicios agregados (BD del paciente) ============ *@
    <div class="asg-col">
        <div class="ase-card asg-col-full">
            <div class="ase-card-h">Ultimo servicios agregados</div>
            <div class="asg-historico">
                @if (_ultimas.Count == 0) { <div class="ase-empty">@(_paciente == null ? "Selecciona un paciente." : "Sin asignaciones previas.")</div> }
                @foreach (var u in _ultimas)
                {
                    var puedeBorrar = !string.Equals(u.Estado, "Asignado", StringComparison.OrdinalIgnoreCase)
                                    && !string.Equals(u.Estado, "Cerrado", StringComparison.OrdinalIgnoreCase);
                    <div class="asg-hist">
                        <div class="asg-hist-h">
                            <div class="asg-hist-nm">@u.NombreServicio</div>
                            <div class="dropdown asg-hist-menu-wrap">
                                <button class="asg-hist-menu-btn" title="Acciones"
                                        @onclick="() => ToggleHistMenu(u.Id)" @onclick:stopPropagation="true">⋮</button>
                                @if (_menuHistAbierto == u.Id)
                                {
                                    <div class="asg-hist-menu" @onclick:stopPropagation="true">
                                        <button class="asg-hist-menu-item" @onclick="() => CopiarProgramacion(u)">
                                            <span>&#128203;</span> Copiar programacion
                                        </button>
                                        <button class="asg-hist-menu-item asg-hist-menu-danger" disabled="@(!puedeBorrar)"
                                                title="@(puedeBorrar ? "Eliminar asignacion" : "Ya esta tomada por Coordinacion - no se puede eliminar desde aqui")"
                                                @onclick="() => EliminarUltimaAsync(u)">
                                            <span>&#128465;</span> Eliminar
                                        </button>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="asg-hist-sub">
                            <span class="asg-pill">@u.TipoServicio</span>
                            <span>Cant: @u.Cantidad</span>
                            <span>@u.FechaInicio.ToString("dd MMM")</span>
                            <span class="asg-state asg-st-@u.Estado.ToLower()">@u.Estado</span>
                        </div>
                        <div class="asg-hist-sub2">@u.ContratoCodigo · @u.CreadoEn.LocalDateTime.ToString("dd MMM yyyy HH:mm")</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* ============ COLUMNA 3: Carrito "Servicios Agregados" ============ *@
    <div class="asg-col">
        <div class="ase-card">
            <div class="ase-card-h">3. Servicios Agregados (@_carrito.Count)</div>
            @* Botones del carrito en su propia fila, debajo del titulo. Asi no compiten por
               ancho con el titulo y no se desbordan a una segunda linea solo cuando se acomodan. *@
            <div class="asg-carrito-acts">
                <button class="btn btn-primary btn-sm" title="Eliminar items seleccionados" @onclick="EliminarSeleccionados" disabled="@(_carrito.Count == 0)">Eliminar items</button>
                <button class="btn btn-danger btn-sm" title="Limpiar carrito" @onclick="LimpiarCarrito" disabled="@(_carrito.Count == 0)">Limpiar items</button>
            </div>
            <div class="asg-carrito">
                @if (_carrito.Count == 0) { <div class="ase-empty">Sin servicios en el lote.</div> }
                @foreach (var c in _carrito)
                {
                    <div class="asg-cart-row">
                        <input type="checkbox" @bind="c.Seleccionado" />
                        <div class="asg-cart-info">
                            <div class="asg-cart-nm">@c.NombreServicio</div>
                            <div class="asg-cart-meta">Codigo: <code>@(c.Servicio.Codigo ?? "-")</code></div>
                            <div class="asg-cart-meta">Cantidad: <strong>@c.Cantidad</strong></div>
                            @if (!string.IsNullOrWhiteSpace(c.Observaciones))
                            {
                                <div class="asg-cart-meta asg-cart-obs">Obs: @c.Observaciones</div>
                            }
                            <div class="asg-cart-sub">
                                <span class="asg-pill">@c.TipoServicio</span>
                                <span>@c.FechaInicio.ToString("dd MMM")@(c.FechaFinal is DateOnly f ? " - " + f.ToString("dd MMM") : "")</span>
                                @if (!string.IsNullOrWhiteSpace(c.Autorizacion))
                                {
                                    <span>Aut: <code>@c.Autorizacion</code></span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* Mensaje contextual: aparece justo encima del bloque "Datos del servicio".
               Cubre los 3 momentos: preseleccion, agregado al carrito y guardado del lote. *@
            @if (_ok is not null) { <div class="ase-ok asg-svc-ok">@_ok</div> }

            <div class="ase-card-h" style="margin-top:14px;">Datos del servicio a agregar</div>
            @* Los campos del form son editables cuando hay paciente cargado, no requieren
               que se haya preseleccionado un servicio. Asi el operador puede ajustar la
               programacion (sea recien escrita o copiada desde una tarjeta) antes de
               elegir un servicio en la grilla. El boton Agregar si sigue gateado por
               la preseleccion de servicio, porque sin servicio no hay nada que agregar. *@
            <div class="ase-form asg-form-col3">
                <div class="ase-f"><label>Autorizacion</label><input class="form-control form-control-sm" @bind="_autorizacion" disabled="@(_paciente == null)" /></div>
                <div class="ase-f"><label>INICIO</label><input type="date" class="form-control form-control-sm" @bind="_fechaInicio" disabled="@(_paciente == null)" /></div>
                <div class="ase-f"><label>FINAL</label><input type="date" class="form-control form-control-sm" @bind="_fechaFinal" disabled="@(_paciente == null)" /></div>
                <div class="ase-f"><label>Periodo (Año)</label>
                    <select class="form-select form-select-sm" @bind="_anio" disabled="@(_paciente == null)">
                        <option value="">--</option>
                        @for (int y = DateTime.Now.Year - 2; y <= DateTime.Now.Year + 2; y++) { <option value="@y">@y</option> }
                    </select>
                </div>
                <div class="ase-f"><label>Mes Vigencia</label>
                    <select class="form-select form-select-sm" @bind="_mesVig" disabled="@(_paciente == null)">
                        <option value="0">--</option>
                        @for (int m = 1; m <= 12; m++) { <option value="@m">@MesNombre(m)</option> }
                    </select>
                </div>
                <div class="ase-f"><label>Mes final</label>
                    <select class="form-select form-select-sm" @bind="_mesFin" disabled="@(_paciente == null)">
                        <option value="0">--</option>
                        @for (int m = 1; m <= 12; m++) { <option value="@m">@MesNombre(m)</option> }
                    </select>
                </div>
                <div class="ase-f ase-f-wide"><label>Observaciones</label><textarea class="form-control form-control-sm" @bind="_obs" rows="2" disabled="@(_paciente == null)"></textarea></div>
                @* Fila final: Cantidad + Agregar (de la izquierda) y Guardar registro a la
                   derecha, todos en linea. Ocupamos el ancho completo (ase-f-wide) y
                   dejamos que asg-input-row distribuya los 3 controles. *@
                <div class="ase-f ase-f-wide">
                    <label>Cantidad</label>
                    <div class="asg-input-row asg-final-row">
                        <input type="number" min="1" class="form-control form-control-sm asg-cant-inp" @bind="_cantidad" disabled="@(_paciente == null)" />
                        <button class="btn btn-primary btn-sm" @onclick="Agregar" disabled="@(_servicioSel == null)" title="@(_servicioSel == null ? "Selecciona primero un servicio en la grilla" : "Agregar al lote")">Agregar</button>
                        <button class="btn btn-primary btn-sm asg-guardar-btn" @onclick="Guardar" disabled="@(_busy || _carrito.Count == 0 || _paciente == null)">@(_busy ? "Guardando..." : "Guardar registro")</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ============ Modal BUSCAR PACIENTES (filtros + grid) ============ *@
@if (_modal)
{
    <div class="cie-backdrop" @onclick="CloseBuscadorModal"></div>
    <div class="cie-modal cie-modal-lg">
        <div class="cie-modal-h">
            <h3>BUSCAR PACIENTES</h3>
            <button class="cie-modal-close" @onclick="CloseBuscadorModal">&times;</button>
        </div>
        <div class="cie-modal-body">

            <div class="bp-section">
                <div class="bp-section-h"><span class="bp-filtro-ico">&#9776;</span> Filtros</div>
                <div class="bp-filtros">
                    <div class="bp-filtros-title">Filtrar Datos</div>
                    <div class="bp-filtros-grid">
                        <div class="bp-f bp-f-contrato">
                            <label>Contrato:</label>
                            <div class="bp-contratos-list">
                                @if (_modalContratos.Count == 0) { <div class="bp-muted">Sin contratos activos.</div> }
                                @foreach (var c in _modalContratos)
                                {
                                    <label class="bp-contrato-row">
                                        <input type="checkbox" checked="@_modalContratoSel.Contains(c.ContratoId)" @onchange="e => ToggleContratoModal(c.ContratoId, e)" />
                                        <span>@c.CodigoContrato - @c.AseguradoraNombre</span>
                                    </label>
                                }
                            </div>
                        </div>
                        <div class="bp-f">
                            <label>No Documento:</label>
                            <input class="form-control form-control-sm" @bind="_modalDoc" @onkeyup="OnModalKey" />
                        </div>
                        <div class="bp-f">
                            <label>Nombre:</label>
                            <input class="form-control form-control-sm" @bind="_modalNombre" @onkeyup="OnModalKey" />
                        </div>
                        <div class="bp-f">
                            <label>Telefono:</label>
                            <input class="form-control form-control-sm" @bind="_modalTel" @onkeyup="OnModalKey" />
                        </div>
                        <div class="bp-f">
                            <label>Correo:</label>
                            <input class="form-control form-control-sm" @bind="_modalCorreo" @onkeyup="OnModalKey" />
                        </div>
                    </div>
                    <div class="bp-actions">
                        <button class="btn btn-primary btn-sm" @onclick="BuscarEnModal" disabled="@_modalBusy">@(_modalBusy ? "..." : "Aplicar filtro")</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarFiltrosModal">Limpiar Filtro</button>
                    </div>
                </div>
            </div>

            <div class="bp-results">
                <table class="table table-sm bp-grid">
                    <thead>
                        <tr>
                            <th style="width:50px"></th>
                            <th>Documento</th>
                            <th>Nombre Paciente</th>
                            <th>Contrato</th>
                            <th>Telefono</th>
                            <th>Correo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_modalGrid.Count == 0)
                        {
                            <tr><td colspan="6" class="bp-empty">@(_modalBusy ? "Buscando..." : "Aplica un filtro para ver pacientes.")</td></tr>
                        }
                        else
                        {
                            @foreach (var r in _modalGrid)
                            {
                                <tr>
                                    <td><button class="btn btn-primary btn-sm" title="Seleccionar" @onclick="() => PickPacienteFromGrid(r)">&#10003;</button></td>
                                    <td class="mono">@r.Documento</td>
                                    <td>@r.NombreCompleto</td>
                                    <td>@(r.Contrato ?? "-")</td>
                                    <td>@(r.Telefono ?? "-")</td>
                                    <td>@(r.Correo ?? "-")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<style>
    .asg-grid { display: grid; grid-template-columns: 1.55fr 0.85fr 1.15fr; gap: 14px; align-items: stretch; }
    /* min-width:0 impide que las tablas internas (asg-grid-wrap) empujen el ancho del track. */
    .asg-col { display: flex; flex-direction: column; gap: 14px; min-height: 760px; min-width: 0; }
    /* La ultima card de cada columna crece para igualar la altura entre las 3. */
    .asg-col > .ase-card:last-child { flex: 1; display: flex; flex-direction: column; }
    .asg-col-full { flex: 1; display: flex; flex-direction: column; }
    .asg-input-row { display:flex; gap:6px; min-width:0; }
    .asg-input-row > input, .asg-input-row > select { flex:1; min-width:0; }
    /* Busqueda de servicio (card 2): lupa antes del input, separacion contra la tabla. */
    .asg-grid-svc { margin-top:12px; }
    /* Mensaje "Servicio preseleccionado/agregado" mostrado dentro de la columna 3,
       justo encima de "Datos del servicio a agregar". */
    .asg-svc-ok { margin-top:14px; padding:8px 12px; background:#ecfdf5; border:1px solid #a7f3d0;
                  border-left:3px solid #10b981; border-radius:6px; font-size:12.5px; color:#065f46; }
    /* Botones de accion del carrito (col 3): fila propia debajo del titulo. */
    .asg-carrito-acts { display:flex; gap:8px; margin:8px 0 10px; flex-wrap:wrap; }
    /* Fila final del form col 3 (Cantidad + Agregar + Guardar registro en linea).
       El input de cantidad se queda pequeno (no se estira), los botones flexibles. */
    .asg-final-row { align-items:stretch; flex-wrap:wrap; }
    .asg-final-row .asg-cant-inp { flex: 0 0 72px; text-align:center; }
    .asg-final-row .asg-guardar-btn { margin-left:auto; }
    /* Form de la columna 3: en lugar de heredar el grid global de 4 columnas (que es muy
       angosto en col 3 y desborda en ventanas pequenas), usamos solo 2 columnas internas
       para que los inputs y la textarea respiren y no se salgan. */
    .asg-form-col3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .asg-form-col3 .ase-f { min-width:0; }
    .asg-form-col3 textarea { resize:vertical; max-width:100%; box-sizing:border-box; }
    .asg-form-col3 input, .asg-form-col3 select { min-width:0; }
    .asg-ro { background: #f1f5f9; color: #475569; }
    .asg-tipos { display: flex; flex-wrap: wrap; gap: 8px; }
    .asg-radio { display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; border: 1.5px solid #e2e8f0; border-radius: 999px; cursor: pointer; font-size: 12px; font-weight: 600; color: #475569; }
    .asg-radio:has(input:checked) { background: #eff6ff; border-color: #1565c0; color: #1565c0; }
    .asg-radio input { margin: 0; }
    .asg-muted { color: #94a3b8; font-style: italic; font-size: 13px; }
    .asg-modulos { display: flex; flex-wrap: wrap; gap: 16px; padding: 4px 0; }
    .asg-mod-radio { display: inline-flex; align-items: center; gap: 6px; font-size: 13px; font-weight: 600; color: #1565c0; cursor: pointer; }
    .asg-mod-radio input { accent-color: #1565c0; }
    .asg-grid-wrap { border: 1px solid #e2e8f0; border-radius: 8px; max-height: 360px; overflow: auto; background: #fff; }
    .asg-tbl { margin: 0; font-size: 12px; min-width: 100%; }
    .asg-tbl thead th { position: sticky; top: 0; background: #f8fafc; color: #334155; font-size: 11px; font-weight: 600; border-bottom: 1px solid #e2e8f0; white-space: nowrap; }
    .asg-tbl td { vertical-align: middle; font-size: 11.5px; }
    .asg-row-sel { background: #eff6ff; }
    .asg-row-sel td { border-left: 2px solid #1565c0; }
    .asg-tbl td:first-child, .asg-tbl th:first-child { border-left: none; padding-left: 8px; }
    .asg-tar { color: #1565c0; font-weight: 600; }
    .asg-historico, .asg-carrito { max-height: 480px; overflow: auto; }
    .asg-hist, .asg-cart-row { padding: 10px 12px; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 6px; background: #fff; }
    .asg-hist-h { display:flex; justify-content:space-between; align-items:flex-start; gap:8px; }
    .asg-hist-menu-wrap { position:relative; }
    .asg-hist-menu-btn { background:transparent; border:0; font-size:18px; line-height:1; color:#64748b; padding:0 6px; cursor:pointer; border-radius:4px; }
    .asg-hist-menu-btn:hover { background:#f1f5f9; color:#0f172a; }
    .asg-hist-menu { position:absolute; right:0; top:24px; background:#fff; border:1px solid #e2e8f0; border-radius:8px; box-shadow:0 8px 20px rgba(15,23,42,.12); min-width:200px; z-index:100; padding:4px 0; }
    .asg-hist-menu-item { display:flex; align-items:center; gap:8px; width:100%; padding:8px 12px; background:none; border:0; text-align:left; font-size:12.5px; color:#0f172a; cursor:pointer; }
    .asg-hist-menu-item:hover:not(:disabled) { background:#f1f5f9; }
    .asg-hist-menu-item:disabled { color:#cbd5e1; cursor:not-allowed; }
    .asg-hist-menu-danger { color:#dc2626; }
    .asg-hist-menu-danger:hover:not(:disabled) { background:#fee2e2; }
    .asg-cart-row { display: flex; gap: 10px; align-items: flex-start; }
    .asg-cart-info { flex: 1; }
