@page "/archivo-central"
@page "/archivo-digital"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@inject IArchivoDigitalService Arch
@inject IExpedienteService Exp

<PageTitle>Archivo Central - Archimente</PageTitle>

<div class="trx-breadcrumb">Inicio &middot; Archivo Digital &middot; Archivo Central</div>

<div style="display: flex; align-items: flex-start; gap: 16px; margin-bottom: 20px;">
    <div style="flex: 1;">
        <div style="font-size: 26px; font-weight: 800; color: #161c2e; letter-spacing: -.5px;">Archivo Central</div>
        <div style="font-size: 13px; font-weight: 500; color: #8a93a8; margin-top: 3px;">
            Carga documentos, clasificalos contra la TRD activa y organizalos en expedientes.
        </div>
    </div>
</div>

@* --- Pestanas Expedientes / Archivo Central --- *@
<div class="tcl-tabs">
    <button class="tcl-tab @(_vista == "expedientes" ? "on" : "")" @onclick='() => _vista = "expedientes"'>
        &#128193; Expedientes <span class="badge2">@_expedientes.Count</span>
    </button>
    <button class="tcl-tab @(_vista == "central" ? "on" : "")" @onclick='() => _vista = "central"'>
        &#128451; Archivo Central
    </button>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

@if (_vista == "expedientes")
{
    <div class="ase-card">
        <div class="ase-card-h">Nuevo expediente</div>
        <div class="ad-form">
            <div class="ad-f ad-grow"><label>Nombre</label><input class="form-control form-control-sm" @bind="_expNombre" placeholder="Contratacion vigencia 2026" /></div>
            <div class="ad-f"><label>&nbsp;</label><button class="trx-btn" @onclick="CrearExpediente">+ Abrir expediente</button></div>
        </div>
        <small class="text-muted">El codigo EXP-XXXX se emite automaticamente.</small>
    </div>

    @if (_expedientes.Count == 0)
    {
        <div class="trx-list"><div class="trx-empty">Aun no hay expedientes. Abre el primero arriba.</div></div>
    }
    else
    {
        <div class="exp-grid">
            @foreach (var e in _expedientes)
            {
                <div class="exp-card" @onclick="() => AbrirExpediente(e)">
                    <div class="exp-card-top">
                        <div class="exp-ico">&#128193;</div>
                        <div style="flex: 1; min-width: 0;">
                            <div class="exp-name">@e.Nombre</div>
                            <div class="exp-code">@e.Codigo</div>
                        </div>
                    </div>
                    <div class="exp-meta">
                        <span class="exp-chip">@(e.Serie ?? "Sin serie")</span>
                        <span class="exp-docs">@e.Documentos docs</span>
                        <span class="exp-fecha">@e.FechaApertura.ToLocalTime().ToString("dd/MM/yyyy")</span>
                    </div>
                </div>
            }
        </div>
    }
}

<div class="ase-card" style="@(_vista == "central" ? "" : "display:none")">
    <div class="ase-card-h">Cargar documento</div>
    <div class="ad-form">
        <div class="ad-f ad-grow"><label>Archivo</label><InputFile class="form-control form-control-sm" OnChange="OnFile" /></div>
        <div class="ad-f ad-grow"><label>Nombre</label><input class="form-control form-control-sm" @bind="_n.Nombre" placeholder="Oficio 001" /></div>
        <div class="ad-f ad-grow"><label>Tipologia (opcional)</label>
            <select class="form-select form-select-sm" @bind="_nTip">
                <option value="">(sin identificar)</option>
                @foreach (var o in _tipos) { <option value="@o.Id">@o.Etiqueta</option> }
            </select>
        </div>
        <div class="ad-f"><label>&nbsp;</label><button class="btn btn-primary btn-sm" @onclick="Subir" disabled="@(_file is null)">Cargar</button></div>
    </div>
    <small class="text-muted">Si cargas sin tipologia, el documento entra a "Documentos sin Identificar". Todo documento nuevo queda PENDIENTE de aprobacion.</small>
</div>

<div class="ase-card" style="@(_vista == "central" ? "" : "display:none")">
    <div class="ase-tabs">
        <button class="ase-tab @(_bandeja == BandejaArchivo.Clasificados ? "on" : "")" @onclick="() => Cambiar(BandejaArchivo.Clasificados)">Archivos clasificados</button>
        <button class="ase-tab @(_bandeja == BandejaArchivo.SinIdentificar ? "on" : "")" @onclick="() => Cambiar(BandejaArchivo.SinIdentificar)">Documentos sin Identificar</button>
        <button class="ase-tab @(_bandeja == BandejaArchivo.SinAprobar ? "on" : "")" @onclick="() => Cambiar(BandejaArchivo.SinAprobar)">Documentos sin Aprobar</button>
    </div>

    <div class="ad-form">
        <div class="ad-f ad-grow"><label>Filtrar por identificador principal</label><input class="form-control form-control-sm" @bind="_filtroIdent" placeholder="cedula, contrato..." /></div>
        <div class="ad-f ad-grow"><label>Carpeta</label>
            <select class="form-select form-select-sm" @bind="_filtroCarpeta">
                <option value="">(todas)</option>
                @foreach (var c in _carpetas) { <option value="@c.Id">@c.Nombre (@c.Archivos)</option> }
            </select>
        </div>
        <div class="ad-f"><label>&nbsp;</label><button class="btn btn-outline-primary btn-sm" @onclick="Load">Filtrar</button></div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead>
                <tr><th>Documento</th><th>Identificador</th><th>Tipologia</th><th>Expediente</th><th>Tags</th><th>Estado</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var a in _items)
                {
                    <tr>
                        <td>@a.Nombre <span class="ad-muted">(@(a.SizeBytes / 1024) KB)</span></td>
                        <td>@(a.IdentificadorPrincipal ?? "-")</td>
                        <td>@(a.TipologiaNombre ?? "-")</td>
                        <td>
                            <select class="form-select form-select-sm" style="min-width:150px"
                                    @onchange="e => AsignarAExpediente(a.Id, e.Value?.ToString() ?? string.Empty)">
                                <option value="">(sin expediente)</option>
                                @foreach (var ex in _expedientes.Where(x => x.Estado == "ABIERTO"))
                                {
                                    <option value="@ex.Id">@ex.Codigo</option>
                                }
                            </select>
                        </td>
                        <td>@(string.IsNullOrEmpty(a.Tags) ? "-" : a.Tags)</td>
                        <td><span class="ad-badge ad-@a.EstadoAprobacion">@a.EstadoAprobacion</span></td>
                        <td class="ase-row-actions">
                            <button class="btn btn-outline-primary btn-sm" @onclick="() => Seleccionar(a)">Clasificar</button>
                            @if (a.EstadoAprobacion == "PENDIENTE")
                            {
                                <button class="btn btn-outline-success btn-sm" @onclick="() => Aprobar(a.Id)">Aprobar</button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => Rechazar(a.Id)">Rechazar</button>
                            }
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Eliminar(a.Id)">&times;</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_items.Count == 0) { <div class="ase-empty">Sin documentos en esta bandeja.</div> }
    </div>
</div>

@if (_sel is not null && _vista == "central")
{
    <div class="ase-card">
        <div class="ase-card-h">Clasificar: @_sel.Nombre</div>
        <div class="ad-form">
            <div class="ad-f ad-grow"><label>Identificador principal</label><input class="form-control form-control-sm" @bind="_cls.IdentificadorPrincipal" placeholder="1130597152" /></div>
            <div class="ad-f ad-grow"><label>Concepto</label><input class="form-control form-control-sm" @bind="_cls.Concepto" /></div>
            <div class="ad-f ad-grow"><label>Tipologia</label>
                <select class="form-select form-select-sm" @bind="_clsTip">
                    <option value="">(sin tipologia)</option>
                    @foreach (var o in _tipos) { <option value="@o.Id">@o.Etiqueta</option> }
                </select>
            </div>
            <div class="ad-f ad-grow"><label>Carpeta</label>
                <select class="form-select form-select-sm" @bind="_clsCarpeta">
                    <option value="">(sin carpeta)</option>
                    @foreach (var c in _carpetas) { <option value="@c.Id">@c.Nombre</option> }
                </select>
            </div>
            <div class="ad-f"><label>&nbsp;</label><button class="btn btn-primary btn-sm" @onclick="Clasificar">Guardar</button></div>
        </div>
        <div class="ad-form">
            <div class="ad-f ad-grow"><label>Asignar tag</label>
                <select class="form-select form-select-sm" @bind="_selTag">
                    <option value="">(elige tag)</option>
                    @foreach (var t in _tags) { <option value="@t.Id">@t.Nombre@(t.Privado ? " (privado)" : "")</option> }
                </select>
            </div>
            <div class="ad-f"><label>&nbsp;</label><button class="btn btn-outline-primary btn-sm" @onclick="AsignarTag">Asignar</button></div>
        </div>
    </div>
}

<div class="ase-card" style="@(_vista == "central" ? "" : "display:none")">
    <div class="ase-card-h">Carpetas de clasificacion (@_carpetas.Count) y tags (@_tags.Count)</div>
    <div class="ad-cols">
        <div>
            @foreach (var c in _carpetas) { <div class="ad-row">@(c.PadreId is null ? "" : "- ")@c.Nombre <span class="ad-muted">(@c.Archivos)</span></div> }
            <div class="ad-form">
                <select class="form-select form-select-sm" style="max-width:170px" @bind="_nuevaCarpetaPadre">
                    <option value="">(raiz)</option>
                    @foreach (var c in _carpetas) { <option value="@c.Id">@c.Nombre</option> }
                </select>
                <input class="form-control form-control-sm" @bind="_nuevaCarpeta" placeholder="Contratos 2026" />
                <button class="btn btn-primary btn-sm" @onclick="CrearCarpeta">+ Carpeta</button>
            </div>
        </div>
        <div>
            @foreach (var t in _tags) { <div class="ad-row">@t.Nombre <span class="ad-muted">@t.Codigo@(t.Privado ? " - privado" : "")</span></div> }
            <div class="ad-form">
                <input class="form-control form-control-sm mono" style="max-width:110px" @bind="_nuevoTagCod" placeholder="URG" />
                <input class="form-control form-control-sm" @bind="_nuevoTagNom" placeholder="Urgente" />
                <label class="ad-chk"><input type="checkbox" class="form-check-input" @bind="_nuevoTagPriv" /> privado</label>
                <button class="btn btn-primary btn-sm" @onclick="CrearTag">+ Tag</button>
            </div>
        </div>
    </div>
</div>

<style>
    .ad-form { display:flex; flex-wrap:wrap; gap:8px; align-items:flex-end; margin-top:8px; }
    .ad-f { display:flex; flex-direction:column; gap:3px; }
    .ad-f label { font-size:11px; font-weight:700; text-transform:uppercase; color:var(--muted-foreground); }
    .ad-grow { flex:1; min-width:170px; }
    .ad-muted { color:var(--muted-foreground); font-size:11px; }
    .ad-row { padding:3px 0; border-bottom:1px solid var(--border); font-size:13px; }
    .ad-cols { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
    .ad-chk { display:flex; align-items:center; gap:5px; font-size:12px; }
    .ase-tabs { display:flex; gap:6px; border-bottom:1px solid var(--border); margin-bottom:8px; }
    .ase-tab { background:none; border:none; padding:8px 14px; font-size:13px; font-weight:600; color:var(--muted-foreground); cursor:pointer; border-bottom:2px solid transparent; }
    .ase-tab.on { color:var(--primary); border-bottom-color:var(--primary); }
    .ad-badge { font-size:11px; font-weight:700; padding:1px 8px; border-radius:999px; }
    .ad-PENDIENTE { background:#fef9c3; color:#854d0e; }
    .ad-APROBADO { background:#dcfce7; color:#166534; }
    .ad-RECHAZADO { background:#fee2e2; color:#991b1b; }
    .mono { font-family:'JetBrains Mono','Consolas',monospace; }
</style>

@* ===================== Detalle de expediente ===================== *@
@if (_expSel is not null)
{
    <div class="doktrino-drawer-scrim" style="display: block;" @onclick="() => _expSel = null"></div>
    <div class="cfg-modal" style="width: 900px;">
        <div class="cfg-modal-head">
            <div style="flex: 1;">
                <div class="ttl">@_expSel.Nombre</div>
                <div class="sub">@_expSel.Codigo &middot; @_expDocs.Count documentos &middot; @_expSel.Estado</div>
            </div>
            <span class="cls" @onclick="() => _expSel = null">&#10005;</span>
        </div>

        <div class="cfg-modal-body">
            @* Tres vistas del expediente, como el prototipo. *@
            <div class="tcl-tabs" style="margin-bottom: 14px;">
                <button class="tcl-tab @(_expVista == "cards" ? "on" : "")" @onclick='() => _expVista = "cards"'>&#9638; Tarjetas</button>
                <button class="tcl-tab @(_expVista == "list" ? "on" : "")" @onclick='() => _expVista = "list"'>&#9776; Lista</button>
                <button class="tcl-tab @(_expVista == "viewer" ? "on" : "")" @onclick='() => _expVista = "viewer"'>&#128065; Visor</button>
            </div>

            @if (_expDocs.Count == 0)
            {
                <div class="trx-empty">
                    Este expediente aun no tiene documentos. Asignalos desde la pestana Archivo Central.
                </div>
            }
            else if (_expVista == "cards")
            {
                <div class="exp-grid">
                    @foreach (var d in _expDocs)
                    {
                        <div class="exp-card" @onclick="() => VerDocumento(d)">
                            <div class="exp-card-top">
                                <div class="exp-ico">@IconoMime(d.Visor)</div>
                                <div style="flex: 1; min-width: 0;">
                                    <div class="exp-name">@d.Nombre</div>
                                    <div class="exp-code">@(d.SizeBytes / 1024) KB</div>
                                </div>
                            </div>
                            <div class="exp-meta">
                                <span class="exp-chip">@(d.Tipologia ?? "sin tipologia")</span>
                                <span class="ad-badge ad-@d.EstadoAprobacion">@d.EstadoAprobacion</span>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (_expVista == "list")
            {
                <div class="trx-list">
                    <div class="cfg-grid-banco cfg-head">
                        <div>Documento</div><div>Tipologia</div><div>Estado</div><div>Fecha</div>
                    </div>
                    @foreach (var d in _expDocs)
                    {
                        <div class="cfg-grid-banco cfg-row" @onclick="() => VerDocumento(d)">
                            <div style="font-weight: 700; font-size: 12.5px;">@d.Nombre</div>
                            <div class="txt">@(d.Tipologia ?? "-")</div>
                            <div><span class="ad-badge ad-@d.EstadoAprobacion">@d.EstadoAprobacion</span></div>
                            <div class="txt">@d.FechaSubida.ToLocalTime().ToString("dd/MM/yyyy")</div>
                        </div>
                    }
                </div>
            }
            else
            {
                @* Visor embebido: la familia sale del MIME del documento. *@
                <div style="display: flex; gap: 12px; align-items: flex-start;">
                    <div style="width: 230px; flex-shrink: 0; max-height: 460px; overflow: auto;">
                        @foreach (var d in _expDocs)
                        {
                            <div class="exp-visor-item @(_docSel?.Id == d.Id ? "on" : "")" @onclick="() => VerDocumento(d)">
                                <span>@IconoMime(d.Visor)</span>
                                <span style="flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@d.Nombre</span>
                            </div>
                        }
                    </div>
                    <div style="flex: 1; min-width: 0;">
                        @if (_docSel is null)
                        {
                            <div class="trx-empty">Elige un documento de la izquierda.</div>
                        }
                        else if (_docSel.Visor is "pdf")
                        {
                            <iframe src="@($"/archivo-digital/{_docSel.Id}/contenido")" style="width: 100%; height: 460px; border: 1px solid var(--chrome-border); border-radius: 12px;"></iframe>
                        }
                        else if (_docSel.Visor is "imagen")
                        {
                            <img src="@($"/archivo-digital/{_docSel.Id}/contenido")" alt="@_docSel.Nombre"
                                 style="max-width: 100%; max-height: 460px; border-radius: 12px; border: 1px solid var(--chrome-border);" />
                        }
                        else if (_docSel.Visor is "texto" or "hoja")
                        {
                            <iframe src="@($"/archivo-digital/{_docSel.Id}/contenido")" style="width: 100%; height: 460px; border: 1px solid var(--chrome-border); border-radius: 12px; background: #fff;"></iframe>
                        }
                        else
                        {
                            <div class="trx-empty">
                                No hay vista previa para <b>@_docSel.Mime</b>.
                                <a href="@($"/archivo-digital/{_docSel.Id}/contenido")" target="_blank">Descargar el documento</a>.
                            </div>
                        }
                    </div>
                </div>
            }

            @if (_expSel.Estado == "ABIERTO")
            {
                <div style="display: flex; justify-content: flex-end; margin-top: 14px;">
                    <button class="trx-btn danger" @onclick="CerrarExpediente">Cerrar expediente</button>
                </div>
            }
        </div>
    </div>
}

<style>
    .exp-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px; }
    .exp-card { background:#fff; border:1px solid #e9ecf5; border-radius:15px; padding:17px; cursor:pointer; box-shadow:0 1px 3px oklch(0.35 0.06 237 / .05); transition:box-shadow .15s; }
    .exp-card:hover { box-shadow:0 10px 26px oklch(0.35 0.06 237 / .12); }
    .exp-card-top { display:flex; align-items:center; gap:11px; margin-bottom:13px; }
    .exp-ico { width:42px; height:42px; border-radius:12px; background:var(--primary-soft); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
    .exp-name { font-size:14px; font-weight:700; color:#1f2433; line-height:1.3; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .exp-code { font-family:'IBM Plex Mono',monospace; font-size:11px; font-weight:600; color:var(--primary); margin-top:2px; }
    .exp-meta { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
    .exp-chip { font-size:10.5px; font-weight:600; color:#5a6378; background:#f4f6fb; border-radius:7px; padding:4px 9px; }
    .exp-docs { font-size:10.5px; font-weight:600; color:#8a93a8; }
    .exp-fecha { font-size:10.5px; font-weight:500; color:var(--chrome-label); margin-left:auto; }
    .exp-visor-item { display:flex; align-items:center; gap:8px; padding:9px 11px; border-radius:10px; cursor:pointer; font-size:12px; color:#37415c; }
    .exp-visor-item:hover { background:#f6f8fc; }
    .exp-visor-item.on { background:var(--primary-soft); color:var(--primary); font-weight:700; }
</style>

@code {
    private const long MaxBytes = 20L * 1024 * 1024;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private List<ArchivoCentralDto> _items = new();
    private List<CarpetaArchivoDto> _carpetas = new();
    private List<TagDto> _tags = new();
    private List<OpcionDto> _tipos = new();
    private BandejaArchivo _bandeja = BandejaArchivo.Clasificados;
    private ArchivoCentralDto? _sel;
    private ClasificarRequest _cls = new();
    private SubirArchivoRequest _n = new();
    private IBrowserFile? _file;
    private string _nTip = "", _clsTip = "", _clsCarpeta = "", _selTag = "";
    private string _filtroIdent = "", _filtroCarpeta = "";
    private string _nuevaCarpeta = "", _nuevaCarpetaPadre = "";
    private string _nuevoTagCod = "", _nuevoTagNom = "";
    private bool _nuevoTagPriv;

    // --- Expedientes (Fase 2F) ---
    private string _vista = "expedientes";
    private string _expVista = "cards";
    private List<ExpedienteDto> _expedientes = new();
    private List<DocumentoExpedienteDto> _expDocs = new();
    private ExpedienteDto? _expSel;
    private DocumentoExpedienteDto? _docSel;
    private string _expNombre = "";
    private string? _error, _ok;

    protected override async Task OnInitializedAsync()
    {
        await Load();
        await CargarExpedientes();
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private async Task Load()
    {
        Guid? carpeta = Guid.TryParse(_filtroCarpeta, out var cf) ? cf : null;
        _items = (await Arch.ListarAsync(_bandeja, carpeta, _filtroIdent)).ToList();
        _carpetas = (await Arch.ListarCarpetasAsync()).ToList();
        _tags = (await Arch.ListarTagsAsync(await Actor())).ToList();
        _tipos = (await Arch.TipologiasParaSelectAsync()).ToList();
    }

    private async Task Cambiar(BandejaArchivo b) { _bandeja = b; _sel = null; await Load(); }

    private void OnFile(InputFileChangeEventArgs e)
    {
        _file = e.File;
        if (string.IsNullOrWhiteSpace(_n.Nombre)) { _n.Nombre = e.File.Name; }
        _n.Mime = string.IsNullOrWhiteSpace(e.File.ContentType) ? "application/octet-stream" : e.File.ContentType;
    }

    private async Task Subir()
    {
        _error = _ok = null;
        if (_file is null) { _error = "Elige un archivo."; return; }
        _n.TipologiaId = Guid.TryParse(_nTip, out var t) ? t : null;
        try
        {
            await using var stream = _file.OpenReadStream(MaxBytes);
            var saved = await Arch.SubirAsync(_n, stream, await Actor());
            if (saved is null) { _error = "Sin tenant activo."; return; }
            _ok = $"Documento '{saved.Nombre}' cargado ({saved.EstadoAprobacion}).";
            _n = new(); _file = null; _nTip = "";
            await Load();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private void Seleccionar(ArchivoCentralDto a)
    {
        _sel = a;
        _cls = new ClasificarRequest { ArchivoId = a.Id, IdentificadorPrincipal = a.IdentificadorPrincipal, Concepto = a.Concepto };
        _clsTip = a.TipologiaId?.ToString() ?? "";
        _clsCarpeta = a.CarpetaArchivoId?.ToString() ?? "";
    }

    private async Task Clasificar()
    {
        _error = _ok = null;
        _cls.TipologiaId = Guid.TryParse(_clsTip, out var t) ? t : null;
        _cls.CarpetaArchivoId = Guid.TryParse(_clsCarpeta, out var c) ? c : null;
        try { await Arch.ClasificarAsync(_cls, await Actor()); _ok = "Documento clasificado."; _sel = null; await Load(); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task AsignarTag()
    {
        _error = _ok = null;
        if (_sel is null || !Guid.TryParse(_selTag, out var tid)) { _error = "Elige un tag."; return; }
        await Arch.AsignarTagAsync(_sel.Id, tid, await Actor());
        _ok = "Tag asignado."; _selTag = "";
        await Load();
    }

    private async Task Aprobar(Guid id)
    {
        _error = _ok = null;
        await Arch.AprobarAsync(id, null, await Actor());
        _ok = "Documento aprobado.";
        await Load();
    }

    private async Task Rechazar(Guid id)
    {
        _error = _ok = null;
        try { await Arch.RechazarAsync(id, "Rechazado desde la bandeja de aprobacion.", await Actor()); _ok = "Documento rechazado."; await Load(); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Eliminar(Guid id) { _error = _ok = null; await Arch.EliminarAsync(id, await Actor()); await Load(); }

    private async Task CrearCarpeta()
    {
        _error = _ok = null;
        Guid? padre = Guid.TryParse(_nuevaCarpetaPadre, out var p) ? p : null;
        try { await Arch.CrearCarpetaAsync(padre, _nuevaCarpeta, await Actor()); _nuevaCarpeta = ""; _nuevaCarpetaPadre = ""; await Load(); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task CrearTag()
    {
        _error = _ok = null;
        try { await Arch.CrearTagAsync(_nuevoTagCod, _nuevoTagNom, null, _nuevoTagPriv, await Actor()); _nuevoTagCod = ""; _nuevoTagNom = ""; _nuevoTagPriv = false; await Load(); }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    // ---------------- Expedientes ----------------

    private async Task CargarExpedientes() => _expedientes = (await Exp.ListarAsync()).ToList();

    private async Task CrearExpediente()
    {
        _error = _ok = null;
        try
        {
            var e = await Exp.CrearAsync(new CrearExpedienteRequest { Nombre = _expNombre }, await Actor());
            if (e is not null) { _ok = $"Expediente {e.Codigo} abierto."; }
            _expNombre = "";
            await CargarExpedientes();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task AbrirExpediente(ExpedienteDto e)
    {
        _expSel = e;
        _expVista = "cards";
        _docSel = null;
        _expDocs = (await Exp.DocumentosAsync(e.Id)).ToList();
    }

    private void VerDocumento(DocumentoExpedienteDto d)
    {
        _docSel = d;
        _expVista = "viewer";
    }

    private async Task CerrarExpediente()
    {
        if (_expSel is null) { return; }
        await Exp.CerrarAsync(_expSel.Id, await Actor());
        _ok = $"Expediente {_expSel.Codigo} cerrado.";
        _expSel = null;
        await CargarExpedientes();
    }

    private async Task AsignarAExpediente(Guid archivoId, string expedienteId)
    {
        _error = _ok = null;
        try
        {
            Guid? destino = Guid.TryParse(expedienteId, out var g) ? g : null;
            await Exp.AsignarDocumentoAsync(archivoId, destino, await Actor());
            _ok = destino is null ? "Documento sacado del expediente." : "Documento asignado al expediente.";
            await CargarExpedientes();
            await Load();
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    /// <summary>Icono por familia de visor.</summary>
    private static MarkupString IconoMime(string visor) => new(visor switch
    {
        "pdf" => "&#128196;",
        "imagen" => "&#128247;",
        "hoja" => "&#128202;",
        "texto" => "&#128209;",
        _ => "&#128206;"
    });
}
