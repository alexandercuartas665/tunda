    // ===================== Drag & drop desde paleta =====================
    // Cuando el usuario arrastra un boton de la paleta, guardamos el tipo en este campo
    // (HTML5 dataTransfer en Blazor Server no llega serializado al server). Al soltar
    // sobre el lienzo o una seccion, leemos esta variable y creamos el nodo en el
    // contenedor destino.

    private string? _dragType;          // ej. "field:text", "field:number", "structure:section", "text:heading"
    private FormNode? _dragOverNode;    // seccion sobre la que se esta hovering (para resaltarla)

    private void OnDragStart(string dragType)
    {
        _dragType = dragType;
    }

    private void OnDragEnd()
    {
        _dragType = null;
        _dragOverNode = null;
    }

    private void OnDragEnterSection(FormNode section)
    {
        if (_dragType is null) { return; }
        _dragOverNode = section;
    }

    private void OnDragLeaveSection(FormNode section)
    {
        if (ReferenceEquals(_dragOverNode, section)) { _dragOverNode = null; }
    }

    private bool IsDragOver(FormNode? section) => ReferenceEquals(_dragOverNode, section);

    /// <summary>Crea el nodo correspondiente al _dragType en la lista destino indicada.</summary>
    private void HandleDrop(List<FormNode> targetList)
    {
        if (string.IsNullOrEmpty(_dragType)) { return; }
        var dt = _dragType;
        _dragType = null;
        _dragOverNode = null;

        var parts = dt.Split(':', 2);
        var category = parts[0];
        var subtype = parts.Length > 1 ? parts[1] : "";

        switch (category)
        {
            case "structure" when subtype == "section":
                // Una seccion solo cabe en la raiz, no anidamos.
                var sec = new FormNode { Type = "section", Label = "Nueva seccion", Children = new() };
                _schema.Children.Add(sec);
                Select(sec);
                break;
            case "structure" when subtype == "header":
                AddHeader();
                break;
            case "text":
                var t = new FormNode
                {
                    Type = "text",
                    TextStyle = subtype,
                    WidthColumns = 12,
                    Content = subtype switch
                    {
                        "heading" => "Titulo de seccion",
                        "subheading" => "Subtitulo",
                        _ => "Texto del parrafo."
                    }
                };
                targetList.Add(t);
                Select(t);
                break;
            case "field":
                var f = new FormNode
                {
                    Type = "field",
                    FieldType = subtype,
                    Label = subtype == "table" ? "Nueva tabla" : "Nuevo campo",
                    Name = "",
                    WidthColumns = subtype is "textarea" or "table" ? 12 : 6,
                    Catalog = subtype is "select" or "autocomplete" ? "estatico" : null,
                    Columns = subtype == "table"
                        ? new List<FormColumn>
                        {
                            new() { Label = "Codigo", Name = "codigo", FieldType = "text" },
                            new() { Label = "Descripcion", Name = "descripcion", FieldType = "text" }
                        }
                        : null
                };
                targetList.Add(f);
                Select(f);
                break;
        }
    }

    private void OnDropOnCanvas() => HandleDrop(_schema.Children);
    private void OnDropOnSection(FormNode section)
    {
        section.Children ??= new();
        HandleDrop(section.Children);
    }

    private void AddField(string fieldType)
    {
        var f = new FormNode
        {
            Type = "field",
            FieldType = fieldType,
            Label = fieldType == "table" ? "Nueva tabla" : "Nuevo campo",
            Name = "",
            WidthColumns = fieldType is "textarea" or "table" ? 12 : 6,
            Catalog = fieldType is "select" or "autocomplete" ? "estatico" : null,
            Columns = fieldType == "table"
                ? new List<FormColumn>
                {
                    new() { Label = "Codigo", Name = "codigo", FieldType = "text" },
                    new() { Label = "Descripcion", Name = "descripcion", FieldType = "text" }
                }
                : null
        };
        GetTargetList().Add(f);
        Select(f);
    }

