    private void ClearHeaderLogo()
    {
        if (_schema.Header is not null) { _schema.Header.LogoUrl = null; }
    }

    private async Task OnHeaderLogoSelected(InputFileChangeEventArgs e)
    {
        if (_schema.Header is null) { return; }
        var file = e.File;
        const long max = 4L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { _error = "El logo debe pesar menos de 4 MB."; return; }
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(max).CopyToAsync(ms);
            var ext = Path.GetExtension(file.Name);
            var dir = Path.Combine(Env.WebRootPath, "uploads", "forms");
            Directory.CreateDirectory(dir);
            var name = $"hdr-{Guid.NewGuid():N}{ext}";
            await File.WriteAllBytesAsync(Path.Combine(dir, name), ms.ToArray());
            _schema.Header.LogoUrl = $"/uploads/forms/{name}";
        }
        catch { _error = "No se pudo subir el logo."; }
    }

    private async Task OnPickForm(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(raw) || !Guid.TryParse(raw, out var id))
        {
            return;
        }
        var d = await FormsSvc.GetAsync(id);
        if (d is null) { return; }
        _currentId = d.Id;
        _codigo = d.Codigo; _codigoSecundario = d.CodigoSecundario; _nombre = d.Nombre; _tipo = d.Tipo; _version = d.Version; _activo = d.Activo;
        _schema = FormSchema.FromJson(d.SchemaJson);
        _prefillRoutes = PrefillRouteSet.FromJson(d.PrefillRoutesJson);
        _selected = null; _headerSel = false;
        _error = null; _ok = null;
    }

    private void AddSection()
