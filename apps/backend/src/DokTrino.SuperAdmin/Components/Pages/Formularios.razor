@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private static readonly Dictionary<string, string> FieldTypes = new()
    {
        ["text"] = "Texto",
        ["textarea"] = "Area de texto",
        ["number"] = "Numero",
        ["date"] = "Fecha",
        ["email"] = "Email",
        ["select"] = "Lista",
        ["autocomplete"] = "Autocompletar",
        ["calculated"] = "Calculado",
        ["table"] = "Tabla"
    };

    private static readonly Dictionary<string, string> Catalogs = new()
    {
        ["estatico"] = "Opciones fijas",
        ["cie11"] = "CIE-11 (diagnosticos)",
        ["cups"] = "CUPS (procedimientos)",
        ["medicamentos"] = "Medicamentos",
        ["profesionales"] = "Profesionales",
        ["ips"] = "IPS / sedes",
        ["generos"] = "Generos"
    };

    private List<FormDefinitionDto> _forms = new();
    private FormSchema _schema = new();
    private FormNode? _selected;
    private bool _headerSel;
    private Guid? _currentId;
    private string _codigo = "";
    private string? _codigoSecundario = null;
    private string _nombre = "";
    private string? _tipo;
    private string? _version;
    private bool _activo = true;
    private bool _busy;
    private string? _error;
    private string? _ok;

    // ── Modal Historial de versiones ──
    private bool _showVersionModal;
    private bool _versionBusy;
    private string? _versionError;
    private string? _versionOk;
    private List<FormDefinitionSnapshotDto> _versions = new();
    private FormDefinitionSnapshotDetailDto? _versionPreview;

    private async Task OpenVersionHistoryAsync()
    {
        if (_currentId is null) { return; }
        _versionError = null; _versionOk = null;
        _versionPreview = null;
        _showVersionModal = true;
        await RecargarVersionesAsync();
    }

    private void CloseVersionModal()
    {
        _showVersionModal = false;
        _versionPreview = null;
        _versionError = null; _versionOk = null;
    }

    private async Task RecargarVersionesAsync()
    {
        if (_currentId is null) { return; }
        _versionBusy = true;
        try { _versions = (await VersionSvc.ListarAsync(_currentId.Value)).ToList(); }
        catch (Exception ex) { _versionError = "No se pudo cargar el historial: " + ex.Message; }
        finally { _versionBusy = false; }
    }

    private async Task VerSnapshotAsync(Guid snapshotId)
    {
        _versionError = null;
        try { _versionPreview = await VersionSvc.ObtenerAsync(snapshotId); }
        catch (Exception ex) { _versionError = "No se pudo cargar el detalle: " + ex.Message; }
    }

    private async Task RestaurarSnapshotAsync(Guid snapshotId, DateTimeOffset snapshotAt)
    {
        var fecha = snapshotAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss");
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Reemplazar la version actual por el snapshot del {fecha}? Esto generara un nuevo snapshot del estado actual, asi que la restauracion tambien es reversible.");
        if (!confirmed) { return; }

        _versionError = null; _versionOk = null;
        _versionBusy = true;
        try
        {
            var userId = await ActorAsync();
            var ok = await VersionSvc.RestaurarAsync(snapshotId, userId);
            if (!ok) { _versionError = "El snapshot no existe o no pertenece al formulario actual."; return; }

            _versionOk = $"Restauracion aplicada (snapshot del {fecha}).";
            // Recargar el formulario activo para que la UI refleje el estado restaurado.
            // Mismo procedimiento que OnPickForm (FromJson + reset de seleccion).
            if (_currentId is Guid id)
            {
                var d = await FormsSvc.GetAsync(id);
                if (d is not null)
                {
                    _codigo = d.Codigo; _codigoSecundario = d.CodigoSecundario;
                    _nombre = d.Nombre; _tipo = d.Tipo; _version = d.Version; _activo = d.Activo;
                    _schema = FormSchema.FromJson(d.SchemaJson);
                    _prefillRoutes = PrefillRouteSet.FromJson(d.PrefillRoutesJson);
                    _selected = null; _headerSel = false;
                }
            }
            await RecargarVersionesAsync();
        }
        catch (Exception ex) { _versionError = "No se pudo restaurar: " + ex.Message; }
        finally { _versionBusy = false; }
    }

    // Modal rutas de prefill
    private bool _showPrefillModal;
    private PrefillRouteSet _prefillRoutes = new();
    private bool _prefillBusy;
    private string? _prefillError;
    private string? _prefillOk;

    private void OpenPrefillRoutesModal()
    {
        if (_currentId is null) { return; }
        _prefillError = null; _prefillOk = null;
        _showPrefillModal = true;
    }

    private void ClosePrefillRoutesModal() => _showPrefillModal = false;

    private void AddRoute() => _prefillRoutes.Routes.Add(new PrefillRoute { Name = "Paciente", SourceModule = "paciente" });
    private void RemoveRoute(PrefillRoute r) => _prefillRoutes.Routes.Remove(r);
    private void AddMapping(PrefillRoute r) => r.Mappings.Add(new PrefillFieldMap());
    private void RemoveMapping(PrefillRoute r, PrefillFieldMap m) => r.Mappings.Remove(m);

    /// <summary>Cuando el usuario cambia el target, limpia el mapeo de columnas
    /// si el nuevo target ya no es una tabla. Evita arrastrar config inutil
    /// y reduce ruido en el JSON guardado.</summary>
    private void OnTargetChanged(PrefillFieldMap m)
    {
        if (GetTableNode(m.Target) is null) { m.ColumnMappings = null; }
    }

    /// <summary>Devuelve el FormNode de tipo tabla cuyo Name = targetName, o null.</summary>
    private FormNode? GetTableNode(string? targetName)
    {
        if (string.IsNullOrWhiteSpace(targetName)) { return null; }
        FormNode? found = null;
        void Walk(IEnumerable<FormNode> ns)
        {
            foreach (var n in ns)
            {
                if (found is not null) { return; }
                if (n.IsSection && n.Children is not null) { Walk(n.Children); continue; }
                if (n.IsTable && string.Equals(n.Name, targetName, StringComparison.OrdinalIgnoreCase))
                { found = n; return; }
            }
        }
        Walk(_schema.Children);
        return found;
    }

    /// <summary>Lectura del mapeo columna -> source. Vacio cuando no hay aun.</summary>
    private string GetColumnSource(PrefillFieldMap m, string columnId)
    {
        if (m.ColumnMappings is null) { return ""; }
        return m.ColumnMappings.TryGetValue(columnId, out var v) ? v ?? "" : "";
    }

    /// <summary>Escritura. Si el valor esta vacio, quita la entrada (vuelve a heuristica).</summary>
    private void SetColumnSource(PrefillFieldMap m, string columnId, string? value)
    {
        m.ColumnMappings ??= new Dictionary<string, string>();
        if (string.IsNullOrWhiteSpace(value)) { m.ColumnMappings.Remove(columnId); }
        else { m.ColumnMappings[columnId] = value!; }
        if (m.ColumnMappings.Count == 0) { m.ColumnMappings = null; }
    }

    /// <summary>Lista de Name de los campos del schema actual para el dropdown destino.
    /// Incluye tablas: las rutas de historiaMedica (medicamentos.lista_numerada, etc.)
    /// expanden los items de la HC en filas de la tabla destino.</summary>
    private List<string> GetSchemaFieldNames()
    {
        var result = new List<string>();
        void Walk(IEnumerable<FormNode> nodes)
        {
            foreach (var n in nodes)
            {
                if (n.IsSection && n.Children is not null) { Walk(n.Children); continue; }
                if (n.IsText) { continue; }
                if (!string.IsNullOrWhiteSpace(n.Name)) { result.Add(n.Name); }
            }
        }
        Walk(_schema.Children);
        return result.Distinct().OrderBy(s => s).ToList();
    }

    private async Task SavePrefillRoutesAsync()
    {
        if (_currentId is not Guid id) { return; }
        _prefillError = null; _prefillOk = null; _prefillBusy = true;
        try
        {
            // Limpiar entradas vacias.
            foreach (var r in _prefillRoutes.Routes)
            {
                r.Mappings = r.Mappings.Where(m => !string.IsNullOrWhiteSpace(m.Source) && !string.IsNullOrWhiteSpace(m.Target)).ToList();
            }
            _prefillRoutes.Routes = _prefillRoutes.Routes.Where(r => !string.IsNullOrWhiteSpace(r.Name)).ToList();

            var json = _prefillRoutes.ToJson();
            var ok = await FormsSvc.UpdatePrefillRoutesAsync(id, json, await ActorAsync());
            if (!ok) { _prefillError = "No se pudo guardar."; return; }
            _prefillOk = $"Rutas guardadas ({_prefillRoutes.Routes.Count}).";
        }
        catch (Exception ex) { _prefillError = "Error: " + ex.Message; }
        finally { _prefillBusy = false; }
    }

    protected override async Task OnInitializedAsync() => await LoadListAsync();

    private async Task LoadListAsync()
    {
        _forms = (await FormsSvc.ListAsync()).ToList();
    }

    private void NewForm()
    {
        _currentId = null;
        _codigo = ""; _codigoSecundario = null; _nombre = ""; _tipo = null; _version = null; _activo = true;
        _schema = new FormSchema();
        _selected = null; _headerSel = false;
        _error = null; _ok = null;
    }

    /// <summary>
    /// Borra definitivamente el formulario abierto. Pide confirmacion (con el
    /// nombre real para evitar borrados por accidente), llama al servicio, recarga
    /// la lista y limpia el editor.
    /// </summary>
    private async Task AutoEnlazarPacienteAsync()
    {
        var ok = await JS.InvokeAsync<bool>("confirm",
            "Auto-enlazar campos Paciente en TODOS los formularios? Esto agrega mapeos prefill inferidos del nombre/etiqueta de cada campo. Los mapeos que ya existen no se modifican.");
        if (!ok) { return; }
        _busy = true; _error = _ok = null;
        try
        {
            var r = await FormsSvc.AutoEnlazarPacienteEnTodosAsync(await ActorAsync());
            _ok = $"Listo. {r.FormulariosRevisados} revisados, {r.FormulariosActualizados} actualizados (+{r.MapeosAgregados} mapeos), {r.FormulariosSinCambios} sin cambios.";
            // Si el form actual fue uno de los actualizados, recargar sus rutas en memoria.
            if (_currentId is Guid id)
            {
                var detail = await FormsSvc.GetAsync(id);
                if (detail is not null)
                {
                    _prefillRoutes = PrefillRouteSet.FromJson(detail.PrefillRoutesJson);
                }
            }
        }
        catch (Exception ex) { _error = "No se pudo auto-enlazar: " + ex.Message; }
        finally { _busy = false; }
    }

    private async Task DeleteFormAsync()
    {
        if (_currentId is not Guid id) { return; }

        var label = string.IsNullOrWhiteSpace(_nombre) ? _codigo : _nombre;
        var ok = await JS.InvokeAsync<bool>("confirm",
            $"Eliminar definitivamente el formulario \"{label}\"? Esta accion no se puede deshacer.");
        if (!ok) { return; }

        _busy = true; _error = _ok = null;
        try
        {
            var deleted = await FormsSvc.DeleteAsync(id, await ActorAsync());
            if (!deleted)
            {
                _error = "El formulario ya no existe o no se pudo eliminar.";
                return;
            }
            await LoadListAsync();
            NewForm();
            _ok = $"Formulario \"{label}\" eliminado.";
        }
        catch (Exception ex) { _error = "No se pudo eliminar: " + ex.Message; }
        finally { _busy = false; }
    }

