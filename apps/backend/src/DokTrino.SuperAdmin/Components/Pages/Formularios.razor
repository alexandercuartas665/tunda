@page "/formularios"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.IO
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@using DokTrino.SuperAdmin.Components.Forms
@inject IFormDefinitionService FormsSvc
@inject IFormDefinitionVersionService VersionSvc
@inject IJSRuntime JS
@inject IWebHostEnvironment Env

<PageTitle>Motor de Formularios - DokTrino</PageTitle>

<div class="fb-shell">

    <!-- Toolbar -->
    <div class="fb-toolbar">
        <div class="fb-tb-left">
            <span class="fb-eyebrow">Operacion Clinica</span>
            <strong class="fb-tb-title">Motor de Formularios</strong>
        </div>
        @* Lado derecho: select arriba (fila 1) + botones de accion abajo (fila 2).
           Las dos filas mantienen su posicion incluso cuando aparecen los botones
           condicionales (Vista documento, Rutas de prefill, Eliminar), asi
           Nuevo/Guardar no saltan de lugar al abrir un formulario. *@
        <div class="fb-tb-right">
            <select class="fb-input fb-input-sm fb-tb-select" @onchange="OnPickForm">
                <option value="">— Abrir formulario —</option>
                @foreach (var f in _forms)
                {
                    <option value="@f.Id" selected="@(f.Id == _currentId)">@f.Nombre (@f.Codigo)</option>
                }
            </select>
            <div class="fb-tb-actions">
                @if (_currentId is not null)
                {
                    <a class="fb-btn" href="@($"/formulario-doc/{_currentId}")" target="_blank">Vista documento</a>
                    <button class="fb-btn" @onclick="OpenPrefillRoutesModal" title="Configurar rutas de prefill desde otros modulos">&#128279; Rutas de prefill</button>
                    <button class="fb-btn" @onclick="OpenVersionHistoryAsync" title="Ver versiones anteriores y restaurar">&#128344; Historial</button>
                    <button class="fb-btn fb-btn-danger" @onclick="DeleteFormAsync" disabled="@_busy"
                            title="Eliminar definitivamente este formulario">&#128465; Eliminar</button>
                }
                <button class="fb-btn" @onclick="AutoEnlazarPacienteAsync" disabled="@_busy"
                        title="Recorre todos los formularios e infiere mapeos prefill desde el modulo Paciente segun el nombre/etiqueta de cada campo. No sobrescribe mapeos existentes.">&#128279; Auto-enlazar Paciente</button>
                <button class="fb-btn" @onclick="NewForm">Nuevo</button>
                <button class="fb-btn fb-btn-primary" @onclick="SaveAsync" disabled="@_busy">@(_busy ? "Guardando..." : "Guardar")</button>
            </div>
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="fb-alert">@_error</div>
    }
    @if (_ok is not null)
    {
        <div class="fb-ok">@_ok</div>
    }

    <!-- Meta del formulario -->
    <div class="fb-meta">
        <div class="fb-meta-field">
            <label>Nombre</label>
            <input class="fb-input" @bind="_nombre" @bind:event="oninput" placeholder="Historia Clinica General" />
        </div>
        <div class="fb-meta-field" style="max-width:160px;">
            <label>Codigo</label>
            <input class="fb-input fb-mono" @bind="_codigo" @bind:event="oninput" placeholder="HC-GENERAL" />
        </div>
        <div class="fb-meta-field" style="max-width:180px;" title="Identificador alternativo opcional (codigo legacy, prestador, integracion). Texto libre.">
            <label>Codigo formulario</label>
            <input class="fb-input fb-mono" @bind="_codigoSecundario" @bind:event="oninput" placeholder="HC-001" />
        </div>
        <div class="fb-meta-field" style="max-width:160px;">
            <label>Tipo</label>
            <input class="fb-input" @bind="_tipo" @bind:event="oninput" placeholder="historia" />
        </div>
        <div class="fb-meta-field" style="max-width:110px;">
            <label>Version</label>
            <input class="fb-input" @bind="_version" @bind:event="oninput" placeholder="1.0" />
        </div>
        <label class="fb-check">
            <input type="checkbox" @bind="_activo" /> Activo
        </label>
    </div>

    <!-- Body: paleta | lienzo | propiedades -->
    <div class="fb-body">

        <!-- Paleta: cada boton es click + draggable. Drag&drop al lienzo o seccion deja el campo
             en la posicion deseada; click sigue funcionando como atajo (cae en la raiz/seccion seleccionada). -->
        <aside class="fb-palette">
            <div class="fb-palette-group">Estructura</div>
            @if (_schema.Header is null)
            {
                <button class="fb-pal-btn" draggable="true"
                        @ondragstart="@(() => OnDragStart("structure:header"))" @ondragend="OnDragEnd"
                        @onclick="AddHeader">+ Encabezado</button>
            }
            <button class="fb-pal-btn" draggable="true"
                    @ondragstart="@(() => OnDragStart("structure:section"))" @ondragend="OnDragEnd"
                    @onclick="AddSection">+ Seccion</button>
            <button class="fb-pal-btn" draggable="true"
                    @ondragstart="@(() => OnDragStart("text:heading"))" @ondragend="OnDragEnd"
                    @onclick='() => AddText("heading")'>Titulo</button>
            <button class="fb-pal-btn" draggable="true"
                    @ondragstart="@(() => OnDragStart("text:subheading"))" @ondragend="OnDragEnd"
                    @onclick='() => AddText("subheading")'>Subtitulo</button>
            <button class="fb-pal-btn" draggable="true"
                    @ondragstart="@(() => OnDragStart("text:paragraph"))" @ondragend="OnDragEnd"
                    @onclick='() => AddText("paragraph")'>Parrafo</button>

            <div class="fb-palette-group">Campos</div>
            @foreach (var ft in FieldTypes)
            {
                <button class="fb-pal-btn" draggable="true"
                        @ondragstart="@(() => OnDragStart($"field:{ft.Key}"))" @ondragend="OnDragEnd"
                        @onclick="() => AddField(ft.Key)">@ft.Value</button>
            }
            <div class="fb-pal-hint">Arrastra al lienzo o haz click para agregar.</div>
        </aside>

        <!-- Lienzo (acepta drop a la raiz) -->
        <section class="fb-canvas @(_dragType is not null ? "fb-canvas-drag" : "")"
                 @ondragover:preventDefault="true" @ondragover:stopPropagation="false"
                 @ondrop="OnDropOnCanvas">
            @if (_schema.Header is not null)
            {
            <div class="fb-header @(_headerSel ? "sel" : "")" @onclick="SelectHeader">
                <div class="fb-hdr-brand">
                    @if (!string.IsNullOrWhiteSpace(_schema.Header?.LogoUrl))
                    {
                        <img class="fb-hdr-logo" src="@_schema.Header!.LogoUrl" alt="logo" />
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    }
                    <div>
                        <div class="fb-hdr-inst">@(string.IsNullOrWhiteSpace(_schema.Header?.Institucion) ? "Institucion" : _schema.Header!.Institucion)</div>
                        <div class="fb-hdr-tag">@_schema.Header?.Tagline</div>
                    </div>
                </div>
                <div class="fb-hdr-title">@(string.IsNullOrWhiteSpace(_schema.Header?.Titulo) ? (string.IsNullOrWhiteSpace(_nombre) ? "Titulo del documento" : _nombre) : _schema.Header!.Titulo)</div>
                <div class="fb-hdr-meta">
                    @foreach (var c in _schema.Header?.Campos ?? new())
                    {
                        <span>@c.Label: ____</span>
                    }
                </div>
            </div>
            }

            @if (_schema.Children.Count == 0)
            {
                <div class="fb-empty">Agrega una seccion o un campo desde la paleta.</div>
            }
            else
            {
                @foreach (var node in _schema.Children)
                {
                    if (node.IsSection)
                    {
                        <div class="fb-section @(IsSelected(node) ? "sel" : "") @(IsDragOver(node) ? "fb-section-drag" : "")"
                             @onclick="() => Select(node)" @onclick:stopPropagation="true"
                             @ondragenter="@(() => OnDragEnterSection(node))"
                             @ondragleave="@(() => OnDragLeaveSection(node))"
                             @ondragover:preventDefault="true" @ondragover:stopPropagation="true"
                             @ondrop="@(() => OnDropOnSection(node))" @ondrop:stopPropagation="true">
                            <div class="fb-section-head">
                                <span class="fb-section-title">@(string.IsNullOrWhiteSpace(node.Label) ? "Seccion" : node.Label)</span>
                                <span class="fb-node-actions">
                                    <button class="fb-mini" title="Subir" @onclick="() => MoveUp(node, _schema.Children)" @onclick:stopPropagation="true">↑</button>
                                    <button class="fb-mini" title="Bajar" @onclick="() => MoveDown(node, _schema.Children)" @onclick:stopPropagation="true">↓</button>
                                    <button class="fb-mini fb-mini-danger" title="Eliminar" @onclick="() => Delete(node)" @onclick:stopPropagation="true">×</button>
                                </span>
                            </div>
                            <div class="fb-section-body fb-grid">
                                @if (node.Children is null || node.Children.Count == 0)
                                {
                                    <div class="fb-empty-sm">Seccion vacia. Selecciona y agrega campos.</div>
                                }
                                else
                                {
                                    @foreach (var fld in node.Children)
                                    {
                                        @RenderNode(fld, node.Children)
                                    }
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="fb-grid">@RenderNode(node, _schema.Children)</div>
                    }
                }
            }
        </section>

        <!-- Propiedades -->
        <aside class="fb-props">
            @if (_headerSel)
            {
                <div class="fb-props-title">Encabezado del documento</div>
                <div class="fb-prop"><label>Institucion</label><input class="fb-input" @bind="_schema.Header!.Institucion" @bind:event="oninput" placeholder="IPS DOKTRINO RT" /></div>
                <div class="fb-prop"><label>Lema</label><input class="fb-input" @bind="_schema.Header!.Tagline" @bind:event="oninput" placeholder="Atencion Humana, Agil y Oportuna" /></div>
                <div class="fb-prop"><label>Titulo del documento</label><input class="fb-input" @bind="_schema.Header!.Titulo" @bind:event="oninput" placeholder="(usa el nombre del formulario)" /></div>

                <div class="fb-props-subtitle">Logo</div>
                @if (!string.IsNullOrWhiteSpace(_schema.Header!.LogoUrl))
                {
                    <div class="fb-logo-prev"><img src="@_schema.Header!.LogoUrl" alt="logo" /></div>
                    <button class="fb-btn" @onclick="ClearHeaderLogo">Quitar logo</button>
                }
                else
                {
                    <InputFile class="fb-input" accept="image/*" OnChange="OnHeaderLogoSelected" />
                    <div class="fb-hint">Sube el logo de la IPS (PNG/JPG, max 4 MB). Si no, se usa el icono por defecto.</div>
                }

                <div class="fb-props-subtitle">Campos de cabecera</div>
                @foreach (var c in _schema.Header!.Campos)
                {
                    <div class="fb-col-row">
                        <input class="fb-input" placeholder="Etiqueta" @bind="c.Label" @bind:event="oninput" />
                        <button class="fb-mini fb-mini-danger" title="Quitar" @onclick="() => RemoveHeaderField(c)">&times;</button>
                    </div>
                }
                <button class="fb-btn" @onclick="AddHeaderField">+ Campo</button>

                <button class="fb-btn fb-btn-danger" @onclick="RemoveHeader">Eliminar encabezado</button>
            }
            else if (_selected is null)
            {
                <div class="fb-props-empty">Selecciona el encabezado o un elemento del lienzo para editar sus propiedades.</div>
            }
            else if (_selected.IsSection)
            {
                <div class="fb-props-title">Seccion</div>
                <div class="fb-prop"><label>Titulo</label><input class="fb-input" @bind="_selected.Label" @bind:event="oninput" /></div>
                <button class="fb-btn fb-btn-danger" @onclick="() => Delete(_selected)">Eliminar seccion</button>
            }
            else if (_selected.IsText)
            {
                <div class="fb-props-title">Texto</div>
                <div class="fb-prop">
                    <label>Estilo</label>
                    <select class="fb-input" @bind="_selected.TextStyle">
                        <option value="heading">Titulo</option>
                        <option value="subheading">Subtitulo</option>
                        <option value="paragraph">Parrafo</option>
                    </select>
                </div>
                <div class="fb-prop"><label>Contenido</label><textarea class="fb-input" rows="3" @bind="_selected.Content" @bind:event="oninput"></textarea></div>
                <button class="fb-btn fb-btn-danger" @onclick="() => Delete(_selected)">Eliminar texto</button>
            }
            else
            {
                <div class="fb-props-title">@(_selected.IsTable ? "Tabla" : "Campo")</div>
                <div class="fb-prop">
                    <label>Tipo de campo</label>
                    <select class="fb-input" @bind="_selected.FieldType">
                        @foreach (var ft in FieldTypes)
                        {
                            <option value="@ft.Key">@ft.Value</option>
                        }
                    </select>
                </div>
                <div class="fb-prop"><label>@(_selected.IsTable ? "Titulo de la tabla" : "Etiqueta")</label><input class="fb-input" @bind="_selected.Label" @bind:event="oninput" @bind:after="SyncName" /></div>
                <div class="fb-prop"><label>Nombre / id</label><input class="fb-input fb-mono" @bind="_selected.Name" @bind:event="oninput" /></div>
                <div class="fb-prop">
                    <label>Ancho (columnas 1-12)</label>
                    <input class="fb-input" type="number" min="1" max="12" @bind="_selected.WidthColumns" />
                </div>

                @if (_selected.IsTable)
                {
                    <div class="fb-props-subtitle">Columnas de la tabla</div>
                    @if (_selected.Columns is not null)
                    {
                        @foreach (var col in _selected.Columns)
                        {
                            <div class="fb-col-edit">
                                <div class="fb-col-row">
                                    <input class="fb-input" placeholder="Etiqueta" @bind="col.Label" @bind:event="oninput" />
                                    <button class="fb-mini" title="Subir columna" @onclick="() => MoveColumnUp(col)">↑</button>
                                    <button class="fb-mini" title="Bajar columna" @onclick="() => MoveColumnDown(col)">↓</button>
                                    <button class="fb-mini fb-mini-danger" title="Quitar columna" @onclick="() => RemoveColumn(col)">×</button>
                                </div>
                                <div class="fb-col-row">
                                    <input class="fb-input fb-mono" placeholder="nombre" @bind="col.Name" @bind:event="oninput" />
                                    <select class="fb-input" @bind="col.FieldType">
                                        <option value="text">Texto</option>
                                        <option value="number">Numero</option>
                                        <option value="date">Fecha</option>
                                        <option value="select">Lista</option>
                                        <option value="autocomplete">Autocompletar</option>
                                    </select>
                                </div>
                                @if (col.FieldType is "select" or "autocomplete")
                                {
                                    <select class="fb-input" @bind="col.Catalog">
                                        @foreach (var c in Catalogs)
                                        {
                                            <option value="@c.Key">@c.Value</option>
                                        }
                                    </select>
                                    @if (col.Catalog == "estatico" || string.IsNullOrEmpty(col.Catalog))
                                    {
                                        // Opciones libres una por linea + toggle de modo
                                        // estricto/libre. Si Catalog viene null se asume
                                        // estatico (camino mas comun en HC).
                                        <textarea class="fb-input fb-mono" rows="3"
                                                  placeholder="Una opcion por linea"
                                                  value="@ColumnOptionsText(col)"
                                                  @oninput="e => SetColumnOptions(col, e.Value?.ToString())"></textarea>
                                        <label class="fb-check">
                                            <input type="checkbox" @bind="col.AllowCustom" />
                                            Permitir valor libre (fuera de la lista)
                                        </label>
                                    }
                                }
                                <input class="fb-input" placeholder="Valor por defecto"
                                       @bind="col.DefaultValue" @bind:event="oninput" />
                                <input class="fb-input" placeholder="Texto de ayuda (placeholder) — opcional"
                                       @bind="col.Placeholder" @bind:event="oninput" />

                                @{
                                    // Otras columnas con valores discretos que pueden actuar como disparadoras.
                                    // Aceptamos cualquier select/autocomplete (asi sea AllowCustom o con
                                    // opciones por fila) y tambien columnas text con Options a nivel columna
                                    // que el viewer promueve a select. Excluye la columna actual.
                                    var triggerCandidates = (_selected!.Columns ?? new())
                                        .Where(o => !ReferenceEquals(o, col)
                                            && !string.IsNullOrWhiteSpace(o.Name)
                                            && (o.FieldType == "select" || o.FieldType == "autocomplete"
                                                || (o.Options is { Count: > 0 })))
                                        .ToList();
                                }
                                @if (triggerCandidates.Count > 0)
                                {
                                    <div class="fb-col-cond">
                                        <small>Habilitar solo si...</small>
                                        <div class="fb-col-row">
                                            <select class="fb-input" @bind="col.EnabledByColumn">
                                                <option value="">(siempre habilitada)</option>
                                                @foreach (var t in triggerCandidates)
                                                {
                                                    <option value="@t.Name">@t.Label</option>
                                                }
                                            </select>
                                            <input class="fb-input" placeholder="= valor"
                                                   @bind="col.EnabledByValue" @bind:event="oninput"
                                                   disabled="@string.IsNullOrEmpty(col.EnabledByColumn)" />
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                    <button class="fb-btn" @onclick="AddColumn">+ Columna</button>

                    @* ---- Editor de filas pre-semilladas + opciones por celda ---- *@
                    @if (_selected.Columns is { Count: > 0 } cols2)
                    {
                        var seedRows = _selected.SeedRows ?? new List<List<string?>>();
                        <div class="fb-prop fb-seed-opts">
                            <label>Filas pre-semilladas (@seedRows.Count)</label>
                            <div class="fb-hint">
                                Cada celda con valor = texto fijo (no editable por el usuario).
                                Vacia = el usuario la rellena. Las opciones por fila solo aplican a
                                celdas editables; sirven para sobreescribir las opciones generales
                                de la columna en filas concretas (ej. "Atrofia" usa NO SE OBSERVA /
                                LEVE; "Pupilas" usa SI / NO).
                            </div>
                            <div class="fb-seed-actions">
                                <button class="fb-btn" @onclick="() => _seedOptsOpen = !_seedOptsOpen">
                                    @(_seedOptsOpen ? "Ocultar" : "Mostrar") editor de filas
                                </button>
                                <button class="fb-btn fb-btn-primary" @onclick="() => AddSeedRow(_selected)">+ Agregar fila</button>
                            </div>
                            @if (_seedOptsOpen)
                            {
                                @if (seedRows.Count == 0)
                                {
                                    <div class="fb-hint" style="margin-top:8px;">Aun no hay filas. Usa "+ Agregar fila" para empezar.</div>
                                }
                                @for (var r = 0; r < seedRows.Count; r++)
                                {
                                    var rowIdx = r;
                                    var seedRow = seedRows[r];
                                    while (seedRow.Count < cols2.Count) { seedRow.Add(null); }
                                    var firstLabel = !string.IsNullOrWhiteSpace(seedRow[0]) ? seedRow[0]! : $"(fila {r + 1})";
                                    <div class="fb-seed-row">
                                        <div class="fb-seed-row-h">
                                            <span>@firstLabel</span>
                                            <button class="fb-mini fb-mini-danger" title="Eliminar fila"
                                                    @onclick="() => RemoveSeedRow(_selected, rowIdx)">×</button>
                                        </div>
                                        @{ var colIdx2 = 0; }
                                        @foreach (var col in cols2)
                                        {
                                            var c2 = col;
                                            var ci2 = colIdx2;
                                            var seedVal2 = ci2 < seedRow.Count ? seedRow[ci2] : null;
                                            <div class="fb-seed-cell">
                                                <small>@(c2.Label) <code>@(c2.Name)</code></small>
                                                <input class="fb-input fb-mono"
                                                       placeholder="Texto fijo (vacio = editable por usuario)"
                                                       value="@seedVal2"
                                                       @oninput="e => SetSeedCellValue(_selected, rowIdx, ci2, e.Value?.ToString())" />
                                                @if (string.IsNullOrEmpty(seedVal2))
                                                {
                                                    <textarea class="fb-input fb-mono" rows="2"
                                                              placeholder="Opciones por fila (una por linea) — vacio = usa opciones de la columna"
                                                              value="@SeedCellOptionsText(_selected, rowIdx, ci2)"
                                                              @oninput="e => SetSeedCellOptions(_selected, rowIdx, ci2, e.Value?.ToString())"></textarea>
                                                }
                                            </div>
                                            colIdx2++;
                                        }
                                    </div>
                                }
                            }
                        </div>
                    }
                }
                else
                {
                    <div class="fb-prop"><label>Placeholder</label><input class="fb-input" @bind="_selected.Placeholder" @bind:event="oninput" /></div>
                    <label class="fb-check"><input type="checkbox" @bind="_selected.Required" /> Requerido</label>

                    @* Dictado por voz: solo tiene sentido en areas de texto largas.
                       El visor mostrara un boton flotante para iniciar la transcripcion. *@
                    @if (_selected.FieldType == "textarea")
                    {
                        <label class="fb-check"><input type="checkbox" @bind="_selected.EnableVoice" /> &#127908; Permitir dictado por voz (Whisper)</label>
                    }

                    @if (_selected.FieldType is "select" or "autocomplete")
                    {
                        <div class="fb-prop">
                            <label>Origen de la lista</label>
                            <select class="fb-input" @bind="_selected.Catalog">
                                @foreach (var c in Catalogs)
                                {
                                    <option value="@c.Key">@c.Value</option>
                                }
                            </select>
                        </div>
                        @if (_selected.Catalog == "estatico")
                        {
                            <div class="fb-prop">
                                <label>Opciones (una por linea)</label>
                                <textarea class="fb-input" rows="4" value="@OptionsText" @oninput="OnOptionsInput"></textarea>
                            </div>
                            <label class="fb-check">
                                <input type="checkbox" @bind="_selected.AllowCustom" />
                                Permitir valor libre (fuera de la lista)
                            </label>
                            <div class="fb-hint">
                                Sin marcar: el usuario solo puede elegir una opcion (select estricto).
                                Marcado: input con sugerencias — puede elegir o escribir lo que sea.
                            </div>
                        }
                    }
                    else if (_selected.FieldType == "calculated")
                    {
                        <div class="fb-prop">
                            <label>Formula</label>
                            <input class="fb-input fb-mono" @bind="_selected.Formula" @bind:event="oninput" placeholder="edad(fecha_nacimiento)" />
                            <div class="fb-hint">Funciones: edad(fecha), sumar(a,b), restar(a,b), hoy(). Referencia campos por su nombre.</div>
                        </div>
                    }
                    else
                    {
                        <div class="fb-prop"><label>Valor por defecto</label><input class="fb-input" @bind="_selected.DefaultValue" @bind:event="oninput" /></div>
                    }
                }

                <button class="fb-btn fb-btn-danger" @onclick="() => Delete(_selected)">@(_selected.IsTable ? "Eliminar tabla" : "Eliminar campo")</button>
            }
        </aside>
    </div>
</div>

@* ===== Modal: Rutas de prefill ===== *@
@if (_showPrefillModal)
{
    <div class="pr-backdrop" @onclick="ClosePrefillRoutesModal"></div>
    <div class="pr-modal">
        <div class="pr-h">
            <div>
                <h3>Rutas de prefill</h3>
                <small>Formulario: <strong>@_codigo - @_nombre</strong></small>
            </div>
            <button class="pr-close" @onclick="ClosePrefillRoutesModal">&times;</button>
        </div>
        <div class="pr-body">
            @if (_prefillError is not null) { <div class="fb-alert">@_prefillError</div> }
            @if (_prefillOk is not null) { <div class="fb-ok">@_prefillOk</div> }

            <div class="pr-info">
                Define las <strong>rutas</strong> de prefill: cada ruta es un mapeo nombrado entre los campos
                de un modulo origen (Paciente, Profesional...) y los campos de este formulario.
                Cuando se inicia una instancia, los campos destino se llenan automaticamente con el dato del origen.
            </div>

            <div class="pr-routes">
                @if (_prefillRoutes.Routes.Count == 0)
                {
                    <div class="pr-empty">Aun no hay rutas configuradas.</div>
                }
                @foreach (var route in _prefillRoutes.Routes)
                {
                    <div class="pr-route">
                        <div class="pr-route-h">
                            <input class="pr-name" @bind="route.Name" placeholder="Nombre de la ruta (ej. Paciente)" />
                            <select class="pr-source-sel" @bind="route.SourceModule">
                                @foreach (var mod in PrefillSourceCatalog.Campos.Keys)
                                {
                                    <option value="@mod">@PrefillSourceCatalog.NombreLegible(mod)</option>
                                }
                            </select>
                            <button class="fb-btn fb-btn-danger" @onclick="() => RemoveRoute(route)" title="Eliminar ruta">&times;</button>
                        </div>

                        <div class="pr-mappings">
                            <div class="pr-map-h">
                                <span>Campo origen (@route.SourceModule)</span>
                                <span>&rarr;</span>
                                <span>Campo destino (este formulario)</span>
                                <span></span>
                            </div>
                            @{
                                var sourceFields = PrefillSourceCatalog.Campos.TryGetValue(route.SourceModule, out var sf) ? sf : Array.Empty<string>();
                                var targetFields = GetSchemaFieldNames();
                            }
                            @foreach (var m in route.Mappings)
                            {
                                <div class="pr-map-row">
                                    <select class="pr-sel" @bind="m.Source">
                                        <option value="">Selecciona...</option>
                                        @foreach (var s in sourceFields) { <option value="@s">@s</option> }
                                    </select>
                                    <span class="pr-arrow">&rarr;</span>
                                    <select class="pr-sel" @bind="m.Target" @bind:after="() => OnTargetChanged(m)">
                                        <option value="">Selecciona...</option>
                                        @foreach (var t in targetFields) { <option value="@t">@t</option> }
                                    </select>
                                    <button class="pr-mini" @onclick="() => RemoveMapping(route, m)" title="Quitar">&times;</button>
                                </div>
                                var tableNode = GetTableNode(m.Target);
                                if (tableNode is not null && PrefillSourceCatalog.CamposColumna.TryGetValue(m.Source ?? "", out var colSourceFields))
                                {
                                    <div class="pr-col-map">
                                        <div class="pr-col-map-h">
                                            Mapeo columna-a-columna: cada columna de la tabla destino se llena con un campo de la fuente.
                                        </div>
                                        @foreach (var col in tableNode.Columns ?? new())
                                        {
                                            <div class="pr-col-map-row">
                                                <div class="pr-col-map-label">@col.Label <small>(@col.Name)</small></div>
                                                <span class="pr-arrow">&larr;</span>
                                                <select class="pr-sel pr-col-sel"
                                                        value="@GetColumnSource(m, col.Id)"
                                                        @onchange="e => SetColumnSource(m, col.Id, e.Value?.ToString())">
                                                    <option value="">(auto por nombre)</option>
                                                    @foreach (var cs in colSourceFields) { <option value="@cs">@cs</option> }
                                                </select>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            <button class="fb-btn pr-add-map" @onclick="() => AddMapping(route)">+ Agregar mapeo</button>
                        </div>
                    </div>
                }

                <button class="fb-btn fb-btn-primary pr-add-route" @onclick="AddRoute">+ Nueva ruta</button>
            </div>
        </div>
        <div class="pr-f">
            <button class="fb-btn" @onclick="ClosePrefillRoutesModal">Cancelar</button>
            <button class="fb-btn fb-btn-primary" @onclick="SavePrefillRoutesAsync" disabled="@_prefillBusy">
                @(_prefillBusy ? "Guardando..." : "Guardar rutas")
            </button>
        </div>
    </div>
}

@* ===== Modal: Historial de versiones ===== *@
@if (_showVersionModal)
{
    <div class="pr-backdrop" @onclick="CloseVersionModal"></div>
    <div class="pr-modal">
        <div class="pr-h">
            <div>
                <h3>Historial de versiones</h3>
                <small>Formulario: <strong>@_codigo - @_nombre</strong> &middot;
                       @_versions.Count de 20 maximo &middot;
                       <em>cada cambio guarda un snapshot del estado anterior.</em></small>
            </div>
            <button class="pr-close" @onclick="CloseVersionModal">&times;</button>
        </div>
        <div class="pr-body">
            @if (_versionError is not null) { <div class="fb-alert">@_versionError</div> }
            @if (_versionOk is not null) { <div class="fb-ok">@_versionOk</div> }

            @if (_versionBusy)
            {
                <div class="pr-empty">Cargando historial...</div>
            }
            else if (_versions.Count == 0)
            {
                <div class="pr-empty">No hay versiones previas guardadas para este formulario.</div>
            }
            else if (_versionPreview is not null)
            {
                <div class="vh-preview-h">
                    <button class="fb-btn" @onclick="() => _versionPreview = null">&larr; Volver a la lista</button>
                    <strong>Snapshot del @(_versionPreview.SnapshotAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss"))</strong>
                </div>
                <div class="vh-preview-meta">
                    <div><label>Codigo:</label> @_versionPreview.Codigo</div>
                    <div><label>Nombre:</label> @_versionPreview.Nombre</div>
                    <div><label>Version:</label> @(_versionPreview.Version ?? "—")</div>
                    <div><label>Tipo:</label> @(_versionPreview.Tipo ?? "—")</div>
                    <div><label>Activo:</label> @(_versionPreview.Activo ? "Si" : "No")</div>
                </div>
                <details>
                    <summary>schema_json (@_versionPreview.SchemaJson.Length chars)</summary>
                    <pre class="vh-json">@_versionPreview.SchemaJson</pre>
                </details>
                @if (!string.IsNullOrEmpty(_versionPreview.PrefillRoutesJson))
                {
                    <details>
                        <summary>prefill_routes_json</summary>
                        <pre class="vh-json">@_versionPreview.PrefillRoutesJson</pre>
                    </details>
                }
            }
            else
            {
                <table class="vh-table">
                    <thead>
                        <tr>
                            <th>Fecha</th><th>Nombre</th><th>Codigo</th>
                            <th>Version</th><th>Tipo</th><th>Activo</th><th>Motivo</th><th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var v in _versions)
                        {
                            <tr>
                                <td>@v.SnapshotAt.LocalDateTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@v.Nombre</td>
                                <td><code>@v.Codigo</code></td>
                                <td>@(v.Version ?? "—")</td>
                                <td>@(v.Tipo ?? "—")</td>
                                <td>@(v.Activo ? "Si" : "No")</td>
                                <td>@(v.Motivo ?? "auto")</td>
                                <td class="vh-acts">
                                    <button class="fb-btn fb-btn-sm" @onclick="() => VerSnapshotAsync(v.Id)">Ver</button>
                                    <button class="fb-btn fb-btn-sm fb-btn-primary"
                                            disabled="@_versionBusy"
                                            @onclick="() => RestaurarSnapshotAsync(v.Id, v.SnapshotAt)">
                                        Restaurar
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
        <div class="pr-f">
            <button class="fb-btn" @onclick="CloseVersionModal">Cerrar</button>
        </div>
    </div>
}

