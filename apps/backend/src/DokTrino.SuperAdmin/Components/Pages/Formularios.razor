    }

    private void MoveColumnUp(FormColumn col) => MoveColumn(col, delta: -1);
    private void MoveColumnDown(FormColumn col) => MoveColumn(col, delta: +1);

    /// <summary>Reordena una columna de la tabla seleccionada. Mueve la columna en
    /// Columns Y reordena en paralelo cada SeedRows[i] (los valores fijos por
    /// celda) y los keys de SeedRowCellOptions (que indexan opciones por
    /// "rowIdx_colIdx"). Sin esto los overrides apuntarian a la columna
    /// equivocada despues del swap.</summary>
    private void MoveColumn(FormColumn col, int delta)
    {
        if (_selected?.Columns is not { } cols) { return; }
        var i = cols.IndexOf(col);
        if (i < 0) { return; }
        var j = i + delta;
        if (j < 0 || j >= cols.Count) { return; }

        // 1) Swap en Columns.
        (cols[i], cols[j]) = (cols[j], cols[i]);

        // 2) Swap del valor en cada SeedRows[r] (cada fila tiene una List<string?>
        //    paralela a Columns). while-padding cubre filas mas cortas que el array.
        if (_selected.SeedRows is { } rows)
        {
            foreach (var row in rows)
            {
                while (row.Count <= Math.Max(i, j)) { row.Add(null); }
                (row[i], row[j]) = (row[j], row[i]);
            }
        }

        // 3) Reindexar SeedRowCellOptions: los keys "r_i" pasan a "r_j" y viceversa.
        //    Construyo un dict nuevo para no chocar con keys colisionando durante
        //    el rename in-place.
        if (_selected.SeedRowCellOptions is { Count: > 0 } opts)
        {
            var renombrado = new Dictionary<string, List<string>>();
            foreach (var kv in opts)
            {
                var parts = kv.Key.Split('_', 2);
                if (parts.Length != 2 || !int.TryParse(parts[1], out var colIdx))
                {
                    renombrado[kv.Key] = kv.Value;
                    continue;
                }
                var nuevoCol = colIdx == i ? j : (colIdx == j ? i : colIdx);
                renombrado[$"{parts[0]}_{nuevoCol}"] = kv.Value;
            }
            _selected.SeedRowCellOptions = renombrado;
        }
    }

    // Donde cae un campo nuevo: en la seccion seleccionada, o en la seccion del campo
    // seleccionado, o en la raiz.
    private List<FormNode> GetTargetList()
    {
        if (_selected is not null)
        {
            if (_selected.IsSection)
            {
                _selected.Children ??= new();
                return _selected.Children;
            }
            var parent = _schema.Children.FirstOrDefault(n => n.IsSection && n.Children is not null && n.Children.Contains(_selected));
            if (parent?.Children is not null) { return parent.Children; }
        }
        return _schema.Children;
    }

    private void Select(FormNode node) { _selected = node; _headerSel = false; _ok = null; }
    private bool IsSelected(FormNode node) => ReferenceEquals(_selected, node);

    private void Delete(FormNode node)
    {
        if (_schema.Children.Remove(node)) { _selected = null; return; }
        foreach (var s in _schema.Children.Where(n => n.IsSection && n.Children is not null))
        {
            if (s.Children!.Remove(node)) { _selected = null; return; }
        }
    }

    private void MoveUp(FormNode node, List<FormNode> list)
    {
        var i = list.IndexOf(node);
        if (i > 0) { list.RemoveAt(i); list.Insert(i - 1, node); }
    }

    private void MoveDown(FormNode node, List<FormNode> list)
    {
        var i = list.IndexOf(node);
        if (i >= 0 && i < list.Count - 1) { list.RemoveAt(i); list.Insert(i + 1, node); }
    }

    private void SyncName()
    {
        if (_selected is not null && string.IsNullOrWhiteSpace(_selected.Name))
        {
            _selected.Name = Slug(_selected.Label);
        }
    }

    private static string Slug(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "";
        var chars = s.Trim().ToLowerInvariant()
            .Replace("á", "a").Replace("é", "e").Replace("í", "i").Replace("ó", "o").Replace("ú", "u").Replace("ñ", "n")
            .Select(c => char.IsLetterOrDigit(c) ? c : '_').ToArray();
        var slug = new string(chars);
        while (slug.Contains("__")) slug = slug.Replace("__", "_");
        return slug.Trim('_');
    }

    private string OptionsText => _selected?.Options is null ? "" : string.Join("\n", _selected.Options);

    /// <summary>Lectura del textarea de opciones de una columna de tabla.</summary>
    private static string ColumnOptionsText(FormColumn col)
        => col.Options is null ? "" : string.Join("\n", col.Options);

    /// <summary>Escritura del textarea: parsea linea por linea y guarda en col.Options.</summary>
    private static void SetColumnOptions(FormColumn col, string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) { col.Options = null; return; }
        col.Options = text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    /// <summary>Estado de visibilidad del editor de opciones por fila seed.</summary>
    private bool _seedOptsOpen = false;

    /// <summary>Lectura del textarea de opciones por celda seed. Cae a "" si no hay nada.</summary>
    private static string SeedCellOptionsText(FormNode table, int rowIdx, int colIdx)
    {
        if (table.SeedRowCellOptions is null) { return ""; }
        return table.SeedRowCellOptions.TryGetValue($"{rowIdx}_{colIdx}", out var opts)
            ? string.Join("\n", opts) : "";
    }

    /// <summary>Escritura. Si el texto esta vacio, quita la entrada del dict.</summary>
    private static void SetSeedCellOptions(FormNode table, int rowIdx, int colIdx, string? text)
    {
        var key = $"{rowIdx}_{colIdx}";
        if (string.IsNullOrWhiteSpace(text))
        {
            table.SeedRowCellOptions?.Remove(key);
            if (table.SeedRowCellOptions is { Count: 0 }) { table.SeedRowCellOptions = null; }
            return;
        }
        table.SeedRowCellOptions ??= new Dictionary<string, List<string>>();
        table.SeedRowCellOptions[key] = text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    /// <summary>Agrega una fila al final de SeedRows. Para columnas tipo select
    /// estricto se pre-rellena con col.DefaultValue (si esta) o la primera opcion
    /// de la lista, para que el doctor abra la HC con un valor sensato y solo
    /// tenga que cambiar las celdas que no aplican. Las columnas tipo text/date/
    /// number/autocomplete quedan en null (sin valor inicial agresivo).</summary>
    private void AddSeedRow(FormNode table)
    {
        if (!table.IsTable || table.Columns is null || table.Columns.Count == 0) { return; }
        table.SeedRows ??= new List<List<string?>>();
        var nuevaFila = new List<string?>();
        foreach (var c in table.Columns)
        {
            nuevaFila.Add(ValorInicialCelda(c));
        }
        table.SeedRows.Add(nuevaFila);
        _seedOptsOpen = true;
    }

    /// <summary>Default para una celda recien creada en + Agregar fila.
    /// Solo aplica a select estricto (no datalist) para no forzar texto en
    /// campos de entrada libre. Devuelve null si no hay default razonable.</summary>
    private static string? ValorInicialCelda(FormColumn c)
    {
        if (c.FieldType == "select" && !c.AllowCustom)
        {
            if (!string.IsNullOrWhiteSpace(c.DefaultValue)) { return c.DefaultValue; }
            if (c.Options is { Count: > 0 }) { return c.Options[0]; }
        }
        return null;
    }

    /// <summary>Elimina la fila rowIdx de SeedRows y re-numera las llaves de
    /// SeedRowCellOptions para que las filas posteriores conserven sus opciones.
    /// Si la fila tenia overrides, esos overrides se descartan.</summary>
    private void RemoveSeedRow(FormNode table, int rowIdx)
    {
        if (table.SeedRows is null || rowIdx < 0 || rowIdx >= table.SeedRows.Count) { return; }
        table.SeedRows.RemoveAt(rowIdx);
        if (table.SeedRows.Count == 0) { table.SeedRows = null; }

        if (table.SeedRowCellOptions is { Count: > 0 } opts)
        {
            var nuevo = new Dictionary<string, List<string>>();
            foreach (var kv in opts)
            {
                var parts = kv.Key.Split('_', 2);
                if (parts.Length != 2 || !int.TryParse(parts[0], out var r))
                {
                    nuevo[kv.Key] = kv.Value;
                    continue;
                }
                if (r == rowIdx) { continue; }
                var nuevaR = r > rowIdx ? r - 1 : r;
                nuevo[$"{nuevaR}_{parts[1]}"] = kv.Value;
            }
            table.SeedRowCellOptions = nuevo.Count == 0 ? null : nuevo;
        }
    }

    /// <summary>Escribe el valor fijo de una celda seed. Vacio => null (celda
    /// editable por el usuario en el formulario final).</summary>
    private static void SetSeedCellValue(FormNode table, int rowIdx, int colIdx, string? text)
    {
        if (table.SeedRows is null || rowIdx < 0 || rowIdx >= table.SeedRows.Count) { return; }
        var fila = table.SeedRows[rowIdx];
        while (fila.Count <= colIdx) { fila.Add(null); }
        fila[colIdx] = string.IsNullOrEmpty(text) ? null : text;
    }

    private void OnOptionsInput(ChangeEventArgs e)
    {
        if (_selected is null) return;
        var text = e.Value?.ToString() ?? "";
        _selected.Options = text.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();
    }

    private async Task SaveAsync()
    {
        _error = null; _ok = null;
        if (string.IsNullOrWhiteSpace(_codigo) || string.IsNullOrWhiteSpace(_nombre))
        {
            _error = "El nombre y el codigo son obligatorios.";
            return;
        }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var req = new SaveFormDefinitionRequest(_currentId, _codigo, _nombre, _version, _tipo, _schema.ToJson(), _activo, CodigoSecundario: _codigoSecundario);
            var saved = await FormsSvc.SaveAsync(req, actor);
            if (saved is null)
            {
                _error = "No se pudo guardar (sin tenant activo o formulario no encontrado).";
                return;
            }
            _currentId = saved.Id;
            await LoadListAsync();
            _ok = $"Formulario \"{saved.Nombre}\" guardado.";
        }
        catch (InvalidOperationException ex)
        {
            _error = ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) return Guid.Empty;
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private static string WidthBasis(FormNode f)
    {
        var pct = Math.Clamp(f.WidthColumns, 1, 12) / 12.0 * 100.0;
        return $"calc({pct.ToString(System.Globalization.CultureInfo.InvariantCulture)}% - 10px)";
    }

    private RenderFragment RenderNode(FormNode n, List<FormNode> list) =>
        n.IsText ? RenderText(n, list) : (n.IsTable ? RenderTable(n, list) : RenderField(n, list));

    private RenderFragment RenderText(FormNode n, List<FormNode> list) => @<div class="fb-textblock fb-ts-@n.TextStyle @(IsSelected(n) ? "sel" : "")" style="@($"flex-basis:{WidthBasis(n)}")" @onclick="() => Select(n)" @onclick:stopPropagation="true">
        <div class="fb-field-top">
            <span class="fb-tb-content">@(string.IsNullOrWhiteSpace(n.Content) ? "(texto)" : n.Content)</span>
            <span class="fb-node-actions">
                <button class="fb-mini" title="Subir" @onclick="() => MoveUp(n, list)" @onclick:stopPropagation="true">↑</button>
                <button class="fb-mini" title="Bajar" @onclick="() => MoveDown(n, list)" @onclick:stopPropagation="true">↓</button>
                <button class="fb-mini fb-mini-danger" title="Eliminar" @onclick="() => Delete(n)" @onclick:stopPropagation="true">×</button>
            </span>
        </div>
    </div>;

    private RenderFragment RenderTable(FormNode n, List<FormNode> list) => @<div class="fb-field @(IsSelected(n) ? "sel" : "")" style="@($"flex-basis:{WidthBasis(n)}")" @onclick="() => Select(n)" @onclick:stopPropagation="true">
        <div class="fb-field-top">
            <span class="fb-field-label">@(string.IsNullOrWhiteSpace(n.Label) ? "Tabla" : n.Label)</span>
            <span class="fb-node-actions">
                <button class="fb-mini" title="Subir" @onclick="() => MoveUp(n, list)" @onclick:stopPropagation="true">↑</button>
                <button class="fb-mini" title="Bajar" @onclick="() => MoveDown(n, list)" @onclick:stopPropagation="true">↓</button>
                <button class="fb-mini fb-mini-danger" title="Eliminar" @onclick="() => Delete(n)" @onclick:stopPropagation="true">×</button>
            </span>
        </div>
        <table class="fb-prev-table">
            <thead>
                <tr>
                    @if (n.Columns is not null)
                    {
                        @foreach (var c in n.Columns)
                        {
                            <th>@(string.IsNullOrWhiteSpace(c.Label) ? "Columna" : c.Label)</th>
                        }
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    @if (n.Columns is not null)
                    {
                        @foreach (var c in n.Columns)
                        {
                            <td>@FieldTypeLabel(c.FieldType)</td>
                        }
                    }
                </tr>
            </tbody>
        </table>
        <div class="fb-field-meta">Tabla repetible &middot; @(n.Columns?.Count ?? 0) columnas</div>
    </div>;

    private RenderFragment RenderField(FormNode f, List<FormNode> list) => @<div class="fb-field @(IsSelected(f) ? "sel" : "")" style="@($"flex-basis:{WidthBasis(f)}")" @onclick="() => Select(f)" @onclick:stopPropagation="true">
        <div class="fb-field-top">
            <span class="fb-field-label">@(string.IsNullOrWhiteSpace(f.Label) ? "(sin etiqueta)" : f.Label)@(f.Required ? " *" : "")</span>
            <span class="fb-node-actions">
                <button class="fb-mini" title="Subir" @onclick="() => MoveUp(f, list)" @onclick:stopPropagation="true">↑</button>
                <button class="fb-mini" title="Bajar" @onclick="() => MoveDown(f, list)" @onclick:stopPropagation="true">↓</button>
                <button class="fb-mini fb-mini-danger" title="Eliminar" @onclick="() => Delete(f)" @onclick:stopPropagation="true">×</button>
            </span>
        </div>
        <div class="fb-field-preview">
            @if (f.FieldType == "textarea")
            {
                <textarea class="fb-prev" rows="2" placeholder="@f.Placeholder" disabled></textarea>
            }
            else if (f.FieldType is "select" or "autocomplete")
            {
                <select class="fb-prev" disabled>
                    <option>@(f.Catalog == "estatico" ? "Opciones fijas" : Catalogs.GetValueOrDefault(f.Catalog ?? "", "lista"))</option>
                </select>
            }
            else if (f.FieldType == "date")
            {
                <input class="fb-prev" type="date" disabled />
            }
            else if (f.FieldType == "number")
            {
                <input class="fb-prev" type="number" placeholder="@f.Placeholder" disabled />
            }
            else if (f.FieldType == "calculated")
            {
                <input class="fb-prev fb-mono" value="@($"= {f.Formula}")" disabled />
            }
            else
            {
                <input class="fb-prev" type="text" placeholder="@f.Placeholder" disabled />
            }
        </div>
        <div class="fb-field-meta">@FieldTypeLabel(f.FieldType) · @(string.IsNullOrWhiteSpace(f.Name) ? "sin nombre" : f.Name)</div>
    </div>;

    private static string FieldTypeLabel(string? ft) => ft is not null && FieldTypes.TryGetValue(ft, out var v) ? v : "Campo";
}
