@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject DokTrino.Application.Admin.IPlatformBrandingService BrandingSvc
@inject DokTrino.Application.Admin.IGoogleAuthConfigService GoogleCfg
@inject DokTrino.Application.Tenancy.ITenantBrandingPublicoService TenantBrand

<PageTitle>Ingresar - @_displayName</PageTitle>

<div class="auth-shell @(StartSignup ? "is-signup" : "")">

    <!-- Panel izquierdo: marca + bienvenida -->
    <aside class="auth-aside">
        <div class="auth-aside-deco auth-deco-tr"></div>
        <div class="auth-aside-deco auth-deco-bl"></div>

        <div class="auth-brand">
            @if (!string.IsNullOrWhiteSpace(_logoUrl))
            {
                <img class="auth-brand-logo-img" src="@_logoUrl" alt="@_displayName" />
            }
            else
            {
                <div class="auth-brand-logo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                </div>
            }
            <span class="auth-brand-name">@_displayName</span>
        </div>

        <div class="auth-aside-body">
            <h2>@(_brand.LoginHeadline ?? "Gestion documental, agil y trazable")</h2>
            <p>@(_brand.LoginSubtext ?? "Coordina tu archivo: TRD, radicacion, expedientes y retencion documental en una sola plataforma.")</p>
            <div class="auth-dots"><span></span><span></span><span></span></div>
        </div>
    </aside>

    <!-- Panel derecho: formularios -->
    <main class="auth-main">
        <div class="auth-form-wrap">

            <!-- INICIAR SESION -->
            <section class="auth-pane auth-pane-login">
                <div class="auth-head">
                    <h1>Iniciar sesion</h1>
                    <p>Bienvenido de nuevo. Ingresa a tu panel.</p>
                </div>

                @if (Error == 1)
                {
                    <div class="auth-alert auth-alert-error">Credenciales invalidas o cuenta sin acceso.</div>
                }
                @if (Reset == 1)
                {
                    <div class="auth-alert auth-alert-ok">Tu contrasena se actualizo. Ya puedes iniciar sesion.</div>
                }
                @if (!string.IsNullOrWhiteSpace(GError))
                {
                    <div class="auth-alert auth-alert-error">@GError</div>
                }

                @if (_googleEnabled)
                {
                    <div class="auth-providers">
                        <a class="auth-provider" href="/connect/google">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
                            </svg>
                            <span>Continuar con Google</span>
                        </a>
                    </div>
                    <div class="auth-divider"><span>o con tu correo</span></div>
                }

                <form method="post" action="/auth/login" class="auth-form">
                    <div class="auth-field">
                        <label for="login-usuario">Usuario / Documento</label>
                        <input id="login-usuario" name="usuario" type="text" required placeholder="Cedula o correo" autocomplete="username" />
                    </div>
                    <div class="auth-field">
                        <div class="auth-label-row">
                            <label for="login-password">Contrasena</label>
                            <a class="auth-forgot" href="/recuperar">Olvidaste tu contrasena?</a>
                        </div>
                        <div class="auth-input-icon">
                            <input id="login-password" name="password" type="password" required placeholder="Tu contrasena" autocomplete="current-password" />
                            <button type="button" class="auth-eye" onclick="doktrinoAuth.toggle('login-password', this)">MOSTRAR</button>
                        </div>
                    </div>
                    @* La sede NO se elige aqui. Listarla antes de autenticar exponia
                       los nombres de las sedes de todas las entidades a cualquier
                       visitante. Se resuelve despues del login en /seleccionar-sede,
                       que ya acota por el tenant del usuario. *@
                    <input type="hidden" name="sede" value="" />

                    @* Solo recuerda el usuario, nunca la contrasena. El navegador
                       lo guarda en este dispositivo; no viaja al servidor. *@
                    <label class="auth-remember">
                        <input id="login-recordar" type="checkbox" />
                        <span>Recordar mi usuario en este dispositivo</span>
                    </label>

                    <button class="auth-submit" type="submit">
                        <span>Ingresar</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </button>
                </form>

                <p class="auth-switch">
                    No tienes una cuenta?
                    <button type="button" onclick="doktrinoAuth.show('signup')">Crea una aqui</button>
                </p>
            </section>

            <!-- CREAR CUENTA (autogestion) -->
            <section class="auth-pane auth-pane-signup">
                <div class="auth-head">
                    <h1>Crear una cuenta</h1>
                    <p>Registra tu agencia y empieza a vender en minutos.</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(RegError))
                {
                    <div class="auth-alert auth-alert-error">@RegError</div>
                }

                <form method="post" action="/auth/register" class="auth-form">
                    <div class="auth-field">
                        <label for="reg-agency">Nombre de tu agencia</label>
                        <input id="reg-agency" name="agencyName" type="text" required placeholder="Ej. Travel Fans" />
                    </div>
                    <div class="auth-field">
                        <label for="reg-name">Tu nombre</label>
                        <input id="reg-name" name="displayName" type="text" placeholder="Ej. Alexander Cuartas" />
                    </div>
                    <div class="auth-field">
                        <label for="reg-email">Correo electronico</label>
                        <input id="reg-email" name="email" type="email" required placeholder="tu.correo@ejemplo.com" />
                    </div>
                    <div class="auth-field">
                        <label for="reg-password">Contrasena</label>
                        <div class="auth-input-icon">
                            <input id="reg-password" name="password" type="password" required minlength="8" placeholder="Minimo 8 caracteres" />
                            <button type="button" class="auth-eye" onclick="doktrinoAuth.toggle('reg-password', this)">MOSTRAR</button>
                        </div>
                    </div>
                    <p class="auth-legal">
                        Al registrarte aceptas los Terminos del Servicio y la Politica de Privacidad de @_displayName.
                    </p>
                    <button class="auth-submit" type="submit">
                        <span>Registrar cuenta</span>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </button>
                </form>

                @if (_googleEnabled)
                {
                    <div class="auth-divider"><span>o registrate con</span></div>
                    <div class="auth-providers">
                        <button type="button" class="auth-provider" onclick="doktrinoAuth.googleSignup()">
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="16" height="16">
                                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
                                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
                            </svg>
                            <span>Continuar con Google</span>
                        </button>
                    </div>
                    <p class="auth-hint" id="reg-google-hint" hidden>Escribe primero el nombre de tu agencia para continuar con Google.</p>
                }

                <p class="auth-switch">
                    Ya tienes una cuenta?
                    <button type="button" onclick="doktrinoAuth.show('login')">Iniciar sesion</button>
                </p>
            </section>

        </div>

        <footer class="auth-footer">&copy; @DateTime.UtcNow.Year @_displayName. Todos los derechos reservados.</footer>
    </main>
</div>

<script>
    window.doktrinoAuth = {
        show: function (mode) {
            var shell = document.querySelector('.auth-shell');
            if (!shell) return;
            shell.classList.toggle('is-signup', mode === 'signup');
        },
        toggle: function (id, btn) {
            var input = document.getElementById(id);
            if (!input) return;
            var show = input.type === 'password';
            input.type = show ? 'text' : 'password';
            btn.textContent = show ? 'OCULTAR' : 'MOSTRAR';
        },
        googleSignup: function () {
            var input = document.getElementById('reg-agency');
            var hint = document.getElementById('reg-google-hint');
            var agency = input ? (input.value || '').trim() : '';
            if (!agency) {
                if (hint) hint.hidden = false;
                if (input) { input.classList.add('auth-input-error'); input.focus(); }
                return;
            }
            if (hint) hint.hidden = true;
            window.location = '/connect/google?mode=signup&agency=' + encodeURIComponent(agency);
        },

        // Recordar usuario: guarda SOLO el identificador en este dispositivo.
        // La contrasena nunca se persiste, y nada de esto viaja al servidor.
        CLAVE: 'doktrino.usuario',

        iniciarRecordar: function () {
            var usuario = document.getElementById('login-usuario');
            var check = document.getElementById('login-recordar');
            var form = usuario ? usuario.closest('form') : null;
            if (!usuario || !check || !form) return;

            var guardado = null;
            try { guardado = localStorage.getItem(this.CLAVE); } catch (e) { return; }

            if (guardado) {
                usuario.value = guardado;
                check.checked = true;
                // Con el usuario ya puesto, el foco util es la contrasena.
                var pass = document.getElementById('login-password');
                if (pass) pass.focus();
            }

            var self = this;
            form.addEventListener('submit', function () {
                try {
                    if (check.checked && usuario.value.trim()) {
                        localStorage.setItem(self.CLAVE, usuario.value.trim());
                    } else {
                        localStorage.removeItem(self.CLAVE);
                    }
                } catch (e) { /* modo privado o storage bloqueado: se ignora */ }
            });
        }
    };

    doktrinoAuth.iniciarRecordar();
</script>

@code {
    [SupplyParameterFromQuery] public int? Error { get; set; }
    [SupplyParameterFromQuery] public int? Reset { get; set; }
    [SupplyParameterFromQuery] public string? RegError { get; set; }
    [SupplyParameterFromQuery(Name = "gerror")] public string? GError { get; set; }
    [SupplyParameterFromQuery] public string? Mode { get; set; }

    private DokTrino.Application.Admin.PlatformBrandingDto _brand = DokTrino.Application.Admin.PlatformBrandingDto.Default;
    private bool _googleEnabled;

    // Logo y nombre que finalmente se renderizan en el panel de la izquierda.
    // Resueltos en OnInitializedAsync con la regla:
    //   1) Branding de plataforma (configurado por super-admin) tiene prioridad.
    //   2) Si no esta puesto, cae al logo/nombre del tenant principal (Mi cuenta).
    //   3) Si no hay ninguno, queda el default del PlatformBrandingDto.
    private string _displayName = "DokTrino";
    private string? _logoUrl;

    private bool StartSignup => string.Equals(Mode, "signup", StringComparison.OrdinalIgnoreCase)
        || !string.IsNullOrWhiteSpace(RegError);

    protected override async Task OnInitializedAsync()
    {
        _brand = await BrandingSvc.GetAsync();
        _googleEnabled = (await GoogleCfg.GetAsync())?.IsEnabled == true;

        // Empezamos con lo que dijo el branding de plataforma.
        _displayName = _brand.PlatformName;
        _logoUrl = _brand.LoginLogoUrl;

        // Si la plataforma no configuro logo (o el nombre quedo en "DokTrino" default),
        // intentamos cargar el branding del tenant principal de esta instancia.
        // Eso cubre instalaciones on-premise donde hay un solo tenant operando.
        var sinLogo = string.IsNullOrWhiteSpace(_logoUrl);
        var nombreDefault = string.Equals(_displayName, "DokTrino", StringComparison.OrdinalIgnoreCase);
        if (sinLogo || nombreDefault)
        {
            var t = await TenantBrand.GetDefaultAsync();
            if (t is not null)
            {
                if (sinLogo) { _logoUrl = t.LogoUrl; }
                if (nombreDefault && !string.IsNullOrWhiteSpace(t.Name)) { _displayName = t.Name; }
            }
        }
    }
}
