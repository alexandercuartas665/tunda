@page "/marca"
@attribute [Authorize(Policy = "PlatformOperator")]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Admin
@using Microsoft.AspNetCore.Components.Forms
@inject IPlatformBrandingService BrandingSvc
@inject IWebHostEnvironment Env

<PageTitle>Marca de la plataforma - Archimente</PageTitle>

<div class="module-head">
    <div>
        <div class="module-eyebrow">
            <div class="module-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></svg>
            </div>
            <span>Super Admin SaaS</span>
        </div>
        <h1 class="page-title" style="margin-top:12px;">Marca de la <span>plataforma</span></h1>
        <p class="page-sub" style="margin-bottom:0;">Configura el logo y los textos que ven los clientes en la pantalla de ingreso y registro.</p>
    </div>
</div>

@if (_loading)
{
    <p><em>Cargando...</em></p>
}
else
{
    <div class="brand-cols">
        <div class="card-soft brand-form">
            <div class="auth-field" style="margin-bottom:16px;">
                <label>Nombre de la plataforma</label>
                <input class="form-control" @bind="_name" maxlength="120" />
            </div>
            <div class="auth-field" style="margin-bottom:16px;">
                <label>Bajada corta (tagline)</label>
                <input class="form-control" @bind="_tagline" maxlength="160" placeholder="Ej. CRM Conversacional" />
            </div>
            <div class="auth-field" style="margin-bottom:16px;">
                <label>Titular del login</label>
                <input class="form-control" @bind="_headline" maxlength="160" placeholder="Ej. Rapido, facil y seguro" />
            </div>
            <div class="auth-field" style="margin-bottom:16px;">
                <label>Texto descriptivo del login</label>
                <textarea class="form-control" rows="3" @bind="_subtext" maxlength="600"></textarea>
            </div>

            <div class="auth-field" style="margin-bottom:8px;">
                <label>Logo del login</label>
                <InputFile OnChange="OnLogoSelected" accept="image/*" class="form-control" />
                <small class="text-muted">PNG/JPG/SVG, hasta 4 MB. Si no subes uno, se usa el logo por defecto.</small>
            </div>

            <div class="auth-field" style="margin-bottom:8px;">
                <label>O usa un logo sugerido</label>
                <div class="brand-suggested">
                    @foreach (var s in _suggested)
                    {
                        <button type="button" class="brand-suggested-item @(s == _logoUrl ? "active" : "")" @onclick="() => UseSuggested(s)">
                            <img src="@s" alt="logo sugerido" />
                        </button>
                    }
                </div>
            </div>
            @if (!string.IsNullOrWhiteSpace(_logoUrl))
            {
                <div class="brand-logo-current">
                    <img src="@_logoUrl" alt="logo" />
                    <button class="btn btn-sm btn-outline-danger" @onclick="ClearLogo">Quitar logo</button>
                </div>
            }

            <div style="margin-top:18px;display:flex;gap:10px;align-items:center;">
                <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Guardando..." : "Guardar cambios")</button>
                @if (_savedOk) { <span class="text-success" style="font-size:.9rem;">Guardado.</span> }
                @if (!string.IsNullOrWhiteSpace(_error)) { <span class="text-danger" style="font-size:.9rem;">@_error</span> }
            </div>
        </div>

        <!-- Vista previa del panel del login -->
        <div class="brand-preview">
            <div class="brand-preview-aside">
                <div class="bp-brand">
                    @if (!string.IsNullOrWhiteSpace(_logoUrl))
                    {
                        <img src="@_logoUrl" alt="logo" />
                    }
                    else
                    {
                        <div class="bp-logo">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                        </div>
                    }
                    <span>@(_name)</span>
                </div>
                <div class="bp-body">
                    <h3>@(_headline)</h3>
                    <p>@(_subtext)</p>
                </div>
            </div>
            <div class="brand-preview-label">Vista previa del panel de ingreso</div>
        </div>
    </div>
}

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _loading = true;
    private bool _saving;
    private bool _savedOk;
    private string? _error;

    private string _name = "DokTrino";
    private string? _tagline;
    private string? _headline;
    private string? _subtext;
    private string? _logoUrl;

    private readonly string[] _suggested = { "/img/brand/logo1.jpeg", "/img/brand/logo2.jpeg" };

    private void UseSuggested(string url) { _logoUrl = url; _savedOk = false; _error = null; }

    protected override async Task OnInitializedAsync()
    {
        var b = await BrandingSvc.GetAsync();
        _name = b.PlatformName;
        _tagline = b.Tagline;
        _headline = b.LoginHeadline;
        _subtext = b.LoginSubtext;
        _logoUrl = b.LoginLogoUrl;
        _loading = false;
    }

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        _error = null;
        _savedOk = false;
        var file = e.File;
        const long max = 4L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { _error = "El logo debe pesar menos de 4 MB."; return; }
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(max).CopyToAsync(ms);
            var ext = System.IO.Path.GetExtension(file.Name);
            var dir = System.IO.Path.Combine(Env.WebRootPath, "uploads", "branding");
            System.IO.Directory.CreateDirectory(dir);
            var name = $"brand-{Guid.NewGuid():N}{ext}";
            await System.IO.File.WriteAllBytesAsync(System.IO.Path.Combine(dir, name), ms.ToArray());
            _logoUrl = $"/uploads/branding/{name}";
        }
        catch { _error = "No se pudo subir el logo."; }
    }

    private void ClearLogo() { _logoUrl = null; _savedOk = false; }

    private async Task SaveAsync()
    {
        _saving = true;
        _savedOk = false;
        _error = null;
        try
        {
            await BrandingSvc.SaveAsync(
                new SaveBrandingRequest(_name, _tagline, _logoUrl, _headline, _subtext),
                await ActorAsync());
            _savedOk = true;
        }
        catch { _error = "No se pudo guardar."; }
        finally { _saving = false; }
    }

    private async Task<Guid> ActorAsync()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }
}
