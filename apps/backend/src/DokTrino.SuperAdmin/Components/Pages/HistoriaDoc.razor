@page "/historia-doc/{Id:guid}"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text.Json
@using DokTrino.Application.Tenancy
@using DokTrino.SuperAdmin.Components.Forms
@inject IHistoriaClinicaService HcSvc
@inject IAsignacionService AsigSvc
@inject IJSRuntime JS
@inject NavigationManager Nav

@*
   Vista documento de una Historia Clinica - renderiza el FormSchema con los
   valores diligenciados y lo manda a impresion del navegador. Se abre en
   nueva pestana desde HistoriasClinicasModulo (boton Imprimir).
*@

<PageTitle>@(_titulo) - DokTrino</PageTitle>

<style>
    .doc-actions { display: flex; gap: 8px; align-items: center; margin: 14px auto; max-width: 920px; }
    .doc-actions .dbtn { padding: 8px 14px; border: 1px solid var(--border); border-radius: 8px; background: var(--card); font-size: 13px; font-weight: 600; cursor: pointer; color: var(--foreground); text-decoration: none; }
    .doc-actions .dbtn.primary { background: var(--primary); border-color: var(--primary); color: #fff; }
    .doc-actions .spacer { flex: 1; }
    .doc-actions .meta { font-size: 12px; color: var(--muted-foreground); }

    .doc { max-width: 920px; margin: 0 auto; background: #fff; color: #000; font-family: 'Segoe UI', Arial, sans-serif; font-size: 12px; line-height: 1.35; border: 1px solid #000; }
    .doc-header { border-bottom: 1px solid #000; padding: 8px 10px; }
    .doc-hdr-top { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
    .doc-hdr-brand { display: flex; align-items: center; gap: 8px; }
    .doc-hdr-brand svg { width: 30px; height: 30px; color: #1565c0; }
    .doc-hdr-logo { max-height: 48px; max-width: 180px; object-fit: contain; }
    .doc-hdr-inst { font-size: 16px; font-weight: 800; color: #1565c0; letter-spacing: .02em; }
    .doc-hdr-tag { font-size: 10px; font-style: italic; color: #555; }
    .doc-hdr-nohist { font-size: 11px; white-space: nowrap; text-align: right; }
    .doc-hdr-nohist b { font-size: 12px; color: #1565c0; }
    .doc-hdr-title { text-align: center; font-size: 15px; font-weight: 800; text-transform: uppercase; margin: 6px 0; }
    .doc-hdr-meta { display: flex; gap: 28px; font-size: 11px; flex-wrap: wrap; }
    .doc-hdr-meta b { color: #1565c0; }

    .doc-grid { display: grid; grid-template-columns: repeat(12, 1fr); }
    .doc-band { grid-column: span 12; background: #dde7f3; font-weight: 800; font-size: 11px; padding: 4px 8px; text-transform: uppercase; border-bottom: 1px solid #000; letter-spacing: .04em; }
    .doc-sub { grid-column: span 12; font-weight: 700; font-size: 11px; padding: 4px 8px; background: #f3f6fb; border-bottom: 1px solid #000; }
    .doc-para { grid-column: span 12; padding: 4px 8px; border-bottom: 1px solid #000; color: #222; white-space: pre-wrap; }
    .doc-cell { border-right: 1px solid #000; border-bottom: 1px solid #000; padding: 2px 6px 4px; min-height: 36px; }
    .doc-label { font-size: 9px; font-weight: 700; text-transform: uppercase; color: #333; }
    .doc-req { color: #b00; }
    .doc-value { min-height: 16px; border-bottom: 1px dotted #999; margin-top: 4px; padding: 1px 2px; font-size: 12px; color: #000; white-space: pre-wrap; word-break: break-word; }
    .doc-value.empty { color: transparent; }
    .doc-tablewrap { grid-column: span 12; border-bottom: 1px solid #000; padding: 0; }
    .doc-table { width: 100%; border-collapse: collapse; }
    .doc-table th { border: 1px solid #000; background: #dde7f3; font-size: 10px; padding: 3px 6px; text-align: left; font-weight: 700; }
    .doc-table td { border: 1px solid #000; height: 22px; padding: 2px 6px; font-size: 11px; }

    .doc-footer { display: flex; justify-content: space-between; gap: 24px; padding: 24px 14px 12px; border-top: 1px solid #000; margin-top: 0; font-size: 11px; }
    .doc-firma { flex: 1; max-width: 280px; }
    .doc-firma-line { border-top: 1px solid #000; padding-top: 4px; font-weight: 700; }
    .doc-firma-rol { font-size: 10px; color: #555; }
    .doc-estado-pill { display: inline-block; padding: 2px 10px; border-radius: 999px; font-size: 10px; font-weight: 800; letter-spacing: .04em; }
    .doc-estado-Abierta { background: #fef3c7; color: #92400e; }
    .doc-estado-Cerrada { background: #dcfce7; color: #166534; }
    .doc-estado-Inactiva { background: #fee2e2; color: #991b1b; }

    @@media print {
        .doktrino-sidebar, .doktrino-topbar, .doc-actions { display: none !important; }
        .doktrino-main, .doktrino-shell { margin: 0 !important; padding: 0 !important; }
        .doc { max-width: none; border: 1px solid #000; }
        body { background: #fff !important; }
        @@page { size: A4; margin: 12mm; }
    }
</style>

@if (_loading)
{
    <p class="doc-actions">Cargando historia clinica...</p>
}
else if (_hc is null)
{
    <p class="doc-actions">Historia clinica no encontrada.</p>
}
else
{
    <div class="doc-actions">
        <a class="dbtn" href="javascript:window.close()">&times; Cerrar</a>
        <button class="dbtn primary" @onclick="PrintAsync">&#128424; Imprimir / Guardar PDF</button>
        <span class="spacer"></span>
        <span class="meta">Formato: <b>@_hc.FormatoCodigo</b> &middot; Estado:
            <span class="doc-estado-pill doc-estado-@_hc.Estado">@_hc.Estado.ToUpperInvariant()</span>
        </span>
    </div>

    <div class="doc">
        @* ============ ENCABEZADO ============ *@
        <div class="doc-header">
            <div class="doc-hdr-top">
                <div class="doc-hdr-brand">
                    @if (!string.IsNullOrWhiteSpace(Hdr.LogoUrl))
                    {
                        <img class="doc-hdr-logo" src="@Hdr.LogoUrl" alt="logo" />
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                    }
                    <div>
                        <div class="doc-hdr-inst">@Hdr.Institucion</div>
                        <div class="doc-hdr-tag">@Hdr.Tagline</div>
                    </div>
                </div>
                <div class="doc-hdr-nohist">
                    No Historia: <b>@_hc.Id.ToString().Substring(0, 8).ToUpperInvariant()</b><br />
                    Apertura: @_hc.FechaApertura.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    @if (_hc.FechaCierre is DateTimeOffset fc)
                    {
                        <br /><span>Cierre: @fc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                    }
                </div>
            </div>
            <div class="doc-hdr-title">@(string.IsNullOrWhiteSpace(Hdr.Titulo) ? _hc.FormatoNombre : Hdr.Titulo)</div>
            <div class="doc-hdr-meta">
                <span><b>Paciente:</b> @(_paciente?.NombreCompleto ?? "-")</span>
                <span><b>Doc:</b> @(_paciente?.TipoDocumento) @(_paciente?.NumeroDocumento)</span>
                @if (!string.IsNullOrWhiteSpace(_hc.EspecialistaNombre))
                {
                    <span><b>Atiende:</b> @_hc.EspecialistaNombre</span>
                }
            </div>
        </div>

        @* ============ CUERPO: secciones + campos diligenciados ============ *@
        @foreach (var node in _schema.Children)
        {
            <div class="doc-grid">
                @if (node.IsSection)
                {
                    @foreach (var ch in node.Children ?? new())
                    {
                        @RenderDocNode(ch)
                    }
                }
                else
                {
                    @RenderDocNode(node)
                }
            </div>
        }

        @* ============ AVISO DE INACTIVACION ============ *@
        @if (_hc.Estado == "Inactiva" && !string.IsNullOrWhiteSpace(_hc.MotivoInactivacion))
        {
            <div class="doc-grid">
                <div class="doc-band">Inactivacion</div>
                <div class="doc-para"><b>Motivo:</b> @_hc.MotivoInactivacion</div>
            </div>
        }

        @* ============ PIE: firma del especialista ============ *@
        <div class="doc-footer">
            <div class="doc-firma">
                <div class="doc-firma-line">@(_hc.EspecialistaNombre ?? "Especialista")</div>
                <div class="doc-firma-rol">Firma del profesional tratante</div>
            </div>
            <div class="doc-firma">
                <div class="doc-firma-line">@(_paciente?.NombreCompleto ?? "Paciente")</div>
                <div class="doc-firma-rol">Firma del paciente / acudiente</div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private HistoriaClinicaDetailDto? _hc;
    private PacienteAsignacionDto? _paciente;
    private FormSchema _schema = new();
    private Dictionary<string, string?> _valores = new();
    private bool _loading = true;
    private string _titulo = "Historia Clinica";

    private FormHeader Hdr => _schema.Header ?? FormHeader.Default();

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _hc = await HcSvc.GetAsync(Id);
        if (_hc is null)
        {
            _loading = false;
            return;
        }

        _schema = FormSchema.FromJson(_hc.SchemaJson);
        _valores = DeserializeValores(_hc.ValoresJson);
        _paciente = await AsigSvc.GetPacienteAsync(_hc.PacienteId);
        _titulo = $"{_hc.FormatoNombre} - {_paciente?.NombreCompleto ?? "Paciente"}";
        _loading = false;
    }

    private async Task PrintAsync() => await JS.InvokeVoidAsync("print");

    private static int Span(FormNode f) => Math.Clamp(f.WidthColumns <= 0 ? 12 : f.WidthColumns, 1, 12);

    private static string KeyOf(FormNode n) => n.Name ?? $"fld:{n.Id}";

    private string? GetValor(FormNode n) =>
        _valores.TryGetValue(KeyOf(n), out var v) ? v : null;

    private RenderFragment RenderDocNode(FormNode n) =>
        n.IsText ? RenderDocText(n) : (n.IsTable ? RenderDocTable(n) : RenderDocField(n));

    private RenderFragment RenderDocText(FormNode n) => n.TextStyle switch
    {
        "heading" => @<div class="doc-band">@n.Content</div>,
        "subheading" => @<div class="doc-sub">@n.Content</div>,
        _ => @<div class="doc-para">@n.Content</div>
    };

    private RenderFragment RenderDocField(FormNode f) =>
        @<div class="doc-cell" style="@($"grid-column: span {Span(f)};")">
            <div class="doc-label">@f.Label@(f.Required ? new MarkupString(" <span class=\"doc-req\">*</span>") : (MarkupString)"")</div>
            @{
                var v = GetValor(f);
                var empty = string.IsNullOrWhiteSpace(v);
            }
            <div class="doc-value @(empty ? "empty" : "")">@(empty ? "_" : v)</div>
        </div>;

    private RenderFragment RenderDocTable(FormNode n) => @<div class="doc-tablewrap">
        <table class="doc-table">
            <thead>
                <tr>
                    @foreach (var c in n.Columns ?? new())
                    {
                        <th>@(string.IsNullOrWhiteSpace(c.Label) ? "Columna" : c.Label)</th>
                    }
                </tr>
            </thead>
            <tbody>
                @{
                    // Lee filas reales: combina SeedRows (filas semilla con texto fijo)
                    // mas las filas extras controladas por tbl:{id}:_rows. Cada celda
                    // viene de valores["tbl:{id}:{idx}:{colId}"]. Asi las tablas auto-
                    // pobladas (medicamentos, remisiones, etc.) muestran su contenido
                    // en la impresion.
                    var tblKey = $"tbl:{n.Id}";
                    var seedCount = n.SeedRows?.Count ?? 0;
                    int extraRows = 0;
                    if (!n.LockRows && _valores.TryGetValue($"{tblKey}:_rows", out var rs)
                        && int.TryParse(rs, out var parsed) && parsed > 0)
                    {
                        extraRows = parsed;
                    }
                    // Fallback: si no hay _rows y no es LockRows, deja al menos 3 filas
                    // vacias para que el doctor pueda escribir a mano sobre papel.
                    var totalRows = seedCount + extraRows;
                    if (totalRows == 0 && !n.LockRows) { totalRows = 3; extraRows = 3; }
                }
                @for (var r = 0; r < totalRows; r++)
                {
                    var idx = r;
                    var isSeed = r < seedCount;
                    var seedRow = isSeed ? n.SeedRows![r] : null;
                    <tr>
                        @{ var colIdx = 0; }
                        @foreach (var c in n.Columns ?? new())
                        {
                            var seedVal = (seedRow is not null && colIdx < seedRow.Count) ? seedRow[colIdx] : null;
                            string? cellVal;
                            if (!string.IsNullOrEmpty(seedVal)) { cellVal = seedVal; }
                            else
                            {
                                _valores.TryGetValue($"{tblKey}:{idx}:{c.Id}", out cellVal);
                            }
                            <td>@(string.IsNullOrWhiteSpace(cellVal) ? new MarkupString("&nbsp;") : (MarkupString)System.Net.WebUtility.HtmlEncode(cellVal))</td>
                            colIdx++;
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>;

    private static Dictionary<string, string?> DeserializeValores(string json)
    {
        if (string.IsNullOrWhiteSpace(json) || json == "{}") { return new(); }
        try
        {
            using var doc = JsonDocument.Parse(json);
            var dict = new Dictionary<string, string?>();
            foreach (var p in doc.RootElement.EnumerateObject())
            {
                dict[p.Name] = p.Value.ValueKind switch
                {
                    JsonValueKind.String => p.Value.GetString(),
                    JsonValueKind.Null => null,
                    JsonValueKind.True => "Si",
                    JsonValueKind.False => "No",
                    _ => p.Value.GetRawText()
                };
            }
            return dict;
        }
        catch
        {
            return new();
        }
    }
}
