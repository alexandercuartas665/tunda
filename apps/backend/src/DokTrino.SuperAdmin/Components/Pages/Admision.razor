    private void OpenCieModal()
    {
        _cieModal = true; _cieQuery = ""; _cieResults = new(); _cieError = null;
    }
    private void CloseCieModal() => _cieModal = false;
    private async Task OnCieKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { await SearchCie(); }
    }
    private async Task SearchCie()
    {
        if (string.IsNullOrWhiteSpace(_cieQuery)) { return; }
        _cieError = null; _cieBusy = true; _cieResults = new();
        try { _cieResults = (await Cie11Svc.SearchAsync(_cieQuery.Trim())).ToList(); }
        catch (InvalidOperationException ex) { _cieError = ex.Message; }
        catch (Exception ex) { _cieError = "Error tecnico: " + ex.Message; }
        finally { _cieBusy = false; }
    }
    private async Task SelectCieAsync(Cie11SearchItem item)
    {
        _cieError = null;
        try
        {
            var d = await Cie11Svc.GetDetailAsync(item.EntityId);
            if (d is null || string.IsNullOrEmpty(d.Code))
            {
                _cieError = "No se pudo obtener el codigo del diagnostico seleccionado.";
                return;
            }
            _cie10Codigo = d.Code;
            _dxPrincipal = d.Title;
            _cieModal = false;
        }
        catch (InvalidOperationException ex) { _cieError = ex.Message; }
        catch (Exception ex) { _cieError = "Error tecnico: " + ex.Message; }
    }
    private static string TrimId(string id)
    {
        if (string.IsNullOrEmpty(id)) { return ""; }
        var slash = id.LastIndexOf('/');
        return slash > 0 ? id[(slash + 1)..] : id;
    }

    // Geografia
    private string? _dir, _barrio, _ciudad;
    private string _codPaisTel = "+57";
    private string? _tel, _email;
    private string _sedeId = "";

    // Selects en cascada de geografia.
    private List<PaisDto> _paises = new();
    private List<DepartamentoDto> _departamentos = new();
    private List<MunicipioDto> _municipios = new();
    private string _paisResidencia = "", _paisOrigen = "", _departamento = "", _municipio = "";

    // Emergencia (legacy, mantenido como fallback de display)
    private string? _emerNombre, _emerParentesco, _emerTel;
    private bool _activo = true;

    /// <summary>Lista N de contactos de emergencia editables. La primera fila
    /// sustituye a los campos legacy al guardar.</summary>
    private List<ContactoEmergenciaEdit> _contactos = new();

    /// <summary>Catalogo simple de codigos de pais frecuentes. Si necesitas mas,
    /// se agregan aqui; no requiere migracion.</summary>
    private static readonly (string Codigo, string Pais)[] _codigosPais = new[]
    {
        ("+57",  "Colombia"),
        ("+58",  "Venezuela"),
        ("+593", "Ecuador"),
        ("+51",  "Peru"),
        ("+56",  "Chile"),
        ("+54",  "Argentina"),
        ("+591", "Bolivia"),
        ("+52",  "Mexico"),
        ("+1",   "EE.UU./Canada"),
        ("+34",  "Espana")
    };

    private void AgregarContactoEmergencia()
    {
        _contactos.Add(new ContactoEmergenciaEdit { CodigoPais = "+57", Orden = _contactos.Count + 1 });
    }

    private void QuitarContactoEmergencia(int idx)
    {
        if (idx < 0 || idx >= _contactos.Count) { return; }
        _contactos.RemoveAt(idx);
        for (var i = 0; i < _contactos.Count; i++) { _contactos[i].Orden = i + 1; }
    }

    /// <summary>Modelo editable de UI para un contacto de emergencia. No persiste
    /// directo: en Save se convierte a PacienteContactoEmergenciaDto.</summary>
    private sealed class ContactoEmergenciaEdit
    {
        public Guid? Id { get; set; }
        public string Nombre { get; set; } = "";
        public string? Parentesco { get; set; }
        public string CodigoPais { get; set; } = "+57";
        public string? Telefono { get; set; }
        public int Orden { get; set; }
    }

    private bool _busy; private string? _error, _ok;

    protected override async Task OnInitializedAsync()
    {
        _aseguradoras = (await AseSvc.ListAseguradorasAsync()).ToList();
        _sedes = (await SucSvc.ListAsync()).ToList();
        _catalogos = (await CatSvc.ListAsync(null)).ToList();
        _paises = (await GeoSvc.ListPaisesAsync()).ToList();
        await LoadLista();
    }

    private async Task OnIpsComentaChanged(ChangeEventArgs e)
    {
        _ipsComenta = e.Value?.ToString() ?? "";
        _contrato1 = _contrato2 = _contrato3 = "";
        if (Guid.TryParse(_ipsComenta, out var iid))
        {
            _contratosAse = (await AseSvc.ListContratosAsync(iid)).ToList();
        }
        else { _contratosAse = new(); }
    }

    private async Task OnPaisResidenciaChanged(ChangeEventArgs e)
    {
        _paisResidencia = e.Value?.ToString() ?? "";
        _departamento = ""; _municipio = ""; _municipios = new();
        if (Guid.TryParse(_paisResidencia, out var pid))
        {
            _departamentos = (await GeoSvc.ListDepartamentosAsync(pid)).ToList();
        }
        else { _departamentos = new(); }
    }

    private async Task OnDepartamentoChanged(ChangeEventArgs e)
    {
        _departamento = e.Value?.ToString() ?? "";
        _municipio = "";
        if (Guid.TryParse(_departamento, out var did))
        {
            _municipios = (await GeoSvc.ListMunicipiosAsync(did)).ToList();
        }
        else { _municipios = new(); }
    }

    private async Task LoadLista() => _lista = (await Svc.ListAsync(string.IsNullOrWhiteSpace(_filtro) ? null : _filtro)).ToList();
    private async Task OnFiltro(ChangeEventArgs e) { _filtro = e.Value?.ToString() ?? ""; await LoadLista(); }

    private void New()
    {
        _id = null;
        _doc = ""; _tipoDoc = "CC";
        _pNombre = _sNombre = _pApellido = _sApellido = null;
        _fnac = null; _edad = null;
        _codAcept = null; _fComenta = _fIngreso = _fEgreso = null; _aseId = "";
        _ipsComenta = ""; _contratosAse = new();
        _diasEst = _opIngreso = null;
        _incapacidad = _grupoRh = _estado = null;
        _tipoUsuario = _clasifPaciente = _clasifGrupo = "";
        _contrato1 = _contrato2 = _contrato3 = "";
        _estrato = _sexo = _estadoCivil = _zona = _ocupacion = _regimen = null;
        _dxPrincipal = _tutela = null;
        _tipoTutela = "";
        _medContratado = "";
        _cie10Codigo = null;
        _dir = _barrio = _ciudad = null;
        _codPaisTel = "+57";
        _tel = _email = null; _sedeId = "";
        _paisResidencia = _paisOrigen = _departamento = _municipio = "";
        _departamentos = new(); _municipios = new();
        _emerNombre = _emerParentesco = _emerTel = null; _activo = true;
        _contactos = new();
        _showForm = true; _tab = "generales"; _error = _ok = null;
    }

    private async Task Select(Guid id)
    {
        var d = await Svc.GetAsync(id);
        if (d is null) { return; }
        _id = d.Id;
        _doc = d.NumeroDocumento; _tipoDoc = d.TipoDocumento;
        _pNombre = d.PrimerNombre; _sNombre = d.SegundoNombre; _pApellido = d.PrimerApellido; _sApellido = d.SegundoApellido;
        _fnac = d.FechaNacimiento; _edad = d.Edad;
        _codAcept = d.CodigoAceptacion; _fComenta = d.FechaComentan;
        _fIngreso = d.FechaIngresoPad; _fEgreso = d.FechaEgresoPad;
        _aseId = d.AseguradoraId?.ToString() ?? "";
        _ipsComenta = d.IpsComentaId?.ToString() ?? "";
        // Cargar contratos de la IPS que comenta del paciente para los selects.
        if (d.IpsComentaId is Guid iid) { _contratosAse = (await AseSvc.ListContratosAsync(iid)).ToList(); }
        else { _contratosAse = new(); }
        _diasEst = d.DiasEstancia; _opIngreso = d.OpIngresoDias;
        _incapacidad = d.Incapacidad; _grupoRh = d.GrupoRh; _estado = d.Estado;
        _tipoUsuario = d.TipoUsuarioId?.ToString() ?? "";
        _clasifPaciente = d.ClasificacionPacienteId?.ToString() ?? "";
        _clasifGrupo = d.ClasificacionGrupoPatologiaId?.ToString() ?? "";
        _contrato1 = d.Contrato1Id?.ToString() ?? "";
        _contrato2 = d.Contrato2Id?.ToString() ?? "";
        _contrato3 = d.Contrato3Id?.ToString() ?? "";
        _estrato = d.EstratoSocial; _sexo = d.Sexo; _estadoCivil = d.EstadoCivil; _zona = d.Zona;
        _ocupacion = d.Ocupacion; _regimen = d.Regimen;
        _dxPrincipal = d.DiagnosticoPrincipal; _tutela = d.Tutela;
        _tipoTutela = d.TipoTutelaId?.ToString() ?? "";
        _medContratado = d.MedContratadoId?.ToString() ?? "";
        _cie10Codigo = d.Cie10Codigo;
        _dir = d.Direccion; _barrio = d.Barrio; _ciudad = d.Ciudad;
        _codPaisTel = string.IsNullOrWhiteSpace(d.CodigoPaisTelefono) ? "+57" : d.CodigoPaisTelefono!;
        _tel = d.Telefono; _email = d.Email;
        _sedeId = d.SedeAtencionId?.ToString() ?? "";
        _paisResidencia = d.PaisResidenciaId?.ToString() ?? "";
        _paisOrigen = d.PaisOrigenId?.ToString() ?? "";
        _departamento = d.DepartamentoId?.ToString() ?? "";
        _municipio = d.MunicipioId?.ToString() ?? "";
        if (Guid.TryParse(_paisResidencia, out var pid)) { _departamentos = (await GeoSvc.ListDepartamentosAsync(pid)).ToList(); }
        else { _departamentos = new(); }
        if (Guid.TryParse(_departamento, out var did)) { _municipios = (await GeoSvc.ListMunicipiosAsync(did)).ToList(); }
        else { _municipios = new(); }
        _emerNombre = d.ContactoEmergencia; _emerParentesco = d.Parentesco; _emerTel = d.TelefonoEmergencia; _activo = d.Activo;
        // Lista de contactos: si vino del backend la usamos; si esta vacia pero hay
        // datos legacy (paciente viejo), creamos una fila con esos datos.
        _contactos = d.ContactosEmergencia
            .Select(c => new ContactoEmergenciaEdit
            {
                Id = c.Id,
                Nombre = c.Nombre,
                Parentesco = c.Parentesco,
                CodigoPais = string.IsNullOrWhiteSpace(c.CodigoPais) ? "+57" : c.CodigoPais,
                Telefono = c.Telefono,
                Orden = c.Orden
            }).ToList();
        if (_contactos.Count == 0 && !string.IsNullOrWhiteSpace(d.ContactoEmergencia))
        {
            _contactos.Add(new ContactoEmergenciaEdit
            {
                Nombre = d.ContactoEmergencia!,
                Parentesco = d.Parentesco,
                CodigoPais = "+57",
                Telefono = d.TelefonoEmergencia,
                Orden = 1
            });
        }
        _showForm = true; _tab = "generales"; _error = _ok = null;
    }

    private async Task Save()
    {
        _error = _ok = null; _busy = true;
        try
        {
            Guid? ase = Guid.TryParse(_aseId, out var ag) ? ag : null;
            Guid? sede = Guid.TryParse(_sedeId, out var sg) ? sg : null;
            Guid? Try(string s) => Guid.TryParse(s, out var g) ? g : null;
            var req = new SavePacienteRequest(
                _id,
                _doc, _tipoDoc, _pNombre, _sNombre, _pApellido, _sApellido, null,
                _fnac, _edad,
                Try(_ipsComenta), _codAcept, _fComenta,
                ase, _fIngreso, _fEgreso, _diasEst, _opIngreso,
                _incapacidad, _grupoRh, Try(_tipoUsuario), _estado,
                Try(_clasifPaciente), Try(_clasifGrupo),
                _estrato, _sexo, _estadoCivil, _zona, _ocupacion, _regimen,
                Try(_contrato1), Try(_contrato2), Try(_contrato3),
                null, _cie10Codigo, _dxPrincipal,
                _tutela, Try(_tipoTutela), Try(_medContratado),
                Try(_paisResidencia), Try(_paisOrigen), Try(_departamento), Try(_municipio),
                _dir, _barrio, _ciudad,
                _codPaisTel, _tel, _email,
                sede,
                _emerNombre, _emerParentesco, _emerTel,
                _contactos
                    .Where(c => !string.IsNullOrWhiteSpace(c.Nombre))
                    .Select((c, i) => new PacienteContactoEmergenciaDto(
                        c.Id, c.Nombre.Trim(), c.Parentesco?.Trim(),
                        string.IsNullOrWhiteSpace(c.CodigoPais) ? "+57" : c.CodigoPais.Trim(),
                        c.Telefono?.Trim(),
                        c.Orden > 0 ? c.Orden : i + 1))
                    .ToList(),
                _activo);
            var saved = await Svc.SaveAsync(req, await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            await Select(saved.Id); await LoadLista(); _ok = $"Paciente \"{saved.NombreCompleto}\" guardado.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task Delete()
    {
        if (_id is not Guid id) { return; }
        _busy = true; _error = null; _ok = null;
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm",
                "Eliminar definitivamente este paciente? Esta accion no se puede deshacer.");
            if (!ok) { return; }
            await Svc.DeleteAsync(id, await Actor());
            _showForm = false; _id = null; await LoadLista(); _ok = "Paciente eliminado.";
        }
        catch (InvalidOperationException ex)
        {
            // Mensaje legible del servicio (paciente con HC/notas/asignaciones).
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            // Error inesperado (incluye violaciones de FK no anticipadas).
            _error = "No se pudo eliminar el paciente: " + ex.Message;
        }
        finally { _busy = false; }
    }

    private async Task Desactivar()
    {
        if (_id is not Guid id) { return; }
        _busy = true; _error = null; _ok = null;
        try
        {
            var ok = await JS.InvokeAsync<bool>("confirm",
                "Marcar este paciente como inactivo? El historial clinico se conserva. Podras reactivarlo despues editando.");
            if (!ok) { return; }
            await Svc.DesactivarAsync(id, await Actor());
            await LoadLista();
            _ok = "Paciente desactivado.";
            // Reflejar el cambio en el form sin cerrar.
            _activo = false;
        }
        catch (Exception ex) { _error = "No se pudo desactivar: " + ex.Message; }
        finally { _busy = false; }
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }
}
