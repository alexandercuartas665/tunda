    private static string FormatTam(long bytes)
    {
        if (bytes < 1024) { return bytes + " B"; }
        if (bytes < 1024 * 1024) { return (bytes / 1024.0).ToString("0.#") + " KB"; }
        return (bytes / (1024.0 * 1024)).ToString("0.##") + " MB";
    }

