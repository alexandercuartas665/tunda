@page "/cfg-empresa"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@inject ISucursalService Svc

<PageTitle>Configuracion de Empresa - DokTrino</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion de la Entidad</div>
        <h1 class="ase-title">Configuracion de Empresa</h1>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-card">
    <div class="ase-card-h">Sucursales / sedes que maneja el sistema
        <button class="btn btn-outline-primary btn-sm ms-2" @onclick="Add">+ Sucursal</button>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead><tr><th>Codigo</th><th>Nombre</th><th>Ciudad</th><th>Direccion</th><th>Telefono</th><th>Activa</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in _items)
                {
                    <tr>
                        <td><input class="form-control form-control-sm mono" style="width:110px" @bind="s.Codigo" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Nombre" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Ciudad" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Direccion" /></td>
                        <td><input class="form-control form-control-sm" style="width:120px" @bind="s.Telefono" /></td>
                        <td class="text-center"><input type="checkbox" class="form-check-input" @bind="s.Activo" /></td>
                        <td class="ase-row-actions">
                            <button class="btn btn-primary btn-sm" @onclick="() => Save(s)">&#10003;</button>
                            @if (s.Id is not null)
                            {
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(s)">&times;</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_items.Count == 0) { <div class="ase-empty">Sin sucursales. Agrega la primera.</div> }
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private List<Row> _items = new();
    private string? _error, _ok;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }
    private async Task Load() => _items = (await Svc.ListAsync()).Select(Row.From).ToList();

    private void Add() => _items.Add(new Row { Activo = true });

    private async Task Save(Row r)
    {
        _error = _ok = null;
        try
        {
            var saved = await Svc.SaveAsync(new SaveSucursalRequest(r.Id, r.Codigo, r.Nombre, r.Direccion, r.Ciudad, r.Telefono, r.Activo), await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            r.Id = saved.Id; _ok = "Sucursal guardada.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Delete(Row r)
    {
        if (r.Id is Guid id) { await Svc.DeleteAsync(id, await Actor()); }
        await Load();
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private sealed class Row
    {
        public Guid? Id { get; set; }
        public string Codigo { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string? Direccion { get; set; }
        public string? Ciudad { get; set; }
        public string? Telefono { get; set; }
        public bool Activo { get; set; } = true;
        public static Row From(SucursalDto d) => new() { Id = d.Id, Codigo = d.Codigo, Nombre = d.Nombre, Direccion = d.Direccion, Ciudad = d.Ciudad, Telefono = d.Telefono, Activo = d.Activo };
    }
}
