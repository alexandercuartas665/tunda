@page "/cfg-empresa"
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using DokTrino.Application.Tenancy
@using DokTrino.Application.Admin
@inject ISucursalService Svc
@inject IModuloMenuService ModulosSvc

<PageTitle>Configuracion de Empresa - Archimente</PageTitle>

<div class="ase-head">
    <div>
        <div class="ase-eyebrow">Configuracion de la Entidad</div>
        <h1 class="ase-title">Configuracion de Empresa</h1>
    </div>
</div>

@if (_error is not null) { <div class="ase-alert">@_error</div> }
@if (_ok is not null) { <div class="ase-ok">@_ok</div> }

<div class="ase-card">
    <div class="ase-card-h">Sucursales / sedes que maneja el sistema
        <button class="btn btn-outline-primary btn-sm ms-2" @onclick="Add">+ Sucursal</button>
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle">
            <thead><tr><th>Codigo</th><th>Nombre</th><th>Ciudad</th><th>Direccion</th><th>Telefono</th><th>Activa</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in _items)
                {
                    <tr>
                        <td><input class="form-control form-control-sm mono" style="width:110px" @bind="s.Codigo" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Nombre" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Ciudad" /></td>
                        <td><input class="form-control form-control-sm" @bind="s.Direccion" /></td>
                        <td><input class="form-control form-control-sm" style="width:120px" @bind="s.Telefono" /></td>
                        <td class="text-center"><input type="checkbox" class="form-check-input" @bind="s.Activo" /></td>
                        <td class="ase-row-actions">
                            <button class="btn btn-primary btn-sm" @onclick="() => Save(s)">&#10003;</button>
                            @if (s.Id is not null)
                            {
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(s)">&times;</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (_items.Count == 0) { <div class="ase-empty">Sin sucursales. Agrega la primera.</div> }
    </div>
</div>

<div class="ase-card">
    <div class="ase-card-h">Modulos del menu</div>
    <p class="ase-modhint">Apaga los modulos que esta entidad no usa. Se ocultan del menu lateral para todos sus usuarios. Un modulo apagado no elimina datos: al volver a encenderlo reaparece.</p>

    @foreach (var grupo in Modulos.GroupBy(m => m.Grupo))
    {
        <div class="ase-modgroup">@grupo.Key</div>
        <div class="ase-modgrid">
            @foreach (var m in grupo)
            {
                <label class="ase-modrow">
                    <input type="checkbox" class="form-check-input"
                           checked="@(!_deshabilitados.Contains(m.Clave))"
                           @onchange="e => Toggle(m.Clave, e)" />
                    <span>@m.Etiqueta</span>
                </label>
            }
        </div>
    }
</div>

<style>
    .ase-modhint { color: #64748b; font-size: .85rem; margin: 0 0 1rem; }
    .ase-modgroup { font-weight: 600; font-size: .8rem; text-transform: uppercase; letter-spacing: .04em; color: #475569; margin: 1rem 0 .5rem; }
    .ase-modgrid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: .35rem .75rem; }
    .ase-modrow { display: flex; align-items: center; gap: .5rem; padding: .3rem .1rem; margin: 0; cursor: pointer; }
    .ase-modrow span { font-size: .9rem; }
</style>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }
    private List<Row> _items = new();
    private string? _error, _ok;

    // Claves de modulos apagados por la entidad. Ausencia = habilitado (default encendido).
    private HashSet<string> _deshabilitados = new(StringComparer.OrdinalIgnoreCase);

    // Espejo de los modulos toggleables de NavMenu. La Clave es el href del modulo.
    private sealed record Modulo(string Clave, string Etiqueta, string Grupo);

    private static readonly Modulo[] Modulos =
    [
        new("radicacion", "Radicacion", "Documental"),
        new("trd", "Encuesta Documental", "Documental"),
        new("archivo-fisico", "Archivo fisico", "Documental"),
        new("topografia-fisica", "Topografia fisica", "Documental"),
        new("archivo-digital", "Archivo digital", "Documental"),
        new("configuracion-documental", "Configuracion Documental", "Documental"),
        new("procesos", "Procesos (BPMN)", "Documental"),
        new("formularios", "Formularios", "Documental"),
        new("capacitaciones", "Capacitaciones", "Documental"),
        new("clasificador-trd", "Clasificador TRD (IA)", "Documental"),
        new("metricas", "Metricas", "Documental"),
        new("bi-servicios", "Power BI Servicios", "Documental"),
        new("cfg-tipologia-archivos", "Tipologia Archivos", "Documental"),

        new("lineas", "Lineas WhatsApp", "Heredados / CRM"),
        new("agentes", "Agentes IA", "Heredados / CRM"),
        new("automatizaciones", "Automatizaciones", "Heredados / CRM"),
        new("cfg-profesionales", "Colaboradores", "Heredados / CRM"),
        new("cfg-tipos-profesional", "Tipos de Colaborador", "Heredados / CRM"),
        new("cfg-subcategorias", "Subcategorias", "Heredados / CRM"),
        new("relaciones-formularios", "Relaciones de formularios", "Heredados / CRM"),
        new("plantillas", "Plantillas", "Heredados / CRM"),

        new("admin/sql-console", "Consola SQL", "Administracion"),
        new("cfg-roles", "Roles y Permisos", "Administracion"),
        new("cfg-usuarios", "Administracion de Usuarios", "Administracion"),
    ];

    protected override async Task OnInitializedAsync()
    {
        await Load();
        _deshabilitados = new HashSet<string>(await ModulosSvc.DeshabilitadosAsync(), StringComparer.OrdinalIgnoreCase);
    }
    private async Task Load() => _items = (await Svc.ListAsync()).Select(Row.From).ToList();

    private async Task Toggle(string clave, ChangeEventArgs e)
    {
        var habilitado = e.Value is bool b && b;
        _error = _ok = null;
        try
        {
            await ModulosSvc.AlternarAsync(clave, habilitado, await Actor());
            if (habilitado) { _deshabilitados.Remove(clave); } else { _deshabilitados.Add(clave); }
            _ok = "Modulo actualizado. Recarga la pagina para ver el menu actualizado.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private void Add() => _items.Add(new Row { Activo = true });

    private async Task Save(Row r)
    {
        _error = _ok = null;
        try
        {
            var saved = await Svc.SaveAsync(new SaveSucursalRequest(r.Id, r.Codigo, r.Nombre, r.Direccion, r.Ciudad, r.Telefono, r.Activo), await Actor());
            if (saved is null) { _error = "No se pudo guardar (sin tenant activo)."; return; }
            r.Id = saved.Id; _ok = "Sucursal guardada.";
        }
        catch (InvalidOperationException ex) { _error = ex.Message; }
    }

    private async Task Delete(Row r)
    {
        if (r.Id is Guid id) { await Svc.DeleteAsync(id, await Actor()); }
        await Load();
    }

    private async Task<Guid> Actor()
    {
        if (AuthState is null) { return Guid.Empty; }
        var st = await AuthState;
        return Guid.TryParse(st.User.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var id) ? id : Guid.Empty;
    }

    private sealed class Row
    {
        public Guid? Id { get; set; }
        public string Codigo { get; set; } = "";
        public string Nombre { get; set; } = "";
        public string? Direccion { get; set; }
        public string? Ciudad { get; set; }
        public string? Telefono { get; set; }
        public bool Activo { get; set; } = true;
        public static Row From(SucursalDto d) => new() { Id = d.Id, Codigo = d.Codigo, Nombre = d.Nombre, Direccion = d.Direccion, Ciudad = d.Ciudad, Telefono = d.Telefono, Activo = d.Activo };
    }
}
