    private RenderFragment RichToolbar(string targetId, Func<bool> emojiOpen, Action<bool> setEmojiOpen) =>@<div class="rt-toolbar">
        <button type="button" class="rt-btn" title="Negrita (*texto*)" @onclick="() => Bold(targetId)"><b>B</b></button>
        <button type="button" class="rt-btn" title="Cursiva (_texto_)" @onclick="() => Italic(targetId)"><i>i</i></button>
        <button type="button" class="rt-btn" title="Tachado (~texto~)" @onclick="() => Strike(targetId)"><s>S</s></button>
        <button type="button" class="rt-btn" title="Monoespaciado" @onclick="() => Mono(targetId)">&lt;/&gt;</button>
        <button type="button" class="rt-btn" title="Vineta" @onclick="() => Bullet(targetId)">&bull;</button>
        <button type="button" class="rt-btn @(emojiOpen() ? "on" : "")" title="Emojis" @onclick="() => setEmojiOpen(!emojiOpen())">😀</button>
        @if (emojiOpen())
        {
            <div class="rt-emojis">
                @foreach (var em in Emojis)
                {
                    <button type="button" class="rt-emoji" @onclick="() => Emoji(targetId, em)">@em</button>
                }
            </div>
        }
    </div>;

    private Task Bold(string id) => Fmt(id, "*", "*");
    private Task Italic(string id) => Fmt(id, "_", "_");
    private Task Strike(string id) => Fmt(id, "~", "~");
    private Task Mono(string id) => Fmt(id, "```", "```");
    private Task Bullet(string id) => JS.InvokeVoidAsync("doktrinoAgentEditor.insert", id, "\n- ").AsTask();
    private async Task Fmt(string id, string before, string after) => await JS.InvokeVoidAsync("doktrinoAgentEditor.wrap", id, before, after);
    private async Task Emoji(string id, string e) => await JS.InvokeVoidAsync("doktrinoAgentEditor.insert", id, e);

    private async Task TestKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) { await SendTestAsync(); }
    }

    private async Task SendTestAsync()
    {
        if (_editId is null || string.IsNullOrWhiteSpace(_testInput)) { return; }
        _testError = null;
        _testMsgs.Add(new TestMsg("user", _testInput!.Trim()));
        _testInput = null;
        _testBusy = true;
        try
        {
            var turns = _testMsgs.Select(m => new AiChatTurn(m.Role, m.Text)).ToList();
            var result = await InferenceSvc.TestChatAsync(_editId.Value, turns, _fPrompt);
            if (result.Ok && (!string.IsNullOrWhiteSpace(result.Text) || result.Attachments is { Count: > 0 }))
            {
                _testMsgs.Add(new TestMsg("model", result.Text ?? "", result.Attachments));
                _usage = await UsageSvc.GetSummaryAsync();
                _quota = await UsageSvc.GetQuotaAsync();
                if (_phoneSend) { await SendToPhoneAsync(result.Text, result.Attachments); }
            }
            else
            {
                _testError = result.Error ?? "El agente no devolvio respuesta.";
            }
        }
        finally { _testBusy = false; }
    }

    // Reenvia la respuesta del agente (texto + adjuntos) a un telefono real por una linea conectada.
    private async Task SendToPhoneAsync(string? text, IReadOnlyList<AiChatAttachment>? attachments)
    {
        _phoneInfo = null;
        if (_phoneLineId == Guid.Empty || string.IsNullOrWhiteSpace(_phoneNumber)) { _phoneInfo = "Elige una linea y un numero."; return; }
        var phone = new string(_phoneNumber.Where(char.IsDigit).ToArray());
        var actor = await ActorAsync();
        try
        {
            if (!string.IsNullOrWhiteSpace(text))
            {
                await Connector.SendTestAsync(_phoneLineId, phone, text!, actor);
            }
            if (attachments is { Count: > 0 })
            {
                foreach (var a in attachments)
                {
                    if (a.ResourceType == AgentResourceType.Text)
                    {
                        if (!string.IsNullOrWhiteSpace(a.Detail)) { await Connector.SendTestAsync(_phoneLineId, phone, a.Detail!, actor); }
                    }
                    else if (a.ResourceType == AgentResourceType.Location)
                    {
                        var parts = (a.Detail ?? "").Split(',');
                        if (parts.Length == 2 && double.TryParse(parts[0], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lat)
                            && double.TryParse(parts[1], System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var lng))
                        {
                            await Connector.SendLocationAsync(_phoneLineId, phone, lat, lng, a.Name, actor);
                        }
                    }
                    else
                    {
                        var b64 = await ReadLocalBase64Async(a.FileUrl);
                        if (b64 is not null)
                        {
                            var mt = a.ResourceType switch
                            {
                                AgentResourceType.Image => MessageMediaType.Image,
                                AgentResourceType.Video => MessageMediaType.Video,
                                AgentResourceType.Audio => MessageMediaType.Audio,
                                _ => MessageMediaType.Document
                            };
                            await Connector.SendMediaAsync(_phoneLineId, phone, mt, b64, null, a.FileName, a.Detail, actor);
                        }
                    }
                }
            }
            _phoneInfo = $"Enviado a {phone}.";
        }
        catch (Exception ex) { _phoneInfo = "No se pudo enviar al telefono: " + ex.Message; }
    }

    private async Task<string?> ReadLocalBase64Async(string? localUrl)
    {
        if (string.IsNullOrWhiteSpace(localUrl)) { return null; }
        var rel = localUrl.TrimStart('/').Replace('/', System.IO.Path.DirectorySeparatorChar);
        var path = System.IO.Path.Combine(Env.WebRootPath, rel);
        if (!System.IO.File.Exists(path)) { return null; }
        return Convert.ToBase64String(await System.IO.File.ReadAllBytesAsync(path));
    }

