    private async Task SaveAgentAsync()
    {
        _editorError = null;
        if (string.IsNullOrWhiteSpace(_fName)) { _editorError = "El nombre es obligatorio."; return; }
        _busy = true;
        try
        {
            var actor = await ActorAsync();
            var model = EffectiveModel(_fProvider);
            if (_editId is null)
            {
                var created = await AgentsSvc.CreateAsync(new CreateAiAgentRequest(_fName, _fRole, _fProvider, model, _fPrompt), actor);
                if (created is null) { _editorError = "No se pudo crear el agente."; return; }
                _editId = created.Id;
            }
            else
            {
                await AgentsSvc.UpdateAsync(_editId.Value, new UpdateAiAgentRequest(_fName, _fRole, _fProvider, model, _fPrompt), actor);
            }
            await ReloadAsync();
        }
        finally { _busy = false; }
    }

