    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_tabSel == "Firma" && _borrador?.Id is not null)
        {
            if (!_firmaCanvasInicializado)
            {
                await Task.Delay(50);
                var ok = await JsRt.InvokeAsync<bool>("doktrinoFirma.init", "nm-firma-canvas");
                if (ok)
                {
                    _firmaCanvasInicializado = true;
                    if (!string.IsNullOrEmpty(_firmaActual))
                    {
                        await JsRt.InvokeVoidAsync("doktrinoFirma.load", "nm-firma-canvas", _firmaActual);
                    }
                }
            }
            if (!_firmaPacienteCanvasInicializado)
            {
                await Task.Delay(50);
                var okP = await JsRt.InvokeAsync<bool>("doktrinoFirma.init", "nm-firma-paciente-canvas");
                if (okP)
                {
                    _firmaPacienteCanvasInicializado = true;
                    if (!string.IsNullOrEmpty(_firmaPacienteActual))
                    {
                        await JsRt.InvokeVoidAsync("doktrinoFirma.load", "nm-firma-paciente-canvas", _firmaPacienteActual);
                    }
                }
            }
        }
        else if (_tabSel != "Firma")
        {
            _firmaCanvasInicializado = false;
            _firmaPacienteCanvasInicializado = false;
        }
    }

