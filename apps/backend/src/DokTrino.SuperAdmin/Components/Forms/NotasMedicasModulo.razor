@code {
    [Parameter] public string? NombrePacienteCtx { get; set; }
    [Parameter] public string? DocumentoPacienteCtx { get; set; }
    [Parameter] public int? SessionNoCtx { get; set; }
    [Parameter] public Guid? AsignacionTurnoIdCtx { get; set; }
    [Parameter] public Guid? HistoriaClinicaId { get; set; }
    [Parameter] public Guid? PacienteId { get; set; }
    /// <summary>Two-way binding del contenido de la nota en redaccion para que el chat IA externo pueda leerlo sin reaches al servicio.</summary>
    [Parameter] public string? ContenidoNotaActual { get; set; }
    [Parameter] public EventCallback<string?> ContenidoNotaActualChanged { get; set; }
    /// <summary>Notifica al padre cuando una nota se guarda con exito. bool true = Definitivo, false = Parcial.</summary>
    [Parameter] public EventCallback<bool> OnNotaGuardada { get; set; }
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    /// <summary>Notifica al parent cada vez que el textarea cambia, para que el chat IA tenga el texto en vivo.</summary>
    private async Task EmitirContenidoActualAsync()
    {
        if (ContenidoNotaActualChanged.HasDelegate)
        {
            await ContenidoNotaActualChanged.InvokeAsync(_borrador?.Contenido);
        }
    }

    private readonly string[] _tabs = new[] {
        "Notas", "Diligenciamiento", "Firma", "Seguimiento", "Documentos Externos", "Ver Historial"
    };
    private readonly string[] _kanbanCols = new[] { "Estable", "Vigilancia", "Alerta", "Critico" };
    private string _tabSel = "Diligenciamiento";

    private NotaBorrador _borrador = new();
    private NotaConteoDto _conteo = new(0, 0);
    private List<NotaMedicaDto> _notas = new();
    private List<NotaMedicaTarjetaDto> _historialPaciente = new();
    private List<NotaDocumentoDto> _documentos = new();
    private bool _busy;
    private bool _guardandoDef;
    private bool _docSubiendo;
    private string? _error;
    private string? _ok;

    private string _docCategoria = "";
    private string _docTipoTerapia = "";
    private string _docMes = "";
    private string _docAnotaciones = "";
    private NotaDocumentoDto? _preview;
    private string? _firmaActual;
    private string? _firmaPacienteActual;
    private bool _firmaCanvasInicializado;
    private bool _firmaPacienteCanvasInicializado;

    // Tipologias activas para el dropdown Categoria del tab Documentos Externos.
    private List<TipologiaArchivoDto> _tipologias = new();

    // ===== Firma remota por WhatsApp =====
    private FirmaRequestDto? _firmaSolicitudActiva;
    private bool _firmaRemotaBusy;
    private string? _firmaRemotaMsg;
    private string? _firmaRemotaError;
    /// <summary>Timer del polling cada 5s mientras esperamos la firma del paciente.</summary>
    private System.Threading.Timer? _firmaPollTimer;
    /// <summary>Cache del nombre del profesional para mostrar bajo la firma. Se setea al cargar la nota.</summary>
    private string? NombreEspecialistaActual;
    [Inject] IJSRuntime JsRt { get; set; } = default!;

    // Filtros del tab Notas (tabla)
    private string _filPaciente = "";
    private DateOnly? _filDesde;
    private DateOnly? _filHasta;
    private NotaMedicaDto? _filaSeleccionada;

    // Filtros del tab Ver Historial (tarjetas)
    private DateOnly? _histDesde;
    private DateOnly? _histHasta;
    private string _histEspecialista = "";
    private string _histEstado = "";
    private string _histCriticidad = "";

    /// <summary>Aplica los filtros de Ver Historial al listado completo.</summary>
    private List<NotaMedicaTarjetaDto> _historialFiltrado => _historialPaciente
        .Where(n => !_histDesde.HasValue || n.FechaNota >= _histDesde.Value)
        .Where(n => !_histHasta.HasValue || n.FechaNota <= _histHasta.Value)
        .Where(n => string.IsNullOrEmpty(_histEspecialista) ||
                    string.Equals(n.EspecialistaNombre, _histEspecialista, StringComparison.OrdinalIgnoreCase))
        .Where(n => string.IsNullOrEmpty(_histEstado) ||
                    string.Equals(n.Estado, _histEstado, StringComparison.OrdinalIgnoreCase))
        .Where(n => string.IsNullOrEmpty(_histCriticidad) ||
                    string.Equals(n.Criticidad, _histCriticidad, StringComparison.OrdinalIgnoreCase))
        .ToList();

    /// <summary>Lista unica de nombres de especialista del historial (para el dropdown).</summary>
    private IEnumerable<string> EspecialistasDistintos() =>
        _historialPaciente
            .Where(n => !string.IsNullOrWhiteSpace(n.EspecialistaNombre))
            .Select(n => n.EspecialistaNombre!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x);

    private void LimpiarFiltrosHistorial()
    {
        _histDesde = null;
        _histHasta = null;
        _histEspecialista = "";
        _histEstado = "";
        _histCriticidad = "";
    }

    /// <summary>Nombre legible del profesional logueado (claim Name o email).</summary>
    private async Task<string?> GetEspecialistaNombreAsync()
    {
        if (AuthState is null) { return null; }
        try
        {
            var st = await AuthState;
            return st.User.Identity?.Name
                ?? st.User.FindFirst(ClaimTypes.Name)?.Value
                ?? st.User.FindFirst(ClaimTypes.Email)?.Value
                ?? st.User.FindFirst("name")?.Value;
        }
        catch { return null; }
    }

    private List<NotaMedicaDto> _notasFiltradas => _notas
        .Where(n => !_filDesde.HasValue || n.FechaNota >= _filDesde.Value)
        .Where(n => !_filHasta.HasValue || n.FechaNota <= _filHasta.Value)
        .OrderByDescending(n => n.FechaNota).ThenByDescending(n => n.HoraNota)
        .ToList();

    private string CodAsignDe(NotaMedicaDto n) => AsignacionTurnoIdCtx?.ToString()[..8] ?? "";
    private string TipoDe(NotaMedicaDto n) => "";

    private void VerNotaSeleccionada()
    {
        if (_filaSeleccionada is NotaMedicaDto n) { CargarEnBorrador(n); }
    }

    private Guid? _ultimoHcId;

    protected override async Task OnParametersSetAsync()
    {
        if (HistoriaClinicaId != _ultimoHcId)
        {
            _ultimoHcId = HistoriaClinicaId;
            NuevoBorrador();
            await Refrescar();
            // Tipologias para el dropdown Categoria del tab Documentos Externos.
            // Si el tenant no tiene ninguna, sembramos defaults para no quedarse vacio.
            _tipologias = (await TipSvc.ListAsync(soloActivos: true)).ToList();
            if (_tipologias.Count == 0)
            {
                await TipSvc.SeedDefaultsAsync();
                _tipologias = (await TipSvc.ListAsync(soloActivos: true)).ToList();
            }
        }
    }

    private async Task Refrescar()
    {
        if (HistoriaClinicaId is not Guid hid) { return; }
        _busy = true; _error = null;
        try
        {
            _conteo = await NotaSvc.ContarPorHistoriaAsync(hid);
            _notas = (await NotaSvc.ListarPorHistoriaAsync(hid)).ToList();
            if (PacienteId is Guid pid)
            {
                _historialPaciente = (await NotaSvc.ListarHistorialPacienteAsync(pid)).ToList();
            }
            // Cargar documentos del borrador actual si hay nota guardada.
            if (_borrador?.Id is Guid nid)
            {
                _documentos = (await NotaSvc.ListarDocumentosAsync(nid)).ToList();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task RefrescarNotas() => await Refrescar();
    private async Task RefrescarHistorial() => await Refrescar();

    private void NuevoBorrador()
    {
        _borrador = new NotaBorrador
        {
            FechaNota = DateOnly.FromDateTime(DateTime.Today),
            SessionNoStr = SessionNoCtx?.ToString() ?? "",
            CodigoUnico = "",
            Criticidad = "Estable",
            Contenido = ""
        };
        _error = _ok = null;
    }

    private void CargarEnBorrador(NotaMedicaDto n)
    {
        _borrador = new NotaBorrador
        {
            Id = n.Id,
            FechaNota = n.FechaNota,
            HoraNotaStr = n.HoraNota is TimeOnly t ? t.ToString("HH:mm") : "",
            SessionNoStr = n.SessionNo?.ToString() ?? "",
            CodigoUnico = n.CodigoUnico,
            Criticidad = n.Criticidad,
            Contenido = n.Contenido
        };
        _firmaActual = n.FirmaDataUrl;
        _firmaPacienteActual = n.FirmaPacienteDataUrl;
        NombreEspecialistaActual = n.EspecialistaNombre;
        _firmaCanvasInicializado = false; // forzar re-init si se entra a tab Firma
        _firmaPacienteCanvasInicializado = false;
        _tabSel = "Diligenciamiento";
        _ok = null;
        _error = null;
        // Refrescar estado de solicitud de firma remota (si hay alguna pendiente o
        // completada para esta nota), para que el bloque del tab Firma muestre
        // el boton "Solicitar" o el estado actual. Disparado en fire-and-forget
        // porque CargarEnBorrador es void; no es critico esperarlo.
        _ = RefrescarSolicitudFirmaAsync();
        _ = RecargarDocumentos();
    }

    private async Task RecargarDocumentos()
    {
        if (_borrador?.Id is Guid nid)
        {
            _documentos = (await NotaSvc.ListarDocumentosAsync(nid)).ToList();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task GuardarAsync(bool definitivo)
    {
        if (HistoriaClinicaId is not Guid hid || PacienteId is not Guid pid)
        {
            _error = "Falta paciente o historia."; return;
        }
        if (string.IsNullOrWhiteSpace(_borrador.Contenido))
        {
            _error = "El contenido es obligatorio."; return;
        }

        _busy = true; _guardandoDef = definitivo; _error = _ok = null;
        try
        {
            TimeOnly? hora = TimeOnly.TryParse(_borrador.HoraNotaStr, out var hh) ? hh : null;
            int? sesion = int.TryParse(_borrador.SessionNoStr, out var ss) ? ss : (int?)SessionNoCtx;
            var especialista = await GetEspecialistaNombreAsync();
            var req = new GuardarNotaRequest(
                _borrador.Id, hid, pid, AsignacionTurnoIdCtx, sesion,
                _borrador.FechaNota ?? DateOnly.FromDateTime(DateTime.Today),
                hora, _borrador.Contenido!,
                definitivo ? "Definitivo" : "Parcial",
                _borrador.Criticidad ?? "Estable",
                null,
                especialista);
            var saved = await NotaSvc.GuardarAsync(req, Guid.Empty);
            _ok = definitivo ? "Nota guardada como DEFINITIVA." : "Nota guardada como PARCIAL.";
            _borrador.Id = saved.Id;
            _borrador.CodigoUnico = saved.CodigoUnico;
            await Refrescar();
            await RecargarDocumentos();
            // Notificar al padre para que pueda disparar la auto-revision IA si la regla lo configuro.
            if (OnNotaGuardada.HasDelegate) { await OnNotaGuardada.InvokeAsync(definitivo); }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; _guardandoDef = false; }
    }

    private async Task MoverEnKanban(NotaMedicaDto n, string? nuevaCritStr)
    {
        if (string.IsNullOrWhiteSpace(nuevaCritStr) || nuevaCritStr == n.Criticidad) { return; }
        await NotaSvc.ActualizarCriticidadAsync(n.Id, nuevaCritStr, Guid.Empty);
        var idx = _notas.FindIndex(x => x.Id == n.Id);
        if (idx >= 0) { _notas[idx] = n with { Criticidad = nuevaCritStr }; }
    }

    private async Task OnDocSeleccionado(InputFileChangeEventArgs e)
    {
        if (_borrador.Id is not Guid notaId) { _error = "Guarda la nota primero."; return; }
        _docSubiendo = true; _error = null;
        try
        {
            var f = e.File;
            var ext = Path.GetExtension(f.Name);
            var nombreEnDisco = $"{Guid.NewGuid()}{ext}";
            var dir = Path.Combine(Env.WebRootPath, "uploads", "notas");
            Directory.CreateDirectory(dir);
            var rutaDisco = Path.Combine(dir, nombreEnDisco);
            await using (var fs = File.Create(rutaDisco))
            await using (var rs = f.OpenReadStream(20L * 1024 * 1024))
            {
                await rs.CopyToAsync(fs);
            }
            var rutaWeb = $"/uploads/notas/{nombreEnDisco}";

            var d = await NotaSvc.AdjuntarDocumentoAsync(new AdjuntarDocumentoRequest(
                notaId, f.Name, rutaWeb, f.ContentType, f.Size,
                _docCategoria, _docTipoTerapia, _docMes, _docAnotaciones), Guid.Empty);
            _documentos.Insert(0, d);
            _docAnotaciones = "";
        }
        catch (Exception ex) { _error = "No se pudo subir el archivo: " + ex.Message; }
        finally { _docSubiendo = false; }
    }

