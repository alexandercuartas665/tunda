    // ===== Firma remota por WhatsApp =====
    private async Task SolicitarFirmaWhatsAppAsync()
    {
        _firmaRemotaError = _firmaRemotaMsg = null;
        if (_borrador?.Id is not Guid notaId) { _firmaRemotaError = "Primero guarda la nota como parcial."; return; }
        if (PacienteId is not Guid pacienteId) { _firmaRemotaError = "Falta el paciente."; return; }

        _firmaRemotaBusy = true;
        try
        {
            // 1. Cargar el paciente para tener el telefono.
            var paciente = await PacientesSvc.GetAsync(pacienteId);
            if (paciente?.Telefono is null or "")
            {
                _firmaRemotaError = "El paciente no tiene telefono asignado. Edita su telefono desde el chat WhatsApp del modulo.";
                return;
            }

            // 2. Buscar una linea WhatsApp conectada del tenant.
            var lineas = (await LineasSvc.ListAsync())
                .Where(l => l.Status == DokTrino.Domain.Enums.WhatsAppLineStatus.Connected)
                .ToList();
            if (lineas.Count == 0)
            {
                _firmaRemotaError = "No hay lineas WhatsApp conectadas. Conecta una en el modulo Lineas WhatsApp.";
                return;
            }

            // 3. Crear la solicitud (o reutilizar la pendiente).
            var req = await FirmaSvc.CrearOReutilizarAsync(notaId, pacienteId, paciente.Telefono!, paciente.NombreCompleto, Guid.Empty);
            if (req is null)
            {
                _firmaRemotaError = "No se pudo crear la solicitud de firma.";
                return;
            }

            // 4. Construir URL absoluta del link publico.
            var urlAbsoluta = new Uri(new Uri(Nav.BaseUri), req.PublicPath).ToString();

            // 5. Enviar por WhatsApp con la primera linea conectada.
            var send = await FirmaSvc.EnviarPorWhatsAppAsync(req.Id, lineas[0].Id, urlAbsoluta, Guid.Empty);
            if (!send.Ok)
            {
                _firmaRemotaError = "El link se genero pero no se pudo enviar el WhatsApp: " + (send.Error ?? "(sin detalle)");
                _firmaSolicitudActiva = req;
                return;
            }

            _firmaSolicitudActiva = req;
            _firmaRemotaMsg = $"Link enviado al +{req.Telefono}. Vence el {req.ExpiresAt.LocalDateTime:dd/MM HH:mm}.";
            ArrancarPollingFirmaAsync(req.Id);
        }
        catch (Exception ex) { _firmaRemotaError = ex.Message; }
        finally { _firmaRemotaBusy = false; }
    }

    private async Task CancelarFirmaRemotaAsync()
    {
        if (_firmaSolicitudActiva is null) { return; }
        _firmaRemotaBusy = true;
        try
        {
            await FirmaSvc.CancelarAsync(_firmaSolicitudActiva.Id, Guid.Empty);
            _firmaSolicitudActiva = null;
            _firmaRemotaMsg = "Solicitud cancelada.";
            DetenerPollingFirma();
        }
        finally { _firmaRemotaBusy = false; }
    }

    /// <summary>Arranca un timer de polling cada 5s para detectar cuando el paciente firmo.
    /// Cuando la solicitud queda en Completada, dibuja la firma en el canvas + persiste.</summary>
    private void ArrancarPollingFirmaAsync(Guid solicitudId)
    {
        DetenerPollingFirma();
        _firmaPollTimer = new System.Threading.Timer(async _ =>
        {
            try
            {
                var estado = await FirmaSvc.ObtenerEstadoAsync(solicitudId);
                if (estado is null) { return; }
                if (estado.Status == DokTrino.Domain.Enums.FirmaRequestStatus.Completada && !string.IsNullOrEmpty(estado.ImageDataUrl))
                {
                    DetenerPollingFirma();
                    await InvokeAsync(async () =>
                    {
                        _firmaPacienteActual = estado.ImageDataUrl;
                        if (_firmaSolicitudActiva is not null) { _firmaSolicitudActiva = _firmaSolicitudActiva with { Status = estado.Status, CompletedAt = estado.CompletedAt }; }
                        // Refrescar el canvas con la firma capturada.
                        try { await JsRt.InvokeVoidAsync("doktrinoFirma.load", "nm-firma-paciente-canvas", estado.ImageDataUrl); } catch { }
                        // Refrescar la lista de Documentos Externos: el backend creo un PNG con
                        // categoria "Firma del Paciente" y queremos que aparezca sin recargar la nota.
                        await RecargarDocumentos();
                        _firmaRemotaMsg = "Firma capturada y guardada. Tambien queda como documento externo (categoria 'Firma del Paciente').";
                        StateHasChanged();
                    });
                }
                else if (estado.Status == DokTrino.Domain.Enums.FirmaRequestStatus.Expirada
                      || estado.Status == DokTrino.Domain.Enums.FirmaRequestStatus.Cancelada)
                {
                    DetenerPollingFirma();
                    await InvokeAsync(() =>
                    {
                        if (_firmaSolicitudActiva is not null) { _firmaSolicitudActiva = _firmaSolicitudActiva with { Status = estado.Status }; }
                        _firmaRemotaError = estado.Status == DokTrino.Domain.Enums.FirmaRequestStatus.Expirada ? "El link expiro sin firma." : "Solicitud cancelada.";
                        StateHasChanged();
                    });
                }
            }
            catch { /* polling resiliente */ }
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private void DetenerPollingFirma()
    {
        _firmaPollTimer?.Dispose();
        _firmaPollTimer = null;
    }

    /// <summary>Cuando se carga una nota guardada, refrescamos la solicitud de firma activa
    /// (si la hay) para que el bloque del tab Firma muestre el estado correcto al volver.</summary>
    private async Task RefrescarSolicitudFirmaAsync()
    {
        if (_borrador?.Id is not Guid notaId) { _firmaSolicitudActiva = null; DetenerPollingFirma(); return; }
        _firmaSolicitudActiva = await FirmaSvc.ObtenerActivaPorNotaAsync(notaId);
        if (_firmaSolicitudActiva?.Status == FirmaRequestStatus.Pendiente)
        {
            ArrancarPollingFirmaAsync(_firmaSolicitudActiva.Id);
        }
        else { DetenerPollingFirma(); }
    }

    public void Dispose()
    {
        DetenerPollingFirma();
    }

    private async Task GuardarFirmaAsync()
    {
        if (_borrador?.Id is not Guid nid) { return; }
        var dataUrl = await JsRt.InvokeAsync<string?>("doktrinoFirma.getDataUrl", "nm-firma-canvas");
        if (string.IsNullOrWhiteSpace(dataUrl)) { _error = "Firma del profesional vacia."; return; }
        _busy = true; _error = _ok = null;
        try
        {
            var actual = await NotaSvc.GetAsync(nid);
            if (actual is null) { _error = "Nota no encontrada."; return; }

            // Guardamos la firma reutilizando GuardarAsync (no cambia el estado).
            TimeOnly? hora = TimeOnly.TryParse(_borrador.HoraNotaStr, out var hh) ? hh : actual.HoraNota;
            var req = new GuardarNotaRequest(
                nid, actual.HistoriaClinicaId, actual.PacienteId, AsignacionTurnoIdCtx,
                actual.SessionNo, actual.FechaNota, hora, actual.Contenido,
                actual.Estado, actual.Criticidad, dataUrl,
                EspecialistaNombre: null,
                FirmaPacienteDataUrl: null);
            await NotaSvc.GuardarAsync(req, Guid.Empty);
            _firmaActual = dataUrl;
            _ok = "Firma del profesional guardada.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task GuardarFirmaPacienteAsync()
    {
        if (_borrador?.Id is not Guid nid) { return; }
        var dataUrl = await JsRt.InvokeAsync<string?>("doktrinoFirma.getDataUrl", "nm-firma-paciente-canvas");
        if (string.IsNullOrWhiteSpace(dataUrl)) { _error = "Firma del paciente vacia."; return; }
        _busy = true; _error = _ok = null;
        try
        {
            var actual = await NotaSvc.GetAsync(nid);
            if (actual is null) { _error = "Nota no encontrada."; return; }

            TimeOnly? hora = TimeOnly.TryParse(_borrador.HoraNotaStr, out var hh) ? hh : actual.HoraNota;
            // Solo enviamos la firma del paciente; la del profesional queda como esta.
            var req = new GuardarNotaRequest(
                nid, actual.HistoriaClinicaId, actual.PacienteId, AsignacionTurnoIdCtx,
                actual.SessionNo, actual.FechaNota, hora, actual.Contenido,
                actual.Estado, actual.Criticidad,
                FirmaDataUrl: null,
                EspecialistaNombre: null,
                FirmaPacienteDataUrl: dataUrl);
            await NotaSvc.GuardarAsync(req, Guid.Empty);
            _firmaPacienteActual = dataUrl;
            _ok = "Firma del paciente guardada.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private static string FormatBytes(long b)
    {
        if (b < 1024) return $"{b} B";
        if (b < 1024 * 1024) return $"{b / 1024} KB";
        return $"{b / (1024 * 1024)} MB";
    }

