@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Forms
@using DokTrino.Application.Tenancy
@using DokTrino.Domain.Enums
@inject INotaMedicaService NotaSvc
@inject IFirmaRemotaService FirmaSvc
@inject IWhatsAppLineService LineasSvc
@inject IPacienteService PacientesSvc
@inject ITipologiaArchivoService TipSvc
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject NavigationManager Nav
@implements IDisposable

@*
   Modulo reutilizable de Notas Medicas. Se invoca como submodulo desde
   /atencion recibiendo paciente + sesion + HistoriaClinicaId como contexto.
*@

<div class="nm-header">
    <div>
        <h1 class="nm-title">&#9994; Notas Medicas</h1>
        <div class="nm-subtitle">Modulo Profesional</div>
    </div>
    <div class="nm-header-right">
        @if (_borrador is not null && !string.IsNullOrEmpty(_borrador.Id?.ToString()))
        {
            <small class="text-muted">Editando: @_borrador.CodigoUnico</small>
        }
    </div>
</div>

<div class="nm-tabs">
    @foreach (var t in _tabs)
    {
        <button class="nm-tab @(t == _tabSel ? "sel" : "")" @onclick="() => _tabSel = t">
            @t
            @if (t == "Notas")
            {
                <span class="nm-tab-badge">@_conteo.Definitivas/@_conteo.Parciales</span>
            }
        </button>
    }
</div>

@* =================== TAB DILIGENCIAMIENTO =================== *@
@if (_tabSel == "Diligenciamiento")
{
    if (HistoriaClinicaId is null || PacienteId is null)
    {
        <div class="ase-card nm-panel"><div class="ase-empty">Selecciona o inicia una historia para registrar notas.</div></div>
    }
    else
    {
        <div class="ase-card nm-panel">
            @if (_error is not null) { <div class="ase-alert">@_error</div> }
            @if (_ok is not null) { <div class="ase-ok">@_ok</div> }

            <div class="nm-row">
                <div class="ase-f">
                    <label>Seleccionar Fecha Nota</label>
                    <input type="date" class="form-control form-control-sm" @bind="_borrador.FechaNota" />
                </div>
                <div class="ase-f nm-col-2">
                    <label>Nombre Paciente</label>
                    <input class="form-control form-control-sm asg-ro" readonly value="@NombrePacienteCtx" />
                </div>
                <div class="ase-f">
                    <label>Documento Paciente</label>
                    <input class="form-control form-control-sm asg-ro mono" readonly value="@DocumentoPacienteCtx" />
                </div>
            </div>
            <div class="nm-row">
                <div class="ase-f">
                    <label>Codigo Unico Nota</label>
                    <input class="form-control form-control-sm asg-ro mono" readonly value="@_borrador.CodigoUnico" />
                </div>
                <div class="ase-f">
                    <label>Hora Nota</label>
                    <select class="form-select form-select-sm" @bind="_borrador.HoraNotaStr">
                        <option value="">Selecciona...</option>
                        @for (int h = 6; h <= 20; h++)
                        {
                            <option value="@($"{h:00}:00")">@($"{h:00}:00")</option>
                            <option value="@($"{h:00}:30")">@($"{h:00}:30")</option>
                        }
                    </select>
                </div>
                <div class="ase-f">
                    <label>Criticidad</label>
                    <select class="form-select form-select-sm" @bind="_borrador.Criticidad">
                        <option value="Estable">Estable</option>
                        <option value="Vigilancia">Vigilancia</option>
                        <option value="Alerta">Alerta</option>
                        <option value="Critico">Critico</option>
                    </select>
                </div>
                <div class="ase-f">
                    <label>Sesion No</label>
                    <input class="form-control form-control-sm mono" @bind="_borrador.SessionNoStr" />
                </div>
            </div>
            <div class="ase-f ase-f-wide nm-row-full">
                <label>Contenido de la Nota</label>
                <textarea class="form-control form-control-sm" rows="12"
                          @bind="_borrador.Contenido" @bind:event="oninput" @bind:after="EmitirContenidoActualAsync"
                          placeholder="Describe la atencion, hallazgos, plan, recomendaciones..."></textarea>
            </div>
            <div class="nm-acciones-center">
                <button class="btn btn-outline-secondary" @onclick="() => GuardarAsync(false)" disabled="@_busy">
                    @(_busy && !_guardandoDef ? "Guardando..." : "Guardado Parcial")
                </button>
                <button class="btn btn-primary nm-btn-gradient" @onclick="() => GuardarAsync(true)" disabled="@_busy">
                    @(_busy && _guardandoDef ? "Guardando..." : "Guardado Definitivo")
                </button>
                <button class="btn btn-outline-danger" @onclick="NuevoBorrador" disabled="@_busy">Cancelar</button>
            </div>
        </div>
    }
}

@* =================== TAB NOTAS (antes "Notas Completadas") =================== *@
else if (_tabSel == "Notas")
{
    <div class="ase-card nm-panel">
        <div class="nm-row-inline">
            <label class="nm-lbl-inline">Paciente:</label>
            <select class="form-select form-select-sm nm-w-280" @bind="_filPaciente">
                <option value="">Todos</option>
                <option value="@DocumentoPacienteCtx">@NombrePacienteCtx</option>
            </select>
            <button class="btn btn-outline-secondary btn-sm" @onclick="RefrescarNotas" disabled="@_busy">Ver Todos</button>
        </div>
        <div class="nm-row-inline">
            <label class="nm-lbl-inline">Desde:</label>
            <input type="date" class="form-control form-control-sm nm-w-150" @bind="_filDesde" />
            <label class="nm-lbl-inline">Hasta:</label>
            <input type="date" class="form-control form-control-sm nm-w-150" @bind="_filHasta" />
            <span class="nm-sep">|</span>
            <span class="nm-counts">
                <strong>@_conteo.Definitivas</strong> definitivas
                <span class="nm-sep">/</span>
                <strong>@_conteo.Parciales</strong> parciales
            </span>
            <span class="ms-auto"></span>
            <button class="btn btn-outline-secondary btn-sm" disabled>Generar Reporte</button>
        </div>
        <div class="nm-row-inline">
            <button class="btn btn-outline-primary btn-sm" disabled="@(_filaSeleccionada is null)" @onclick="VerNotaSeleccionada">Ver Nota</button>
            <button class="btn btn-outline-secondary btn-sm" disabled>Generar Informes Fin</button>
            <button class="btn btn-outline-success btn-sm" disabled>Crear Cuenta de Cobro</button>
        </div>

        <div class="nm-grid-wrap">
            <table class="table table-sm nm-tbl">
                <thead>
                    <tr>
                        <th></th>
                        <th>CodInt</th>
                        <th>CodAsign</th>
                        <th>Tipo</th>
                        <th>Sesion</th>
                        <th>Estado</th>
                        <th>Criticidad</th>
                        <th>Paciente ID</th>
                        <th>Paciente</th>
                        <th>Profesional</th>
                        <th>Fecha Nota</th>
                        <th>Hora</th>
                        <th>Contenido</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_notasFiltradas.Count == 0)
                    {
                        <tr><td colspan="13" class="ase-empty">No hay notas registradas. Usa "Diligenciamiento" para crear una.</td></tr>
                    }
                    @foreach (var n in _notasFiltradas)
                    {
                        <tr class="@(n.Id == _filaSeleccionada?.Id ? "nm-row-sel" : "")" @onclick="() => _filaSeleccionada = n">
                            <td><input type="radio" checked="@(n.Id == _filaSeleccionada?.Id)" /></td>
                            <td class="mono">@n.CodigoUnico</td>
                            <td class="mono">@CodAsignDe(n)</td>
                            <td>@TipoDe(n)</td>
                            <td class="text-center">@(n.SessionNo?.ToString() ?? "-")</td>
                            <td>
                                @if (n.Estado == "Definitivo")
                                {
                                    <span class="nm-pill nm-pill-def">DEFINITIVO</span>
                                }
                                else
                                {
                                    <span class="nm-pill nm-pill-par">PARCIAL</span>
                                }
                            </td>
                            <td><span class="nm-crit-tag @CritClass(n.Criticidad)">@n.Criticidad</span></td>
                            <td class="mono">@DocumentoPacienteCtx</td>
                            <td>@NombrePacienteCtx</td>
                            <td>@(n.EspecialistaNombre ?? "")</td>
                            <td>@n.FechaNota.ToString("dd/MM/yyyy")</td>
                            <td>@(n.HoraNota is TimeOnly h ? h.ToString("HH:mm") : "")</td>
                            <td class="nm-truncate" title="@n.Contenido">@n.Contenido</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* =================== TAB SEGUIMIENTO (KANBAN) =================== *@
else if (_tabSel == "Seguimiento")
{
    <div class="ase-card nm-panel">
        <div class="nm-row-inline">
            <strong>Seguimiento por criticidad</strong>
            <span class="ms-auto"></span>
            <small class="text-muted">Cambia el dropdown de cada nota para moverla de columna.</small>
        </div>
        <div class="nm-kanban">
            @foreach (var col in _kanbanCols)
            {
                var items = _notas.Where(n => n.Criticidad == col).ToList();
                <div class="nm-kanban-col">
                    <div class="nm-kanban-h @CritClass(col)">
                        <span>@col</span>
                        <span class="nm-kanban-count">@items.Count</span>
                    </div>
                    <div class="nm-kanban-body">
                        @if (items.Count == 0)
                        {
                            <div class="nm-kanban-empty">Sin notas</div>
                        }
                        @foreach (var n in items)
                        {
                            <div class="nm-kanban-card @CritClass(n.Criticidad)">
                                <div class="nm-card-fecha">@n.FechaNota.ToString("dd/MM/yyyy")</div>
                                <div class="nm-kanban-prev">@(n.Contenido.Length > 90 ? n.Contenido.Substring(0,90) + "..." : n.Contenido)</div>
                                <select class="form-select form-select-sm" value="@n.Criticidad"
                                        @onchange="@(e => MoverEnKanban(n, e.Value?.ToString()))">
                                    @foreach (var c in _kanbanCols) { <option value="@c">@c</option> }
                                </select>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

@* =================== TAB FIRMA (DEL PROFESIONAL) =================== *@
else if (_tabSel == "Firma")
{
    <div class="ase-card nm-panel">
        @if (_borrador?.Id is null)
        {
            <div class="ase-empty">Guarda primero la nota (parcial o definitiva) para poder firmar.</div>
        }
        else
        {
            <div class="nm-firmas-grid">
                @* ====== Firma del Profesional ====== *@
                <div class="nm-firma-block">
                    <h6 class="nm-firma-h">
                        Firma del Profesional
                        @if (!string.IsNullOrEmpty(_firmaActual)) { <span class="nm-firma-badge nm-firma-badge-ok">&#10003; Firmada</span> }
                        else { <span class="nm-firma-badge nm-firma-badge-pendiente">Pendiente</span> }
                    </h6>
                    <div class="nm-firma-subt">@(NombreEspecialistaActual ?? "(sin nombre)")</div>
                    <div class="nm-firma-instr">Firma con el dedo (movil) o el mouse (escritorio).</div>
                    <canvas id="nm-firma-canvas" class="nm-firma-canvas-real"></canvas>
                    <div class="nm-firma-acciones">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarFirmaAsync" disabled="@_busy">&#129529; Limpiar</button>
                        <button class="btn btn-primary btn-sm nm-btn-gradient" @onclick="GuardarFirmaAsync" disabled="@_busy">&#128190; Guardar firma profesional</button>
                    </div>
                </div>

                @* ====== Firma del Paciente ====== *@
                <div class="nm-firma-block">
                    <h6 class="nm-firma-h">
                        Firma del Paciente
                        @if (!string.IsNullOrEmpty(_firmaPacienteActual)) { <span class="nm-firma-badge nm-firma-badge-ok">&#10003; Firmada</span> }
                        else { <span class="nm-firma-badge nm-firma-badge-pendiente">Pendiente</span> }
                    </h6>
                    <div class="nm-firma-subt">@(NombrePacienteCtx ?? "(sin nombre)")</div>
                    <div class="nm-firma-instr">El paciente o acudiente confirma haber recibido la atencion.</div>
                    <canvas id="nm-firma-paciente-canvas" class="nm-firma-canvas-real"></canvas>
                    <div class="nm-firma-acciones">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="LimpiarFirmaPacienteAsync" disabled="@_busy">&#129529; Limpiar</button>
                        <button class="btn btn-primary btn-sm nm-btn-gradient" @onclick="GuardarFirmaPacienteAsync" disabled="@_busy">&#128190; Guardar firma paciente</button>
                    </div>

                    @* ===== Solicitud remota de firma por WhatsApp ===== *@
                    @if (_borrador?.Id is Guid notaIdParaFirma)
                    {
                        <div class="nm-firma-remota">
                            @if (_firmaSolicitudActiva is null)
                            {
                                <button class="btn btn-success btn-sm" @onclick="SolicitarFirmaWhatsAppAsync" disabled="@_firmaRemotaBusy" title="Genera un link y lo envia por WhatsApp al paciente">
                                    &#128241; Solicitar firma por WhatsApp
                                </button>
                            }
                            else if (_firmaSolicitudActiva.Status == FirmaRequestStatus.Pendiente)
                            {
                                <div class="nm-firma-remota-pend">
                                    <div><strong>Solicitud enviada</strong> al +@_firmaSolicitudActiva.Telefono</div>
                                    <div class="text-muted" style="font-size:11px;">Esperando que el paciente firme desde su celular. Refrescando cada 5 segundos...</div>
                                    <div class="text-muted" style="font-size:11px;">Vence: @_firmaSolicitudActiva.ExpiresAt.LocalDateTime.ToString("dd/MM HH:mm")</div>
                                    <button class="btn btn-link btn-sm" @onclick="CancelarFirmaRemotaAsync" disabled="@_firmaRemotaBusy">Cancelar solicitud</button>
                                </div>
                            }
                            else if (_firmaSolicitudActiva.Status == FirmaRequestStatus.Completada)
                            {
                                <div class="nm-firma-remota-ok">
                                    &#10003; Firma capturada por WhatsApp el @(_firmaSolicitudActiva.CompletedAt?.LocalDateTime.ToString("dd/MM HH:mm") ?? "-").
                                    <button class="btn btn-link btn-sm" @onclick="SolicitarFirmaWhatsAppAsync" disabled="@_firmaRemotaBusy">Solicitar nueva firma</button>
                                </div>
                            }
                            @if (_firmaRemotaMsg is not null) { <div class="text-muted small" style="margin-top:4px;">@_firmaRemotaMsg</div> }
                            @if (_firmaRemotaError is not null) { <div class="text-danger small" style="margin-top:4px;">@_firmaRemotaError</div> }
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrEmpty(_firmaActual) || !string.IsNullOrEmpty(_firmaPacienteActual))
            {
                <div class="nm-firma-prev-info">
                    Al guardar de nuevo cualquier firma se sobrescribira la anterior.
                </div>
            }
        }
    </div>
}

@* =================== TAB DOCUMENTOS EXTERNOS =================== *@
else if (_tabSel == "Documentos Externos")
{
    <div class="ase-card nm-panel">
        @if (_borrador?.Id is null)
        {
            <div class="ase-empty">Para subir documentos primero guarda la nota como parcial o definitiva.</div>
        }
        else
        {
            <div class="nm-row-inline">
                <label class="nm-lbl-inline">Categoria:</label>
                <select class="form-select form-select-sm nm-w-280" @bind="_docCategoria">
                    <option value="">Seleccione...</option>
                    @foreach (var t in _tipologias)
                    {
                        <option value="@t.Nombre">@t.Nombre</option>
                    }
                </select>
                @if (_tipologias.Count == 0)
                {
                    <span class="text-muted" style="font-size:11px;margin-left:8px;">
                        (Configura tipologias en <em>Configuracion del Sistema -> Tipologia Archivos</em>)
                    </span>
                }
            </div>
            <div class="nm-row-inline">
                <label class="nm-lbl-inline">Tipo de Terapia:</label>
                <select class="form-select form-select-sm nm-w-280" @bind="_docTipoTerapia">
                    <option value="">Selecciona...</option>
                    <option>FISIOTERAPEUTA</option>
                    <option>FONOAUDIOLOGIA</option>
                    <option>TERAPIAOCUPACIONAL</option>
                    <option>TERAPIARESPIRATORIA</option>
                    <option>NEBULIZACION</option>
                    <option>TRAQUEOSTOMIA</option>
                </select>
                <label class="nm-lbl-inline">Mes:</label>
                <select class="form-select form-select-sm nm-w-150" @bind="_docMes">
                    <option value="">Selecciona...</option>
                    @foreach (var m in new[] { "ENERO","FEBRERO","MARZO","ABRIL","MAYO","JUNIO","JULIO","AGOSTO","SEPTIEMBRE","OCTUBRE","NOVIEMBRE","DICIEMBRE" })
                    {
                        <option>@m</option>
                    }
                </select>
            </div>
            <div class="nm-doc-grid">
                <div class="nm-doc-card">
                    <div class="nm-doc-h">Subir archivo</div>
                    <textarea class="form-control form-control-sm" rows="3" placeholder="Anotaciones del archivo..." @bind="_docAnotaciones"></textarea>
                    <hr />
                    <InputFile OnChange="OnDocSeleccionado" class="form-control form-control-sm" accept=".pdf,.png,.jpg,.jpeg,.webp,.docx,.xlsx" />
                    @if (_docSubiendo) { <div class="text-muted small">Subiendo...</div> }
                </div>
                <div class="nm-doc-card nm-doc-list">
                    <div class="nm-doc-h" style="display:flex;justify-content:space-between;align-items:center;">
                        <span>Archivos adjuntos (@_documentos.Count)</span>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="RecargarDocumentos" title="Refrescar lista">&#128260; Refrescar</button>
                    </div>
                    @if (_documentos.Count == 0)
                    {
                        <div class="nm-doc-empty">Sin archivos.</div>
                    }
                    else
                    {
                        <div class="nm-doc-thumbs">
                            @foreach (var d in _documentos)
                            {
                                var esImg = EsImagen(d.TipoMime, d.NombreOriginal);
                                <div class="nm-doc-thumb">
                                    <div class="nm-doc-thumb-img" @onclick="() => AbrirPreview(d)" title="Click para ampliar">
                                        @if (esImg)
                                        {
                                            <img src="@d.RutaArchivo" alt="@d.NombreOriginal" />
                                        }
                                        else
                                        {
                                            <div class="nm-doc-thumb-icon">@IconoPara(d.NombreOriginal)</div>
                                        }
                                    </div>
                                    <div class="nm-doc-thumb-nm" title="@d.NombreOriginal">@d.NombreOriginal</div>
                                    <div class="nm-doc-thumb-meta">
                                        <small>@FormatBytes(d.Tamano)</small>
                                        @if (!string.IsNullOrEmpty(d.Categoria)) { <span class="nm-doc-badge">@d.Categoria</span> }
                                    </div>
                                    <div class="nm-doc-thumb-actions">
                                        <a class="btn btn-sm btn-outline-primary" href="@d.RutaArchivo" download="@d.NombreOriginal" title="Descargar">&#11015; Descargar</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
}

@* =================== TAB VER HISTORIAL (notas anteriores del paciente) =================== *@
else if (_tabSel == "Ver Historial")
{
    <div class="ase-card nm-panel">
        <div class="nm-row-inline">
            <strong>Notas previas de @NombrePacienteCtx</strong>
            <span class="ms-auto"></span>
            <button class="btn btn-outline-primary btn-sm" @onclick="RefrescarHistorial" disabled="@_busy">&#128260; Refrescar</button>
        </div>

        @* ---- Barra de filtros ---- *@
        <div class="nm-hist-filtros">
            <div class="ase-f">
                <label>Desde</label>
                <input type="date" class="form-control form-control-sm" @bind="_histDesde" />
            </div>
            <div class="ase-f">
                <label>Hasta</label>
                <input type="date" class="form-control form-control-sm" @bind="_histHasta" />
            </div>
            <div class="ase-f">
                <label>Especialista / Doctor</label>
                <select class="form-select form-select-sm" @bind="_histEspecialista">
                    <option value="">Todos</option>
                    @foreach (var esp in EspecialistasDistintos())
                    {
                        <option value="@esp">@esp</option>
                    }
                </select>
            </div>
            <div class="ase-f">
                <label>Estado</label>
                <select class="form-select form-select-sm" @bind="_histEstado">
                    <option value="">Todos</option>
                    <option value="Definitivo">Definitivo</option>
                    <option value="Parcial">Parcial</option>
                </select>
            </div>
            <div class="ase-f">
                <label>Criticidad</label>
                <select class="form-select form-select-sm" @bind="_histCriticidad">
                    <option value="">Todas</option>
                    <option value="Estable">Estable</option>
                    <option value="Vigilancia">Vigilancia</option>
                    <option value="Alerta">Alerta</option>
                    <option value="Critico">Critico</option>
                </select>
            </div>
            <button class="btn btn-outline-secondary btn-sm nm-hist-clear" @onclick="LimpiarFiltrosHistorial" title="Limpiar filtros">&#10006; Limpiar</button>
        </div>
        <div class="nm-hist-resumen">
            Mostrando <strong>@_historialFiltrado.Count</strong> de @_historialPaciente.Count notas.
        </div>

        @if (_historialFiltrado.Count == 0)
        {
            <div class="ase-empty">
                @(_historialPaciente.Count == 0
                    ? "No hay notas previas registradas para este paciente."
                    : "Ningun resultado con los filtros aplicados.")
            </div>
        }
        else
        {
            <div class="nm-cards-grid">
                @foreach (var n in _historialFiltrado)
                {
                    <div class="nm-card-mini @CritClass(n.Criticidad)">
                        <div class="nm-card-h">
                            <span class="nm-card-fecha">@n.FechaNota.ToString("dd/MM/yyyy") @(n.HoraNota is TimeOnly h ? h.ToString("HH:mm") : "")</span>
                            @if (n.Estado == "Definitivo")
                            {
                                <span class="nm-pill nm-pill-def">DEFINITIVO</span>
                            }
                            else
                            {
                                <span class="nm-pill nm-pill-par">PARCIAL</span>
                            }
                        </div>
                        <div class="nm-card-cod">@n.CodigoUnico @if (n.SessionNo is int s) { <span class="nm-sess">Sesion @s</span> }</div>
                        @if (!string.IsNullOrWhiteSpace(n.FormatoCodigo))
                        {
                            <div class="nm-card-fmt">@n.FormatoNombre (@n.FormatoCodigo)</div>
                        }
                        <div class="nm-card-body">@n.ContenidoPreview</div>
                        <div class="nm-card-f">
                            <small><strong>@n.EspecialistaNombre</strong></small>
                            <small class="nm-card-crit">@n.Criticidad</small>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@* ============== Modal preview de documento ============== *@
@if (_preview is NotaDocumentoDto pv)
{
    <div class="nm-prev-bk" @onclick="CerrarPreview"></div>
    <div class="nm-prev-modal" @onclick:stopPropagation>
        <div class="nm-prev-h">
            <strong>@pv.NombreOriginal</strong>
            <div>
                <a class="btn btn-sm btn-outline-primary" href="@pv.RutaArchivo" download="@pv.NombreOriginal">&#11015; Descargar</a>
                <button class="btn btn-sm btn-outline-secondary" @onclick="CerrarPreview">&#10006; Cerrar</button>
            </div>
        </div>
        <div class="nm-prev-body">
            @if (EsImagen(pv.TipoMime, pv.NombreOriginal))
            {
                <img src="@pv.RutaArchivo" alt="@pv.NombreOriginal" />
            }
            else if (string.Equals(pv.TipoMime, "application/pdf", StringComparison.OrdinalIgnoreCase) || pv.NombreOriginal.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
            {
                <iframe src="@pv.RutaArchivo" title="@pv.NombreOriginal"></iframe>
            }
            else
            {
                <div class="nm-prev-other">
                    <div class="nm-doc-thumb-icon nm-prev-icon">@IconoPara(pv.NombreOriginal)</div>
                    <div>@pv.NombreOriginal</div>
                    <small class="text-muted">No se puede previsualizar este tipo de archivo. Usa "Descargar".</small>
                </div>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(pv.Anotaciones))
        {
            <div class="nm-prev-f">@pv.Anotaciones</div>
        }
    </div>
}

