@using DokTrino.Application.Tenancy
@using DokTrino.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.Components.Forms
@inject IChatService Chat
@inject IWhatsAppLineService LineasSvc
@inject IMessageTemplateService TplSvc
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IAsyncDisposable

@*
   Panel WhatsApp embebible. Se usa hoy en el modal de Historias Clinicas, manana
   en Notas Medicas y Paciente. La idea es portable: recibe un telefono + nombre
   y maneja todo el thread internamente.

   Reglas de diseno:
   - Si no hay telefono: mensaje + boton "Asignar" (event callback que el padre maneja).
   - Si hay telefono: carga/crea la conversacion y lista los mensajes.
   - Chip de linea siempre visible cuando hay >=1 conectada (selector si hay >1).
   - Plantillas pregrabadas (chips + tabs + modal gestor + token replacement).
   - Adjuntos (clip + submenu + drop zone + render media).
   - Date divider entre dias en el thread.
   - Boton << para colapsar a una franja estrecha vertical.
   - Tema visual estilo WhatsApp (burbujas in/out, fondo claro).
*@

<div class="wac @(_colapsado ? "wac-colapsado" : "")">
    @if (_colapsado)
    {
        <button class="wac-expand" @onclick="ToggleColapsado" title="Abrir chat WhatsApp">
            <span class="wac-expand-ico">&#128172;</span>
            <span class="wac-expand-text">WhatsApp</span>
            @if (_mensajes.Count > 0)
            {
                <span class="wac-expand-badge">@_mensajes.Count</span>
            }
        </button>
    }
    else
    {
        <div class="wac-head" title="@(PacienteId is null ? null : "Click para editar el telefono")">
            <div class="wac-head-l @(PacienteId is null ? "" : "wac-head-clickable")" @onclick="OpenEditTelefono">
                <span class="wac-head-ico">&#128172;</span>
                <div>
                    <div class="wac-head-t">WhatsApp</div>
                    <div class="wac-head-s">@(string.IsNullOrWhiteSpace(NombreContacto) ? "Sin contacto" : NombreContacto) &middot; @(string.IsNullOrWhiteSpace(_telefonoDigits) ? "(sin numero)" : "+" + _telefonoDigits)</div>
                </div>
            </div>
            @if (Colapsable)
            {
                <button class="wac-head-toggle" @onclick="ToggleColapsado" title="Colapsar">&laquo;</button>
            }
        </div>

        @if (string.IsNullOrWhiteSpace(_telefonoDigits))
        {
            <div class="wac-empty">
                <div class="wac-empty-ico">&#128241;</div>
                <div class="wac-empty-t">Paciente sin telefono</div>
                <div class="wac-empty-d">Asigna un numero al paciente para empezar a conversar por WhatsApp.</div>
                @if (PacienteId is not null)
                {
                    <button class="wac-empty-btn" @onclick="OpenEditTelefono">Asignar telefono</button>
                }
                else if (OnAsignarTelefono.HasDelegate)
                {
                    <button class="wac-empty-btn" @onclick="() => OnAsignarTelefono.InvokeAsync()">Asignar telefono</button>
                }
            </div>
        }
        else if (_lineasConectadas.Count == 0)
        {
            <div class="wac-empty">
                <div class="wac-empty-ico">&#128226;</div>
                <div class="wac-empty-t">Sin lineas WhatsApp conectadas</div>
                <div class="wac-empty-d">Configura y conecta una linea en el modulo "Lineas WhatsApp" antes de enviar mensajes.</div>
            </div>
        }
        else
        {
            @* Chip de linea siempre visible. Si hay >1 se muestra como selector real. *@
            <div class="wac-line-bar">
                <span class="wac-line-dot"></span>
                <span class="wac-line-label">Linea</span>
                @if (_lineasConectadas.Count == 1)
                {
                    var l = _lineasConectadas[0];
                    <span class="wac-line-name" title="@l.InstanceName">@l.InstanceName @(string.IsNullOrWhiteSpace(l.PhoneNumber) ? "" : "(+" + l.PhoneNumber + ")")</span>
                }
                else
                {
                    <select class="wac-line-select" @bind="_lineaSelIdStr" title="Linea WhatsApp a usar para enviar">
                        @foreach (var l in _lineasConectadas)
                        {
                            <option value="@l.Id">@l.InstanceName @(string.IsNullOrWhiteSpace(l.PhoneNumber) ? "" : "(+" + l.PhoneNumber + ")")</option>
                        }
                    </select>
                }
            </div>

            <div class="wac-bodywrap @(_dragOver ? "wac-dragover" : "")"
                 @ondragenter:preventDefault="true" @ondragover:preventDefault="true"
                 @ondragenter="OnDragEnter" @ondragleave="OnDragLeave" @ondrop="OnDrop">
                <div class="wac-dropmask">Suelta el archivo para adjuntarlo</div>
                <div class="wac-thread" @ref="_threadRef">
                    @if (_cargando)
                    {
                        <div class="wac-thread-empty">Cargando mensajes...</div>
                    }
                    else if (_mensajes.Count == 0)
                    {
                        <div class="wac-thread-empty">Sin mensajes. Escribe el primero abajo.</div>
                    }
                    else
                    {
                        DateTime? lastDay = null;
                        @foreach (var m in _mensajes)
                        {
                            var day = m.SentAt.LocalDateTime.Date;
                            if (lastDay != day)
                            {
                                lastDay = day;
                                <div class="wac-date-divider"><span>@FormatDayHeader(day)</span></div>
                            }
                            var entrada = m.Direction == MessageDirection.Inbound;
                            <div class="wac-msg @(entrada ? "wac-in" : "wac-out")">
                                @switch (m.MediaType)
                                {
                                    case MessageMediaType.Image:
                                        <img class="wac-media-img" src="@m.MediaUrl" alt="imagen" loading="lazy" />
                                        break;
                                    case MessageMediaType.Video:
                                        <video class="wac-media-img" src="@m.MediaUrl" controls></video>
                                        break;
                                    case MessageMediaType.Audio:
                                        <audio src="@m.MediaUrl" controls class="wac-media-audio"></audio>
                                        break;
                                    case MessageMediaType.Document:
                                        <a class="wac-media-doc" href="@m.MediaUrl" target="_blank">&#128206; Documento adjunto</a>
                                        break;
                                    case MessageMediaType.Location:
                                        <a class="wac-media-doc" href="@MapsLink(m.MediaUrl)" target="_blank">&#128205; Ver ubicacion en el mapa</a>
                                        break;
                                }
                                @if (!string.IsNullOrWhiteSpace(m.Body))
                                {
                                    <div class="wac-msg-body">@m.Body</div>
                                }
                                <div class="wac-msg-meta">
                                    @if (!entrada && !string.IsNullOrWhiteSpace(m.SentByName)) { <span>@m.SentByName &middot; </span> }
                                    <span>@m.SentAt.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            @* Plantillas pregrabadas: tabs + chips + boton + Gestionar. *@
            <div class="wac-quick">
                <div class="wac-quick-head">
                    <span>Mensajes pregrabados</span>
                    <div class="wac-quick-tabs">
                        @foreach (var cat in QrCategories)
                        {
                            <button class="wac-qr-tab @(cat.Key == _qrCategory ? "active" : "")" @onclick="() => _qrCategory = cat.Key">@cat.Label</button>
                        }
                        <button class="wac-qr-tab wac-qr-tab-manage" @onclick="OpenTemplateManager" title="Crear/editar pregrabados">+ Gestionar</button>
                    </div>
                </div>
                <div class="wac-quick-list">
                    @foreach (var tpl in CurrentTemplates())
                    {
                        var filled = FillTemplate(tpl.Body);
                        <button class="wac-chip" title="@filled" @onclick="() => UseTemplateAsync(tpl)">
                            @if (tpl.MediaType != MessageMediaType.None) { <span>@MediaIcon(tpl.MediaType) </span> }
                            @(string.IsNullOrWhiteSpace(filled) ? tpl.MediaType.ToString() : filled)
                        </button>
                    }
                    @if (CurrentTemplates().Count == 0)
                    {
                        <span class="wac-quick-hint">Sin pregrabados en esta categoria. Usa "+ Gestionar".</span>
                    }
                </div>
            </div>

            <div class="wac-input">
                <div class="wac-attach">
                    <button class="wac-attach-btn" title="Adjuntar" @onclick="() => _attachOpen = !_attachOpen" disabled="@_enviando">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                    </button>
                    @if (_attachOpen)
                    {
                        <div class="wac-attach-menu" @onmouseleave="() => _attachOpen = false">
                            <label class="wac-attach-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.1-3.1a2 2 0 0 0-2.8 0L6 21"/></svg>
                                Imagen
                                <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Image))" accept="image/*" style="display:none;" />
                            </label>
                            <label class="wac-attach-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 8-6 4 6 4V8Z"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>
                                Video
                                <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Video))" accept="video/*" style="display:none;" />
                            </label>
                            <label class="wac-attach-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/></svg>
                                Audio
                                <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Audio))" accept="audio/*" style="display:none;" />
                            </label>
                            <label class="wac-attach-item">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/></svg>
                                Documento
                                <InputFile OnChange="@(e => OnAttachAsync(e, MessageMediaType.Document))" accept="*/*" style="display:none;" />
                            </label>
                            <button class="wac-attach-item" @onclick="OpenLocation" type="button">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                                Ubicacion
                            </button>
                        </div>
                    }
                </div>
                <textarea class="wac-input-text"
                          rows="2"
                          placeholder="Escribe un mensaje..."
                          @bind="_borrador"
                          @bind:event="oninput"
                          disabled="@_enviando"></textarea>
                <button class="wac-send" @onclick="EnviarAsync"
                        disabled="@(_enviando || string.IsNullOrWhiteSpace(_borrador))"
                        title="Enviar (Ctrl+Enter)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>

            @if (_error is not null) { <div class="wac-error">@_error</div> }
        }
    }
</div>

@* ===== Modal: gestor de pregrabados ===== *@
@if (_tplManagerOpen)
{
    <div class="wac-modal-ov" @onclick="() => _tplManagerOpen = false">
        <div class="wac-modal" @onclick:stopPropagation="true">
            <div class="wac-modal-head">
                <h3>Mensajes pregrabados</h3>
                <button class="wac-modal-close" @onclick="() => _tplManagerOpen = false">&times;</button>
            </div>
            <div class="wac-modal-body">
                <div class="wac-field">
                    <label>Categoria</label>
                    <input class="form-control" list="wac-tpl-cats" @bind="_tplFormCategory" placeholder="Elige una o escribe una nueva" autocomplete="off" />
                    <datalist id="wac-tpl-cats">
                        @foreach (var cat in QrCategories)
                        {
                            <option value="@cat.Key">@cat.Label</option>
                        }
                    </datalist>
                </div>
                <div class="wac-field">
                    <label>Mensaje</label>
                    <textarea class="form-control" rows="3" @bind="_tplFormBody"
                              placeholder="Tip: usa {paciente}, {cedula} o {fecha} para reemplazar con datos del paciente activo."></textarea>
                </div>
                @if (_tplFormError is not null)
                {
                    <div class="wac-error">@_tplFormError</div>
                }
                <div class="wac-modal-actions">
                    <button class="btn btn-primary" @onclick="SaveTemplateAsync" disabled="@_tplBusy">@(_tplEditId is null ? "+ Agregar" : "Guardar cambios")</button>
                    @if (_tplEditId is not null)
                    {
                        <button class="btn btn-outline-secondary" @onclick="ResetTemplateForm">Cancelar edicion</button>
                    }
                </div>

                <hr style="margin:14px 0;" />

                @foreach (var cat in QrCategories)
                {
                    var items = _templates.Where(t => t.Category == cat.Key).OrderBy(t => t.SortOrder).ToList();
                    if (items.Count == 0) { continue; }
                    <div class="wac-tpl-cat">
                        <div class="wac-tpl-cat-h">@cat.Label</div>
                        @foreach (var t in items)
                        {
                            <div class="wac-tpl-row">
                                <div class="wac-tpl-body">@t.Body</div>
                                <div class="wac-tpl-actions">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => EditTemplate(t)">Editar</button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteTemplateAsync(t.Id)" disabled="@_tplBusy">Eliminar</button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ===== Modal: actualizar telefono del paciente =====
   Usamos <dialog> con showModal() para que el browser lo mande al "top layer"
   y supere CUALQUIER stacking context (ej. el modal de HC que tiene z-index 1001
   y crearia un nuevo contexto que limitaria nuestros overlays normales). *@
<dialog id="wac-tel-dialog" class="wac-dialog" @onclose="OnTelDialogClosed">
    <div class="wac-modal-head">
        <h3>Telefono del paciente</h3>
        <button class="wac-modal-close" @onclick="CloseTelefonoAsync" type="button">&times;</button>
    </div>
    <div class="wac-modal-body">
        <div class="wac-field">
            <label>Pais / Codigo</label>
            <select class="form-control" @bind="_telCodigoPais">
                @foreach (var p in PaisesCodigos)
                {
                    <option value="@p.Codigo">@p.Nombre (+@p.Codigo)</option>
                }
            </select>
        </div>
        <div class="wac-field">
            <label>Numero local (sin codigo de pais)</label>
            <input class="form-control wac-tel-input" @bind="_telNumero" placeholder="Ej: 3001234567" inputmode="numeric" maxlength="15" />
            <div class="wac-tel-preview">Se guardara: <strong>+@_telCodigoPais @(_telNumero ?? "")</strong></div>
        </div>
        @if (_telError is not null) { <div class="wac-error">@_telError</div> }
        <div class="wac-modal-actions">
            <button class="btn btn-primary" @onclick="SaveTelefonoAsync" disabled="@_telBusy" type="button">@(_telBusy ? "Guardando..." : "Guardar")</button>
            <button class="btn btn-outline-secondary" @onclick="CloseTelefonoAsync" disabled="@_telBusy" type="button">Cancelar</button>
        </div>
    </div>
</dialog>

@* ===== Modal: enviar ubicacion ===== *@
@if (_locationOpen)
{
    <div class="wac-modal-ov" @onclick="() => _locationOpen = false">
        <div class="wac-modal wac-modal-sm" @onclick:stopPropagation="true">
            <div class="wac-modal-head">
                <h3>Enviar ubicacion</h3>
                <button class="wac-modal-close" @onclick="() => _locationOpen = false">&times;</button>
            </div>
            <div class="wac-modal-body">
                <div class="wac-field">
                    <label>Nombre (opcional)</label>
                    <input class="form-control" @bind="_locName" placeholder="Ej: Sede principal DokTrino" />
                </div>
                <div class="wac-field-row">
                    <div class="wac-field">
                        <label>Latitud</label>
                        <input class="form-control" @bind="_locLat" placeholder="4.6097" />
                    </div>
                    <div class="wac-field">
                        <label>Longitud</label>
                        <input class="form-control" @bind="_locLng" placeholder="-74.0817" />
                    </div>
                </div>
                @if (_locError is not null) { <div class="wac-error">@_locError</div> }
                <div class="wac-modal-actions">
                    <button class="btn btn-primary" @onclick="SendLocationAsync" disabled="@_enviando">Enviar</button>
                    <button class="btn btn-outline-secondary" @onclick="() => _locationOpen = false">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* Tema WhatsApp sobrio: verde header, fondo claro, burbujas redondeadas. */
    .wac { display: flex; flex-direction: column; background: #efeae2; border-left: 1px solid #d4d4d4; border-right: 1px solid #d4d4d4; height: 100%; min-height: 360px; overflow: hidden; }
    .wac-colapsado { background: transparent; border: none; align-items: center; padding-top: 12px; }

    .wac-expand { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 8px 4px; border: 1px solid #cbd5e1; background: #f8fafc; border-radius: 8px; cursor: pointer; min-width: 44px; }
    .wac-expand:hover { background: #eef6ff; border-color: #25d366; }
    .wac-expand-ico { font-size: 18px; }
    .wac-expand-text { font-size: 9px; font-weight: 700; color: #475569; writing-mode: vertical-rl; transform: rotate(180deg); letter-spacing: .04em; text-transform: uppercase; }
    .wac-expand-badge { background: #25d366; color: white; font-size: 9px; font-weight: 700; padding: 1px 5px; border-radius: 999px; }

    .wac-head { display: flex; justify-content: space-between; align-items: center; padding: 8px 10px; background: #128c7e; color: white; }
    .wac-head-l { display: flex; align-items: center; gap: 8px; flex: 1; min-width: 0; }
    .wac-head-clickable { cursor: pointer; border-radius: 4px; padding: 2px 4px; margin: -2px -4px; transition: background .15s; }
    .wac-head-clickable:hover { background: rgba(255,255,255,.15); }
    .wac-head-ico { font-size: 18px; }
    .wac-head-t { font-weight: 700; font-size: 12px; }
    .wac-head-s { font-size: 10px; opacity: .9; }
    .wac-head-toggle { background: rgba(255,255,255,.15); border: none; color: white; padding: 2px 8px; border-radius: 4px; cursor: pointer; font-size: 14px; }
    .wac-head-toggle:hover { background: rgba(255,255,255,.25); }
    .wac-tel-input { font-family: ui-monospace, "Cascadia Code", monospace; letter-spacing: .04em; font-size: 14px; }
    .wac-tel-preview { font-size: 11px; color: #64748b; margin-top: 4px; }
    .wac-tel-preview strong { color: #128c7e; font-family: ui-monospace, "Cascadia Code", monospace; }

    /* Chip de linea conectada (siempre visible cuando hay >=1 linea). */
    .wac-line-bar { display: flex; align-items: center; gap: 8px; padding: 6px 10px; background: #f0f0f0; border-bottom: 1px solid #d4d4d4; font-size: 11px; }
    .wac-line-dot { width: 8px; height: 8px; border-radius: 50%; background: #25d366; box-shadow: 0 0 0 2px rgba(37,211,102,.2); flex-shrink: 0; }
    .wac-line-label { color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: .06em; font-size: 9.5px; }
    .wac-line-name { color: #0f172a; font-weight: 700; font-size: 11px; }
    .wac-line-select { border: 1px solid #cbd5e1; background: white; border-radius: 4px; padding: 2px 6px; font-size: 11px; font-weight: 600; color: #0f172a; cursor: pointer; }

    /* Thread + drop zone. */
    .wac-bodywrap { position: relative; flex: 1; display: flex; flex-direction: column; min-height: 0; }
    .wac-dropmask { display: none; position: absolute; inset: 8px; z-index: 5; border: 2px dashed #128c7e; border-radius: 12px; background: rgba(18,140,126,.08); color: #128c7e; font-weight: 700; align-items: center; justify-content: center; text-align: center; pointer-events: none; font-size: 13px; }
    .wac-bodywrap.wac-dragover .wac-dropmask { display: flex; }

    .wac-thread { flex: 1; overflow-y: auto; padding: 10px 8px; background: #efeae2; display: flex; flex-direction: column; gap: 4px; }
    .wac-thread-empty { text-align: center; color: #64748b; font-size: 11px; font-style: italic; margin: auto; }

    .wac-date-divider { text-align: center; font-size: 9.5px; color: #64748b; letter-spacing: .12em; text-transform: uppercase; font-weight: 700; margin: 6px 0 4px; display: flex; align-items: center; gap: 10px; }
    .wac-date-divider::before, .wac-date-divider::after { content: ""; flex: 1; height: 1px; background: #d4d4d4; }
    .wac-date-divider span { background: rgba(255,255,255,.6); padding: 2px 10px; border-radius: 999px; }

    .wac-msg { max-width: 80%; padding: 6px 9px; border-radius: 8px; box-shadow: 0 1px 1px rgba(0,0,0,.08); font-size: 12px; word-wrap: break-word; }
    .wac-msg-body { white-space: pre-wrap; color: #0f172a; }
    .wac-msg-meta { font-size: 9px; color: #64748b; margin-top: 2px; text-align: right; }
    .wac-in { background: #ffffff; align-self: flex-start; border-top-left-radius: 0; }
    .wac-out { background: #dcf8c6; align-self: flex-end; border-top-right-radius: 0; }

    .wac-media-img { max-width: 220px; max-height: 220px; border-radius: 6px; display: block; margin-bottom: 4px; }
    .wac-media-audio { max-width: 220px; display: block; margin-bottom: 4px; }
    .wac-media-doc { display: inline-block; font-size: 12px; text-decoration: underline; margin-bottom: 4px; color: #0b5b54; }

    /* Plantillas pregrabadas. */
    .wac-quick { padding: 6px 8px; background: #f8fafc; border-top: 1px solid #d4d4d4; }
    .wac-quick-head { display: flex; align-items: center; justify-content: space-between; gap: 6px; margin-bottom: 5px; flex-wrap: wrap; }
    .wac-quick-head > span { font-size: 9.5px; letter-spacing: .1em; text-transform: uppercase; font-weight: 700; color: #64748b; }
    .wac-quick-tabs { display: flex; gap: 3px; flex-wrap: wrap; }
