    // ===== Ubicacion =====
    private void OpenLocation()
    {
        _attachOpen = false;
        _locName = null; _locLat = null; _locLng = null; _locError = null;
        _locationOpen = true;
    }

    private async Task SendLocationAsync()
    {
        _locError = null;
        if (_conv is null) { _locError = "No hay conversacion."; return; }
        if (!Guid.TryParse(_lineaSelIdStr, out var lineId)) { _locError = "Selecciona una linea."; return; }
        var ci = System.Globalization.CultureInfo.InvariantCulture;
        if (!double.TryParse(_locLat, System.Globalization.NumberStyles.Any, ci, out var lat)
            || !double.TryParse(_locLng, System.Globalization.NumberStyles.Any, ci, out var lng))
        {
            _locError = "Latitud y longitud invalidas.";
            return;
        }
        await _dbLock.WaitAsync();
        _enviando = true;
        try
        {
            var r = await Chat.SendLocationViaLineAsync(_conv.Id, lineId, lat, lng, _locName, Guid.Empty);
            if (!r.Ok) { _locError = r.Error; return; }
            if (r.Message is { } sent && _mensajes.All(m => m.Id != sent.Id)) { _mensajes.Add(sent); }
            _locationOpen = false;
        }
        catch (Exception ex) { _locError = ex.Message; }
        finally { _enviando = false; _dbLock.Release(); }
    }

    private static string FormatDayHeader(DateTime day)
    {
        var today = DateTime.Today;
        if (day == today) { return "HOY"; }
        if (day == today.AddDays(-1)) { return "AYER"; }
        return day.ToString("dd 'DE' MMMM yyyy", new System.Globalization.CultureInfo("es-CO")).ToUpperInvariant();
    }

    // ===== Edicion de telefono del paciente =====
    private async Task OpenEditTelefono()
    {
        if (PacienteId is null) { return; }
        _telError = null;
        var actual = _telefonoDigits ?? string.Empty;
        var match = PaisesCodigos
            .OrderByDescending(p => p.Codigo.Length)
            .FirstOrDefault(p => actual.StartsWith(p.Codigo) && actual.Length > p.Codigo.Length);
        if (!string.IsNullOrEmpty(match.Codigo))
        {
            _telCodigoPais = match.Codigo;
            _telNumero = actual.Substring(match.Codigo.Length);
        }
        else
        {
            _telCodigoPais = "57";
            _telNumero = string.IsNullOrWhiteSpace(actual) ? null : actual;
        }
        _telOpen = true;
        // Llamar showModal() del <dialog> para que vaya al top layer del browser y
        // se renderice por encima de cualquier stacking context (como el modal HC).
        try { await JS.InvokeVoidAsync("eval", "var d=document.getElementById('wac-tel-dialog'); if (d && !d.open) d.showModal();"); }
        catch { }
    }

    private async Task CloseTelefonoAsync()
    {
        _telOpen = false;
        try { await JS.InvokeVoidAsync("eval", "var d=document.getElementById('wac-tel-dialog'); if (d && d.open) d.close();"); }
        catch { }
    }

    private void OnTelDialogClosed()
    {
        // El user cerro con ESC: solo sincronizamos el flag.
        _telOpen = false;
    }

    private async Task SaveTelefonoAsync()
    {
        _telError = null;
        if (PacienteId is not Guid pid) { _telError = "No hay paciente."; return; }
        var numero = new string((_telNumero ?? "").Where(char.IsDigit).ToArray());
        if (numero.Length < 6)
        {
            _telError = "El numero local debe tener al menos 6 digitos.";
            return;
        }
        await _dbLock.WaitAsync();
        _telBusy = true;
        try
        {
            var completo = _telCodigoPais + numero;
            // Edicion de telefono del contacto pendiente de re-cableado al modelo
            // documental (se removio el acoplamiento clinico a Paciente).
            _ = pid; await Task.CompletedTask;
            string? guardado = null;
            if (string.IsNullOrEmpty(guardado))
            {
                _telError = "No se pudo guardar el telefono.";
                return;
            }
            _telefonoDigits = guardado;
            _ultimoTelefono = guardado;
            _telOpen = false;
            try { await JS.InvokeVoidAsync("eval", "var d=document.getElementById('wac-tel-dialog'); if (d && d.open) d.close();"); }
            catch { }
        }
        catch (Exception ex) { _telError = ex.Message; }
        finally { _telBusy = false; _dbLock.Release(); }
        // Recargamos fuera del lock: CargarTodoAsync vuelve a tomarlo internamente.
        await CargarTodoAsync();
        await JoinConversationRealtimeAsync();
        if (OnTelefonoActualizado.HasDelegate && !string.IsNullOrEmpty(_telefonoDigits))
        {
            await OnTelefonoActualizado.InvokeAsync(_telefonoDigits);
        }
    }
