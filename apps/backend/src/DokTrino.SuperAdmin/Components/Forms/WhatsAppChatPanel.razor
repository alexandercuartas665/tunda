@code {
    /// <summary>Telefono del paciente. Si es nulo/vacio se muestra el panel sin
    /// telefono con el boton "Asignar" (si OnAsignarTelefono esta enganchado).</summary>
    [Parameter] public string? Telefono { get; set; }

    /// <summary>Nombre del contacto, solo se usa para el header y como ContactName
    /// inicial al crear la conversacion.</summary>
    [Parameter] public string? NombreContacto { get; set; }

    /// <summary>Documento (cedula) del paciente. Se usa para el token {cedula} en plantillas.</summary>
    [Parameter] public string? Cedula { get; set; }

    /// <summary>Id del paciente. Si esta presente, el header del chat es clickable y abre
    /// el modal "Actualizar telefono" para editar el numero directamente desde aqui.</summary>
    [Parameter] public Guid? PacienteId { get; set; }

    /// <summary>Callback opcional que el padre engancha para refrescar PacienteActivo
    /// despues de que el usuario actualice el telefono desde el chat. Recibe el telefono
    /// ya normalizado a digitos.</summary>
    [Parameter] public EventCallback<string> OnTelefonoActualizado { get; set; }

    /// <summary>Si true, muestra el boton « para colapsar el panel a una franja vertical.</summary>
    [Parameter] public bool Colapsable { get; set; } = true;

    /// <summary>Estado inicial del colapso (controlado por el padre si quiere persistirlo).</summary>
    [Parameter] public bool Colapsado { get; set; }
    [Parameter] public EventCallback<bool> ColapsadoChanged { get; set; }

    /// <summary>Callback opcional que el padre engancha cuando el panel sugiere
    /// asignar telefono. Pensado para abrir el modal de edicion de paciente.</summary>
    [Parameter] public EventCallback OnAsignarTelefono { get; set; }

    private bool _colapsado;
    private string _telefonoDigits = "";
    private string _ultimoTelefono = "";
    private ConversationDto? _conv;
    private List<MessageDto> _mensajes = new();
    private List<WhatsAppLineDto> _lineasConectadas = new();
    private string _lineaSelIdStr = "";
    private string _borrador = "";
    private bool _cargando;
    private bool _enviando;
    private string? _error;
    private ElementReference _threadRef;

    // SignalR
    private HubConnection? _hub;
    private string? _joinedConversation;

    // Serializa accesos al DbContext (Chat, Lineas, Templates, Pacientes comparten scope
    // del circuito Blazor). Sin esto, OnParametersSetAsync + MessageAdded del hub pueden
    // arrancar dos queries simultaneos y EF revienta con "A second operation was started".
    private readonly System.Threading.SemaphoreSlim _dbLock = new(1, 1);

    // Plantillas pregrabadas
    private List<MessageTemplateDto> _templates = new();
    private string _qrCategory = "saludo";
    private bool _tplManagerOpen;
    private Guid? _tplEditId;
    private string _tplFormCategory = "saludo";
    private string? _tplFormBody;
    private string? _tplFormError;
    private bool _tplBusy;

    // Adjuntos
    private bool _attachOpen;
    private bool _dragOver;

    // Ubicacion
    private bool _locationOpen;
    private string? _locName;
    private string? _locLat;
    private string? _locLng;
    private string? _locError;

    // Edicion de telefono del paciente (modal abierto al clickear el header).
    private bool _telOpen;
    private bool _telBusy;
    private string _telCodigoPais = "57"; // Colombia por defecto.
    private string? _telNumero;
    private string? _telError;

    /// <summary>Lista corta de paises (Latam + comunes) con codigo internacional.</summary>
    private static readonly (string Codigo, string Nombre, string Bandera)[] PaisesCodigos = new[]
    {
        ("57",  "Colombia",        "\U0001F1E8\U0001F1F4"),
        ("52",  "Mexico",          "\U0001F1F2\U0001F1FD"),
        ("51",  "Peru",            "\U0001F1F5\U0001F1EA"),
        ("593", "Ecuador",         "\U0001F1EA\U0001F1E8"),
        ("58",  "Venezuela",       "\U0001F1FB\U0001F1EA"),
        ("56",  "Chile",           "\U0001F1E8\U0001F1F1"),
        ("54",  "Argentina",       "\U0001F1E6\U0001F1F7"),
        ("591", "Bolivia",         "\U0001F1E7\U0001F1F4"),
        ("595", "Paraguay",        "\U0001F1F5\U0001F1FE"),
        ("598", "Uruguay",         "\U0001F1FA\U0001F1FE"),
        ("507", "Panama",          "\U0001F1F5\U0001F1E6"),
        ("506", "Costa Rica",      "\U0001F1E8\U0001F1F7"),
        ("503", "El Salvador",     "\U0001F1F8\U0001F1FB"),
        ("502", "Guatemala",       "\U0001F1EC\U0001F1F9"),
        ("504", "Honduras",        "\U0001F1ED\U0001F1F3"),
        ("505", "Nicaragua",       "\U0001F1F3\U0001F1EE"),
        ("1",   "Estados Unidos",  "\U0001F1FA\U0001F1F8"),
        ("34",  "Espana",          "\U0001F1EA\U0001F1F8"),
    };

    private bool _primerLoad = true;
    protected override async Task OnParametersSetAsync()
    {
        _colapsado = Colapsado;
        var nuevo = SoloDigitos(Telefono);
        if (nuevo != _ultimoTelefono)
        {
            _ultimoTelefono = nuevo;
            _telefonoDigits = nuevo;
            _error = null;
            // Si compartimos el DbContext de un circuito Blazor donde tambien viven
            // otros componentes pesados (NotasMedicasModulo + AsistenteChatNotas),
            // demoramos 400ms el primer query para que el componente principal
            // termine antes y EF Core no reviente con "A second operation was started".
            if (_primerLoad)
            {
                _primerLoad = false;
                await Task.Delay(400);
            }
            await CargarTodoAsync();
            await JoinConversationRealtimeAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await EnsureHubAsync();
            await JoinConversationRealtimeAsync();
        }
    }

    // ===== SignalR =====
    private async Task EnsureHubAsync()
    {
        if (_hub is not null) { return; }
        try
        {
            _hub = new HubConnectionBuilder()
                .WithUrl(Nav.ToAbsoluteUri("/hubs/chat"))
                .WithAutomaticReconnect()
                .Build();

            _hub.On<MessageDto>("MessageAdded", async msg =>
            {
                if (_conv is not null && msg.ConversationId == _conv.Id && _mensajes.All(m => m.Id != msg.Id))
                {
                    _mensajes.Add(msg);
                    await InvokeAsync(StateHasChanged);
                    try { await JS.InvokeVoidAsync("eval", "setTimeout(() => { var el = document.querySelector('.wac-thread'); if (el) el.scrollTop = el.scrollHeight; }, 50);"); }
                    catch { }
                }
            });

            await _hub.StartAsync();
        }
        catch
        {
            _hub = null;
        }
    }

    private async Task JoinConversationRealtimeAsync()
    {
        if (_hub is null || _conv is null) { return; }
        try
        {
            var nuevo = _conv.Id.ToString();
            if (_joinedConversation == nuevo) { return; }
            if (_joinedConversation is not null)
            {
                await _hub.SendAsync("LeaveConversation", _joinedConversation);
            }
            await _hub.SendAsync("JoinConversation", nuevo);
            _joinedConversation = nuevo;
        }
        catch { }
    }

    public async ValueTask DisposeAsync()
    {
        if (_hub is not null)
        {
            try
            {
                if (_joinedConversation is not null)
                {
                    await _hub.SendAsync("LeaveConversation", _joinedConversation);
                }
                await _hub.DisposeAsync();
            }
            catch { }
            _hub = null;
            _joinedConversation = null;
        }
    }

    // ===== Carga + envio basico =====
    private async Task CargarTodoAsync()
    {
        if (string.IsNullOrWhiteSpace(_telefonoDigits))
        {
            _conv = null; _mensajes = new(); _lineasConectadas = new(); return;
        }
        await _dbLock.WaitAsync();
        _cargando = true;
        try
        {
            var lineas = await LineasSvc.ListAsync();
            _lineasConectadas = lineas.Where(l => l.Status == WhatsAppLineStatus.Connected).ToList();
            if (_lineasConectadas.Count > 0 && (string.IsNullOrEmpty(_lineaSelIdStr) || !_lineasConectadas.Any(l => l.Id.ToString() == _lineaSelIdStr)))
            {
                _lineaSelIdStr = _lineasConectadas[0].Id.ToString();
            }

            _conv = await Chat.GetOrCreateByPhoneAsync(_telefonoDigits, NombreContacto);
            if (_conv is not null)
            {
                var lst = await Chat.ListMessagesAsync(_conv.Id);
                _mensajes = lst.ToList();
            }
            else
            {
                _mensajes = new();
            }

            // Plantillas: cargar y, si no hay nada, sembrar defaults una vez.
            _templates = (await TplSvc.ListAsync()).ToList();
            if (_templates.Count == 0)
            {
                var seeded = await TplSvc.SeedDefaultsAsync();
                if (seeded > 0) { _templates = (await TplSvc.ListAsync()).ToList(); }
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _cargando = false; _dbLock.Release(); }
    }

    private async Task EnviarAsync()
    {
        if (_conv is null) { _error = "No hay conversacion."; return; }
        if (string.IsNullOrWhiteSpace(_borrador)) { return; }
        if (!Guid.TryParse(_lineaSelIdStr, out var lineId))
        {
            _error = "Selecciona una linea WhatsApp."; return;
        }
        await _dbLock.WaitAsync();
        _enviando = true; _error = null;
        try
        {
            var result = await Chat.SendViaLineAsync(_conv.Id, lineId, _borrador.Trim(), Guid.Empty);
            if (!result.Ok)
            {
                _error = result.Error ?? "No se pudo enviar.";
                return;
            }
            _borrador = "";

            if (_hub is null || _hub.State != HubConnectionState.Connected)
            {
                var lst = await Chat.ListMessagesAsync(_conv.Id);
                _mensajes = lst.ToList();
            }
            else if (result.Message is { } sent && _mensajes.All(m => m.Id != sent.Id))
            {
                _mensajes.Add(sent);
            }
            try { await JS.InvokeVoidAsync("eval", "setTimeout(() => { var el = document.querySelector('.wac-thread'); if (el) el.scrollTop = el.scrollHeight; }, 50);"); }
            catch { }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _enviando = false; _dbLock.Release(); }
    }

    private async Task ToggleColapsado()
    {
        _colapsado = !_colapsado;
        if (ColapsadoChanged.HasDelegate) { await ColapsadoChanged.InvokeAsync(_colapsado); }
    }

    private static string SoloDigitos(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) { return ""; }
        return new string(s.Where(char.IsDigit).ToArray());
    }

    // ===== Plantillas pregrabadas =====
    private List<(string Key, string Label)> QrCategories
    {
        get
        {
            var keys = MessageTemplateCategories.All.Select(c => c.Key).ToList();
            foreach (var t in _templates)
            {
                if (!keys.Contains(t.Category)) { keys.Add(t.Category); }
            }
            return keys.Select(k => (k, CategoryLabel(k))).ToList();
        }
    }

    private static string CategoryLabel(string key)
    {
        var lbl = MessageTemplateCategories.Label(key);
        if (lbl == key && key.Length > 0) { return char.ToUpperInvariant(key[0]) + key[1..]; }
        return lbl;
    }

    private List<MessageTemplateDto> CurrentTemplates()
        => _templates.Where(t => t.Category == _qrCategory).OrderBy(t => t.SortOrder).ToList();

    private string FillTemplate(string template)
    {
        var paciente = string.IsNullOrWhiteSpace(NombreContacto) ? "paciente" : NombreContacto!.Split(' ').FirstOrDefault() ?? NombreContacto!;
        var cedula = string.IsNullOrWhiteSpace(Cedula) ? "" : Cedula!;
        var fecha = DateTime.Now.ToString("dd 'de' MMMM yyyy", new System.Globalization.CultureInfo("es-CO"));
        return template
            .Replace("{paciente}", paciente)
            .Replace("{cedula}", cedula)
            .Replace("{fecha}", fecha)
            .Replace("{telefono}", _telefonoDigits);
    }

    private static string MediaIcon(MessageMediaType t) => t switch
    {
        MessageMediaType.Image => "[IMG]",
        MessageMediaType.Video => "[VID]",
        MessageMediaType.Audio => "[AUD]",
        MessageMediaType.Document => "[DOC]",
        MessageMediaType.Location => "[UBI]",
        _ => ""
    };

    private static string MapsLink(string? coords) => $"https://www.google.com/maps?q={coords}";

    private async Task UseTemplateAsync(MessageTemplateDto t)
    {
        _error = null;
        if (t.MediaType == MessageMediaType.None)
        {
            // Rellena el borrador para que el operador pueda editar antes de enviar.
            _borrador = FillTemplate(t.Body);
            await InvokeAsync(StateHasChanged);
            return;
        }
        // Plantillas con media adjunta: por ahora solo se permite plantilla de texto.
        // (El gestor solo guarda texto en esta version.) Si la plantilla tiene media,
        // dejamos el caption en el borrador para que el operador la adjunte manualmente.
        _borrador = FillTemplate(t.Body);
    }

    private void OpenTemplateManager()
    {
        _attachOpen = false;
        ResetTemplateForm();
        _tplFormCategory = _qrCategory;
        _tplManagerOpen = true;
    }

    private void EditTemplate(MessageTemplateDto t)
    {
        _tplEditId = t.Id;
        _tplFormCategory = t.Category;
        _tplFormBody = t.Body;
        _tplFormError = null;
    }

    private void ResetTemplateForm()
    {
        _tplEditId = null;
        _tplFormBody = null;
        _tplFormError = null;
    }

    private async Task SaveTemplateAsync()
    {
        _tplFormError = null;
        if (string.IsNullOrWhiteSpace(_tplFormBody))
        {
            _tplFormError = "Escribe un mensaje.";
            return;
        }
        await _dbLock.WaitAsync();
        _tplBusy = true;
        try
        {
            if (_tplEditId is null)
            {
                await TplSvc.CreateAsync(new CreateMessageTemplateRequest(_tplFormCategory, _tplFormBody ?? ""), Guid.Empty);
            }
            else
            {
                await TplSvc.UpdateAsync(_tplEditId.Value, new UpdateMessageTemplateRequest(_tplFormCategory, _tplFormBody ?? ""), Guid.Empty);
            }
            _templates = (await TplSvc.ListAsync()).ToList();
            ResetTemplateForm();
        }
        catch (Exception ex) { _tplFormError = ex.Message; }
        finally { _tplBusy = false; _dbLock.Release(); }
    }

    private async Task DeleteTemplateAsync(Guid id)
    {
        await _dbLock.WaitAsync();
        _tplBusy = true;
        try
        {
            await TplSvc.DeleteAsync(id, Guid.Empty);
            _templates = (await TplSvc.ListAsync()).ToList();
            if (_tplEditId == id) { ResetTemplateForm(); }
        }
        finally { _tplBusy = false; _dbLock.Release(); }
    }

    // ===== Adjuntos =====
    private async Task OnAttachAsync(InputFileChangeEventArgs e, MessageMediaType type)
    {
        _attachOpen = false;
        _error = null;
        if (_conv is null) { _error = "No hay conversacion."; return; }
        if (!Guid.TryParse(_lineaSelIdStr, out var lineId)) { _error = "Selecciona una linea."; return; }

        var saved = await SaveChatFileAsync(e.File, type);
        if (saved is null) { _error = "Archivo invalido o supera 16 MB."; return; }
        await _dbLock.WaitAsync();
        _enviando = true;
        try
        {
            var caption = string.IsNullOrWhiteSpace(_borrador) ? null : _borrador!.Trim();
            var r = await Chat.SendMediaViaLineAsync(_conv.Id, lineId, type, saved.Value.Base64, saved.Value.Url, saved.Value.Mime, saved.Value.Name, caption, Guid.Empty);
            if (!r.Ok) { _error = r.Error; return; }
            if (r.Message is { } sent && _mensajes.All(m => m.Id != sent.Id)) { _mensajes.Add(sent); }
            _borrador = "";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _enviando = false; _dbLock.Release(); }
    }

    private async Task<(string Url, string Base64, string Mime, string Name)?> SaveChatFileAsync(IBrowserFile file, MessageMediaType type)
    {
        const long max = 16L * 1024 * 1024;
        if (file.Size <= 0 || file.Size > max) { return null; }
        using var ms = new MemoryStream();
        await file.OpenReadStream(max).CopyToAsync(ms);
        var bytes = ms.ToArray();
        var ext = Path.GetExtension(file.Name);
        if (string.IsNullOrWhiteSpace(ext))
        {
            ext = type switch
            {
                MessageMediaType.Image => ".jpg",
                MessageMediaType.Video => ".mp4",
                MessageMediaType.Audio => ".ogg",
                _ => ".bin"
            };
        }
        var dir = Path.Combine(Env.WebRootPath, "uploads", "chat");
        Directory.CreateDirectory(dir);
        var name = $"chat-{Guid.NewGuid():N}{ext}";
        await File.WriteAllBytesAsync(Path.Combine(dir, name), bytes);
        var mime = string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType;
        return ($"/uploads/chat/{name}", Convert.ToBase64String(bytes), mime, file.Name);
    }

