# =========================================================================
#  .env para docker-compose.from-git.yml
#  Copia este archivo a .env (sin el .example) en E:\DOCKER\doktrino del server
#  y edita los valores. NO versionar el .env real.
# =========================================================================

# ---------- Rama del repo ----------
# Rama a clonar y construir. La sintaxis de git context tambien acepta
# un tag (v1.2.3) o un commit sha (abcd123) - pinea cuando quieras
# garantizar que un deploy concreto no cambie.
DOKTRINO_BRANCH=main

# ---------- Puerto local ----------
# Puerto del host donde el reverse proxy global del servidor (nginx-proxy-manager,
# traefik, otro Caddy, etc.) va a apuntar. Se bindea SOLO a 127.0.0.1 (no a 0.0.0.0)
# para que nadie de internet pueda llegar directo sin pasar por el proxy.
# Antes de elegir, verifica que NO este en uso en tu Docker actual.
DOKTRINO_PORT=5380

# ---------- Postgres ----------
POSTGRES_DB=doktrino
POSTGRES_USER=doktrino
# CAMBIA esta clave por una larga y aleatoria antes del primer arranque.
# En PowerShell: -join ((33..126) | Get-Random -Count 32 | % { [char]$_ })
POSTGRES_PASSWORD=CAMBIAR_ESTA_CLAVE_LARGA_Y_ALEATORIA
