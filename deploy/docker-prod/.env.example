# =========================================================================
#  DokTrino IPS - configuracion del entorno de PRODUCCION (docker-compose)
#  Copia este archivo como .env y edita los valores.
#  NO versionar el .env real (esta en .gitignore).
# =========================================================================

# ---------- Imagen a desplegar ----------
# Tag de GHCR. Default :latest (ultimo build de main). Para pinear: :sha-abcd123 o :v1.2.3.
DOKTRINO_IMAGE=ghcr.io/alexandercuartas665/doktrino/superadmin:latest

# ---------- Puerto local ----------
# Puerto del host donde el reverse proxy global del servidor (nginx-proxy-manager,
# traefik, otro Caddy, etc.) va a apuntar. Se bindea SOLO a 127.0.0.1 (no a 0.0.0.0)
# para que nadie de internet pueda llegar directo sin pasar por el proxy.
# Elige uno que NO este en uso por otros servicios de tu docker.
DOKTRINO_PORT=5380

# ---------- Postgres ----------
POSTGRES_DB=doktrino
POSTGRES_USER=doktrino
# CAMBIA esta clave por una larga y aleatoria antes del primer arranque.
# Sugerencia: openssl rand -base64 32
POSTGRES_PASSWORD=CAMBIAR_ESTA_CLAVE_LARGA_Y_ALEATORIA
