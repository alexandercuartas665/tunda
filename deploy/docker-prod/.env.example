# =========================================================================
#  DokTrino - configuracion del entorno de PRODUCCION (docker-compose)
#  Copia este archivo como .env y edita los valores.
#  NO versionar el .env real (esta en .gitignore).
# =========================================================================

# ---------- Imagen a desplegar ----------
# Tag de GHCR. Default :latest (ultimo build de main). Para pinear: :sha-abcd123 o :v1.2.3.
DOKTRINO_IMAGE=ghcr.io/alexandercuartas665/tunda/superadmin:latest

# ---------- Puerto local ----------
# Puerto del host donde el Caddy externo (en otra maquina) va a apuntar.
# En el host compartido 5380=Visal y 5480=ECOREX ya estan ocupados; 5580 esta libre.
DOKTRINO_PORT=5580

# ---------- Postgres (interno, no expuesto al host) ----------
POSTGRES_DB=doktrino
POSTGRES_USER=doktrino
# CAMBIA esta clave por una larga y aleatoria antes del primer arranque.
# Sugerencia: openssl rand -base64 32
POSTGRES_PASSWORD=CAMBIAR_ESTA_CLAVE_LARGA_Y_ALEATORIA

# ---------- MinIO (interno, no expuesto al host) ----------
# Guarda los blobs: archivo digital y media de los cursos (video/imagen/pdf).
MINIO_ROOT_USER=doktrino
# CAMBIA esta clave por una larga y aleatoria antes del primer arranque.
MINIO_ROOT_PASSWORD=CAMBIAR_ESTA_CLAVE_LARGA_Y_ALEATORIA
MINIO_BUCKET=doktrino-blobs
