# ======================================================================
#  DokTrino - variables del docker-compose LOCAL (dev)
# ======================================================================
#  Puertos de la doc (pueden chocar con otras pilas vivas en la maquina:
#  CUBOT 5434/6381/5673..., Visal 5435/6382/5674..., propia-* 5433/6380...).
#  Si un puerto esta ocupado, subir al siguiente libre en el .env local
#  (este .env.example es la referencia; el .env real no se commitea).
# ======================================================================

# --- App Web (DokTrino.SuperAdmin / Blazor) ---
# WEB_PORT es el puerto de host; dentro del contenedor la app escucha en 8080.
WEB_PORT=8082

# --- PostgreSQL 16 ---
POSTGRES_PORT=5436
POSTGRES_USER=doktrino
POSTGRES_PASSWORD=doktrino_dev
POSTGRES_DB=doktrino_dev

# --- Redis (opcional en MVP; util al escalar SignalR) ---
REDIS_PORT=6383

# --- RabbitMQ (opcional en MVP) ---
RABBITMQ_PORT=5675
RABBITMQ_MGMT_PORT=15675
RABBITMQ_USER=doktrino
RABBITMQ_PASSWORD=doktrino_dev

# --- pgAdmin (administracion local) ---
# El correo de acceso se arma en el compose como USER@DOMAIN (evita correo literal).
PGADMIN_PORT=5052
PGADMIN_EMAIL_USER=admin
PGADMIN_EMAIL_DOMAIN=doktrino.local
PGADMIN_DEFAULT_PASSWORD=doktrino_dev

# --- MinIO (Object Storage para blobs documentales - NUEVO en DokTrino) ---
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_ROOT_USER=doktrino
MINIO_ROOT_PASSWORD=doktrino_dev_minio
MINIO_BUCKET=doktrino-blobs

# --- Connection strings que consume la app (pegar en appsettings.Development.json) ---
# DOKTRINO_DB_CONNECTION=Host=localhost;Port=5436;Database=doktrino_dev;Username=doktrino;Password=doktrino_dev
# DOKTRINO_REDIS=localhost:6383
# DOKTRINO_RABBIT=amqp://doktrino:doktrino_dev@localhost:5675/
# DOKTRINO_MINIO_ENDPOINT=http://localhost:9002
# DOKTRINO_MINIO_ACCESSKEY=doktrino
# DOKTRINO_MINIO_SECRETKEY=doktrino_dev_minio
# DOKTRINO_MINIO_BUCKET=doktrino-blobs
